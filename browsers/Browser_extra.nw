<<function [[ftpcmt]](hget.c)>>=
int
ftpcmd(int ctl, char *fmt, ...)
{
    va_list arg;
    char buf[2*1024], *s;

    va_start(arg, fmt);
    s = vseprint(buf, buf + (sizeof(buf)-4) / sizeof(*buf), fmt, arg);
    va_end(arg);
    if(debug)
        fprint(STDERR, "%d -> %s\n", ctl, buf);
    *s++ = '\r';
    *s++ = '\n';
    if(write(ctl, buf, s - buf) != s - buf)
        return -1;
    return 0;
}
