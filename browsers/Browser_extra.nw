<<function [[ftprcode]](hget.c)>>=
int
ftprcode(int ctl, char *msg, int len)
{
    int rv;
    int i;
    char *p;

    len--;  /* room for terminating null */
    for(;;){
        *msg = 0;
        i = readline(ctl, msg, len);
        if(i < 0)
            break;
        if(debug)
            fprint(STDERR, "%d <- %s\n", ctl, msg);

        /* stop if not a continuation */
        rv = strtol(msg, &p, 10);
        if(rv >= 100 && rv < 600 && p==msg+3 && *p == ' ')
            return rv/100;
    }
    *msg = 0;

    return -1;
}
