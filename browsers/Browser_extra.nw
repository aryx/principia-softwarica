<<function [[pl_bread]](mothra)>>=
/*
 * Buffered read, no translation
 * Save in cache.
 */
int pl_bread(Hglob *g){
    int n, c;
    char err[1024];
    if(g->hbufp==g->ehbuf){
        n=read(g->hfd, g->hbuf, NHBUF);
        if(n<=0){
            if(n<0){
                snprint(err, sizeof(err), "%r reading %s", g->name);
                pl_htmloutput(g, 1, err, 0);
            }
            g->heof=1;
            return EOF;
        }
        g->hbufp=g->hbuf;
        g->ehbuf=g->hbuf+n;
    }
    c=*g->hbufp++&255;
    if(c=='\n') g->lineno++;
    return c;
}
