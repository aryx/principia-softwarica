<<function [[isoutf_out]](tcs)>>=
void
isoutf_out(Rune *base, int n, long *notused)
{
    char *p;
    Rune *r;

    USED(notused);
    nrunes += n;
    for(r = base, p = obuf; n-- > 0; r++)
        p += runetoisoutf(p, r);
    noutput += p-obuf;
    write(1, obuf, p-obuf);
}
