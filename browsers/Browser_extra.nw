<<function [[fsdestroyfid]](webcookies)>>=
void
fsdestroyfid(Fid *fid)
{
    char *p, *nextp;
    Aux *a;
    int i;

    a = fid->aux;
    if(a == nil)
        return;
    switch((uintptr)fid->file->aux){
    case Xhttp:
        parsehttp(jar, a->inhttp, a->dom, a->path);
        break;
    case Xcookies:
        for(i=0; i<jar->nc; i++)
            jar->c[i].mark = 1;
        for(p=a->ctext; *p; p=nextp){
            if((nextp = strchr(p, '\n')) != nil)
                *nextp++ = '\0';
            else
                nextp = "";
            addtojar(jar, p, 0);
        }
        for(i=0; i<jar->nc; i++)
            if(jar->c[i].mark)
                delcookie(jar, &jar->c[i]);
        break;
    }
    syncjar(jar);
    free(a->dom);
    free(a->path);
    free(a->inhttp);
    free(a->outhttp);
    free(a->ctext);
    free(a);
}
