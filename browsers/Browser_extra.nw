<<function [[plumbwebthread]](webfs)>>=
static void
plumbwebthread(void*)
{
    char *base;
    Plumbmsg *m;

    for(;;){
        m = recvp(plumbchan);
        if(m == nil)
            threadexits(nil);
        base = plumblookup(m->attr, "baseurl");
        if(base == nil)
            base = m->wdir;
        plumburl(m->data, base);
        plumbfree(m);
    }
}
