<<function [[plumbwebproc]](webfs)>>=
static void
plumbwebproc(void*)
{
    Plumbmsg *m;

    for(;;){
        m = plumbrecv(plumbwebfd);
        sendp(plumbchan, m);
        if(m == nil)
            threadexits(nil);
    }
}
