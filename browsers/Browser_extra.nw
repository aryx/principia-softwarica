<<function [[scrollpanel]](mothra)>>=
void scrollpanel(Panel *p, int dy, int whence)
{
    Scroll s;

    s = plgetscroll(p);
    switch(whence){
    case 0:
        s.pos.y = dy;
        break;
    case 1:
        s.pos.y += dy;
        break;
    case 2:
        s.pos.y = s.size.y+dy;
        break;
    }
    if(s.pos.y > s.size.y)
        s.pos.y = s.size.y;
    if(s.pos.y < 0)
        s.pos.y = 0;
    plsetscroll(p, s);
}
@

<<function [[sidescroll]](mothra)>>=
void sidescroll(int dx, int whence)
{
    Scroll s;

    s = plgetscroll(text);
    switch(whence){
    case 0:
        s.pos.x = dx;
        break;
    case 1:
        s.pos.x += dx;
        break;
    case 2:
        s.pos.x = s.size.x+dx;
        break;
    }
    if(s.pos.x > s.size.x - text->size.x + 5)
        s.pos.x = s.size.x - text->size.x + 5;
    if(s.pos.x < 0)
        s.pos.x = 0;
    plsetscroll(text, s);
}
