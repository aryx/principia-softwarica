<<function [[parse_query]](webfs)>>=
static int
parse_query(SplitUrl *su, Url *u)
{
    if(su->query.s == nil)
        return 0;
    u->query = estredup(su->query.s, su->query.e);
    if(!ismatch(REquery, u->query, "query"))
        return -1;
    return 0;
}
