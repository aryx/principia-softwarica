initfs(void)
{
    time0 = time(0);
    creq = chancreate(sizeof(void*), 0);
    creqwait = chancreate(sizeof(void*), 0);
    cclunk = chancreate(sizeof(void*), 0);
    cclunkwait = chancreate(sizeof(void*), 0);
