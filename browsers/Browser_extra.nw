/*
 * Sunday, 25-Jan-2002 12:24:36 GMT
 * Sunday, 25 Jan 2002 12:24:36 GMT
 * Sun, 25 Jan 02 12:24:36 GMT
 */
static int
isleap(int year)
{
    return year%4==0 && (year%100!=0 || year%400==0);
}
