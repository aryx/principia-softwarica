<<function [[pl_nextc]](mothra)>>=
int pl_nextc(Hglob *g){
    int c;

    if(g->heof) return EOF;
    if(g->npeekc!=0) return g->peekc[--g->npeekc];
    c=pl_readc(g);
    if(c=='<'){
        c=pl_readc(g);
        if(c=='/'){
            c=pl_readc(g);
            pl_putback(g, c);
            pl_putback(g, '/');
            if('a'<=c && c<='z' || 'A'<=c && c<='Z') return STAG;
            return '<';
        }
        pl_putback(g, c);
        if(c=='!' || 'a'<=c && c<='z' || 'A'<=c && c<='Z' || c=='?') return STAG;
        return '<';
    }
    if(c=='>') return ETAG;
    return c;
}
@

<<function [[unquot]](mothra)>>=
char *unquot(char *src){
    char *e, *dst;
    int len;

    e=0;
    while(*src && strchr(" \t\r\n", *src))
        src++;
    if(*src=='\'' || *src=='"'){
        e=strrchr(src+1, *src);
        src++;
    }
    if(e==0) e=strchr(src, 0);
    len=e-src;
    dst = emalloc(len+1);
    memmove(dst, src, len);
    dst[len]=0;
    return dst;
}
@

<<function [[alnumchar]](mothra)>>=
int alnumchar(int c){
    return 'a'<=c && c<='z' || 'A'<=c && c<='Z' || '0'<=c && c<='9';
}
@

<<function [[entchar]](mothra)>>=
int entchar(int c){
    return c=='#' || alnumchar(c);
}
