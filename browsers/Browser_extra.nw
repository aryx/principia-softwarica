<<function [[genwww]](mothra)>>=
char *genwww(Panel *, int index){
    static char buf[1024];
    Www *w;
    int i;

    if(index >= nwww())
        return 0;
    i = wwwtop-index-1;
    w = www(i);
    if(!w->url)
        return 0;
    if(w->title[0]!='\0'){
        w->gottitle=1;
        snprint(buf, sizeof(buf), "%2d %s", i+1, w->title);
    } else
        snprint(buf, sizeof(buf), "%2d %s", i+1, urlstr(w->url));
    return buf;
}
