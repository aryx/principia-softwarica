<<function [[h_fileinput]](mothra)>>=
void h_fileinput(Panel *p, int){
    char name[NNAME];
    Field *f;

    f = p->userp;
    nstrcpy(name, f->value, sizeof(name));
    for(;;){
        if(eenter("Upload file", name, sizeof(name), &mouse) <= 0)
            break;
        if(access(name, AREAD) == 0)
            break;
    }
    free(f->value);
    f->value = strdup(name);
    p->state = name[0] != 0;
    pldraw(f->p, view);
}
