<<function [[gettext]](mothra)>>=
void gettext(Www *w, int fd, int type){
    switch(rfork(RFFDG|RFPROC|RFMEM|RFNOWAIT)){
    case -1:
        message("Can't fork, please wait");
        break;
    case 0:
        if(type==HTML)
            plrdhtml(w->url->fullname, fd, w, killimgs);
        else
            plrdplain(w->url->fullname, fd, w);
        _exits(0);
    }
    close(fd);
}
