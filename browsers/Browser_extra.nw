    if(*argv){
        close(0);
        if(open(*argv, OREAD) != 0)
            sysfatal("open: %r");
    }
    nbuf = 0;
    while(nbuf < sizeof(buf)-1){
        if((n = read(0, buf + nbuf, sizeof(buf)-1-nbuf)) <= 0)
            break;
        nbuf += n;
        buf[nbuf] = 0;
    }

    p = buf;
    if(nbuf >= 3 && memcmp(p, "\xEF\xBB\xBF", 3)==0){
        p += 3;
        nbuf -= 3;
        cset = "utf";
        goto Found;
    }
    if(nbuf >= 2 && memcmp(p, "\xFE\xFF", 2) == 0){
        p += 2;
        nbuf -= 2;
        cset = "unicode-be";
        goto Found;
    }
    if(nbuf >= 2 && memcmp(p, "\xFF\xFE", 2) == 0){
        p += 2;
        nbuf -= 2;
        cset = "unicode-le";
        goto Found;
    }

    s = p;
    do {
        if((s = strchr(s, '<')) == nil)
            break;
        q = 0;
        g = ++s;
        e = buf+nbuf;
        while(s < e){
            if(*s == '=' && q == 0)
                q = '=';
            else if(*s == '\'' || *s == '"'){
                if(q == '=')
                    q = *s;
                else if(q == *s)
                    q = 0;
