<<function [[pl_putback]](mothra)>>=
void pl_putback(Hglob *g, int c){
    if(g->npeekc==NPEEKC) htmlerror(g->name, g->lineno, "too much putback!");
    else if(c!=EOF) g->peekc[g->npeekc++]=c;
