<<function [[linkify]](mothra)>>=
/* return url if text token looks like a hyperlink */
char *linkify(char *s){
    int i;
    if(s == 0 && s[0] == 0)
        return 0;
    for(i = 0; i < nelem(links); i++)
        if(!cistrncmp(s, links[i].prefix, links[i].len))
            return strdup(s);
    if(!cistrncmp(s, "www.", 4)){
        int d, i;

        d = 1;
        for(i=4; s[i]; i++){
            if(s[i] == '.'){
                if(s[i-1] == '.')
                    return 0;
                d++;
            } else if(!alnumchar(s[i]))
                break;
        }
        if(d >= 2)
            return smprint("http://%s", s);
    }
    return 0;
}
