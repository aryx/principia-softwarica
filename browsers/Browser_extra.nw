<<function [[purgejar]](webcookies)>>=
void
purgejar(Jar *j)
{
    int i;

    for(i=j->nc-1; i>=0; i--){
        if(!j->c[i].deleted)
            continue;
        freecookie(&j->c[i]);
        --j->nc;
        j->c[i] = j->c[j->nc];
    }
}
