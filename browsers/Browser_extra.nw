<<function [[expirejar]](webcookies)>>=
int
expirejar(Jar *jar, int exiting)
{
    int i, n;
    uint now;

    now = time(0);
    n = 0;
    for(i=0; i<jar->nc; i++){
        if(jar->c[i].expire < now || (exiting && jar->c[i].expire==~0)){
            delcookie(jar, &jar->c[i]);
            n++;
        }
    }
    return n;
}
