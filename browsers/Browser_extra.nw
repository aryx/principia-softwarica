<<function [[unicode_out]](tcs)>>=
void
unicode_out(Rune *base, int n, long *notused)
{
    static int first = 1;

    USED(notused);
    nrunes += n;
    if(first){
        unsigned short x = 0xFEFF;
        noutput += 2;
        write(1, (char *)&x, 2);
        first = 0;
    }
    noutput += 2*n;
    write(1, (char *)base, 2*n);
}
@

<<function [[unicode_out_be]](tcs)>>=
void
unicode_out_be(Rune *base, int n, long *notused)
{
    int i;
    uchar *p;
    Rune r;

    USED(notused);
    p = (uchar*)base;
    for(i=0; i<n; i++){
        r = base[i];
        *p++ = r>>8;
        *p++ = r;
    }
    nrunes += n;
    noutput += 2*n;
    write(1, (char *)base, 2*n);
}
