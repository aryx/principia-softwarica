<<function [[attr]](uhtml)>>=
char*
attr(char *s, char *a)
{
    char *e, q;

    if((s = cistrstr(s, a)) == nil)
        return nil;
    s += strlen(a);
    while(*s && strchr(whitespace, *s))
        s++;
    if(*s++ != '=')
        return nil;
    while(*s && strchr(whitespace, *s))
        s++;
    q = 0;
    if(*s == '"' || *s == '\'')
        q = *s++;
    for(e = s; *e; e++){
        if(*e == q)
            break;
        if(isalnum(*e))
            continue;
        if(*e == '-' || *e == '_')
            continue;
        break;
    }
    if((e - s) > 1)
        return smprint("%.*s", (int)(e - s), s);
    return nil;
}
