<<function [[jarfmt]](webcookies)>>=
/* HTTP format */
int
jarfmt(Fmt *fmt)
{
    int i;
    Jar *jar;

    jar = va_arg(fmt->args, Jar*);
    if(jar == nil || jar->nc == 0)
        return fmtstrcpy(fmt, "");

    fmtprint(fmt, "Cookie: ");
    if(jar->c[0].version)
        fmtprint(fmt, "$Version=%s; ", jar->c[0].version);
    for(i=0; i<jar->nc; i++)
        fmtprint(fmt, "%s%s=%s", i ? "; ":"", jar->c[i].name, jar->c[i].value);
    fmtprint(fmt, "\r\n");
    return 0;
}
