<<function [[plaintext]](mothra)>>=
void plaintext(Hglob *g){
    char line[NLINE];
    char *lp, *elp;
    int c;
    g->state->font=CWIDTH;
    g->state->size=NORMAL;
    g->state->sub = 0;
    elp=&line[NLINE-UTFmax-1];
    lp=line;
    for(;;){
        c=pl_readc(g);
        if(c==EOF) break;
        if(c=='\n' || lp>=elp){
            *lp='\0';
            g->linebrk=1;
            pl_htmloutput(g, 0, line, 0);
            lp=line;
        }
        if(c=='\t'){
            do *lp++=' '; while(lp<elp && utfnlen(line, lp-line)%8!=0);
        }
        else if(c!='\n')
            lp += lrunetochar(lp, c);
    }
    if(lp!=line){
        *lp='\0';
        g->linebrk=1;
        pl_htmloutput(g, 0, line, 0);
    }
}
