<<function [[freeattrs]](webfs)>>=
static void
freeattrs(Plumbmsg *m)
{
    Plumbattr *a, *next;

    a = m->attr;
    while(a != nil) {
        next = a->next;
        free(a);
        a = next;
    }
}
