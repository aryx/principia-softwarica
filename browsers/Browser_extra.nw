<<function [[h_radioinput]](mothra)>>=
void h_radioinput(Panel *p, int, int v){
    Field *f, *me;
    me=p->userp;
    me->state=v;
    if(v){
        for(f=me->form->fields;f;f=f->next)
            if(f->type==RADIO && f!=me && strcmp(f->name, me->name)==0){
                plsetbutton(f->p, 0);
                f->state=0;
                pldraw(f->p, view);
            }
    }
}
