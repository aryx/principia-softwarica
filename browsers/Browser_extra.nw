/* get the http response code */
int
httprcode(int fd)
{
    int n;
    char *p;
    char buf[256];

    n = readline(fd, buf, sizeof(buf)-1);
    if(n <= 0)
        return n;
    if(debug)
        fprint(STDERR, "%d <- %s\n", fd, buf);
    p = strchr(buf, ' ');
    if(strncmp(buf, "HTTP/", 5) != 0 || p == nil){
        werrstr("bad response from server");
        return -1;
    }
    buf[n] = 0;
    return atoi(p+1);
}
