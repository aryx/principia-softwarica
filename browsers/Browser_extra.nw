<<function [[pl_readc]](mothra)>>=
/*
 * Read a character, translating \r\n, \n\r, \r and \n into \n
 * convert to runes.
 */
int pl_readc(Hglob *g){
    static int peek=-1;
    char crune[UTFmax+1];
    int c, n;
    Rune r;

    if(peek!=-1){
        c=peek;
        peek=-1;
    }
    else
        c=pl_bread(g);
    if(c=='\r'){
        c=pl_bread(g);
        if(c!='\n') peek=c;
        return '\n';
    }
    if(c=='\n'){
        c=pl_bread(g);
        if(c!='\r') peek=c;
        return '\n';
    }

    if(c < Runeself)
        return c;

    crune[0]=c;
    for (n=1; n<=sizeof(crune); n++){
        if(fullrune(crune, n)){
            chartorune(&r, crune);
            return r;
        }
        c=pl_bread(g);
        if(c==EOF)
            return EOF;
        crune[n]=c;
    }
    return c;
}
