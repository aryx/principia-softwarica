}
@

<<function [[ismatch]](webfs)>>=
static int
ismatch(int i, char *s, char *desc)
{
    Resub m[1];

    m[0].s.sp = m[0].e.ep = nil;
    if(!regx(retab[i].prog, s, m, 1)){
        werrstr("malformed %s: %q", desc, s);
        return 0;
    }
    return 1;
}
