<<function [[strtolength]](mothra)>>=
int strtolength(Hglob *g, int dir, char *str){
    double f;
    Point p;

    f = atof(str);
    if(cistrstr(str, "%"))
        return 0;
    if(cistrstr(str, "em")){
        p=stringsize(pl_whichfont(g->state->font, g->state->size, nil), "M");
        return floor(f*((dir==HORIZ) ? p.x : p.y));
    }
    return floor(f);
}
