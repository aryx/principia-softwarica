<<function [[pl_whitespace]](mothra)>>=
/*
 * Skip over white space
 */
char *pl_whitespace(char *s){
    while(*s==' ' || *s=='\t' || *s=='\n' || *s=='\r') s++;
    return s;
}
@

<<function [[pl_word]](mothra)>>=
/*
 * Skip over HTML word
 */
char *pl_word(char *s){
    if ('a'<=*s && *s<='z' || 'A'<=*s && *s<='Z') {
        s++;
        while('a'<=*s && *s<='z' || 'A'<=*s && *s<='Z' || '0'<=*s && *s<='9' || 
            *s=='-' || *s=='.' || *s==':') s++;
    }
    return s;
}
@

<<function [[pl_quote]](mothra)>>=
/*
 * Skip to matching quote
 */
char *pl_quote(char *s){
    char q;
    q=*s++;
    while(*s!=q && *s!='\0') s++;
    return s;
}
@

<<function [[pl_dnl]](mothra)>>=
void pl_dnl(char *s){
    char *t;
    for(t=s;*s;s++) if(*s!='\r' && *s!='\n') *t++=*s;
    *t='\0';
}
