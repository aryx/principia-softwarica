<<function [[xfer]](webfsget)>>=
void
xfer(fdt from, fdt to)
{
    char buf[12*1024];
    int n;

    while((n = read(from, buf, sizeof buf)) > 0)
        if(write(to, buf, n) < 0)
            sysfatal("write failed: %r");
    if(n < 0)
        sysfatal("read failed: %r");
}
@

<<function [[usage]](webfsget)>>=
