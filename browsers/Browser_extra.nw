<<function [[threadmain]](webfs)>>=
void
threadmain(int argc, char **argv)
{
    rfork(RFNOTEG);
    ARGBEGIN{
    case 'd':
        mainmem->flags |= POOL_PARANOIA|POOL_ANTAGONISM;
        break;
    case 'D':
        chatty9p++;
        break;
    case 'c':
        cookiefile = EARGF(usage());
        break;
    case 'm':
        mtpt = EARGF(usage());
        break;
    case 's':
        service = EARGF(usage());
        break;
    default:
        usage();
    }ARGEND


    quotefmtinstall();
    if(argc != 0)
        usage();

    plumbinit();
    globalctl.useragent = estrdup(globalctl.useragent);
    initcookies(cookiefile);
    initurl();
    initfs();
    threadpostmountsrv(&fs, service, mtpt, MREPL);
    threadexits(nil);
}
