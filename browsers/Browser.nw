}
@

<<function [[freeurl]](mothra)>>=
void freeurl(Url *u){
    free(u->reltext);
    free(u->basename);
    free(u);
}
@

<<function [[seturl]](mothra)>>=
void seturl(Url *url, char *urlname, char *base){
    url->reltext = strdup(urlname);
    url->basename = strdup(base);
    url->fullname[0] = 0;
    url->tag[0] = 0;
    url->map = 0;
