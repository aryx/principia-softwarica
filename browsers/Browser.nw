<<function [[servername]](webfs)>>=
static char*
servername(char *addr)
{
    char *p;

    if(strncmp(addr, "tcp!", 4) == 0
    || strncmp(addr, "net!", 4) == 0)
        addr += 4;
    addr = estrdup(addr);
    p = addr+strlen(addr);
    if(p>addr && *(p-1) == 's')
        p--;
    if(p>addr+5 && strcmp(p-5, "!http") == 0)
        p[-5] = 0;
    return addr;
}
