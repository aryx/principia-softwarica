case 0:
    url=getenv("url");
    break;
@

%yoann: explain

<<[[main()]](mothra) other locals>>=
enum { Eplumb = 128, Ekick = 256 };
@



\subsection{[[current]]}

%yoann: explain

<<global [[current]](mothra)>>=
Www *current=nil;
@

<<[[main()]](mothra) in event loop, if [[current]] and no buttons>>=
if(mouse.buttons==0 && current){
    if(current->finished){
        updtext(current);
        if(current->url->tag[0])
            scrollto(current->url->tag);
        current->finished=0;
        current->changed=false;
        current->alldone=1;
        message(mothra);
        donecurs();
    }
}
@


\subsection{Cohort group}

First, \verb+rfork(RFPROC|RFNOTEG|RFNAMEG|RFREND)+ creates a
``cohort'': mothra's parent process becomes a sentinel that just calls
\verb+waitpid+ and reaps everything, while the child runs the GUI. The
flags \verb+RFNOTEG+ and \verb+RFNAMEG+ isolate the cohort's note group
and namespace, so a \verb+kill+ note delivered to the parent stops every
helper at once and a per-cohort namespace lets the \verb+-m+ flag take
effect.
%yoann1: introduce and explain better cohort

<<global [[cohort]](mothra)>>=
int cohort = -1;
@

<<[[main()]](mothra) cohort setup>>=
/*
 * so that we can stop all subprocesses with a note,
 * and to isolate rendezvous from other processes
 */
if(cohort=rfork(RFPROC|RFNOTEG|RFNAMEG|RFREND)){
    atexit(killcohort);
    notify(catch);
    waitpid();
    exits(nil);
}
cohort = getpid();
atexit(killcohort);
@

\subsection{Kick pipe}

%claude:
The \verb+kickpipe+ self-pipe is
created and registered as event source \verb+Ekick+; worker threads write
one byte to it to wake the loop without manufacturing a fake mouse event.
%yoann1: introduce and explain better kick pipe

<<[[main()]](mothra) kickpipe initialisation>>=
if(pipe(kickpipe) < 0)
    sysfatal("pipe: %r");
estart(Ekick, kickpipe[0], 256);
@

<<[[main()]](mothra) in event loop, switch [[i]] cases>>=
case Ekick:
    if(mouse.buttons==0 && current && current->changed){
        if(!current->finished)
            updtext(current);
        current->changed=false;
    }
    break;
@

