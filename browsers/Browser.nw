\subsection{[[eresized()]]}

There is no resize logic: \verb+eresized+ tears down the
whole layout and rebuilds it with [<mkpanels()>].
%yoann1: are you sure? I see no call to mkpanels below

<<function [[eresized]](mothra)>>=
void eresized(bool new){
    Rectangle r;

    drawlock(1);
    if(new && getwindow(display, Refnone) == -1) {
        fprint(2, "getwindow: %r\n");
        exits("getwindow");
    }
    r=view->r;
    plpack(root, r);
    plpack(alt, r);
    pldraw(cmd, view);  /* put cmd box on screen for alt display */
    pldraw(root, view);
    flushimage(display, 1);
    drawlock(0);
}
@


\subsection{XXX}


%claude:
[<www()>] returns the [<Www>] slot for index \verb+i+, modulo the static
array size \verb+NWWW+. The whole history is therefore a circular buffer:
visiting more than \verb+NWWW+ pages overwrites the oldest. Mothra never
allocates a [<Www>] off the heap; the address taken from \verb+www(i)+
remains valid forever, which simplifies the few places that keep a
[<Www*>] across an event-loop iteration.

<<function [[www]](mothra)>>=
/// -> <>
Www *www(int index){
    static Www a[NWWW];
    return &a[index % NWWW];
}
@

<<function [[nwww]](mothra)>>=
int nwww(void){
    return wwwtop<NWWW ? wwwtop : NWWW;
}
@

<<function [[subpanel]](mothra)>>=
/// ???? -> <>
int subpanel(Panel *obj, Panel *subj){
    if(obj==0) return 0;
    if(obj==subj) return 1;
    for(obj=obj->child;obj;obj=obj->next)
        if(subpanel(obj, subj)) return 1;
    return 0;
}
@

<<function [[adjkb]](mothra)>>=
/*
 * Make sure that the keyboard focus is on-screen, by adjusting it to
 * be the cmd entry if necessary.
 */
int adjkb(void){
    Rtext *t;
    int yoffs;
    if(current){
        yoffs=text->r.min.y-plgetpostextview(text);
        for(t=current->text;t;t=t->next) if(!eqrect(t->r, Rect(0,0,0,0))){
            if(t->r.max.y+yoffs>=text->r.min.y
            && t->r.min.y+yoffs<text->r.max.y
            && t->b==0
            && subpanel(t->p, plkbfocus))
                return 1;
        }
    }
    plgrabkb(cmd);
    return 0;
}
@

<<function [[scrollpanel]](mothra)>>=
void scrollpanel(Panel *p, int dy, int whence)
{
    Scroll s;

    s = plgetscroll(p);
    switch(whence){
    case 0:
        s.pos.y = dy;
        break;
    case 1:
        s.pos.y += dy;
        break;
    case 2:
        s.pos.y = s.size.y+dy;
        break;
    }
    if(s.pos.y > s.size.y)
        s.pos.y = s.size.y;
    if(s.pos.y < 0)
        s.pos.y = 0;
    plsetscroll(p, s);
}
@

<<function [[sidescroll]](mothra)>>=
void sidescroll(int dx, int whence)
{
    Scroll s;

    s = plgetscroll(text);
    switch(whence){
    case 0:
        s.pos.x = dx;
        break;
    case 1:
        s.pos.x += dx;
        break;
    case 2:
        s.pos.x = s.size.x+dx;
        break;
    }
    if(s.pos.x > s.size.x - text->size.x + 5)
        s.pos.x = s.size.x - text->size.x + 5;
    if(s.pos.x < 0)
        s.pos.x = 0;
    plsetscroll(text, s);
}
@



\section{Reading from a URL: [[geturl()]]}

%claude:
This section is the boundary between the GUI and the network. The
function [<geturl()>] is what every code path leading to a fetch ends up
calling --- the address bar, link clicks, plumb messages, command-line
URL --- so a tour of it is effectively a tour of how mothra goes from
``user wanted this URL'' to ``page is being parsed''.

%claude:
There are five steps. (1) If the URL is just a fragment
\verb+#anchor+, scroll to it and stop --- no fetch needed. (2) Otherwise
[<selurl()>] turns the typed string into a [<Url>]. (3) [<urlget()>]
talks to \verb+/mnt/web+ and returns a fd from which the response body can
be read; if it fails, the error is shown in \verb+msg+ and the loop ends.
(4) Detect the content type by header (\verb+contenttype+) or by sniffing
the first bytes ([<snooptype()>]). (5) Dispatch on the type: HTML goes
through \verb+uhtml+ via [<pipeline()>] before reaching [<gettext()>]
(which forks the parser); PLAIN goes straight to [<gettext()>]; images
get handed to \verb+page -w+ via [<filter()>] (which spawns it as a
sibling); anything unknown prompts the user to save it to a file.

%claude:
The HTML/PLAIN branch also does history bookkeeping: it advances
\verb+wwwtop+, picks the next slot in the static [<Www>] ring, frees the
slot's old content if it is wrapping around, and copies the URL into
\verb+w->url+. After [<gettext()>] is forked, a separate watchdog process
is forked to write to \verb+kickpipe+ once a second whenever
\verb+w->changed+ is set, which is what lets the page redraw
incrementally as bytes arrive.

<<function [[geturl]](mothra)>>=
/// main -> <>
/*
 * get the file at the given url
 */
void geturl(char *urlname, int post, int plumb, int map){
    int i, fd, typ;
    char cmd[NNAME];
    ulong n;
    Www *w;

    if(*urlname == '#' && post < 0){
        scrollto(urlname+1);
        return;
    }

    selurl(urlname);
    selection->map=map;

    message("getting %s", urlstr(selection));
    esetcursor(&patientcurs);
    for(;;){
        if((fd=urlget(selection, post)) < 0){
            message("%r");
            break;
        }
        message("getting %s", selection->fullname);
        if(mothmode && !plumb)
            typ = -1;
        else if((typ = mimetotype(selection->contenttype)) < 0)
            typ = snooptype(fd);

        switch(typ){
        default:
            if(plumb){
                message("unknown file type");
                close(fd);
                break;
            }
            snprint(cmd, sizeof(cmd), "%s", urltofile(selection));
            if(eenter("Save to", cmd, sizeof(cmd), &mouse) <= 0){
                close(fd);
                break;
            }
            save(fd, cmd);
            break;
        case HTML:
            fd = pipeline(fd, "exec uhtml");
        case PLAIN:
            n=0; 
            for(i=wwwtop-1; i>=0 && i!=(wwwtop-NWWW-1); i--){
                w = www(i);
                n += countpix(w->pix);
                if(n >= NPIXMB*1024*1024)
                    killpix(w);
            }
            w = www(i = wwwtop++);
            if(i >= NWWW){
                /* wait for the reader to finish the document */
                while(!w->finished && !w->alldone){
                    drawlock(0);
                    sleep(10);
                    drawlock(1);
                }
                freetext(w->text);
                freeform(w->form);
                freepix(w->pix);
                freeurl(w->url);
                memset(w, 0, sizeof(*w));
            }
            if(selection->map)
                w->url=copyurl(current->url);
            else
                w->url=copyurl(selection);
            w->finished = 0;
            w->alldone = 0;
            gettext(w, fd, typ);
            if(rfork(RFPROC|RFMEM|RFNOWAIT) == 0){
                for(;;){
                    sleep(1000);
                    if(w->finished || w->alldone)
                        break;
                    if(w->changed)
                        write(kickpipe[1], "C", 1);
                }
                _exits(0);
            }
            plinitlist(list, PACKN|FILLX, genwww, 8, doprev);
            if(defdisplay) pldraw(list, view);
            setcurrent(i, selection->tag);
            break;
        case GIF:
        case JPEG:
        case PNG:
        case BMP:
        case PAGE:
            filter(fd, "exec page -w");
            break;
        }
        break;
    }
    donecurs();
}
@

<<function [[updtext]](mothra)>>=
void updtext(Www *w){
    Rtext *t;
    Action *a;
    if(defdisplay && w->gottitle==0 && w->title[0]!='\0')
        pldraw(list, view);
    for(t=w->text;t;t=t->next){
        a=t->user;
        if(a){
            if(a->field)
                mkfieldpanel(t);
            a->field=0;
        }
    }
    if(w != current)
        return;
    w->yoffs=plgetpostextview(text);
    plinittextview(text, PACKE|EXPAND, Pt(0, 0), w->text, dolink);
    plsetpostextview(text, w->yoffs);
    pldraw(text, view);
}
@

<<function [[finish]](mothra)>>=
void finish(Www *w){
    w->finished = 1;
    write(kickpipe[1], "F", 1);
}
@

%claude:
[<mothon()>] toggles ``moth mode''. The name is a play on \verb+mothra+
(which itself is a pun on Mosaic, the parent in the lineage). In moth
mode, image downloads are disabled and clickable images get an inline
\verb+->+ marker appended (a tiny synthetic Rtext + Action). The walk
over the text list is the easiest place to see the
\verb+Rtext+/\verb+Action+ relationship: every ``mothable'' item is
recognized by \verb+a->image != nil+; the click-target distinction is
recognized by \verb+a->link != nil+. The marker insertion does a
splice-in/splice-out of one extra Rtext rather than rebuilding the list.

<<function [[mothon]](mothra)>>=
void
mothon(Www *w, int on)
{
    Rtext *t, *x;
    Action *a, *ap;

    if(w==0 || mothmode==on)
        return;
    if(mothmode = on)
        message("moth mode!");
    else
        message(mothra);
    /*
     * insert or remove artificial links to the href for 
     * images that are also links
     */
    for(t=w->text;t;t=t->next){
        a=t->user;
        if(a == nil || a->image == nil)
            continue;
        if(a->link == nil){
            if(on)
                t->flags |= PL_HOT;
            else
                t->flags &= ~PL_HOT;
            continue;
        }
        x = t->next;
        if(on){
            t->next = nil;
            ap=emalloc(sizeof(Action));
            ap->link = strdup(a->link);
            plrtstr(&t->next, 0, 0, /*0,*/ t->font, strdup("->"), PL_HOT, ap);
            t->next->next = x;
        } else {
            if(x) {
                t->next = x->next;
                x->next = nil;
                freetext(x);
            }
        }
    }
    updtext(w);
    donecurs();
}
@

<<function [[killpix]](mothra)>>=
void killpix(Www *w){
    Rtext *t;

    if(w==0 || !w->finished && !w->alldone)
        return;
    for(t=w->text; t; t=t->next)
        if(t->b && t->user)
            t->b=0;
    freepix(w->pix);
    w->pix=0;
    updtext(w);
}
@

\section{The main I/O loop}

%claude:
The previous section showed the static layout. This section covers the
helpers that surround the main loop: cursor management, the cohort kill
note, the URL-string accessors, and the two pieces of process-creation
plumbing that the rest of the browser relies on, [<pipeline()>] and
[<gettext()>].

%claude:
[<mkhome()>] is the small, common idiom for finding a per-user state
directory: prefer \verb+$home/lib/mothra+ if \verb+$home+ is set, fall
back to \verb+/tmp+ otherwise. It is called lazily and memoized so that
the directory only gets created the first time something wants to write
to it (e.g. saving a page).

<<function [[mkhome]](mothra)>>=
char* mkhome(void){
    static char *home;          /* where to put files */
    char *henv, *tmp;
    int f;

    if(home == nil){
        henv=getenv("home");
        if(henv){
            tmp = smprint("%s/lib", henv);
            f=create(tmp, OREAD, DMDIR|0777);
            if(f!=-1) close(f);
            free(tmp);

            home = smprint("%s/lib/mothra", henv);
            f=create(home, OREAD, DMDIR|0777);
            if(f!=-1) close(f);
            free(henv);
        }
        else
            home = strdup("/tmp");
    }
    return home;
}
@

<<function [[donecurs]](mothra)>>=
void donecurs(void){
    if(current && current->alldone==0)
        esetcursor(&readingcurs);
    else if(mothmode)
        esetcursor(&mothcurs);
    else
        esetcursor(0);
}
@

<<function [[drawlock]](mothra)>>=
void drawlock(int dolock){
    static int ref = 0;
    if(dolock){
        if(ref++ == 0)
            lockdisplay(display);
    } else {
        if(--ref == 0)
            unlockdisplay(display);
    }
}
@

%claude:
[<killcohort()>] is the cohort cleanup routine, run on \verb+atexit+. The
three-iteration loop with one-second sleeps is defensive: a single
\verb+kill+ note can race with a process that has notes blocked or that
forks just as it arrives. Sending three times virtually guarantees a
clean wipe of every helper (image fetcher, network reader, charset
filter, format converter) before mothra itself exits. The cute comment
\verb+It's a long way to the kitchen+ is the original Plan 9 source
quoting the song lyric.

<<function [[killcohort]](mothra)>>=
void killcohort(void){
    int i;
    for(i=0;i!=3;i++){  /* It's a long way to the kitchen */
        postnote(PNGROUP, cohort, "kill\n");
        sleep(1);
    }
}
@

<<function [[catch]](mothra)>>=
void catch(void*, char*){
    noted(NCONT);
}
@

<<function [[dienow]](mothra)>>=
void dienow(void*, char*){
    noted(NDFLT);
}
@

<<function [[message]](mothra)>>=
void message(char *s, ...){
    static char buf[1024];
    char *out;
    va_list args;
    va_start(args, s);
    out = buf + vsnprint(buf, sizeof(buf), s, args);
    va_end(args);
    *out='\0';
    plinitlabel(msg, PACKN|FILLX, buf);
    if(defdisplay) pldraw(msg, view);
}
@

<<function [[htmlerror]](mothra)>>=
void htmlerror(char *name, int line, char *m, ...){
    static char buf[1024];
    char *out;
    va_list args;
    if(verbose){
        va_start(args, m);
        out=buf+snprint(buf, sizeof(buf), "%s: line %d: ", name, line);
        out+=vsnprint(out, sizeof(buf)-(out-buf)-1, m, args);
        va_end(args);
        *out='\0';
        fprint(2, "%s\n", buf);
    }
}
@

<<function [[confirm]](mothra)>>=
int confirm(int b){
    Mouse down, up;
    esetcursor(&confirmcursor);
    do down=emouse(); while(!down.buttons);
    do up=emouse(); while(up.buttons);
    donecurs();
    return down.buttons==(1<<(b-1));
}
