    [Qcookies]     = { "cookies",     0666,       0 },

    [Qclient]      = { "XXX",         DMDIR|0555, 0 },
    [Qctl]         = { "ctl",         0666,       0 },
    [Qbody]        = { "body",        0444,       0 },
    [Qbodyext]     = { "XXX",         0444,       0 },

