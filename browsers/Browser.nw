<<function [[clientthread]](webfs)>>=
static void
clientthread(void *a)
{
    Client *c;
    Req *r;

    c = a;
    if(c->plumbed) {
        recvp(c->creq);
        if(c->url == nil){
            fprint(2, "bad url got plumbed\n");
            return;
        }
        clientbodyopen(c, nil);
        replumb(c);
    }
    while((r = recvp(c->creq)) != nil){
        if(fsdebug)
            fprint(2, "clientthread %F\n", &r->ifcall);
        switch(r->ifcall.type){
        case Topen:
            if(c->plumbed) {
                c->plumbed = 0;
                c->ref--;                       /* from plumburl() */
                respond(r, nil);
            }
            else
                clientbodyopen(c, r);
            break;
        case Tread:
            clientbodyread(c, r);
            break;
        case Tflush:
            respond(r, nil);
        }
        if(fsdebug)
            fprint(2, "clientthread finished req\n");
    }
}
@

<<function [[clientbodyread]](webfs)>>=
void
clientbodyread(Client *c, Req *r)
{
    char e[ERRMAX];

    if(c->url->read == nil){
        respond(r, "unsupported url type");
        return;
    }
    if(c->url->read(c, r) < 0){
        rerrstr(e, sizeof e);
        c->iobusy = 0;
        respond(r, e);
        return;
    }
    c->iobusy = 0;
    respond(r, nil);
}
