<<function [[readjar]](webfs)>>=
static Jar*
readjar(char *file)
{
    char *lock, *p;
    Jar *jar;

    jar = newjar();
    lock = emalloc9p(strlen(file)+10);
    strcpy(lock, file);
    if((p = strrchr(lock, '/')) != nil)
        p++;
    else
        p = lock;
    memmove(p+2, p, strlen(p)+1);
    p[0] = 'L';
    p[1] = '.';
    jar->lockfile = lock;
    jar->file = file;
    jar->dirty = 1;

    if(syncjar(jar) < 0){
        free(jar->file);
        free(jar->lockfile);
        free(jar);
        return nil;
    }
    return jar;
}
