@

%XXX
<<[[mkpanels()]](mothra) set [[alt]]>>=
alt=plpopup(0, PACKE|EXPAND, 0, 0, menu3);
    ybar=plscrollbar(alt, PACKW|USERFL);
    xbar=plscrollbar(alt, xflags);
    alttext=pltextview(alt, PACKE|EXPAND, Pt(0, 0), 0, dolink);
