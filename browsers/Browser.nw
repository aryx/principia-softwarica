/*
 * convert a url into a local file name.
 */
char *urltofile(Url *url){
    char *name, *slash;
    if(url == nil)
        return nil;
    name = urlstr(url);
    if(name == nil || name[0] == 0)
        name = "/";
    if(slash = strrchr(name, '/'))
        name = slash+1;
    if(name[0] == 0)
        name = "index";
