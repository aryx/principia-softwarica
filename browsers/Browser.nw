<<function [[plumburl]](webfs)>>=
void
plumburl(char *url, char *base)
{
    int i;
    Client *c;
    Url *ubase, *uurl;

    ubase = nil;
    if(base){
        ubase = parseurl(base, nil);
        if(ubase == nil)
            return;
    }
    uurl = parseurl(url, ubase);
    if(uurl == nil){
        freeurl(ubase);
        return;
    }
    i = newclient(1);
    c = client[i];
    c->ref++;
    c->baseurl = ubase;
    c->url = uurl;
    sendp(c->creq, nil);
}
