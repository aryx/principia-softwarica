/* individual cookie */
static int
cookiefmt(Fmt *fp)
{
    int j, k, first;
    char *t;
    Cookie *c;

    c = va_arg(fp->args, Cookie*);

    first = 1;
    for(j=0; j<nelem(stab); j++){
        t = *(char**)((uintptr)c+stab[j].offset);
        if(t == nil)
            continue;
        if(first)
            first = 0;
        else
            fmtstrcpy(fp, " ");
        fmtprint(fp, "%s=%q", stab[j].s, t);
    }
    for(j=0; j<nelem(itab); j++){
        k = *(int*)((uintptr)c+itab[j].offset);
        if(k == 0)
            continue;
        if(first)
            first = 0;
        else
            fmtstrcpy(fp, " ");
        fmtprint(fp, "%s=%ud", itab[j].s, k);
    }
    return 0;
}
