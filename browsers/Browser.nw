<<function [[httpclose]](webfs)>>=
void
httpclose(Client *c)
{
    HttpState *hs;

    hs = c->aux;
    if(hs == nil)
        return;
    if(hs->fd >= 0)
        ioclose(c->io, hs->fd);
    hs->fd = -1;
    free(hs->location);
    free(hs->setcookie);
    free(hs->netaddr);
    free(hs->credentials);
    free(hs);
    c->aux = nil;
}
