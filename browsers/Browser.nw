static void
closejar(Jar *jar)
{
    int i;

    if(jar == nil)
        return;
    expirejar(jar, 0);
    if(syncjar(jar) < 0)
        fprint(2, "warning: cannot rewrite cookie jar: %r\n");

    for(i=0; i<jar->nc; i++)
        freecookie(&jar->c[i]);

    free(jar->file);
    free(jar);  
}
