<<function [[filter]](mothra)>>=
void filter(int fd, char *cmd){
    switch(rfork(RFFDG|RFPROC|RFMEM|RFREND|RFNOWAIT|RFNOTEG)){
    case -1:
        message("Can't fork!");
        break;
    case 0:
        dupfds(fd, 1, 2, -1);
        execl("/bin/rc", "rc", "-c", cmd, nil);
        _exits(0);
    }
    close(fd);
}
