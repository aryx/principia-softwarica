<<function [[pl_htmloutput]](mothra)>>=
void pl_htmloutput(Hglob *g, int nsp, char *s, Field *field){
    Font *f;
    int space, indent, flags, voff;
    Action *ap;
    if(g->state->tag==Tag_title
/*      || g->state->tag==Tag_textarea */
    || g->state->tag==Tag_select){
        if(s){
            if(g->tp!=g->text && g->tp!=g->etext && g->tp[-1]!=' ')
                *g->tp++=' ';
            while(g->tp!=g->etext && *s) *g->tp++=*s++;
            if(g->state->tag==Tag_title) g->dst->changed=1;
            *g->tp='\0';
        }
        return;
    }
    voff = 0;
    f=pl_whichfont(g->state->font, g->state->size, &space);
    if(g->state->sub){
        voff = g->state->sub * f->ascent / 2;
        g->state->size = SMALL;
        f=pl_whichfont(g->state->font, g->state->size, &space);
    }
    indent=g->state->margin;
    if(g->para){
        space=1000000;
        indent+=g->state->indent;
    }
    else if(g->linebrk)
        space=1000000;
    else if(nsp<=0)
        space=0;
    if(g->state->image==0 && g->state->link==0 && g->state->name==0 && field==0)
        ap=0;
    else{
        ap=emalloc(sizeof(Action));
        if(g->state->image)
            ap->image = strdup(g->state->image);
        if(g->state->link)
            ap->link = strdup(g->state->link);
        if(g->state->name)
            ap->name = strdup(g->state->name);
        ap->ismap=g->state->ismap;
        ap->width=g->state->width;
        ap->height=g->state->height;
        ap->field=field;
    }
    if(space<0) space=0;
    if(indent<0) indent=0;
    if(g->state->pre && s[0]=='\t'){
        space=0;
        while(s[0]=='\t'){
            space++;
            s++;
        }
        space=PL_TAB|space;
        if(g->linebrk){
            indent=space;
            space=1000000;
        }
    }
    flags = 0;
    if(g->state->link)
        flags |= PL_HOT;
    //if(g->state->strike)
    //  flags |= PL_STR;
    plrtstr(&g->dst->text, space, indent, /*voff,*/ f, strdup(s), flags, ap);
    g->para=0;
    g->linebrk=0;
    g->dst->changed=1;
}
@

\section{Building a flat list of items (no DOM)}

%claude:
This section is the core dispatch loop. [<plrdhtml()>] is the entry
point: it initializes a fresh [<Hglob>], pushes the implicit
\verb+<html>+ frame on the formatting stack, then enters the big
[[for(;;) switch(pl_gettoken(...))]] loop. Each iteration pulls one
token (TAG/ENDTAG/TEXT/EOF), runs the per-tag handler that mutates the
formatting stack and appends to the [<Www>]'s text list, and loops.

%claude:
The handler set is a long switch that the rest of this section walks
through tag by tag. Most cases fit in two or three lines: ``read this
attribute, set this stack field, maybe emit one Rtext.'' The remarkable
property is that the same dispatch covers tags as different as
\verb+<a>+ (sets \verb+state->link+, then emits one Rtext-with-Action
per text run inside it), \verb+<img>+ (emits one Rtext-with-Action
right now, with no enclosed run), and \verb+<table>+ (almost a no-op,
linear pass-through). The ``flat list'' invariant is maintained because
no handler ever recurses --- they all just push, mutate, or pop the
current formatting state.

<<function [[plaintext]](mothra)>>=
void plaintext(Hglob *g){
    char line[NLINE];
    char *lp, *elp;
    int c;
    g->state->font=CWIDTH;
    g->state->size=NORMAL;
    g->state->sub = 0;
    elp=&line[NLINE-UTFmax-1];
    lp=line;
    for(;;){
        c=pl_readc(g);
        if(c==EOF) break;
        if(c=='\n' || lp>=elp){
            *lp='\0';
            g->linebrk=1;
            pl_htmloutput(g, 0, line, 0);
            lp=line;
        }
        if(c=='\t'){
            do *lp++=' '; while(lp<elp && utfnlen(line, lp-line)%8!=0);
        }
        else if(c!='\n')
            lp += lrunetochar(lp, c);
    }
    if(lp!=line){
        *lp='\0';
        g->linebrk=1;
        pl_htmloutput(g, 0, line, 0);
    }
}
@

<<function [[plrdplain]](mothra)>>=
void plrdplain(char *name, int fd, Www *dst){
    Hglob g;
    g.state=g.stack;
    g.state->tag=Tag_html;
    g.state->font=CWIDTH;
    g.state->size=NORMAL;
    g.state->sub=0;
    g.state->pre=0;
    g.state->image=0;
    g.state->link=0;
    g.state->name=0;
    g.state->margin=0;
    g.state->indent=20;
    g.state->ismap=0;
    g.state->isscript=0;
    g.state->strike=0;
    g.state->width=0;
    g.state->height=0;
    g.dst=dst;
    g.hfd=fd;
    g.name=name;
    g.ehbuf=g.hbufp=g.hbuf;
    g.npeekc=0;
    g.heof=0;
    g.lineno=1;
    g.linebrk=1;
    g.para=0;
    g.text=dst->title;
    g.tp=g.text;
    g.etext=g.text+NTITLE-1;
    g.spacc=0;
    g.form=0;
    nstrcpy(g.text, name, NTITLE);
    plaintext(&g);
    finish(dst);
}
@

%claude:
[<plrdhtml()>] is the parser entry point. The first half is just
clearing the [<Hglob>] and seeding the bottom-of-stack frame with the
root document state. The interesting half is the dispatch loop. A few
things to notice in passing through it:
\begin{itemize}
\item \verb+OPTEND+ tags (paragraph-like things that may or may not have
a matching close) get handled by walking down the stack to find a
matching open and popping back to it; the lenient real-world HTML rule
``end tag is allowed to skip several levels'' is implemented exactly here.
\item \verb+END+ tags (normally well-formed) just push.
\item \verb+<img>+ resolves the \verb+src+ attribute, optionally falls
back to ``find any URL-shaped attribute'' for sites that lazy-load
images via JavaScript-rewritten attributes, and emits one Rtext with the
alt text or fallback string.
\item \verb+<a>+ stores the \verb+href+ in the current state frame and
the \verb+name+ in the same frame for fragment-jump targets, then emits
an empty Rtext to anchor the name.
\item \verb+<meta http-equiv=refresh>+ is rendered as the literal
\verb+[refresh: URL]+ text, so the user sees the redirect URL rather
than mothra silently following it.
\end{itemize}

<<function [[plrdhtml]](mothra)>>=
void plrdhtml(char *name, int fd, Www *dst, int killimgs){
    int tagerr;
    Stack *sp;
    char buf[20];
    char *str;
    Hglob g;

    g.state=g.stack;
    g.state->tag=Tag_html;
    g.state->font=ROMAN;
    g.state->size=NORMAL;
    g.state->sub=0;
    g.state->pre=0;
    g.state->image=0;
    g.state->link=0;
    g.state->name=0;
    g.state->margin=0;
    g.state->indent=25;
    g.state->ismap=0;
    g.state->isscript=0;
    g.state->strike=0;
    g.state->width=0;
    g.state->height=0;
    g.dst=dst;
    g.hfd=fd;
    g.name=name;
    g.ehbuf=g.hbufp=g.hbuf;
    g.npeekc=0;
    g.heof=0;
    g.lineno=1;
    g.linebrk=1;
    g.para=0;
    g.text=dst->title;
    g.tp=g.text;
    g.etext=g.text+NTITLE-1;
    dst->title[0]='\0';
    g.spacc=0;
    g.form=0;

    for(;;) switch(pl_gettoken(&g)){
    case TAG:
        switch(tag[g.tag].action){
        case OPTEND:
            for(sp=g.state;sp!=g.stack && sp->tag!=g.tag;--sp);
            if(sp->tag!=g.tag)
                pl_pushstate(&g, g.tag);
            else
                for(;g.state!=sp;--g.state){
                    if(tag[g.state->tag].action!=OPTEND)
                        htmlerror(g.name, g.lineno,
                            "end tag </%s> missing",
                            tag[g.state->tag].name);
                    pl_popstate(g.state);
                }
            break;
        case END:
            pl_pushstate(&g, g.tag);
            break;
        }
        str=pl_getattr(g.attr, "id");
        if(str && *str){
            char *swap;

            swap = g.state->name;
            g.state->name = str;
            pl_htmloutput(&g, 0, "", 0);
            g.state->name = swap;
        }
        switch(g.tag){
        default:
            htmlerror(g.name, g.lineno,
                "unimplemented tag <%s>", tag[g.tag].name);
            break;
        case Tag_end:   /* unrecognized start tag */
            break;
        case Tag_img:
        case Tag_image:
            str=pl_getattr(g.attr, "src");
            if(str && *str){
                free(g.state->image);
                g.state->image = strdup(str);
                //Url x;
                //seturl(&x, str, "http://iwp9.org");
                //// TODO: check return code
                //urlresolve(&x);
                ////free(str?)
                //g.state->image = strdup(urlstr(&x));
            } else {
                Pair *a;

                /*
                 * hack to emulate javascript that rewrites some attribute
                 * into src= after page got loaded. just look for some
                 * attribute that looks like a url.
                 */
                for(a = g.attr; a->name; a++){
                    if(strcmp(a->name, "longdesc") == 0)
                        continue;
                    if(str = linkify(a->value)){
                        free(g.state->image);
                        g.state->image = str;
                        break;
                    }
                }
            }
            g.state->ismap=pl_hasattr(g.attr, "ismap");
            str=pl_getattr(g.attr, "width");
            if(str && *str)
                g.state->width=strtolength(&g, HORIZ, str);
            str=pl_getattr(g.attr, "height");
            if(str && *str)
                g.state->height=strtolength(&g, VERT, str);
            str=pl_getattr(g.attr, "alt");
            if(str==0 || *str == 0){
                if(g.state->image)
                    str=g.state->image;
                else
                    str="[[image]]";
            }
            pl_htmloutput(&g, 0, str, 0);
            free(g.state->image);
            g.state->image=0;
            g.state->ismap=0;
            g.state->width=0;
            g.state->height=0;
            break;
        case Tag_plaintext:
            g.spacc=0;
            plaintext(&g);
            break;
        case Tag_comment:
        case Tag_html:
        case Tag_link:
        case Tag_nextid:
        case Tag_table:
            break;
        case Tag_tr:
            g.spacc=0;
            g.linebrk=1;
            break;
        case Tag_th:
            g.state->font=BOLD;
        case Tag_td:
            g.spacc++;
            break;
        case Tag_base:
            str=pl_getattr(g.attr, "href");
            if(str && *str){
                seturl(g.dst->url, str, g.dst->url->fullname);
                nstrcpy(g.dst->url->fullname, str, sizeof(g.dst->url->fullname));
                /* base should be a full url, but it often isnt so have to resolve */
                urlresolve(g.dst->url);
            }
            break;
        case Tag_a:
            str=pl_getattr(g.attr, "name");
            if(str && *str){
                free(g.state->name);
                g.state->name = strdup(str);
            }
            pl_htmloutput(&g, 0, "", 0);
            str=pl_getattr(g.attr, "href");
            if(str && *str){
                free(g.state->link);
                g.state->link = strdup(str);
            }
            break;
        case Tag_meta:
            if((str=pl_getattr(g.attr, "http-equiv"))==0)
                break;
            if(cistrcmp(str, "refresh"))
                break;
            if((str=pl_getattr(g.attr, "content"))==0)
                break;
            if((str=strchr(str, '='))==0)
                break;
            str++;
            pl_htmloutput(&g, 0, "[refresh: ", 0);
            free(g.state->link);
            g.state->link=unquot(str);
            pl_htmloutput(&g, 0, g.state->link, 0);
            free(g.state->link);
            g.state->link=0;
            pl_htmloutput(&g, 0, "]", 0);
            g.linebrk=1;
            g.spacc=0;
            break;
        case Tag_source:
        case Tag_video:
        case Tag_audio:
        case Tag_embed:
        case Tag_frame:
        case Tag_iframe:
            snprint(buf, sizeof(buf), "[%s: ", tag[g.tag].name);
            pl_htmloutput(&g, 0, buf, 0);
            str=pl_getattr(g.attr, "src");
            if(str && *str){
                free(g.state->link);
                g.state->link = strdup(str);
            }
            str=pl_getattr(g.attr, "name");
            if(str && *str){
                free(g.state->name);
                g.state->name = strdup(str);
            } else if(g.state->link)
                str = g.state->link;
            else
                str = "";
            pl_htmloutput(&g, 0, str, 0);
            free(g.state->link);
            g.state->link=0;
            free(g.state->name);
            g.state->name=0;
            pl_htmloutput(&g, 0, "]", 0);
            g.linebrk=1;
            g.spacc=0;
            break;
        case Tag_address:
            g.spacc=0;
            g.linebrk=1;
            g.state->font=ROMAN;
            g.state->size=NORMAL;
            g.state->margin=300;
            g.state->indent=50;
            break;
        case Tag_b:
        case Tag_strong:
            g.state->font=BOLD;
            break;
        case Tag_s:
        case Tag_strike:
        case Tag_del:
            g.state->strike=1;
            break;
        case Tag_sub:
            g.state->sub++;
            break;
        case Tag_sup:
            g.state->sub--;
            break;
        case Tag_blockquot:
            g.spacc=0;
            g.linebrk=1;
            g.state->margin+=50;
            g.state->indent=20;
            break;
        case Tag_body:
            break;
        case Tag_head:
            g.state->font=ROMAN;
            g.state->size=NORMAL;
            g.state->margin=0;
            g.state->indent=20;
            g.spacc=0;
            break;
        case Tag_div:
            g.spacc=0;
            break;
        case Tag_br:
        case Tag_wbr:
            g.spacc=0;
            g.linebrk=1;
            break;
        case Tag_span:
        case Tag_center:
            /* more to come */
            break;
        case Tag_cite:
        case Tag_acronym:
            g.state->font=ITALIC;
            g.state->size=NORMAL;
            break;
        case Tag_code:
        case Tag_samp:
            g.state->font=CWIDTH;
            g.state->size=NORMAL;
            break;
        case Tag_dd:
            g.linebrk=1;
            g.state->indent=0;
            g.state->font=ROMAN;
            g.spacc=0;
            break;
        case Tag_dfn:
            htmlerror(g.name, g.lineno, "<dfn> deprecated");
        case Tag_abbr:
            g.state->font=BOLD;
            g.state->size=NORMAL;
            break;
        case Tag_dl:
            g.state->font=BOLD;
            g.state->size=NORMAL;
            g.state->margin+=40;
            g.spacc=0;
            break;
        case Tag_dt:
            g.para=1;
            g.state->indent=-40;
            g.state->font=BOLD;
            g.spacc=0;
            break;
        case Tag_figcaption:
            g.linebrk=1;
            break;
        case Tag_font:
            /* more to come */
            break;
        case Tag_u:
            htmlerror(g.name, g.lineno, "<u> deprecated");
        case Tag_ins:
        case Tag_em:
        case Tag_i:
        case Tag_var:
            g.state->font=ITALIC;
            break;
        case Tag_h1:
            g.linebrk=1;
            g.state->font=BOLD;
            g.state->size=ENORMOUS;
            g.state->margin+=100;
            g.spacc=0;
            break;
        case Tag_h2:
            pl_linespace(&g);
            g.state->font=BOLD;
            g.state->size=ENORMOUS;
            g.spacc=0;
            break;
        case Tag_h3:
            g.linebrk=1;
            pl_linespace(&g);
            g.state->font=ITALIC;
            g.state->size=ENORMOUS;
            g.state->margin+=20;
            g.spacc=0;
            break;
        case Tag_h4:
            pl_linespace(&g);
            g.state->font=BOLD;
            g.state->size=LARGE;
            g.state->margin+=10;
            g.spacc=0;
            break;
        case Tag_h5:
            pl_linespace(&g);
            g.state->font=ITALIC;
            g.state->size=LARGE;
            g.state->margin+=10;
            g.spacc=0;
            break;
        case Tag_h6:
            pl_linespace(&g);
            g.state->font=BOLD;
            g.state->size=LARGE;
            g.spacc=0;
            break;
        case Tag_hr:
            g.spacc=0;
            plrtbitmap(&g.dst->text, 1000000, g.state->margin, /*0,*/ hrule, 0, 0);
            break;
        case Tag_key:
            htmlerror(g.name, g.lineno, "<key> deprecated");
        case Tag_kbd:
            g.state->font=CWIDTH;
            break;
        case Tag_dir:
        case Tag_menu:
        case Tag_ol:
        case Tag_ul:
            g.state->number=0;
            g.linebrk=1;
            g.state->margin+=25;
            g.state->indent=-25;
            g.spacc=0;
            break;
        case Tag_li:
            g.spacc=0;
            switch(g.state->tag){
            default:
                htmlerror(g.name, g.lineno, "can't have <li> in <%s>",
                    tag[g.state->tag].name);
            case Tag_dir:       /* supposed to be multi-columns, can't do! */
            case Tag_menu:
                g.linebrk=1;
                break;
            case Tag_ol:
                g.para=1;
                snprint(buf, sizeof(buf), "%2d  ", ++g.state->number);
                pl_htmloutput(&g, 0, buf, 0);
                break;
            case Tag_ul:
                g.para=0;
                g.linebrk=0;
                g.spacc=-1;
                plrtbitmap(&g.dst->text, 100000,
                    g.state->margin+g.state->indent, /*0,*/ bullet, 0, 0);
                break;
            }
            break;
        case Tag_p:
            pl_linespace(&g);
            g.linebrk=1;
            g.spacc=0;
            break;
        case Tag_listing:
        case Tag_xmp:
            htmlerror(g.name, g.lineno, "<%s> deprecated", tag[g.tag].name);
        case Tag_pre:
            g.state->indent=0;
            g.state->pre=1;
            g.state->font=CWIDTH;
            g.state->size=NORMAL;
            pl_linespace(&g);
            break;
        case Tag_tt:
            g.state->font=CWIDTH;
            g.state->size=NORMAL;
            break;
        case Tag_title:
            g.text=dst->title+strlen(dst->title);
            g.tp=g.text;
            g.etext=dst->title+NTITLE-1;
            break;
        case Tag_form:
        case Tag_input:
        case Tag_button:
        case Tag_select:
        case Tag_option:
        case Tag_textarea:
        case Tag_isindex:
            rdform(&g);
            break;
        case Tag_script:
        case Tag_style:
            g.state->isscript=1;
            break;
        }
        break;

    case ENDTAG:
        /*
         * If the end tag doesn't match the top, we try to uncover a match
         * on the stack.
         */
        if(g.state->tag!=g.tag){
            tagerr=0;
            for(sp=g.state;sp!=g.stack;--sp){
                if(sp->tag==g.tag)
                    break;
                if(tag[g.state->tag].action!=OPTEND) tagerr++;
            }
            if(sp==g.stack){
                if(tagerr)
                    htmlerror(g.name, g.lineno,
                        "end tag mismatch <%s>...</%s>, ignored",
                        tag[g.state->tag].name, tag[g.tag].name);
            }
            else{
                if(tagerr)
                    htmlerror(g.name, g.lineno,
                        "end tag mismatch <%s>...</%s>, "
                        "intervening tags popped",
                        tag[g.state->tag].name, tag[g.tag].name);

                for(--sp; g.state!=sp; --g.state)
                    pl_popstate(g.state);
            }
        }
        else if(g.state==g.stack)
            htmlerror(g.name, g.lineno, "end tag </%s> at stack bottom",
                tag[g.tag].name);
        else
            pl_popstate(g.state--);
        switch(g.tag){
        case Tag_select:
        case Tag_form:
        case Tag_textarea:
            endform(&g);
            break;
        case Tag_h1:
        case Tag_h2:
        case Tag_h3:
        case Tag_h4:
            pl_linespace(&g);
            break;
        case Tag_div:
        case Tag_address:
        case Tag_blockquot:
        case Tag_body:
        case Tag_dir:
        case Tag_dl:
        case Tag_dt:
        case Tag_h5:
        case Tag_h6:
        case Tag_listing:
        case Tag_menu:
        case Tag_ol:
        case Tag_title:
        case Tag_ul:
        case Tag_xmp:
        case Tag_table:
            g.linebrk=1;
            break;
        case Tag_article:
        case Tag_pre:
            pl_linespace(&g);
            break;
        }
        break;
    case TEXT:
        if(g.state->isscript)
            continue;
        if(g.state->link==0 && (str = linkify(g.token))){
            g.state->link=str; 
            pl_htmloutput(&g, g.nsp, g.token, 0);
            free(g.state->link);
            g.state->link=0;
        } else
            pl_htmloutput(&g, g.nsp, g.token, 0);
        break;
    case EOF:
        for(;g.state!=g.stack;--g.state){
            if(tag[g.state->tag].action!=OPTEND)
                htmlerror(g.name, g.lineno,
                    "missing </%s> at EOF", tag[g.state->tag].name);
            pl_popstate(g.state);
        }
        pl_popstate(g.state);
        *g.tp='\0';
        if (!killimgs)
            getpix(dst->text, dst);
        finish(dst);
        return;
    }
}
@

\section{Entities and character references}

%claude:
HTML lets the document use \verb+&amp;+ instead of literal \verb+&+,
\verb+&#955;+ for U+03BB ($\lambda$), \verb+&lambda;+ for the same
thing, etc. The parser turns each of these back into a single rune via
[<pl_rmentities()>], which scans the freshly accumulated TEXT token in
place and replaces every recognized escape with its rune. The lookup is
a linear scan of the [<entity>] table because there are only a few
hundred named entities and they are touched at most once per text run.

%claude:
The numeric forms (\verb+&#NNN;+ for decimal, \verb+&#xHH;+ for hex)
are handled inline since they do not require a table lookup.


<<function [[alnumchar]](mothra)>>=
int alnumchar(int c){
    return 'a'<=c && c<='z' || 'A'<=c && c<='Z' || '0'<=c && c<='9';
}
@

<<function [[entchar]](mothra)>>=
int entchar(int c){
    return c=='#' || alnumchar(c);
}
@

<<function [[linkify]](mothra)>>=
/* return url if text token looks like a hyperlink */
char *linkify(char *s){
    int i;
    if(s == 0 && s[0] == 0)
        return 0;
    for(i = 0; i < nelem(links); i++)
        if(!cistrncmp(s, links[i].prefix, links[i].len))
            return strdup(s);
    if(!cistrncmp(s, "www.", 4)){
        int d, i;

        d = 1;
        for(i=4; s[i]; i++){
            if(s[i] == '.'){
                if(s[i-1] == '.')
                    return 0;
                d++;
            } else if(!alnumchar(s[i]))
                break;
        }
        if(d >= 2)
            return smprint("http://%s", s);
    }
    return 0;
}
@

<<function [[pl_rmentities]](mothra)>>=
/*
 * remove entity references, in place.
 * Potential bug:
 *      This doesn't work if removing an entity reference can lengthen the string!
 *      Fortunately, this doesn't happen.
 */
void pl_rmentities(Hglob *, char *s){
    char *t, *u, c, svc;
    t=s;
    do{
        c=*s++;
        if(c=='&'
        && ((*s=='#' && strchr("0123456789Xx", s[1]))
          || 'a'<=*s && *s<='z'
          || 'A'<=*s && *s<='Z')){
            u=s;
            while(entchar(*s)) s++;
            svc=*s;
            *s = 0;
            if(svc==';') s++;
            if(strcmp(u, "lt") == 0)
                *t++='<';
            else if(strcmp(u, "gt") == 0)
                *t++='>';
            else if(strcmp(u, "quot") == 0)
                *t++='"';
            else if(strcmp(u, "apos") == 0)
                *t++='\'';
            else if(strcmp(u, "amp") == 0)
                *t++='&';
            else {
                if(svc==';') s--;
                *s=svc;
                *t++='&';
                while(u<s)
                    *t++=*u++;
            }
        }
        else if((uchar)c == 0xc2 && (uchar)*s == 0xad)
            s++; /* ignore soft hyphens */
        else
            *t++=c;
    }while(c);
}
@

\section{Surviving real-world HTML}

%claude:
Real HTML is messy. Tags get closed in the wrong order. Attributes are
unquoted with embedded spaces. Whole sections of malformed markup get
shovelled out by content management systems. The parser stays robust by
following two rules: every error path calls [<htmlerror()>] (which is
just a logger, not a fatal abort) and every state mutation is bounded
(the formatting stack has a fixed cap, the token buffer is fixed, etc.).
The OPTEND walking up the formatting stack is the most aggressive
recovery: ``you said \verb+</p>+ but I am eight nesting levels deep
inside paragraphs'' becomes ``pop everything, find the open
\verb+<p>+, pop back to its level.''

%******************************************************************************
\chapter{Content Dispatch}
%******************************************************************************
\label{chap:content-dispatch}

%claude:
After webfs hands mothra a body fd, mothra has to decide what kind of
content it is and which renderer to feed it to. Three strategies are
tried in order: trust the server's \verb+Content-Type:+ header
(transmitted via \verb+/mnt/web/N/contenttype+); if absent, sniff the
first bytes of the body via \verb+/bin/file -m+ in a subprocess; if
that comes back ambiguous, default to plain text. The dispatch then
picks one of the supported viewers ([<XKind>] enum: PLAIN, HTML, GIF,
JPEG, PNG, BMP, ICO, PAGE) and either parses the bytes inline (for HTML
and PLAIN) or shells out to an external viewer like \verb+page -w+ (for
images).

\section{MIME sniffing ([[snoop.c]])}

%claude:
[<XKind>] is the small enum of content kinds mothra knows about. There
is no separate ``font'' or ``video'' kind because mothra would not know
what to do with them anyway --- those go through the unknown-content
branch, which falls back to ``save to a file'' or ``shell out to
\verb+page+'' depending on the type prefix.

<<enum [[XKind]](mothra)>>=
enum{
    PLAIN,
    HTML,

    GIF,
    JPEG,
    PNG,
    BMP,
    ICO,

    PAGE,
};
@

%claude:
[<filetype()>] is the heart of MIME sniffing. The challenge is that the
fd is a one-shot stream: mothra cannot read the first 4~KiB to sniff
and then ``unread'' them. The trick: read up to 4~KiB into a buffer,
spawn a \verb+/bin/file -m+ subprocess with three pipes
(\verb+ifd+/\verb+ofd+/\verb+xfd+), send the buffer to \verb+file+'s
stdin, and then a second subprocess re-emits the same buffer plus
whatever else can be read from \verb+fd+ into a fresh fd that replaces
\verb+fd+ via \verb+dup+. The caller never notices that bytes were peeked
at. The MIME type comes back from \verb+file+'s stdout via a third pipe.

%claude:
This is the only place in mothra that does MIME sniffing for content
type. The subprocess pattern (peek-and-replumb) is one of the most
underused tricks in Unix/Plan~9 programming.

<<function [[filetype]](mothra)>>=
int
filetype(int fd, char *typ, int ntyp)
{
    int ifd[2], ofd[2], xfd[2], n;
    char *argv[3], buf[4096];

    typ[0] = 0;
    if((n = readn(fd, buf, sizeof(buf))) < 0)
        return -1;
    if(n == 0)
        return 0;
    if(pipe(ifd) < 0)
        return -1;
    if(pipe(ofd) < 0){
Err1:
        close(ifd[0]);
        close(ifd[1]);
        return -1;
    }
    switch(rfork(RFFDG|RFPROC|RFNOWAIT)){
    case -1:
        close(ofd[0]);
        close(ofd[1]);
        goto Err1;      
    case 0:
        dup(ifd[1], 0);
        dup(ofd[1], 1);

        close(ifd[1]);
        close(ifd[0]);
        close(ofd[1]);
        close(ofd[0]);
        close(fd);

        argv[0] = "file";
        argv[1] = "-m";
        argv[2] = 0;
        exec("/bin/file", argv);
    }
    close(ifd[1]);
    close(ofd[1]);

    if(rfork(RFFDG|RFPROC|RFNOWAIT) == 0){
        close(fd);
        close(ofd[0]);
        write(ifd[0], buf, n);
        exits(nil);
    }
    close(ifd[0]);

    if(pipe(xfd) < 0){
        close(ofd[0]);
        return -1;
    }
    switch(rfork(RFFDG|RFPROC|RFNOWAIT)){
    case -1:
        break;
    case 0:
        close(ofd[0]);
        close(xfd[0]);
        do {
            if(write(xfd[1], buf, n) != n)
                break;
        } while((n = read(fd, buf, sizeof(buf))) > 0);
        exits(nil);
    default:
        dup(xfd[0], fd);
    }
    close(xfd[0]);
    close(xfd[1]);

    if((n = readn(ofd[0], typ, ntyp-1)) < 0)
        n = 0;
    close(ofd[0]);
    while(n > 0 && typ[n-1] == '\n')
        n--;
    typ[n] = 0;
    return 0;
}
@

%claude:
[<mimetotype()>] is the lookup table from MIME type strings to
[<XKind>] values. The \verb+image/+ and \verb+text/+ rows at the bottom
are prefix matches: anything that starts with \verb+image/+ but is not
explicitly listed (e.g.\ \verb+image/svg+xml+) maps to PAGE so it gets
opened with the page viewer; anything that starts with \verb+text/+ but
is not HTML maps to PLAIN.

<<function [[mimetotype]](mothra)>>=
int
mimetotype(char *mime)
{
    int i;
    static struct {
        char    *typ;
        int     val;
    } tab[] = {
    "text/plain",                       PLAIN,
    "text/html",                        HTML,

    "image/jpeg",                       JPEG,
    "image/gif",                        GIF,
    "image/png",                        PNG,
    "image/bmp",                        BMP,
    "image/x-icon",                     ICO,

    "application/pdf",          PAGE,
    "application/postscript",   PAGE,
    "application/ghostscript",  PAGE,
    "application/troff",                PAGE,

    "image/",                   PAGE,
    "text/",                    PLAIN,
    "message/rfc822",           PLAIN,
    };  

    for(i=0; i<nelem(tab); i++)
        if(strncmp(mime, tab[i].typ, strlen(tab[i].typ)) == 0)
            return tab[i].val;
            
    return -1;
}
@

<<function [[snooptype]](mothra)>>=
int
snooptype(int fd)
{
    char buf[128];
    
    if(filetype(fd, buf, sizeof(buf)) < 0)
        return -1;
        
    return mimetotype(buf);
}
@

\section{MIME detection via [[/bin/file -m]] subprocess}

%claude:
The previous section's [<filetype()>] is what dispatches to
\verb+/bin/file -m+. The \verb+-m+ flag asks \verb+file+ to print the
MIME type instead of its usual chatty description. Mothra inherits all
of \verb+file+'s sniffing rules (the magic-byte tables in \verb+/lib/file/magic+)
without having to ship them itself. Adding support for a new format
becomes ``add an entry to the magic table'' rather than ``add a sniffer
to mothra.''

\section{The viewer table (HTML, PLAIN, JPEG, GIF, PNG, \ldots)}

%claude:
The viewer table is implicit in [<geturl()>]'s switch on [<XKind>]:
HTML and PLAIN go through the in-process \verb+plrdhtml+/\verb+plrdplain+;
images and PAGE go through \verb+filter(fd, "exec page -w")+, which
spawns \verb+/bin/page+ as a sibling window. Everything else falls
through to the ``save to file'' prompt. There is no plug-in system; the
table is hard-coded.

\section{Fallback logic: [[image/]] and [[text/]] prefix rules}

%claude:
The \verb+image/+ and \verb+text/+ prefix rows at the bottom of
[<mimetotype()>] are the fallback. Any unrecognised \verb+image/...+
type maps to PAGE (so SVG, TIFF, WebP, etc.\ all open in
\verb+page -w+). Any unrecognised \verb+text/...+ maps to PLAIN. This
is enough for nearly every document type users actually encounter.

\section{Dispatching to the right reader}

%claude:
Dispatch happens in [<geturl()>]'s big switch on [<XKind>], which I
covered when introducing the function in chapter
\ref{chap:mothra-main}. The connection to this chapter is that the
[<XKind>] value returned by [<snooptype()>] is what the switch is
keyed on.

\section{Handling non-HTML content}

%claude:
Non-HTML, non-PLAIN, non-image content (PDF, PostScript, etc.) goes
through PAGE which spawns \verb+page -w+ as a separate window. Anything
that does not even fit one of those categories triggers the ``Save to
file'' prompt. Mothra never tries to render content it does not
understand --- that responsibility belongs to the external viewer or
the user.

%******************************************************************************
\chapter{Laying Out the Page}
%******************************************************************************
\label{chap:layout}

%claude:
``Layout'' for mothra is a thin wrapper over what \verb+libpanel+
already does for any \verb+pltextview+ widget: take a linked list of
\verb+Rtext+ nodes, lay them out as a flowing paragraph that respects
the widget's current width, hand it to libdraw to render. Mothra has no
layout engine of its own. The work it does is per-node:
\verb+pl_htmloutput()+ chooses the font, indentation, and link colour
for each Rtext as it is appended. Once the whole list is built,
\verb+plrtbitmap+/\verb+plrtstr+ in libpanel handle line breaks and
reflow on every resize.

\section{From parsed items to on-screen text runs}

%claude:
This is what the parser already does. \verb+pl_htmloutput()+ in
\verb+rdhtml.c+ takes the current formatting state from
\verb+g.state+ and translates it into the right libpanel call:
\verb+plrtstr+ for normal text runs, \verb+plrtbitmap+ for inline
images, both extending the same Rtext linked list. The Rtexts are not
``items'' in the layout sense --- they are leaves of a flowing
paragraph that libpanel sequences with horizontal/vertical glue.

\section{Word wrapping and reflow}

%claude:
Word wrapping is in libpanel \book{Widgets}, not in mothra. Each Rtext
carries an inter-word space hint; libpanel's textview walks the linked
list and inserts line breaks wherever the next Rtext would overflow the
current line. Resizing the window triggers \verb+eresized+, which calls
\verb+plpack+ on the root, which propagates new sizes down to the
textview, which re-flows automatically. Mothra never recomputes layout
itself.

\section{Fonts and text styles}

%claude:
Mothra uses four font families ([<XFonts>]: ROMAN, ITALIC, BOLD,
CWIDTH for typewriter) at four sizes ([<XFontSize>]: SMALL, NORMAL,
LARGE, ENORMOUS). The 16 combinations are stored in [<fontlist>], a
two-dimensional array initialized lazily by [<pl_whichfont()>]. The
DejaVu Sans / Sans Italic / Sans Bold / Terminus pairing is mothra's
default; the source comments preserve the original Lucida pairing for
historical reference.

\section{Hyperlinks and their rendering}

%claude:
A hyperlink is just an Rtext whose \verb+flags+ field has \verb+PL_HOT+
set and whose Action's \verb+link+ slot holds the URL. libpanel
renders hot text underlined and lets \verb+dolink+ (registered as the
textview's click handler in [<mkpanels()>]) find the right Rtext under
the cursor by walking back through the list to whichever node owns the
clicked rectangle.

\section{Scrolling and repaint}

%claude:
Vertical scrolling is the textview's \verb+ybar+. Horizontal scrolling
is the optional \verb+xbar+, attached only when explicit horizontal
overflow is needed. Both are libpanel scrollbars with no mothra-side
state. Repaint is driven by the main loop's \verb+Ekick+ event: when a
worker thread (HTML parser, image fetcher) sets \verb+w->changed+, the
watchdog forked at the end of [<geturl()>] writes one byte to
\verb+kickpipe+; the main loop wakes up, sees the changed flag, calls
\verb+updtext()+ to rebuild the textview's content, and repaints.

%******************************************************************************
\chapter{Tag-by-Tag Rendering}
%******************************************************************************
\label{chap:tag-rendering}

%claude:
The tag dispatch in [<plrdhtml()>] is one big switch on \verb+g.tag+
([<Tagxxx>]). I covered the structural pattern (push-modify-pop on the
formatting stack) when introducing the parser's main loop. This chapter
is a quick tour of the per-tag handlers organized by category. Most are
two-liners; the only intricate ones are \verb+<a>+ (handles both
\verb+href+ for hyperlinks and \verb+name+ for fragment targets) and
\verb+<form>+ (covered in chapter \ref{chap:forms}).

\section{Structural ([[<html>]], [[<head>]], [[<body>]])}

%claude:
The structural tags are no-ops in mothra's layout: \verb+<html>+ pushes
nothing extra (the bottom-of-stack frame already represents an HTML
document), \verb+<head>+ similarly, \verb+<body>+ is just a line break.
The interesting head children are \verb+<title>+ (sets the page title
for the history list) and \verb+<base href=...>+ (changes the base URL
that subsequent relative links resolve against, by overwriting
\verb+g.dst->url->fullname+).

\section{Headings and paragraphs}

%claude:
\verb+<h1>+--\verb+<h6>+ push a frame with a larger size and bolder
font. \verb+<p>+ inserts a blank line and an indent. \verb+<br>+ just
sets \verb+g.linebrk+, which the next call to \verb+pl_htmloutput+
honours by emitting an extra-large inter-word space (\verb+1000000+, a
sentinel meaning ``always wrap here'').

\section{Text styles ([[<b>]], [[<i>]], [[<tt>]], [[<em>]], \ldots)}

%claude:
Each style tag pushes a frame with a different \verb+font+ field
(BOLD, ITALIC, etc.); the matching close tag pops back. \verb+<em>+
maps to ITALIC, \verb+<strong>+ to BOLD, \verb+<tt>+/\verb+<code>+ to
CWIDTH. \verb+<sub>+ and \verb+<sup>+ shift the baseline via the
\verb+sub+ field. The set of mappings is small enough that a generic
``style tag'' handler did not seem worth the abstraction.

\section{Lists ([[<ul>]], [[<ol>]], [[<dl>]])}

%claude:
List tags push a frame with bumped \verb+margin+ and \verb+indent+
fields. \verb+<li>+ inside an \verb+<ol>+ increments \verb+number+
and emits its decimal value as the marker; inside \verb+<ul>+ it emits
the static \verb+bullet+ image. \verb+<dl>+ does the same for
description lists with \verb+<dt>+ and \verb+<dd>+ as alternating
indent levels.

\section{Breaks and rules ([[<br>]], [[<hr>]])}

%claude:
\verb+<br>+ sets the line-break flag, mentioned above. \verb+<hr>+
emits the static \verb+hrule+ image (a 1-pixel-tall horizontal black
line bracketed by white space) as a one-line block. Both are void
tags --- no end tag, no nested content.

\section{Anchors ([[<a>]])}

%claude:
\verb+<a>+ is the most-used tag with side-data. The handler does two
things: if there is a \verb+name+ attribute, it is stored in the
current state's \verb+name+ field (so a synthetic empty Rtext is
emitted to anchor the fragment target); if there is an \verb+href+
attribute, it is stored in \verb+state->link+. From this point until
the matching \verb+</a>+ close, every Rtext emitted will inherit
\verb+state->link+ via the action it carries. The textview renders
those Rtexts as hot links because of the [[PL_HOT]] flag set in
\verb+pl_htmloutput()+.

%******************************************************************************
\chapter{Tables}
%******************************************************************************
\label{chap:tables}

%claude:
Real HTML tables --- with rowspan, colspan, computed column widths, and
horizontal alignment --- need a two-pass layout algorithm: pass~1
walks the whole table to determine each column's natural width, pass~2
lays out each cell at the chosen width with the right vertical
alignment. That is genuinely complex, and CSS only made it more so.
Mothra deliberately punts: tables are rendered as a flat sequence of
cells, one cell per line, indented to suggest structure but with no
column alignment. Most pages still read correctly because cell
content is short and the rest of the page provides enough context.

\section{HTML tables: [[<table>]], [[<tr>]], [[<td>]]}

%claude:
The relevant tags fall through to the linebreak/indent handlers. From
[<plrdhtml()>]: \verb+<tr>+ flushes the current line; \verb+<td>+
adds whitespace; \verb+<th>+ does the same plus switches to BOLD. The
\verb+<table>+ tag itself is a no-op except for forcing a line break.

\section{What mothra does: linear pass-through}

%claude:
The cells of a table render as their inner content with one space of
separation. There is no column-width computation, no row alignment, no
cell-border rendering. A simple table like
\verb+<table><tr><td>name<td>value+ shows up as ``name~~value'' in the
output, breaking onto multiple lines based on the surrounding context.

\section{Why full table layout is hard (column widths, rowspan, colspan)}

%claude:
Three complications make table layout an order of magnitude more code
than every other tag. Column widths require knowing every cell's
natural minimum and maximum width before deciding the layout; that is
two passes (or a complete in-memory model) just to start. Rowspan and
colspan let cells overlap multiple rows/columns, so the model is no
longer a simple 2D array. Vertical alignment within a cell needs the
cell to be laid out at the chosen width before its content height is
known. Real browsers solve this with several thousand lines of code; abaco
attempts most of it; mothra opts out entirely.

\section{Comparison with abaco and full browsers}

%claude:
abaco does support tables, complete with colspan/rowspan, by building a
real DOM tree and running a two-pass layout. The table code is several
thousand lines on its own. Modern browsers add CSS 
\verb+display: table+ and the related properties on top, easily another 10$\times$.
Mothra's choice not to do tables is what keeps the rendering loop a
single linear pass; the cost is that tabular data renders as flowing
text, which is fine for HTML used as documentation, awkward for
spreadsheet-style content.

%******************************************************************************
\chapter{Images}
%******************************************************************************
\label{chap:images}

%claude:
This chapter covers how an inline image goes from \verb+<img src="...">+
in the HTML to a rendered \verb+Image+ in the textview. The pipeline
has three stages: fetch the image bytes from the URL via webfs; sniff
the format and run the matching format-specific decoder
(\verb+gif+/\verb+jpg+/\verb+png+/\verb+bmp+); optionally pipe through
\verb+resize+ for scaling. All three stages are subprocesses spawned
by [<getpix()>] / [<getimage()>]. Mothra never links libimage formats
directly --- they live entirely outside the binary.

%claude:
The chapter also covers the parallelism layer: [<getpix()>] runs up
to \verb+NXPROC+ image fetches in parallel by forking and \verb+waitpid+ing
in a sliding window, so a page with 30 images does not bottleneck on
serial fetches.

\section{The [[<img>]] tag}

%claude:
The HTML parser handler for \verb+<img>+ records the \verb+src+,
\verb+width+, \verb+height+, and \verb+alt+ attributes into the
current state frame and emits one Rtext as a placeholder containing
the alt text. The actual image fetch is deferred until [<getpix()>]
runs, which happens once the body is fully parsed. (Until then, the
page renders with alt text in place, which lets the user start
reading before images arrive.)

\section{[[getpix]] as a subprocess image fetcher}


%claude:
[<pixcmd>] is the per-format decoder dispatch: an [<XKind>] enum to
the rc command line that converts that format to Plan~9's bitmap
format. The \verb+-9t+ flag tells \verb+gif+/\verb+jpg+/etc.\ to emit
the standard Plan~9 image format with transparency support.

<<global [[pixcmd]](mothra)>>=
char *pixcmd[]={
[GIF]   "gif -9t",
[JPEG]  "jpg -9t",
[PNG]   "png -9t",
[BMP]   "bmp -9t",
[ICO]   "ico -c",
};
@

%claude:
[<getpix()>] is the parallel-fetch driver. It walks the Rtext list
looking for nodes with an \verb+image+ action, forks one
[<getimage()>] subprocess for each, and uses a sliding-window
\verb+worker[]+ array to cap concurrency at \verb+NXPROC+. When the
window fills, it \verb+waitpid+s for any worker to finish before
starting the next. This is the classic ``bounded fork pool'' pattern
without a thread library.

<<function [[getpix]](mothra)>>=
void getpix(Rtext *t, Www *w){
    int i, pid, nworker, worker[NXPROC];
    Action *ap;

    nworker = 0;
    for(i=0; i<nelem(worker); i++)
        worker[i] = -1;

    for(;t!=0;t=t->next){
        ap=t->user;
        if(ap && ap->image){
            pid = rfork(RFFDG|RFPROC|RFMEM);
            switch(pid){
            case -1:
                fprint(2, "fork: %r\n");
                break;
            case 0:
                getimage(t, w);
                exits(0);
            default:
                for(i=0; i<nelem(worker); i++)
                    if(worker[i] == -1){
                        worker[i] = pid;
                        nworker++;
                        break;
                    }

                while(nworker == nelem(worker)){
                    if((pid = waitpid()) < 0)
                        break;
                    for(i=0; i<nelem(worker); i++)
                        if(worker[i] == pid){
                            worker[i] = -1;
                            nworker--;
                            break;
                        }
                }
            }
            
        }
    }
    while(nworker > 0){
        if((pid = waitpid()) < 0)
            break;
        for(i=0; i<nelem(worker); i++)
            if(worker[i] == pid){
                worker[i] = -1;
                nworker--;
                break;
            }
    }
}
@

%claude:
[<getimage()>] runs in each worker subprocess. Resolve the image URL
against the page URL, dedupe against the Pix cache, fetch through
\verb+urlget+ (which goes through webfs), sniff the format with
[<snooptype()>], pipe through the format decoder ([<pixcmd>]), then
optionally pipe through \verb+resize+ if width/height was specified.
The final \verb+readimage()+ pulls the decoded Plan~9 bitmap into
display memory and links a fresh [<Pix>] into \verb+w->pix+.

%claude:
The \verb+-d+ debug branch saves a copy of each decoded bitmap to
\verb+/tmp/mothra-N.bit+ before piping through resize, so a crashing
\verb+resize+ leaves a reproducible test case behind. The numbering by
counter (rather than by URL hash) preserves every intermediate even
when one image fails partway through a parallel batch.

<<function [[getimage]](mothra)>>=
void getimage(Rtext *t, Www *w){
    Action *ap;
    Url *url;
    Image *b;
    int fd, typ;
    char err[512], buf[80], *s;
    Pix *p;

    ap=t->user;
    url=emalloc(sizeof(Url));
    seturl(url, ap->image, w->url->fullname);
    if(debug)
        fprint(STDERR, "getimage: %s from %s\n", ap->image, w->url->fullname);

    if(urlresolve(url) < 0) {
        sysfatal("xxx: %r");
    };
    //snprint(url->fullname, sizeof(url->fullname), "%s%s", 
    //        w->url->fullname,
    //        ap->image
    //        );
    //url->reltext[0] = 0;
    //url->basename[0] = 0;

    if(debug)
        fprint(STDERR, "getimage resolved: %s\n", urlstr(url));

    for(p=w->pix;p!=nil; p=p->next)
        if(strcmp(ap->image, p->name)==0 && ap->width==p->width && ap->height==p->height){
            t->b = p->b;
            w->changed=true;
            return;
        }
    fd=urlget(url, -1);
    if(fd==-1){
    Err:
        snprint(err, sizeof(err), "[img: %s: %r]", urlstr(url));
        free(t->text);
        t->text=strdup(err);
        w->changed=true;
        close(fd);
        goto Out;
    }
    typ = snooptype(fd);
    if(typ < 0 || typ >= nelem(pixcmd) || pixcmd[typ] == nil){
        werrstr("unknown image type");
        goto Err;
    }
    if((fd = pipeline(fd, "exec %s", pixcmd[typ])) < 0)
        goto Err;
    if(ap->width>0 || ap->height>0){
        s = buf;
        /*
         * claude: under -d, save a copy of each decoded bitmap that's
         * about to be piped into resize, one file per image. If resize
         * crashes on an image, the corresponding .bit file survives and
         * can be replayed as `resize -x N -y N < /tmp/mothra-NNN.bit`.
         * We use a counter rather than a hash of the image URL because
         * mothra keeps loading images after a child resize crashes, and
         * we want every intermediate bitmap preserved.
         */
        static int imgcount;
        if(debug)
            s += sprint(s, "tee /tmp/mothra-%d.bit | ", imgcount);
        s += sprint(s, "exec resize");
        if(ap->width>0)
            s += sprint(s, " -x %d", ap->width);
        if(ap->height>0)
            s += sprint(s, " -y %d", ap->height);
        USED(s);
        if(debug){
            fprint(STDERR, "getimage[%d]: piping %s through `%s` for %s\n",
                imgcount, pixcmd[typ], buf, ap->image);
            imgcount++;
        }
        if((fd = pipeline(fd, buf)) < 0)
            goto Err;
    }
    b=readimage(display, fd, 1);
    if(b==0){
        werrstr("can't read image");
        goto Err;
    }
    close(fd);
    p=emalloc(sizeof(Pix));
    nstrcpy(p->name, ap->image, sizeof(p->name));
    p->b=b;
    p->width=ap->width;
    p->height=ap->height;
    p->next=w->pix;
    w->pix=p;
    t->b=b;
    w->changed=true;
Out:
    freeurl(url);
}
@

<<function [[countpix]](mothra)>>=
ulong countpix(void *p){
    ulong n=0;
    Pix *x;
    for(x = p; x; x = x->next)
        n += Dy(x->b->r)*bytesperline(x->b->r, x->b->depth);
    return n;
}
@

<<function [[freepix]](mothra)>>=
void freepix(void *p){
    Pix *x, *xx;
    xx = p;
    while(x = xx){
        xx = x->next;
        freeimage(x->b);
        free(x);
    }
}
@

\section{The three-stage pipeline: [[snooptype()]] $\rightarrow$ format filter $\rightarrow$ [[resize]]}

%claude:
The pipeline shape, reading right to left in [<getimage()>]:

\begin{verbatim}
   webfs body fd  -->  format decoder       -->  resize -x W -y H  -->  readimage
   (raw network)       (gif/jpg/png/bmp/ico)     (optional scaling)     (Plan 9 bitmap)
\end{verbatim}

%claude:
The format decoder is selected from the [<pixcmd>] table by sniffing
type, the resize stage is added only if the \verb+<img>+ tag specified
explicit dimensions, and \verb+readimage()+ pulls the result into a
real display Image. Each pipe stage is a fork+exec; mothra never has
to know how PNG or JPEG works internally.

\section{Process management ([[rfork]], [[waitpid]])}

%claude:
Process management is the loop in [<getpix()>]: \verb+rfork+ to spawn
each worker, \verb+waitpid+ in a sliding window to bound concurrency.
The cohort group set up at mothra's startup ensures that all these
descendants get killed together when mothra exits, so abandoned
network fetches do not leak background processes after the user
quits.

\section{[[resize]] for scaling}

%claude:
\verb+resize+ is the small standalone scaler that reads a Plan~9
bitmap on stdin and writes a resized one on stdout, controlled by
\verb+-x N+/\verb+-y N+ flags (or \verb+-x N\%+/\verb+-y N\%+ for
percentages). It uses bilinear interpolation; nearest-neighbour is
available with \verb+-n+. The whole tool is about 200 lines, and is
shared with image viewers throughout the system.

<<function [[checkimag]](resize)>>=
static void
checkimag(char *where)
{
    if(!debug)
        return;
    fprint(2, "resize: poolcheck before %s... ", where);
    poolcheck(imagmem);
    poolcheck(mainmem);
    fprint(2, "ok\n");
}
@

%claude:
[<resample()>] is the bilinear interpolation kernel: for each
destination pixel, walk back to fractional source coordinates, take
the four surrounding source pixels, blend them by the fractional
weights. The fixed-point trick uses 12 bits of fraction
(\verb+<<12+/\verb+>>12+) so the four blend coefficients
(\verb+s00..s11+) fit in 24 bits each. The inner switch handles
1/3/4-channel pixels by falling through, doing one channel at a time.

<<function [[resample]](resize)>>=
static void
resample(Memimage *dst, Rectangle r, Memimage *src, Rectangle sr)
{
    Point sp, dp;
    Point _sp, qp;
    Point ssize, dsize;
    uchar *pdst0, *pdst, *psrc0, *psrc;
    ulong s00, s01, s10, s11;
    int tx, ty, bpp, bpl;

    ssize = subpt(subpt(sr.max, sr.min), Pt(1,1));
    dsize = subpt(subpt(r.max, r.min), Pt(1,1));
    pdst0 = byteaddr(dst, r.min);
    bpp = src->depth/8;
    bpl = src->width*sizeof(int);

    qp = Pt(0, 0);
    if(dsize.x > 0)
        qp.x = (ssize.x<<12)/dsize.x;
    if(dsize.y > 0)
        qp.y = (ssize.y<<12)/dsize.y;

    _sp.y = sr.min.y<<12;
    for(dp.y=0; dp.y<=dsize.y; dp.y++){
        sp.y = _sp.y>>12;
        ty = _sp.y&0xFFF;
        if(nflag)
            ty = ty << 1 & 0x1000;
        pdst = pdst0;
        sp.x = sr.min.x;
        psrc0 = byteaddr(src, sp);
        _sp.x = 0;
        for(dp.x=0; dp.x<=dsize.x; dp.x++){
            sp.x = _sp.x>>12;
            tx = _sp.x&0xFFF;
            if(nflag)
                tx = tx << 1 & 0x1000;
            psrc = psrc0 + sp.x*bpp;
            s00 = (0x1000-tx)*(0x1000-ty);
            s01 = tx*(0x1000-ty);
            s10 = (0x1000-tx)*ty;
            s11 = tx*ty;
            switch(bpp){
            case 4:
                pdst[3] = (s11*psrc[bpl+bpp+3] + 
                       s10*psrc[bpl+3] + 
                       s01*psrc[bpp+3] +
                       s00*psrc[3]) >>24;
            case 3:
                pdst[2] = (s11*psrc[bpl+bpp+2] + 
                       s10*psrc[bpl+2] + 
                       s01*psrc[bpp+2] +
                       s00*psrc[2]) >>24;
                pdst[1] = (s11*psrc[bpl+bpp+1] + 
                       s10*psrc[bpl+1] + 
                       s01*psrc[bpp+1] +
                       s00*psrc[1]) >>24;
            case 1:
                pdst[0] = (s11*psrc[bpl+bpp] + 
                       s10*psrc[bpl] + 
                       s01*psrc[bpp] +
                       s00*psrc[0]) >>24;
            }
            pdst += bpp;
            _sp.x += qp.x;
        }
        pdst0 += dst->width*sizeof(int);
        _sp.y += qp.y;
    }
}
@

<<function [[getsize]](resize)>>=
static int
getsize(char *s)
{
    int v;

    v = strtol(s, &s, 10) & ~PERCENT;
    if(*s == '%')
        v |= PERCENT;
    return v;
}
@

<<function [[usage]](resize)>>=
void
usage(void)
{
    fprint(2, "Usage: %s [-d] [ -x width ] [ -y height ] [ file ]\n", argv0);
    exits("usage");
}
@

<<function [[main]](resize)>>=
void
main(int argc, char **argv)
{
    int fd, xsize, ysize;
    Memimage *im, *nim;
    ulong ochan, tchan;

    xsize = ysize = 0;
    ARGBEGIN{
    case 'a':
        xsize = ysize = getsize(EARGF(usage()));
        break;
    case 'x':
        xsize = getsize(EARGF(usage()));
        break;
    case 'y':
        ysize = getsize(EARGF(usage()));
        break;
    case 'n':
        nflag++;
        break;
    case 'd':
        debug = true;
        break;
    default:
        usage();
    }ARGEND
    fd = 0;
    if(*argv){
        fd = open(*argv, OREAD);
        if(fd < 0)
            sysfatal("open: %r");
    }
    memimageinit();
    if((im = readmemimage(fd)) == nil)
        sysfatal("readmemimage: %r");
    if(xsize & PERCENT)
        xsize = ((xsize & ~PERCENT) * Dx(im->r)) / 100;
    if(ysize & PERCENT)
        ysize = ((ysize & ~PERCENT) * Dy(im->r)) / 100;
    if(xsize || ysize){
        if(ysize == 0)
            ysize = (xsize * Dy(im->r)) / Dx(im->r);
        if(xsize == 0)
            xsize = (ysize * Dx(im->r)) / Dy(im->r);
        ochan = im->chan;
        switch(ochan){
        default:
            for(tchan = ochan; tchan; tchan >>= 8)
                if(TYPE(tchan) == CAlpha){
                    tchan = RGBA32;
                    break;
                }
            if(tchan == 0)
                tchan = RGB24;
            break;
        case GREY8:
        case RGB24:
        case RGBA32:
        case ARGB32:
        case XRGB32:
            tchan = ochan;
            break;
        case GREY1:
        case GREY2:
        case GREY4:
            tchan = GREY8;
            break;
        }
        checkimag("enter");
        if(tchan != ochan){
            if((nim = allocmemimage(im->r, tchan)) == nil)
                sysfatal("allocimage: %r");
            checkimag("memimagedraw1 (ochan->tchan)");
            memimagedraw(nim, nim->r, im, im->r.min, nil, ZP, S);
            checkimag("freememimage(im) #1");
            freememimage(im);
            im = nim;
        }
        if((nim = allocmemimage(
            Rect(im->r.min.x, im->r.min.y, im->r.min.x+xsize, im->r.min.y+ysize),
            tchan)) == nil)
            sysfatal("allocmemimage: %r");
        checkimag("resample");
        resample(nim, nim->r, im, im->r);
        checkimag("freememimage(im) #2");
        freememimage(im);
        im = nim;
        if(tchan != ochan){
            if((im = allocmemimage(nim->r, ochan)) == nil)
                sysfatal("allocimage: %r");
            checkimag("memimagedraw2 (tchan->ochan)");
            memimagedraw(im, im->r, nim, nim->r.min, nil, ZP, S);
            checkimag("freememimage(nim)");
            freememimage(nim);
        }
    }
    if(writememimage(1, im) < 0)
        sysfatal("writememimage: %r");
    exits(0);
}
@

\section{Image formats (JPEG/GIF/PNG via [[libdraw]])}

%claude:
The format decoders (\verb+gif+, \verb+jpg+, \verb+png+, \verb+bmp+,
\verb+ico+) live in \verb+/cmd/jpg/+ and friends, not here. They are
standalone Plan~9 image utilities that mothra invokes as subprocesses.
Each reads its native format on stdin and writes Plan~9 bitmap on
stdout. Adding support for a new format means writing a new decoder
binary and adding a row to [<pixcmd>].

\section{Lazy loading and placeholders}

%claude:
Mothra does not lazy-load images in the modern sense (delaying fetch
until the image is on screen). What it does is the opposite: render the
page without images first (using alt text as a placeholder) and then
trigger [<getpix()>] after the body is fully parsed. This is the
right thing for a browser whose typical document is short enough that
all images fit in memory. Modern browsers with hundreds of viewport-sized
images do something fancier.

\section{Debug instrumentation ([[-d]] flag, [[poolcheck]], heap dumps)}

%claude:
The \verb+-d+ flag in mothra and its companion \verb+resize+ binary
turns on three things: HTTP-tracing prints in the network paths,
heap-validity checks ([<poolcheck()>]) at hot points in resize, and
the per-image bitmap dump from [<getimage()>] mentioned earlier. The
combination has caught several real bugs in the image path, where a
crash deep in libdraw could be replayed by piping the saved bitmap
back through resize on its own.

%******************************************************************************
\chapter{Forms}
%******************************************************************************
\label{chap:forms}

%claude:
Forms are the only piece of mothra that has to maintain non-textual
state across the lifetime of a page. While the parser builds the
visible Rtext list, [<rdform()>] is called from \verb+plrdhtml()+ for
every form-related tag, and accumulates a parallel structure: a
linked list of [<Form>]s, each with a linked list of [<Field>]s, each
with optional list of [<Option>]s for selects. When the user clicks
a submit button, [<doform()>] walks the [<Form>] for the
clicked button, encodes the field values, and submits via GET or POST.

%claude:
The widgets themselves are libpanel widgets (\verb+plentry+ for text
input, \verb+plbutton+ for buttons, \verb+plcheckbutton+ for
checkboxes, etc.). Mothra registers callbacks on each so that the
text-entry contents can be read out at submit time, and so that
clicking a submit button kicks off [<doform()>]. The Rtexts the
parser emits for form fields are placeholders that
\verb+mkfieldpanel+ later replaces with the live widget.

\section{The [[<form>]] tag and [[forms.c]]}

%claude:
[<Form>] holds the per-form state: HTTP method (GET or POST), encoding
type (\verb+x-www-form-urlencoded+ or \verb+multipart/form-data+), the
submit URL (\verb+action+), a singly-linked list of fields, and a
\verb+next+ pointer to chain forms when the page has more than one.

<<struct [[Form]](mothra)>>=
struct Form{
    int method;
    char *ctype;
    char *action;
    Field *fields, *efields;
    Form *next;
};
@

<<constant [[BOUNDARY]](mothra)>>=
#define BOUNDARY "nAboJ9uN6ZXsqoVGzLAdjKq97TWDTGjo"
@

%claude:
[<rdform()>] is the parser's hand-off to the forms code. The big
switch dispatches per form-related tag: \verb+<form>+ allocates a new
[<Form>] and stores it in \verb+g->form+; \verb+<input>+ /
\verb+<textarea>+ / \verb+<select>+ allocate a [<Field>] and append it
to the form's field list; \verb+<option>+ inside a \verb+<select>+
appends a new [<Option>] to the current field's option list;
\verb+</form>+ resets \verb+g->form+ to nil. The state-machine model
is simple but error-prone: ill-nested forms (a \verb+<form>+ inside
another \verb+<form>+) are detected and rejected, but most other
malformed inputs are silently absorbed.

<<function [[rdform]](mothra)>>=
/*
 * Called by rdhtml on seeing a forms-related tag
 */
void rdform(Hglob *g){
    char *s;
    Field *f;
    Option *o, **op;
    Form *form;
    switch(g->tag){
    default:
        fprint(2, "Bad tag <%s> in rdform (Can't happen!)\n", g->token);
        return;
    case Tag_form:
        if(g->form){
            htmlerror(g->name, g->lineno, "nested forms illegal\n");
            break;
        }
        g->form=emalloc(sizeof(Form));
        s=pl_getattr(g->attr, "action");
        g->form->action=strdup((s && *s) ? s : g->dst->url->fullname);
        s=pl_getattr(g->attr, "method");
        if(s==0 || *s==0)
            g->form->method=GET;
        else if(cistrcmp(s, "post")==0)
            g->form->method=POST;
        else{
            if(cistrcmp(s, "get")!=0)
                htmlerror(g->name, g->lineno,
                    "unknown form method %s\n", s);
            g->form->method=GET;
        }
        s=pl_getattr(g->attr, "enctype");
        if(s && cistrcmp(s, "multipart/form-data")==0)
            g->form->ctype = "multipart/form-data; boundary=" BOUNDARY;
        g->form->fields=0;

        g->form->next = g->dst->form;
        g->dst->form = g->form;
        break;
    case Tag_input:
    case Tag_button:
        if(g->form==0){
            /* no form, assume link button */
            form = emalloc(sizeof(Form));       
            form->method = 0;
            form->fields = 0;
            form->efields = 0;
            if(g->state->link)
                form->action = strdup(g->state->link);
            form->next = g->dst->form;
            g->dst->form = form;
            f=newfield(form);
        } else
            f=newfield(g->form);
        s=pl_getattr(g->attr, "name");
        if(s==0 || *s == 0)
            f->name=0;
        else
            f->name=strdup(s);
        s=pl_getattr(g->attr, "value");
        if(s==0)
            f->value=strdup("");
        else
            f->value=strdup(s);
        f->checked=pl_hasattr(g->attr, "checked");
        s=pl_getattr(g->attr, "size");
        if(s==0 || *s==0)
            f->size=20;
        else
            f->size=atoi(s);
        s=pl_getattr(g->attr, "maxlength");
        if(s==0 || *s==0)
            f->maxlength=0x3fffffff;
        else
            f->maxlength=atoi(s);
        s=pl_getattr(g->attr, "type");
        if((g->tag == Tag_button) && 
           (s==0 || cistrcmp(s, "reset") || cistrcmp(s, "button")))
            s="submit";
        else if(s==0)
            s="text";
        if(cistrcmp(s, "checkbox")==0)
            f->type=CHECK;
        else if(cistrcmp(s, "radio")==0)
            f->type=RADIO;
        else if(cistrcmp(s, "submit")==0)
            f->type=SUBMIT;
        else if(cistrcmp(s, "image")==0){
            f->type=SUBMIT;
            s=pl_getattr(g->attr, "src");
            if(s && *s){
                free(g->state->image);
                g->state->image = strdup(s);
            }
            s=pl_getattr(g->attr, "width");
            if(s && *s)
                g->state->width=strtolength(g, HORIZ, s);
            s=pl_getattr(g->attr, "height");
            if(s && *s)
                g->state->height=strtolength(g, VERT, s);
            s=pl_getattr(g->attr, "alt");
            if(s==0 || *s == 0) s = f->value;
            pl_htmloutput(g, g->nsp, s, f);
            free(g->state->image);
            g->state->image = 0;
            g->state->width=0;
            g->state->height=0;
            break;
        }
        else if(cistrcmp(s, "button")==0)
            f->type=BUTTON;
        else if(cistrcmp(s, "file")==0)
            f->type=FILE;
        else if(cistrcmp(s, "reset")==0)
            f->type=RESET;
        else if(cistrcmp(s, "hidden")==0)
            f->type=HIDDEN;
        else{
            f->type=TYPEIN;
            if(cistrcmp(s, "password")==0)
                f->type=PASSWD;
            s=f->name;
            if(s && cistrcmp(s, "isindex")==0)
                f->type=INDEX;

            /*
             * If there's exactly one attribute, use its value as the name,
             * regardless of the attribute name.  This makes
             * http://linus.att.com/ias/puborder.html work.
             */
            if(s==0){
                if(g->attr[0].name && g->attr[1].name==0)
                    f->name=strdup(g->attr[0].value);
                else
                    f->name=strdup("no-name");
            }
        }
        if((f->type==CHECK || f->type==RADIO) && !pl_hasattr(g->attr, "value")){
            free(f->value);
            f->value=strdup("on");
        }
        if(f->type!=HIDDEN)
            pl_htmloutput(g, g->nsp, f->value[0]?f->value:"blank field", f);
        break;
    case Tag_select:
        if(g->form==0){
        BadTag:
            htmlerror(g->name, g->lineno, "<%s> not in form, ignored\n",
                tag[g->tag].name);
            break;
        }
        f=newfield(g->form);
        s=pl_getattr(g->attr, "name");
        if(s==0 || *s==0){
            f->name=strdup("select");
            htmlerror(g->name, g->lineno, "select has no name=\n");
        }
        else
            f->name=strdup(s);
        f->multiple=pl_hasattr(g->attr, "multiple");
        f->type=SELECT;
        f->size=0;
        f->options=0;
        g->text=g->token;
        g->tp=g->text;
        g->etext=g->text;
        break;
    case Tag_option:
        if(g->form==0) goto BadTag;
        if((f=g->form->efields)==0) goto BadTag;
        if(f->size<8)
            f->size++;
        o=emalloc(sizeof(Option));
        for(op=&f->options;*op;op=&(*op)->next);
        *op=o;
        o->next=0;
        g->text=o->label;
        g->tp=o->label;
        g->etext=o->label+NLABEL;
        memset(o->label, 0, NLABEL+1);
        *g->tp++=' ';
        o->def=pl_hasattr(g->attr, "selected");
        o->selected=o->def;
        if(pl_hasattr(g->attr, "disabled"))
            o->selected=0;
        s=pl_getattr(g->attr, "value");
        if(s==0)
            o->value=o->label+1;
        else
            o->value=strdup(s);
        break;
    case Tag_textarea:
        if(g->form==0) goto BadTag;
        f=newfield(g->form);
        s=pl_getattr(g->attr, "name");
        if(s==0 || *s==0){
            f->name=strdup("enter text");
            htmlerror(g->name, g->lineno, "select has no name=\n");
        }
        else
            f->name=strdup(s);
        s=pl_getattr(g->attr, "rows");
        f->rows=(s && *s)?atoi(s):8;
        s=pl_getattr(g->attr, "cols");
        f->cols=(s && *s)?atoi(s):30;
        f->type=TEXTWIN;
        /* suck up initial text */
        pl_htmloutput(g, g->nsp, f->name, f);
        break;
    case Tag_isindex:
        /*
         * Make up a form with one tag, of type INDEX
         * I have seen a page with <ISINDEX PROMPT="Enter a title here ">,
         * which is nonstandard and not handled here.
         */
        form=emalloc(sizeof(Form));
        form->fields=0;
        form->efields=0;
        s=pl_getattr(g->attr, "action");
        form->action=strdup((s && *s) ? s : g->dst->url->fullname);
        form->method=GET;
        form->fields=0;
        f=newfield(form);
        f->name=0;
        f->value=strdup("");
        f->size=20;
        f->maxlength=0x3fffffff;
        f->type=INDEX;
        pl_htmloutput(g, g->nsp, f->value[0]?f->value:"blank field", f);
        break;
    }
}
@

<<function [[endform]](mothra)>>=
/*
 * Called by rdhtml on seeing a forms-related end tag
 */
void endform(Hglob *g){
    Field *f;

    switch(g->tag){
    case Tag_form:
        g->form=0;
        break;
    case Tag_select:
        if(g->form==0)
            htmlerror(g->name, g->lineno, "</select> not in form, ignored\n");
        else if((f=g->form->efields)==0)
            htmlerror(g->name, g->lineno, "spurious </select>\n");
        else
            pl_htmloutput(g, g->nsp, f->name, f);
        break;
    case Tag_textarea:
        break;
    }
}
@

<<function [[freeform]](mothra)>>=
void freeform(void *p)
{
    Form *form;
    Field *f;
    Option *o;

    while(form = p){
        p = form->next;
        free(form->action);
        while(f = form->fields){
            form->fields = f->next;

            if(f->p!=0)
                plfree(f->p);

            free(f->name);
            free(f->value);

            while(o = f->options){
                f->options = o->next;
                if(o->value != o->label+1)
                    free(o->value);
                free(o);
            }

            free(f);
        }
        free(form);
    }
}
@

\section{The [[Field]] state machine (TYPEIN, CHECK, PASSWD, RADIO, \ldots)}

%claude:
[<Field>] is one form widget. The \verb+ftype+ enum (TYPEIN, CHECK,
RADIO, PASSWD, RESET, SUBMIT, IMAGE, BUTTON, TEXTWIN, SELECT) selects
which widget to spawn. The \verb+state+ field is the per-field
mutable state: text contents for TYPEIN, on/off for CHECK and RADIO,
selected option index for SELECT. The widget pointer in \verb+p+ is
filled in at \verb+mkfieldpanel+ time, when the parser's
synthetic-Rtext placeholder is replaced by a live libpanel widget.


<<enum [[FieldType]](mothra)>>=
/*
 * Field types
 */
enum{
    TYPEIN=1,
    CHECK,
    PASSWD,
    RADIO,
    SUBMIT,
    RESET,
    BUTTON,
    SELECT,
    TEXTWIN,
    HIDDEN,
    INDEX,
    FILE,
};
@

<<struct [[Field]](mothra)>>=
struct Field{
    Field *next;
    Form *form;
    char *name;
    char *value;
    int checked;
    int size;           /* should be a point, but that feature is deprecated */
    int maxlength;
    int type;
    int rows, cols;
    Option *options;
    int multiple;
    int state;          /* is the button marked? */
    Panel *p;
    Panel *pulldown;
    Panel *textwin;
};
@

<<struct [[Option]](mothra)>>=
struct Option{
    int selected;
    int def;
    char label[NLABEL+1];
    char *value;
    Option *next;
};
@

<<function [[newfield]](mothra)>>=
Field *newfield(Form *form){
    Field *f;
    f=emalloc(sizeof(Field));
    if(form->efields==0)
        form->fields=f;
    else
        form->efields->next=f;
    form->efields=f;
    f->next=0;
    f->form=form;
    return f;
}
@

\section{Input widgets ([[<input type=...>]])}

%claude:
\verb+<input>+'s \verb+type=+ attribute is the dispatcher: \verb+text+
becomes a \verb+plentry+, \verb+checkbox+ becomes a \verb+plcheckbutton+,
\verb+radio+ becomes a \verb+plradiobutton+ in a group, \verb+submit+
becomes a \verb+plbutton+ that calls [<doform()>], \verb+image+
becomes a button with a fetched image, \verb+hidden+ is just stored as
state without a visible widget. Each branch maps a \verb+ftype+ enum
value to a libpanel widget, with the form-time data flow consistently:
the widget's user pointer points back at the [<Field>], so events can
update it.


<<function [[mkfieldpanel]](mothra)>>=
void mkfieldpanel(Rtext *t){
    Action *a;
    Panel *win, *scrl;
    Field *f;

    if((a = t->user) == nil)
        return;
    if((f = a->field) == nil)
        return;

    f->p=0;
    switch(f->type){
    case TYPEIN:
        f->p=plentry(0, 0, f->size*chrwidth, f->value, h_submittype);
        break;
    case PASSWD:
        f->p=plentry(0, USERFL, f->size*chrwidth, f->value, h_submittype);
        break;
    case CHECK:
        f->p=plcheckbutton(0, 0, "", h_checkinput);
        f->state=f->checked;
        plsetbutton(f->p, f->checked);
        break;
    case RADIO:
        f->p=plradiobutton(0, 0, "", h_radioinput);
        f->state=f->checked;
        plsetbutton(f->p, f->checked);
        break;
    case SUBMIT:
        f->p=plbutton(0, 0, f->value[0]?f->value:"submit", h_submitinput);
        break;
    case RESET:
        f->p=plbutton(0, 0, f->value[0]?f->value:"reset", h_resetinput);
        break;
    case BUTTON:
        f->p=plbutton(0, 0, f->value[0]?f->value:"button", h_buttoninput);
        break;
    case FILE:
        f->p=plbutton(0, 0, f->value[0]?f->value:"file", h_fileinput);
        break;
    case SELECT:
        if(f->size <= 0)
            f->size=1;
        f->pulldown=plgroup(0,0);
        scrl=plscrollbar(f->pulldown, PACKW|FILLY);
        win=pllist(f->pulldown, PACKN, nullgen, f->size, h_select);
        win->userp=f;
        plinitlist(win, PACKN, selgen, f->size, h_select);
        plscroll(win, 0, scrl);
        plpack(f->pulldown, Rect(0,0,1024,1024));
        f->p=plpulldown(0, FIXEDX, seloption(f), f->pulldown, PACKS);
        f->p->fixedsize.x=f->pulldown->r.max.x-f->pulldown->r.min.x;
        break;
    case TEXTWIN:
        f->p=plframe(0,0);
        pllabel(f->p, PACKN|FILLX, f->name);
        scrl=plscrollbar(f->p, PACKW|FILLY);
        f->textwin=pledit(f->p, EXPAND, Pt(f->cols*chrwidth, f->rows*font->height), 0, 0, 0);
        f->textwin->userp=f;
        plscroll(f->textwin, 0, scrl);
        break;
    case INDEX:
        f->p=plentry(0, 0, f->size*chrwidth, f->value, h_submitindex);
        break;
    }
    if(f->p){
        f->p->userp=f;
        free(t->text);
        t->text=0;
        t->p=f->p;
        t->flags|=PL_HOT;
    }
}
@

<<function [[h_checkinput]](mothra)>>=
void h_checkinput(Panel *p, int, int v){
    ((Field *)p->userp)->state=v;
}
@

<<function [[h_radioinput]](mothra)>>=
void h_radioinput(Panel *p, int, int v){
    Field *f, *me;
    me=p->userp;
    me->state=v;
    if(v){
        for(f=me->form->fields;f;f=f->next)
            if(f->type==RADIO && f!=me && strcmp(f->name, me->name)==0){
                plsetbutton(f->p, 0);
                f->state=0;
                pldraw(f->p, view);
            }
    }
}
@

<<function [[h_buttoninput]](mothra)>>=
void h_buttoninput(Panel *p, int){
    Field *f;

    f = p->userp;
    if(f && f->form && f->form->method != POST && f->form->action)
        geturl(f->form->action, -1, 0, 0);
}
@

<<function [[h_resetinput]](mothra)>>=
void h_resetinput(Panel *p, int){
    Field *f;
    Option *o;
    for(f=((Field *)p->userp)->form->fields;f;f=f->next) switch(f->type){
    case TYPEIN:
        plinitentry(f->p, 0, f->size*chrwidth, f->value, 0);
        break;
    case PASSWD:
        plinitentry(f->p, USERFL, f->size*chrwidth, f->value, 0);
        break;
    case FILE:
        free(f->value);
        f->value=strdup("");
        if(f->p==nil) break;
        f->p->state=0;
        pldraw(f->p, view);
        break;
    case CHECK:
    case RADIO:
        f->state=f->checked;
        plsetbutton(f->p, f->checked);
        break;
    case SELECT:
        for(o=f->options;o;o=o->next)
            o->selected=o->def;
        break;
    }
    pldraw(text, view);
}
@

<<function [[h_fileinput]](mothra)>>=
void h_fileinput(Panel *p, int){
    char name[NNAME];
    Field *f;

    f = p->userp;
    nstrcpy(name, f->value, sizeof(name));
    for(;;){
        if(eenter("Upload file", name, sizeof(name), &mouse) <= 0)
            break;
        if(access(name, AREAD) == 0)
            break;
    }
    free(f->value);
    f->value = strdup(name);
    p->state = name[0] != 0;
    pldraw(f->p, view);
}
@

\section{Text areas and select menus}

%claude:
\verb+<select>+ is the most complex widget. The handler uses libpanel's
pulldown popup driven by a callback table: [<selgen()>] iterates the
options and renders each row, [<h_select()>] handles the user picking
an option (or, for multi-select, toggling it). The \verb+label+
field's first byte is overloaded as a marker (\verb+'*'+ for selected,
space for not), which lets one storage cell serve both the menu
display and the option list.

<<function [[h_select]](mothra)>>=
void h_select(Panel *p, int, int index){
    Option *a;
    Field *f;
    f=p->userp;
    if(f==0) return;
    if(!f->multiple) for(a=f->options;a;a=a->next) a->selected=0;
    for(a=f->options;index!=0 && a!=0;--index,a=a->next);
    if(a==0) return;
    a->selected=!a->selected;
    plinitpulldown(f->p, FIXEDX, seloption(f), f->pulldown, PACKS);
    pldraw(f->p, view);
}
@

<<function [[seloption]](mothra)>>=
char *seloption(Field *f){
    Option *a;
    for(a=f->options;a!=0;a=a->next)
        if(a->selected)
            return a->label+1;
    return f->name;
}
@

<<function [[selgen]](mothra)>>=
char *selgen(Panel *p, int index){
    Option *a;
    Field *f;
    f=p->userp;
    if(f==0) return 0;
    for(a=f->options;index!=0 && a!=0;--index,a=a->next);
    if(a==0) return 0;
    a->label[0]=a->selected?'*':' ';
    return a->label;
}
@

<<function [[nullgen]](mothra)>>=
char *nullgen(Panel *, int ){
    return 0;
}
@

\section{Password fields}

%claude:
Password fields (\verb+<input type=password>+) get the same widget as
TYPEIN but with a masking flag set on the libpanel entry, so the
display shows asterisks rather than the typed text. The character data
itself flows through the same form-encoding paths as plain text. There
is no special TLS warning, autofill suppression, or password-manager
integration --- mothra is a viewing tool, not a credential manager.

\section{Form encoding}

%claude:
Form submission picks one of two encodings based on the
\verb+enctype=+ attribute. \verb+application/x-www-form-urlencoded+
(the default) uses [<uencodeform()>]: each field becomes
\verb+name=value+, joined by \verb+&+, with values percent-encoded
(the URL alphabet). \verb+multipart/form-data+ (used by file uploads)
uses [<mencodeform()>]: each field becomes a MIME part with its own
headers, separated by a fixed boundary string. The two are similar
shapes built from the same field walk.

\subsection{[[uencodeform]] (application/x-www-form-urlencoded)}

%claude:
[<uencodeform()>] walks the field list and emits \verb+name=value+
pairs separated by \verb+&+. Each switch case handles one [<Field>]
type: TYPEIN/PASSWD read the live widget's contents via
\verb+plentryval+; CHECK/RADIO/SUBMIT read the \verb+state+ flag;
HIDDEN reads the static \verb+value+; SELECT walks selected options;
TEXTWIN reads the multi-line entry. The \verb+%U+ format verb
percent-encodes its string argument for safe URL use.

<<function [[uencodeform]](mothra)>>=
void uencodeform(Form *form, int fd){
    char *b, *p, *sep;
    Option *o;
    Field *f;
    Rune *rp;
    int n;

    sep = "";
    for(f=form->fields;f;f=f->next) switch(f->type){
    case TYPEIN:
    case PASSWD:
        fprint(fd, "%s%U=%U", sep, f->name, plentryval(f->p));
        sep = "&";
        break;
    case INDEX:
        fprint(fd, "%s%U", sep, plentryval(f->p));
        sep = "&";
        break;
    case CHECK:
    case RADIO:
    case SUBMIT:
        if(!f->state) break;
    case HIDDEN:
        if(f->name==0 || f->value==0)
            break;
        fprint(fd, "%s%U=%U", sep, f->name, f->value);
        sep = "&";
        break;
    case SELECT:
        if(f->name==0) break;
        for(o=f->options;o;o=o->next)
            if(o->selected && o->value){
                fprint(fd, "%s%U=%U", sep, f->name, o->value);
                sep = "&";
            }
        break;
    case TEXTWIN:
        if(f->name==0) break;
        n=plelen(f->textwin);
        rp=pleget(f->textwin);
        p=b=malloc(UTFmax*n+1);
        if(b == nil)
            break;
        while(n > 0){
            p += runetochar(p, rp);
            rp++;
            n--;
        }
        *p = 0;
        fprint(fd, "%s%U=%U", sep, f->name, b);
        sep = "&";
        free(b);
        break;
    }
}
@

\subsection{[[mencodeform]] (multipart/form-data)}

%claude:
[<mencodeform()>] is structurally identical but emits each field as a
MIME part with a \verb+Content-Disposition+ header and a fixed
boundary string between parts. The boundary itself is a hard-coded
random string [[BOUNDARY]] picked once at compile time --- a real
implementation should pick one per request to avoid collisions with
field contents, but mothra trusts that 32 random base64 chars will not
appear in any real form value. The FILE case opens the local file,
sniffs its content type via [<filetype()>], adds the right
\verb+Content-Type:+ header, and streams the file bytes inline.

<<function [[mencodeform]](mothra)>>=
void mencodeform(Form *form, int fd){
    char *b, *p, *sep;
    int ifd, n, nb;
    Option *o;
    Field *f;
    Rune *rp;

    sep = "--" BOUNDARY;
    for(f=form->fields;f;f=f->next)switch(f->type){
    case TYPEIN:
    case PASSWD:
        fprint(fd, "%s\r\nContent-Disposition: form-data; name=\"%s\"\r\n\r\n%s",
            sep, f->name, plentryval(f->p));
        sep = "\r\n--" BOUNDARY;
        break;
    case CHECK:
    case RADIO:
    case SUBMIT:
        if(!f->state) break;
    case HIDDEN:
        if(f->name==0 || f->value==0)
            break;
        fprint(fd, "%s\r\nContent-Disposition: form-data; name=\"%s\"\r\n\r\n%s",
            sep, f->name, f->value);
        sep = "\r\n--" BOUNDARY;
        break;
    case SELECT:
        if(f->name==0) break;
        for(o=f->options;o;o=o->next)
            if(o->selected && o->value){
                fprint(fd, "%s\r\nContent-Disposition: form-data; name=\"%s\"\r\n\r\n%s",
                    sep, f->name, o->value);
                sep = "\r\n--" BOUNDARY;
            }
        break;
    case TEXTWIN:
        if(f->name==0) break;
        n=plelen(f->textwin);
        rp=pleget(f->textwin);
        p=b=malloc(UTFmax*n+1);
        if(b == nil)
            break;
        while(n > 0){
            p += runetochar(p, rp);
            rp++;
            n--;
        }
        *p = 0;
        fprint(fd, "%s\r\nContent-Disposition: form-data; name=\"%s\"\r\n\r\n%s",
            sep, f->name, b);
        sep = "\r\n--" BOUNDARY;
        free(b);
        break;
    case FILE:
        if(f->name==0 || f->value[0]==0)
            break;
        if(p = strrchr(f->value, '/'))
            p++;
        if(p == 0 || *p == 0)
            p = f->value;
        if((b = malloc(nb = 8192)) == nil)
            break;
        if((ifd = open(f->value, OREAD)) >= 0){
            if(filetype(ifd, b, nb) < 0)
                strcpy(b, "application/octet-stream");
            fprint(fd, "%s\r\nContent-Disposition: form-data; name=\"%s\"; filename=\"%s\""
                "\r\nContent-Type: %s\r\n\r\n", sep, f->name, p, b);
            sep = "\r\n--" BOUNDARY;
            while((n = read(ifd, b, nb)) > 0)
                if(write(fd, b, n) != n)
                    break;
            close(ifd);
        }
        free(b);
        break;
    }
    fprint(fd, "%s--\r\n", sep);
}
@

\section{Submission: [[GET]] vs [[POST]]}

%claude:
[<h_submitinput()>] is the click handler for any submit button. It
records which submit button was pressed (a form may have several;
each becomes its own field whose name+value goes into the encoded
payload), then dispatches on the form method.

%claude:
For GET, the encoded payload is appended to the action URL after a
\verb+?+ and the result handed to [<geturl()>] as a fresh fetch.
For POST, [<urlpost()>] opens \verb+/mnt/web/N/postbody+ for writing,
the encoded payload is streamed into it, and the page is fetched
with the postbody flag set so webfs sends it as a POST request.

<<enum [[HttpMethod]](mothra)>>=
/*
 * HTTP methods
 */
enum{
    GET=1,
    POST,
};
@

<<function [[h_submitinput]](mothra)>>=
void h_submitinput(Panel *p, int){
    char buf[NNAME];
    Form *form;
    Field *f;
    int n, fd;

    f = p->userp;
    form=f->form;
    for(f=form->fields;f;f=f->next)
        if(f->type==SUBMIT)
            f->state = (f->p == p);

    switch(form->method){
    case GET:
        strcpy(buf, "/tmp/mfXXXXXXXXXXX");
        fd = create(mktemp(buf), ORDWR|ORCLOSE, 0600);
        break;
    case POST:
        fd = urlpost(selurl(form->action), form->ctype);
        break;
    default:
        return;
    }

    if(fd < 0){
        message("submit: %r");
        return;
    }
    if(form->method==GET){
        fprint(fd, "%s?", form->action);
        uencodeform(form, fd);
        seek(fd, 0, 0);
        n = readn(fd, buf, sizeof(buf));
        close(fd);
        if(n < 0 || n >= sizeof(buf)){
            message("submit: too large");
            return;
        }
        buf[n] = 0;
        geturl(buf, -1, 0, 0);
    } else {
        /* only set for multipart/form-data */
        if(form->ctype)
            mencodeform(form, fd);
        else
            uencodeform(form, fd);
        geturl(form->action, fd, 0, 0);
    }
}
@

<<function [[h_submittype]](mothra)>>=
/*
 * If there's exactly one button with type=text, then
 * a CR in the button is supposed to submit the form.
 */
void h_submittype(Panel *p, char *){
    int ntype;
    Field *f;
    ntype=0;
    for(f=((Field *)p->userp)->form->fields;f;f=f->next)
        if(f->type==TYPEIN || f->type==PASSWD)
            ntype++;
    if(ntype==1) h_submitinput(p, 0);
}
@

<<function [[h_submitindex]](mothra)>>=
void h_submitindex(Panel *p, char *){
    h_submitinput(p, 0);
}
@

%###############################################################################
\part{Beyond the Basics}
%###############################################################################

%claude:
The first two parts cover what the browser does on a single page
load. This part covers what makes mothra usable as a sustained tool:
navigation and history (forward/back through mothra's [<Www>] ring
buffer, plus bookmarks); integration with the rest of \plan---snarf
and paste through [[/dev/snarf]], plumbing URLs to other programs
through [[/mnt/plumb]], the alternate-display panel for opening a
link without losing the current page; the developer-facing tools
that ship in the same source tree; and a handful of advanced topics
that don't fit elsewhere. The book closes with a Conclusion chapter
and a set of appendices on debugging, 
%profiling,
error management, and shared utilities.

%******************************************************************************
\chapter{Navigation and History}
%******************************************************************************
\label{chap:navigation}

%claude:
This chapter covers the user's navigation actions. Following a
hyperlink is the most common: the user mouse-clicks a hot Rtext, the
click handler turns the underlying URL into a [<geturl()>] call,
mothra advances to a new history slot. The forward/back buttons just
move \verb+wwwtop+ up or down within the [<Www>] ring buffer.
Bookmarks are managed separately as a small file in the user's home
directory.

\section{Following links}

%claude:
[<hiturl()>] is the dispatch on which mouse button was clicked: B1
fetches the URL into a new history slot, B2 selects the URL (so it
can be sent to plumber or yanked into the address bar), B3 pops the
button~3 menu (save, plumb, etc.). The map flag is for image-map
clicks, where the click coordinates need to be appended to the URL as
\verb+?x,y+.

<<function [[hiturl]](mothra)>>=
void hiturl(int buttons, char *url, int map){
    switch(buttons){
    case 1: geturl(url, -1, 0, map); break;
    case 2: urlresolve(selurl(url)); break;
    case 4: message("Button 3 hit on url can't happen!"); break;
    }
}
@

%claude:
[<dolink()>] is what libpanel calls when the user clicks somewhere in
the textview. The clicked Rtext is passed in as \verb+word+; if its
Action carries a \verb+link+, that is the URL to follow. The image-map
case computes the click coordinate relative to the Rtext's bounding
rectangle and appends it to the URL --- this is the server-side
image-map dispatch that pre-CSS sites used for clickable maps.

<<function [[dolink]](mothra)>>=
/*
 * Follow an html link
 */
void dolink(Panel *p, int buttons, Rtext *word){
    Action *a;

    a=word->user;
    if(a == nil || (a->link == nil && a->image == nil))
        return;
    if(mothmode)
        hiturl(buttons, a->image ? a->image : a->link, 0);
    else if(a->link){
        if(a->ismap){
            char mapurl[NNAME];
            Point coord;
            int yoffs;

            yoffs=plgetpostextview(p);
            coord=subpt(subpt(mouse.xy, word->r.min), p->r.min);
            snprint(mapurl, sizeof(mapurl), "%s?%d,%d", a->link, coord.x, coord.y+yoffs);
            hiturl(buttons, mapurl, 1);
        } else
            hiturl(buttons, a->link, 0);
    }
}
@

\section{Back, forward, and history}

%claude:
The history is the [<Www>] ring buffer keyed by \verb+wwwtop+ (the
slot that the next fetch will populate). [<doprev()>] is the click
handler on the visible history list (the bottom panel): given the
list-index of the clicked entry, walk back to the matching slot and
[<setcurrent()>] it. The same primitive supports the keyboard
``j N'' (jump-to-history-N) command from the address bar.

<<function [[doprev]](mothra)>>=
/*
 * user selected from the list of available pages
 */
void doprev(Panel *p, int buttons, int index){
    int i;
    USED(p);
    if(index < 0 || index >= nwww())
        return;
    i = wwwtop-index-1;
    switch(buttons){
    case 1: setcurrent(i, 0);   /* no break ... */
    case 2: selurl(www(i)->url->fullname); break;
    case 4: message("Button 3 hit on page can't happen!"); break;
    }
}
@

<<function [[setcurrent]](mothra)>>=
/*
 * selected text should be a url.
 */
void setcurrent(int index, char *tag){
    Www *new;
    int i;
    new=www(index);
    if(new==current && (tag==0 || tag[0]==0)) return;
    if(current)
        current->yoffs=plgetpostextview(text);
    current=new;
    plinitlabel(cururl, PACKE|EXPAND, current->url->fullname);
    if(defdisplay) pldraw(cururl, view);
    plinittextview(text, PACKE|EXPAND, Pt(0, 0), current->text, dolink);
    scrollto(tag);
    if((i = open("/dev/label", OWRITE)) >= 0){
        fprint(i, "%s %s", mothra, current->url->fullname);
        close(i);
    }
    donecurs();
}
@

<<function [[genwww]](mothra)>>=
char *genwww(Panel *, int index){
    static char buf[1024];
    Www *w;
    int i;

    if(index >= nwww())
        return 0;
    i = wwwtop-index-1;
    w = www(i);
    if(!w->url)
        return 0;
    if(w->title[0]!='\0'){
        w->gottitle=1;
        snprint(buf, sizeof(buf), "%2d %s", i+1, w->title);
    } else
        snprint(buf, sizeof(buf), "%2d %s", i+1, urlstr(w->url));
    return buf;
}
@

<<function [[scrollto]](mothra)>>=
void scrollto(char *tag){
    Rtext *tp;
    Action *ap;
    if(current == nil || text == nil)
        return;
    if(tag && tag[0]){
        for(tp=current->text;tp;tp=tp->next){
            ap=tp->user;
            if(ap && ap->name && strcmp(ap->name, tag)==0){
                current->yoffs=tp->topy;
                break;
            }
        }
    }
    plsetpostextview(text, current->yoffs);
}
@

\section{Bookmarks and hotlist}

%claude:
Mothra has no separate bookmark database. Instead, the ``add to
hotlist'' (hit3 menu item~6) opens
\verb+$home/lib/mothra/hit.html+ for append, and writes one
\verb+<a href=...>+ line for the currently selected URL. The hotlist
is therefore a real HTML page that the user can open in mothra itself
via menu item~7 --- bookmarks become a self-edited web page, no
separate UI required. This is the same trick acme uses for plumber
rules and other application config.

%******************************************************************************
\chapter{Events and Integration}
%******************************************************************************
\label{chap:events}

%claude:
Two kinds of integration cross mothra's boundary: keyboard/mouse input
that drives the GUI, and the plumb~(2) protocol that connects mothra
to the rest of Plan~9 (so that clicking a URL in acme launches mothra,
or so that mothra's snarf works the same as in every other Plan~9
application). This chapter covers both.

\section{Mouse clicks and scrolling}

%claude:
Mouse handling lives in [<main()>]'s \verb+Emouse+ branch.

<<[[main()]](mothra) in event loop, switch [[i]] cases>>=
case Emouse:
    mouse=e.mouse;
    if(mouse.buttons & (8|16) && ptinrect(mouse.xy, list->r) && defdisplay){
        if(mouse.buttons & 8)
            scrollpanel(list, list->r.min.y - mouse.xy.y, 1);
        else
            scrollpanel(list, mouse.xy.y - list->r.min.y, 1);
        break;
    }
    if(mouse.buttons & (8|16) && ptinrect(mouse.xy, text->r)){
        if(mouse.buttons & 8)
            scrollpanel(text, text->r.min.y - mouse.xy.y, 1);
        else
            scrollpanel(text, mouse.xy.y - text->r.min.y, 1);
        break;
    }
    plmouse(root, &mouse);
    if(mouse.buttons == 1 && root->lastmouse == root)
        plgrabkb(nil);
    break;
@



The interesting wrinkle is button~4
and~5: scroll-wheel events, encoded as the high mouse buttons in
Plan~9's mouse(3) interface. Mothra reads them as ``scroll up/down by
a quarter screen'' on whichever pane the cursor is in.

%claude:
[<hit3()>] is the right-click menu dispatch, with one item per common
operation: swap to alt display, toggle moth mode, snarf, paste, plumb,
search, add to hit list, view hit list, exit. Most cases are
two-liners; the only intricate one is item~4 (plumb), which figures
out which widget has keyboard focus and grabs its current snarf
contents.

<<function [[hit3]](mothra)>>=
void hit3(int button, int item){
    char buf[1024];
    char name[NNAME];
    char *s;
    Panel *swap;
    int fd;
    USED(button);
    switch(item){
    case 0:
        swap=root;
        root=alt;
        alt=swap;
        if(current)
            current->yoffs=plgetpostextview(text);
        swap=text;
        text=alttext;
        alttext=swap;
        defdisplay=!defdisplay;
        plpack(root, view->r);
        if(current){
            plinittextview(text, PACKE|EXPAND, Pt(0, 0), current->text, dolink);
            plsetpostextview(text, current->yoffs);
        }
        pldraw(root, view);
        break;
    case 1:
        mothon(current, !mothmode);
        break;
    case 2:
        snarf(plkbfocus);
        break;
    case 3:
        paste(plkbfocus);
        break;
    case 4:
        if(plkbfocus==nil || plkbfocus==cmd){
            if(text==nil || text->snarf==nil || selection==nil)
                return;
            if((s=text->snarf(text))==nil)
                s=smprint("%s", urlstr(selection));
        }else
            if((s=plkbfocus->snarf(plkbfocus))==nil)
                return;
        if((fd=plumbopen("send", OWRITE))<0){
            message("can't plumb");
            free(s);
            return;
        }
        plumbsendtext(fd, "mothra", nil, getwd(buf, sizeof buf), s);
        close(fd);
        free(s);
        break;
    case 5:
        search();
        break;
    case 6:
        if(!selection){
            message("no url selected");
            break;
        }
        snprint(name, sizeof(name), "%s/hit.html", mkhome());
        fd=open(name, OWRITE);
        if(fd==-1){
            fd=create(name, OWRITE, 0666);
            if(fd==-1){
                message("can't open %s", name);
                return;
            }
            fprint(fd, "<html><head><title>Hit List</title></head>\n");
            fprint(fd, "<body><h1>Hit list</h1>\n");
        }
        seek(fd, 0, 2);
        fprint(fd, "<p><a href=\"%s\">%s</a>\n", urlstr(selection), urlstr(selection));
        close(fd);
        break;
    case 7:
        snprint(name, sizeof(name), "file:%s/hit.html", mkhome());
        geturl(name, -1, 1, 0);
        break;
    case 8:
        if(confirm(3))
            exits(0);
        break;
    }
}
@

\section{Keyboard shortcuts}

%claude:
Keyboard handling is in [<main()>]'s \verb+Ekeyboard+ branch.
%
Movement keys (Home/End, PgUp/PgDn, arrows) scroll the textview.
%
\verb+^F+ (\verb+Kack+) opens the search prompt.
%
Anything else with focus on the cmd entry goes through the libpanel
\verb+plkeyboard()+ for normal text input.
%
There are no other
mothra-specific keystrokes; the cmd entry's \verb+/+, \verb+a+,
\verb+g+, etc.\ commands are typed plain.


<<[[main()]](mothra) in event loop, switch [[i]] cases>>=
case Ekeyboard:
    switch(e.kbdc){
    default:
    Plkey:
        adjkb();
        plkeyboard(e.kbdc);
        break;
    case Khome:
        scrollpanel(text, 0, 0);
        break;
    case Kup:
        scrollpanel(text, -text->size.y/4, 1);
        break;
    case Kpgup:
        scrollpanel(text, -text->size.y/2, 1);
        break;
    case Kdown:
        scrollpanel(text, text->size.y/4, 1);
        break;
    case Kpgdown:
        scrollpanel(text, text->size.y/2, 1);
        break;
    case Kend:
        scrollpanel(text, -text->size.y, 2);
        break;
    case Kack:
        search();
        break;
    case Kright:
        if(plkbfocus)
            goto Plkey;
        sidescroll(text->size.x/4, 1);
        break;
    case Kleft:
        if(plkbfocus)
            goto Plkey;
        sidescroll(-text->size.x/4, 1);
        break;
    }
    break;
@




\section{The [[plumb(2)]] protocol}


<<[[main()]](mothra) plumb initialisation>>=
eplumb(Eplumb, "web");
@

%claude:
\verb+eplumb+ subscribes to the
\verb+web+ port so external programs can send a URL with
\verb+plumb -d web foo.html+.

<<[[main()]](mothra) other locals>>=
Plumbmsg *pm;
@

<<[[main()]](mothra) in event loop, switch [[i]] cases>>=
case Eplumb:
    pm=e.v;
    if(pm->ndata > 0)
        geturl(pm->data, -1, 1, 0);
    plumbfree(pm);
    break;
@


%claude:
Plumb is Plan~9's content-routing daemon: small messages with
attributes that get matched against a rule file and sent to a
subscribed application. Mothra both publishes and subscribes. As a
publisher, hit3 menu item~4 sends the selected URL to the plumber
(rules typically open it in a different application like acme or a
PDF viewer). As a subscriber, mothra registers
\verb+eplumb(Eplumb, "web")+ in [<main()>] so that any other
program that plumbs a URL with destination ``web'' triggers a fetch.

%claude:
Webfs has its own plumb subscription too: [[webfs]] listens on the
``web'' port if mothra is not running, so a plumb of a URL turns into
a webfs request and the result is delivered to whichever viewer the
plumber rules pick.

<<global [[ctypes]](webfs)>>=
static struct
{
    char        *ctype;
    char        *ext;
}
ctypes[] =
{
    { "application/msword", "doc" },
    { "application/pdf", "pdf" },
    { "application/postscript", "ps" },
    { "application/rtf", "rtf" },
    { "image/gif", "gif" },
    { "image/jpeg", "jpg" },
    { "image/png", "png" },
    { "image/ppm", "ppm" },
    { "image/tiff", "tiff" },
    { "text/html", "html" },
    { "text/plain", "txt" },
    { "text/xml", "xml" },
};
@

<<function [[plumbinit]](webfs)>>=
void
plumbinit(void)
{
    plumbsendfd = plumbopen("send", OWRITE|OCEXEC);
    plumbwebfd = plumbopen("web", OREAD|OCEXEC);
}
@

<<function [[plumbstart]](webfs)>>=
void
plumbstart(void)
{
    plumbchan = chancreate(sizeof(Plumbmsg*), 0);
    proccreate(plumbwebproc, nil, STACK);
    threadcreate(plumbwebthread, nil, STACK);
}
@

<<function [[plumbwebthread]](webfs)>>=
static void
plumbwebthread(void*)
{
    char *base;
    Plumbmsg *m;

    for(;;){
        m = recvp(plumbchan);
        if(m == nil)
            threadexits(nil);
        base = plumblookup(m->attr, "baseurl");
        if(base == nil)
            base = m->wdir;
        plumburl(m->data, base);
        plumbfree(m);
    }
}
@

<<function [[plumbwebproc]](webfs)>>=
static void
plumbwebproc(void*)
{
    Plumbmsg *m;

    for(;;){
        m = plumbrecv(plumbwebfd);
        sendp(plumbchan, m);
        if(m == nil)
            threadexits(nil);
    }
}
@

<<function [[addattr]](webfs)>>=
static void
addattr(Plumbmsg *m, char *name, char *value)
{
    Plumbattr *a;

    a = malloc(sizeof(Plumbattr));
    a->name = name;
    a->value = value;
    a->next = m->attr;
    m->attr = a;
}
@

<<function [[freeattrs]](webfs)>>=
static void
freeattrs(Plumbmsg *m)
{
    Plumbattr *a, *next;

    a = m->attr;
    while(a != nil) {
        next = a->next;
        free(a);
        a = next;
    }
}
@

\section{Plumb messages: MIME type + filename}

%claude:
A plumb message is a small struct with src/dst, a working directory
(\verb+wdir+), a list of (name,~value) attributes, and a data
payload. For mothra's purposes the payload is the URL string and the
attribute \verb+baseurl+ optionally carries the base for relative
resolution. Webfs's plumb subscriber [<plumbwebproc()>] receives the
message off the kernel queue, hands it to [<plumbwebthread()>] which
calls [<plumburl()>] to start the fetch.

\section{Spawning external viewers}

%claude:
[<replumb()>] is webfs's contribution: once a URL has been fetched and
the content type is known, webfs sends a fresh plumb message to the
plumber with the response's MIME type as an attribute. The plumber
matches that against its rule file (typically routing PDFs to
\verb+page+, images to \verb+page -w+, etc.) and forwards to the
matching application. Mothra never has to know about external viewers
--- the plumber rules do.

<<function [[replumb]](webfs)>>=
void
replumb(Client *c)
{
    int i;
    Plumbmsg *m;
    char name[128], *ctype, *ext, *p;

    if(!c->plumbed)
        return;
    m = emalloc(sizeof(Plumbmsg));
    m->src = "webfs";
    m->dst = nil;
    m->wdir = "/";
    m->type = "text";
    m->attr = nil;
    addattr(m, "url", c->url->url);
    ctype = c->contenttype;
    ext = nil;
    if(ctype != nil) {
        addattr(m, "content-type", ctype);
        for(i = 0; i < nelem(ctypes); i++) {
            if(strcmp(ctype, ctypes[i].ctype) == 0) {
                ext = ctypes[i].ext;
                break;
            }
        }
    }
    if(ext == nil) {
        p = strrchr(c->url->url, '/');
        if(p != nil)
            p = strrchr(p+1, '.');
        if(p != nil && strlen(p) <= 5)
            ext = p+1;
        else
            ext = "txt";                /* punt */
    }
    c->ext = ext;
if(0)fprint(2, "content type %s -> extension .%s\n", ctype, ext);
    m->ndata = snprint(name, sizeof name, "/mnt/web/%d/body.%s", c->num, ext);
    m->data = estrdup(name);
    proccreate(plumbsendproc, m, STACK);        /* separate proc to avoid a deadlock */
}
@

<<function [[plumbsendproc]](webfs)>>=
static void
plumbsendproc(void *x)
{
    Plumbmsg *m;

    m = x;
    plumbsend(plumbsendfd, m);
    freeattrs(m);
    free(m->data);
    free(m);
}
@

\section{Snarf (selection and clipboard)}

%claude:
Plan~9's clipboard is the file \verb+/dev/snarf+. Reading it returns
the current selection, writing replaces it. Mothra's [[snarf()]] and
[[paste()]] just read/write that file, with no special protocol or
clipboard manager. Selecting text in mothra means highlighting it
with the mouse, then pressing the snarf shortcut
(B3 menu item~2 or [[^W]]); pasting takes the file contents and inserts them into the
current focus widget.

%claude:
This works across all Plan~9 GUI applications without any of them
having to coordinate. A select-snarf in mothra and a paste in acme is
the same protocol as a select-snarf in acme and a paste in rio.


<<function [[snarf]](mothra)>>=
void snarf(Panel *p){
    if(p==0 || p==cmd){
        if(selection){
            plputsnarf(urlstr(selection));
            plsnarf(text);
        }else
            message("no url selected");
    }else
        plsnarf(p);
}
@

<<function [[paste]](mothra)>>=
void paste(Panel *p){
    if(p==0) p=cmd;
    plpaste(p);
}
@

%******************************************************************************
\chapter{Developer Tools}
%******************************************************************************
\label{chap:devtools}

%claude:
Mothra has small but useful inspection tools. ``View source'' is just
a separate fetch of the same URL with the renderer overridden to
PLAIN, so the HTML appears as text. HTTP tracing (the \verb+-d+ flag)
prints request and response headers to stderr. The \verb+snoop+
command in the GUI displays the MIME type that the type-sniffer
returned for the current page, useful when content negotiation is
acting up. ``Save page'' grabs the body and writes it to a file the
user names. None of these is a separate subsystem; each is a thin
wrapper around the existing fetch and dispatch primitives.

\section{View source}

%claude:
There is no dedicated ``view source'' menu item in mothra. The
equivalent is to type \verb+g <url>+ on the cmd entry while in
\verb+m+ (moth) mode, which suppresses the HTML parse and renders the
body as plain text. For occasional source inspection, plumbing the URL
to acme is more comfortable.

\section{HTTP tracing ([[-d]] flag)}

%claude:
The \verb+-d+ flag from mothra and the matching \verb+httpdebug+
ctl-knob in webfs both turn on a stream of trace prints to stderr:
each request line, each header line, each response code. The format is
deliberately the same as a wire-level dump, so it can be eyeballed
against an HTTP spec or piped through grep when chasing a regression.

\section{MIME-type dumping ([[snoop.c]])}

%claude:
The \verb+snoop+ command in mothra prints the MIME type that the
type-sniffer returned for the current page. Useful when the rendering
looks wrong and the question is whether the bug is in the sniffer or
the renderer.

\section{The debug-instrumentation pattern (fork + [[poolcheck]] + temp files)}

%claude:
The image path uses a recurring debug pattern: when \verb+-d+ is on,
fork an extra subprocess that captures intermediate state to
\verb+/tmp+, and run \verb+poolcheck()+ on the libdraw allocator at
key points to catch heap corruption early. The temp-file dumps mean
that a crash an hour into a session can still be reproduced from disk;
the poolchecks mean that a corruption is reported the moment it
happens rather than at the eventual fault. This pattern would not
exist if mothra did its image work in-process: the temp files only
make sense because each image is a sibling subprocess that can be
re-invoked on its own.

\section{Saving a page}

%claude:
The \verb+s+ command and B3-menu equivalent both open the same modal
file-name prompt and write the URL's body to a chosen file.
Internally it is just a fresh fetch with the body fd's contents
written to the named file via [<save()>]. No special encoding,
no rewriting of relative URLs in the saved HTML --- mothra is a
viewer, not an archiver.


<<function [[save]](mothra)>>=
void save(int ifd, char *name){
    char buf[NNAME+64];
    int ofd;
    if(ifd < 0){
        message("save: %s: %r", name);
        return;
    }
    ofd=create(name, OWRITE, 0666);
    if(ofd < 0){
        message("save: %s: %r", name);
        return;
    }
    switch(rfork(RFNOTEG|RFNAMEG|RFFDG|RFMEM|RFPROC|RFNOWAIT)){
    case -1:
        message("Can't fork: %r");
        break;
    case 0:
        dup(ifd, 0);
        close(ifd);
        dup(ofd, 1);
        close(ofd);

        snprint(buf, sizeof(buf),
            "{tput -p || cat} |[2] {aux/statusmsg -k %q >/dev/null || cat >/dev/null}", name);
        execl("/bin/rc", "rc", "-c", buf, nil);
        exits("exec");
    }
    close(ifd);
    close(ofd);
    donecurs();
}
@

<<function [[urltofile]](mothra)>>=
/*
 * convert a url into a local file name.
 */
char *urltofile(Url *url){
    char *name, *slash;
    if(url == nil)
        return nil;
    name = urlstr(url);
    if(name == nil || name[0] == 0)
        name = "/";
    if(slash = strrchr(name, '/'))
        name = slash+1;
    if(name[0] == 0)
        name = "index";
    return name;
}
@

<<function [[screendump]](mothra)>>=
void screendump(char *name, int full){
    Image *b;
    int fd;
    fd=create(name, OWRITE, 0666);
    if(fd==-1){
        message("can't create %s", name);
        return;
    }
    if(full){
        writeimage(fd, view, 0);
    } else {
        if((b=allocimage(display, text->r, view->chan, 0, DNofill)) == nil){
            message("can't allocate image");
            close(fd);
            return;
        }
        draw(b, b->r, view, 0, b->r.min);
        writeimage(fd, b, 0);
        freeimage(b);
    }
    close(fd);
}
@

<<function [[search]](mothra)>>=
void search(void){
    static char last[256];
    char buf[256];
    Reprog *re;
    Rtext *tp;

    for(;;){
        if(current == nil || current->text == nil || text == nil)
            return;
        strncpy(buf, last, sizeof(buf)-1);
        if(eenter("Search for", buf, sizeof(buf), &mouse) <= 0)
            return;
        strncpy(last, buf, sizeof(buf)-1);
        re = regcompnl(buf);
        if(re == nil){
            message("%r");
            continue;
        }
        for(tp=current->text;tp;tp=tp->next)
            if(tp->flags & PL_SEL)
                break;
        if(tp == nil)
            tp = current->text;
        else {
            tp->flags &= ~PL_SEL;
            tp = tp->next;
        }
        while(tp != nil){
            tp->flags &= ~PL_SEL;
            if(tp->text && *tp->text)
            if(regexec(re, tp->text, nil, 0)){
                tp->flags |= PL_SEL;
                plsetpostextview(text, tp->topy);
                break;
            }
            tp = tp->next;
        }
        free(re);
        updtext(current);
    }
}
@

%******************************************************************************
\chapter{Advanced Topics}
%******************************************************************************
\label{chap:advanced}

%claude:
This chapter is a series of short notes on features that exist in the
code but did not warrant their own chapter: HTTP proxy support, the
Referer header, content compression, animated GIFs, the file://
protocol, and FTP. Each is a few lines of code in webfs or hget that
plug into the existing fetch pipeline.

\section{Proxy (via [[$http_proxy]])}

%claude:
hget consults \verb+$httpproxy+ at startup; if set, the proxy URL is
parsed into a separate [<URL>] (\verb+px+) and every request is sent
to the proxy with the absolute URL as the request line, instead of
directly to the origin server. webfs has no built-in proxy support;
the user is expected to mount a different webfs or run [[webfs]]
behind a SOCKS or HTTP proxy at the system level.

\section{Referer header}

%claude:
Mothra does not send the \verb+Referer+ header. (Yes, it is
spelled wrong in the spec.) This is a privacy choice: the previous
URL the user was viewing is sometimes sensitive (auth tokens in query
strings, internal URLs), and the Referer header has historically been
the leak. Sites that demand a Referer for hotlink protection or CSRF
defence will fail in mothra.

\section{Content encoding (gzip)}

%claude:
HTTP responses with \verb+Content-Encoding: gzip+ (or compress, or
bzip2) are transparently decompressed by mothra: [<urlget()>] reads
\verb+/mnt/web/N/contentencoding+ and pipes the body through the
matching command (\verb+gunzip+, \verb+bunzip2+) before handing the
fd back to the caller. The pipeline is just one extra
[<pipeline()>] call --- the rest of mothra is unaware that the body
was ever compressed.

\section{Animated GIFs}

%claude:
Animated GIFs render as the first frame. The \verb+gif+ decoder
called by [<getimage()>] reads only the first image from the stream;
later frames are silently dropped. Real animation would need a timer
loop to replace the displayed Image at the right intervals, which the
flat Rtext list does not support.

\section{File protocol ([[file://]])}

%claude:
\verb+file://+ URLs are handled by mothra's own [<fileget()>]
without going through webfs. The path is parsed out, opened with
\verb+OREAD+, and the fd returned. Relative URLs in the page resolve
against the file's directory, so a documentation tree of HTML on disk
works the same as one served by HTTP.





\section{FTP protocol support ([[doftp]] in hget, ftp in [[webfs/url.c]])}

%USftp scheme not aspectized, because useful for explanations

<<[[freeurl()]] switch scheme other cases>>=
case USftp:
    free(u->ftp.path_spec);
    free(u->ftp.type);
    break;
@

<<[[copyurl()]] switch scheme other cases>>=
case USftp:
    dupp(&v->ftp.path_spec);
    dupp(&v->ftp.type);
    break;
@

<<[[Url]](webfs) union members>>=
struct {
    char *path_spec;
    char *type;
} ftp;
@

<<[[Qxxx]] other cases>>=
Qftptype,
@

<<[[tab]](webfs) other elements>>=
[Qftptype]     = { "ftptype",     0444,       offsetof(Url, ftp.type)   },
@


%claude:
FTP support exists in two places: \verb+webfs/ftpfs.c+ (proper FTP
client used by webfs) and \verb+hget+'s [<doftp()>]. Both speak
RFC~959: open the control connection, USER/PASS, optional CWD, then
PASV/PORT for the data connection, then RETR or LIST. The lazy
implementation: anonymous login if no credentials are in the URL,
data connection in passive mode only, no resume. FTP is mostly dead
on the modern web but stays in for the long-tail mirrors of Plan~9
itself, which still distribute via FTP.


<<function [[doftp]](hget.c)>>=
int
doftp(URL *u, URL *px, Range *r, Out *out, long mtime)
{
    int pid, ctl, data, rv;
    Waitmsg *w;
    char msg[64];
    char conndir[NETPATHLEN];
    char *p;

    /* untested, proxy doesn't work with ftp (I think) */
    if(px->host == nil){
        ctl = dial(netmkaddr(u->host, tcpdir, u->port), 0, conndir, 0);
    } else {
        ctl = dial(netmkaddr(px->host, tcpdir, px->port), 0, conndir, 0);
    }

    if(ctl < 0)
        return Error;
    if(net == nil){
        p = strrchr(conndir, '/');
        *p = 0;
        snprint(tcpdir, sizeof(tcpdir), conndir);
    }

    initibuf();

    rv = hello(ctl);
    if(rv < 0)
        return terminateftp(ctl, rv);

    rv = logon(ctl);
    if(rv < 0)
        return terminateftp(ctl, rv);

    rv = xfertype(ctl, "I");
    if(rv < 0)
        return terminateftp(ctl, rv);

    /* if file is up to date and the right size, stop */
    if(ftprestart(ctl, out, u, r, mtime) > 0){
        close(ctl);
        return Eof;
    }
        
    /* first try passive mode, then active */
    data = passive(ctl, u);
    if(data < 0){
        data = active(ctl, u);
        if(data < 0)
            return Error;
    }

    /* fork */
    switch(pid = rfork(RFPROC|RFFDG|RFMEM)){
    case -1:
        close(data);
        return terminateftp(ctl, Error);
    case 0:
        ftpxfer(data, out, r);
        close(data);
        _exits(0);
    default:
        close(data);
        break;
    }

    /* wait for reply message */
    rv = ftprcode(ctl, msg, sizeof(msg));
    close(ctl);

    /* wait for process to terminate */
    w = nil;
    for(;;){
        free(w);
        w = wait();
        if(w == nil)
            return Error;
        if(w->pid == pid){
            if(w->msg[0] == 0){
                free(w);
                break;
            }
            werrstr("xfer: %s", w->msg);
            free(w);
            return Error;
        }
    }

    switch(rv){
    case Success:
        return Eof;
    case TempFail:
        return Server;
    default:
        return Error;
    }
}
@

<<function [[ftpcmt]](hget.c)>>=
int
ftpcmd(int ctl, char *fmt, ...)
{
    va_list arg;
    char buf[2*1024], *s;

    va_start(arg, fmt);
    s = vseprint(buf, buf + (sizeof(buf)-4) / sizeof(*buf), fmt, arg);
    va_end(arg);
    if(debug)
        fprint(STDERR, "%d -> %s\n", ctl, buf);
    *s++ = '\r';
    *s++ = '\n';
    if(write(ctl, buf, s - buf) != s - buf)
        return -1;
    return 0;
}
@

<<function [[ftprcode]](hget.c)>>=
int
ftprcode(int ctl, char *msg, int len)
{
    int rv;
    int i;
    char *p;

    len--;  /* room for terminating null */
    for(;;){
        *msg = 0;
        i = readline(ctl, msg, len);
        if(i < 0)
            break;
        if(debug)
            fprint(STDERR, "%d <- %s\n", ctl, msg);

        /* stop if not a continuation */
        rv = strtol(msg, &p, 10);
        if(rv >= 100 && rv < 600 && p==msg+3 && *p == ' ')
            return rv/100;
    }
    *msg = 0;

    return -1;
}
@

<<function [[hello]](hget.c)>>=
int
hello(int ctl)
{
    char msg[1024];

    /* wait for hello from other side */
    if(ftprcode(ctl, msg, sizeof(msg)) != Success){
        werrstr("HELLO: %s", msg);
        return Server;
    }
    return 0;
}
@

<<function [[getdec]](hget.c)>>=
int
getdec(char *p, int n)
{
    int x = 0;
    int i;

    for(i = 0; i < n; i++)
        x = x*10 + (*p++ - '0');
    return x;
}
@

<<function [[ftprestart]](hget.c)>>=
int
ftprestart(int ctl, Out *out, URL *u, Range *r, long mtime)
{
    Tm tm;
    char msg[1024];
    long x, rmtime;

    ftpcmd(ctl, "MDTM %s", u->page);
    if(ftprcode(ctl, msg, sizeof(msg)) != Success){
        r->start = 0;
        return 0;       /* need to do something */
    }

    /* decode modification time */
    if(strlen(msg) < 4 + 4 + 2 + 2 + 2 + 2 + 2){
        r->start = 0;
        return 0;       /* need to do something */
    }
    memset(&tm, 0, sizeof(tm));
    tm.year = getdec(msg+4, 4) - 1900;
    tm.mon = getdec(msg+4+4, 2) - 1;
    tm.mday = getdec(msg+4+4+2, 2);
    tm.hour = getdec(msg+4+4+2+2, 2);
    tm.min = getdec(msg+4+4+2+2+2, 2);
    tm.sec = getdec(msg+4+4+2+2+2+2, 2);
    strcpy(tm.zone, "GMT");
    rmtime = tm2sec(&tm);
    if(rmtime > mtime)
        r->start = 0;

    /* get size */
    ftpcmd(ctl, "SIZE %s", u->page);
    if(ftprcode(ctl, msg, sizeof(msg)) == Success){
        x = atol(msg+4);
        if(r->start == x)
            return 1;   /* we're up to date */
        r->end = x;
    }

    /* seek to restart point */
    if(r->start > 0){
        ftpcmd(ctl, "REST %lud", r->start);
        if(ftprcode(ctl, msg, sizeof(msg)) == Incomplete){
            setoffset(out, r->start);
        }else
            r->start = 0;
    }

    return 0;   /* need to do something */
}
@

<<function [[logon]](hget.c)>>=
int
logon(int ctl)
{
    char msg[1024];

    /* login anonymous */
    ftpcmd(ctl, "USER anonymous");
    switch(ftprcode(ctl, msg, sizeof(msg))){
    case Success:
        return 0;
    case Incomplete:
        break;  /* need password */
    default:
        werrstr("USER: %s", msg);
        return Server;
    }

    /* send user id as password */
    sprint(msg, "%s@closedmind.org", getuser());
    ftpcmd(ctl, "PASS %s", msg);
    if(ftprcode(ctl, msg, sizeof(msg)) != Success){
        werrstr("PASS: %s", msg);
        return Server;
    }

    return 0;
}
@

\section{External viewers via plumbing}

%claude:
Covered in chapter \ref{chap:events}. The plumber rules route by MIME
type and filename extension: PDFs to \verb+page+, video to
\verb+mplayer+ wrapper, etc.\ Mothra never has to know about external
viewers because the plumber dispatches them by content rather than by
the URL.

\section{Caching in [[webfs]]}

%claude:
There is no caching layer in webfs. Each fetch is a real round-trip;
the only persistence is the cookie jar and the per-connection
[<Client>] state. Mothra has its own per-page [<Pix>] cache for
images, but it is per-page only --- navigating away discards it. The
size cap (NPIXMB) is a 5~MiB ceiling on the image cache for
all currently-open pages, beyond which oldest pages have their
images dropped.

\section{Internationalization}

%claude:
Internationalization is split between charset conversion (chapter
\ref{chap:charset}) and the entity table for HTML named character
references (chapter \ref{chap:html-parsing}). Mothra's default font
set is DejaVu Sans, which covers most of Unicode; CJK and other
non-Latin scripts render as long as the corresponding font is
installed under \verb+/lib/font/bit/+. There is no language-specific
behaviour: no right-to-left layout, no complex script shaping (these
require a real text-shaping library like Harfbuzz), no
locale-dependent date or number formats.

%******************************************************************************
\chapter{Conclusion}
%******************************************************************************
\label{chap:conclusion}

%dup: Make.nw
%claude:
You now know how the \plan web browser [[mothra]] works, to the
smallest details, and more generally how many web browsers work at
their core.
%claude:
You have followed a URL like [[http://example.com/]] from the address
bar, through mothra's URL parser, through a 9P conversation with
[[webfs]], through a TCP (or TLS) dial to the origin server, through
the charset pipeline [[uhtml | tcs]], into mothra's [[rdhtml.c]]
parser, out as a flat list of [[Item]]s, and finally onto the screen
as word-wrapped text with clickable anchors and inlined images.
Click a link and the same machinery runs again, one page at a time.

%\section{Putting it all together}

%claude:
At its core, [[mothra]] solves the browser problem by {\em refusing
to solve most of it}. It does not have a layout engine; it treats
documents as a flow of text. It does not have a TLS library; it opens
[[/net/tls]] and writes plaintext. It does not have a cookie subsystem
of its own; it delegates to [[webfs]] and [[webcookies]]. It does not
have an image decoder; it spawns [[getpix]]. It does not have a
charset library; it pipes through [[uhtml]] and [[tcs]].

%claude:
%plan9-is-cleaner:
What is left in [[mothra]], once all that is subtracted, is about
4400 lines of C that do the three things a browser cannot avoid
doing itself: parse HTML, lay out a flow of text, and drive a
user-facing event loop. Everything else is somebody else's job.

\section{Patterns and techniques}

%claude:
Several techniques appear repeatedly across the stack, and apply
far beyond web browsers:

\begin{itemize}

\item \emph{File server as API boundary}: [[/mnt/web]], [[/mnt/webcookies]],
and [[/net/tls]] are all file servers. A program interacts with them
through [[open]], [[read]], and [[write]]---the same operations it uses
for ordinary files. No library needs to be linked, no versioning of
APIs is needed: the filesystem is the ABI. This is the \plan design
signature and appears throughout the \book{Kernel}, the \book{Graphics},
the \book{Windows}, and the \book{Libcore} as well.

\item \emph{Pipe composition for transformation}: the
[[fetch | uhtml | tcs]] pipeline is a chain of tiny programs, each
doing one thing. It is literally a \plan shell pipeline, dressed up
as a browser input stage. The same pattern appears wherever a
sequence of transformations is more easily expressed as cooperating
processes than as a monolithic routine; the \book{Shell} develops it
in full as well as \book{Utilities}.

\item \emph{Subprocess per helper}: [[getpix]] is not a library call,
it is a separate program mothra [[fork]]s. This keeps the browser's
address space clean of decoder bugs, makes helpers replaceable, and
gives each helper its own debug flags. Modern browsers reinvent this
pattern in the large: Chrome's per-tab process, its GPU process, and
its network process are all helpers-in-processes, with millions of
lines of IPC plumbing around them.

\item \emph{Content dispatch from MIME type}: [[snoop.c]] runs
[[/bin/file -m]] as a subprocess, classifies the content, and chooses
a renderer. Polymorphism by sniffing, rather than by type declaration.
The same idea is behind \unix's shebang lines, \plan's [[/mnt/plumb]]
dispatch, and HTTP's own [[Content-Type]] negotiation.

\item \emph{Lenient parsing}: [[rdhtml.c]] never refuses a malformed
document. This is the same approach every real HTML parser takes,
because rejecting real-world HTML would reject most of the web.
The lesson---that a public data format, once popular, cannot be made
strict after the fact---recurs in HTTP header parsing, email, URLs,
CSV, JSON in the wild, and every other popular text format.

\item \emph{Flat item list instead of a DOM}: mothra does not build a
tree you can query after the fact, because it never needs to. Removing
the DOM removes tens of thousands of lines of bookkeeping; that is the
price the modern web pays for letting JavaScript inspect the document.
The general lesson: if nobody {\em queries} your parsed representation
later, you do not need an inspectable tree.

\end{itemize}

\section{Connections to other books}

%claude:
Because mothra is a user-space graphical program that talks to a
file-server network stack, it sits at the top of several books in
\principia, and I encourage you to continue with any of them:

\begin{itemize}

\item The \book{Kernel} explains what lies behind many of the services
mothra uses: 
%[[/net/tls]] ([[devtls.c]]), 
the namespace mechanism that attaches [[/mnt/web]] into the process's
view of the filesystem, and the [[rfork]] syscall mothra uses to
spawn [[getpix]].

\item The \book{Libcore} explains the user-space C library underneath:
[[print]], [[Bio]] buffered I/O, [[exec]], [[pipe]], the 9P client
library [[lib9p]] that both mothra and [[webfs]] use, and the memory
allocator whose debug hooks are exposed by [[mothra -d]].

\item The \book{Widgets} explains [[libpanel]], the toolkit mothra
uses for its address bar, display pane, status bar, and form widgets.
Form fields in particular are ordinary libpanel widgets
(text entry, check box, radio group) assembled by [[forms.c]].

\item The \book{Windows} explains [[rio]], the \plan window manager
mothra runs under. Mothra's event loop, plumb integration, and
snarf (selection) behavior only make sense in the context of rio's
conventions.

\item The \book{Network} explains the TCP/IP stack, the [[/net]]
filesystem, DNS resolution, and TLS---everything [[webfs]] ultimately
delegates to the kernel for.

\item The \book{Shell} is, somewhat unexpectedly, relevant to the
browser: [[uhtml]] literally execs [[rc]] to run a
[[\{tcs -f cset || cat\} | tcs -f html]] pipeline. The charset
stage of the browser is a shell pipeline.

\end{itemize}

\section{What's missing: CSS, JavaScript, modern web}

%claude:
%modern:
As mentioned many times in the books, there are many web features
you will {\em not} find in [[mothra]]:

\begin{itemize}

\item {CSS}. No selectors, no cascade, no box model. Styling is
implicit in mothra's per-tag rendering defaults (headings get bold
larger fonts, [[<code>]] gets a fixed-width font, and so on). Sites
that rely on CSS for layout will render as linearized text.

\item {JavaScript}. No script execution, no DOM, no event model
beyond the browser-native clicks and keyboard. Pages that generate
their content in JavaScript after load (single-page apps) will appear
mostly empty.

\item {Cross-origin policies}, CORS, service workers, web sockets,
WebAssembly, WebGL, indexed DB, fetch API, and the long tail of modern
web platform features. None of this exists.

\item {Modern security model}: mothra will happily submit a form
to any URL, cross-origin or not. There is no concept of a secure
context beyond HTTPS itself.

\item Incremental {layout}: mothra fetches the full document, parses
it, and renders. It does not progressively update the page as bytes
arrive. (It does progressively fetch images in parallel, however.)

\end{itemize}

%claude:
%why-study:
Whether any of this matters for you depends on what you want the
browser for. For reading documents on the web, mothra still works
surprisingly well in 2026, especially on text-heavy sites. For
using web applications---which is what most users today mean by
``the web''---it does not.

\section{Comparison with abaco}

%claude:
\plan has another graphical browser, [[abaco]], written in~2004 by
Federico Benavento. The two make different design choices and are
worth comparing.

\begin{itemize}

\item {Size}: [[mothra]] is about 4400 LOC; [[abaco]] is about
7900 LOC. [[abaco]] also depends on [[libhtml]], a separate
~4500 LOC HTML library by Russ Cox, which [[mothra]] does not use.

\item {Parser}: [[abaco]] uses [[libhtml]], a more thorough HTML~4
parser with better support for tables, styles, and HTML entities.
[[mothra]] has its own parser in [[rdhtml.c]], 1300 LOC, that trades
coverage for simplicity.

\item {UI toolkit}: [[mothra]] uses [[libpanel]] (see the \book{Widgets}),
which gives it integration with the rest of the \plan widget ecosystem.
[[abaco]] has its own UI layer written directly on [[libdraw]], with
support for tabs, incremental layout, and a more modern event model.

\item {Composition}: [[mothra]] uses the [[uhtml | tcs]] pipeline
for charset handling, spawned as a subprocess. [[abaco]] links
[[tcs]] in directly, with its own [[charsets.txt]]/[[charsets.awk]]
generator. Mothra's is the more \plan-native design; abaco's is
more self-contained.

%\item {Maintenance}: [[mothra]] is still carried and patched by the
%9front fork of \plan. [[abaco]] has been frozen since its original
%release, with only cosmetic changes since.

\end{itemize}

%claude:
I chose [[mothra]] for this book because it is smaller, because its
composition through pipes and file servers makes it a cleaner case
study of \plan design principles, and because [[libpanel]] integration
gives us a natural cross-reference to the \book{Widgets}.
%
[[abaco]] is more architecturally ambitious but tells a muddier
design story.

\section{Modern browser scale}

%claude:
%modern:
For perspective, Table~\ref{tab:browser-loc} lists the rough sizes of modern web engines compared
to [[mothra]]:

\begin{table}[htbp]
\centering
\begin{tabular}{lr}
\toprule
{\bf Engine / browser}      & {\bf LOC (approx.)} \\
\midrule
mothra + webfs + helpers (this book) & 10 k \\
Links                       & 85 k \\
Lynx                        & 170 k \\
Gecko (Firefox's engine)    & 6 M \\
WebKit (Safari's engine)    & 9 M \\
Chromium (Chrome, Edge, \ldots)      & 32 M \\
\bottomrule
\end{tabular}
\caption{Approximate lines of code of web browsers (2026).}
\label{tab:browser-loc}
\end{table}

%claude:
The three orders of magnitude between [[mothra]] and Chromium are
not gratuitous: they buy CSS layout, a JavaScript engine with JIT,
GPU compositing, a sandbox, WebAssembly, Web APIs, modern cryptography,
and thousands of quirks accreted over 30 years of web compatibility.
But they also hide the essential structure that is plainly visible
in [[mothra]]: URL, HTTP, HTML, flow layout, click to follow.

%claude:
%plan9-is-cleaner:
The core algorithm of a browser has not changed since 1991. What
changed is what a browser is expected to do {\em besides} displaying
hypertext. Reading [[mothra]] is a way to see that core without the
accretions---to understand, from end to end, what is actually
necessary to turn a URL into a clickable page. Everything else, as
far as pedagogy is concerned, is an optimization.

%###############################################################################
\appendix
%###############################################################################

%******************************************************************************
\chapter{Debugging}
%******************************************************************************
\label{chap:debugging}

%claude:
This appendix collects the debugging facilities scattered throughout
the browser into one place: per-subsystem trace flags that control how
chatty the code is, and the dumpers that print structured state in
human-readable form.

\section{Logging}

%claude:
There is no central log: each subsystem has its own trace flag written
to stderr when set.
%
\verb+debug+ in mothra controls HTTP-level traces
and image-pipeline temp files.
%
\verb+httpdebug+, \verb+urldebug+,
\verb+cookiedebug+, and \verb+fsdebug+ in webfs control the matching
subsystems.
%
\verb+chatty9p+ in libthread controls 9P-message tracing.
%
All are settable at startup (\verb+webfs -d -D+) or at runtime
(\verb+echo httpdebug 1 > /mnt/web/ctl+).

<<global [[debug]](mothra)>>=
bool debug;             /* command line flag */
@
% set by -d

<<[[main()]](mothra) debug notify>>=
if(debug) notify(dienow);
@



\section{Per-subsystem tracing}

%claude:
Each subsystem trace is gated by its own
\verb+if(xxxdebug) fprint(2, ...)+ block. The tradeoff is performance vs.\ noise: the checks are
cheap when off (one global int load), but on a busy webfs the volume
can swamp other output. Most runs leave them all off and turn on the
relevant one for the bug at hand.

\section{Dumpers}

%claude:
Each major data type has a [[Format]] verb installed via
[[fmtinstall()]] so that \verb+%U+ prints a Url, \verb+%K+ a Cookie,
\verb+%J+ a Jar. The dumper is what backs both the trace prints
above and the human-readable view of \verb+/mnt/webcookies/cookies+.

<<[[main()]](mothra) fmt setup>>=
quotefmtinstall();
@

\subsection{URLs}

%claude:
\verb+%U+ in mothra prints a Url's \verb+fullname+ (or
\verb+reltext+ if the full form has not been computed yet). In webfs,
the equivalent is the \verb+/parsed/url+ file that read returns the
canonical serialisation of the parsed URL.

<<[[main()]](mothra) fmt setup>>=
fmtinstall('U', Ufmt);
@

<<function [[Ufmt]](mothra)>>=
int Ufmt(Fmt *f){
    char *s = va_arg(f->args, char*);
    for(; *s; s++){
        if(strchr("/$-_@.!*'(),", *s)
        || 'a'<=*s && *s<='z'
        || 'A'<=*s && *s<='Z'
        || '0'<=*s && *s<='9')
            fmtprint(f, "%c", *s);
        else if(*s==' ')
            fmtprint(f, "+");
        else
            fmtprint(f, "%%%.2X", *s & 0xFF);
    }
    return 0;
}
@

\subsection{HTML items}

%claude:
There is no built-in dumper for the Rtext list, but the parser's
\verb+htmlerror()+ logs offer a window into where in the input each
tag was hit. For deeper inspection, a fresh fetch with the renderer
set to PLAIN shows the raw HTML directly.

\subsection{Cookie jar}

%claude:
\verb+/mnt/webcookies/cookies+ is the dumper's running output: every
read returns the full jar in human-readable form. Edit it, write it
back, and the changes propagate to the in-memory state. The
\verb+webcookies -D+ flag also turns on chatty 9P tracing.




%******************************************************************************
%\chapter{Profiling}
%%******************************************************************************
%\label{chap:profiling}
%
%%claude:
%There is no profiler in the browser. The dominant cost is network
%round-trip time, which no profiler would meaningfully measure: a flame
%graph would just show \verb+read()+ on the network socket near the
%top. For CPU bottlenecks (which would have to be in HTML parsing or
%image decoding to matter), Plan~9's [[tprof]] (\book{Profiler}) can
%be attached to mothra externally and produces a normal sample-based
%profile.

%******************************************************************************
\chapter{Error Management}
%******************************************************************************
\label{chap:errors}

%claude:
This appendix collects the browser's error-handling vocabulary in
one place. There are two systems at play: in-process error returns
(C-style \verb+-1+ + \verb+errstr+) and the 9P \verb+Rerror+
messages that carry strings across the file-server boundary. Both end
up as the same kind of string when the client \verb+%r+s them.

\section{Per-subsystem error paths}

%claude:
Each subsystem chooses between fatal-on-error and propagate-on-error
based on what is reasonable. Memory-allocation primitives
([<emalloc()>], [<estrdup()>]) call \verb+sysfatal+ because there is
no recovery from out-of-memory in any tool. Network primitives
return \verb+-1+ and set \verb+errstr+ via \verb+werrstr()+ so the
caller can decide whether to retry, abort the request, or fail the
whole transaction. The HTML parser splits the difference: minor errors
log via \verb+htmlerror()+ and continue; structural errors that would
corrupt the parse stack reset the relevant frame and continue
anyway.

\section{9P error strings across the [[webfs]] boundary}

%claude:
9P has one kind of error: a string. Webfs and webcookies both follow
the standard \plan convention that error strings are short, lowercase,
and parseable: ``url is not yet set'', ``permission denied'', ``cookie
file too large''. When mothra's [<urlget()>] sees the error string,
it appears in the message bar via [<message()>]. There is no
structured error format because there does not need to be: the error
strings are the API.

%******************************************************************************
\chapter{Utilities}
%******************************************************************************
\label{chap:utilities}

%claude:
This appendix collects the small support functions used throughout webfs.
%
Three categories:
memory wrappers that exit on failure (\verb+emalloc+, \verb+erealloc+, \ldots),
string helpers that the standard \verb+libc+ does not include, and the
buffered file-reading primitives ([<Ibuf>] manipulation) on top of which the
HTTP and FTP parsers are built.

<<function [[erealloc]](webfs)>>=
void*
erealloc(void *a, uint n)
{
    a = realloc(a, n);
    if(a == nil)
        sysfatal("realloc %d: out of memory", n);
    setrealloctag(a, getcallerpc(&a));
    return a;
}
@

%claude:
[<emalloc()>] is the zeroing-malloc-or-die wrapper: it calls
\verb+mallocz(n, 1)+ to get zeroed memory and \verb+sysfatal+s on
NULL. \verb+setmalloctag+ tags the allocation with the return PC of
the caller, which acid uses to attribute leaks to a particular call
site. Almost every allocation in webfs goes through this rather than
plain \verb+malloc+.

<<function [[emalloc]](webfs)>>=
void*
emalloc(uint n)
{
    void *a;

    a = mallocz(n, 1);
    if(a == nil)
        sysfatal("malloc %d: out of memory", n);
    setmalloctag(a, getcallerpc(&n));
    return a;
}
@

% sad that dupe between mothra and webfs; should be in libc!
<<function [[emalloc]](mothra)>>=
void *emalloc(int n){
    void *v;

    v=malloc(n);
    if(v==nil)
        sysfatal("out of memory");
    memset(v, 0, n);
    setmalloctag(v, getcallerpc(&n));
    return v;
}
@

\section{Strings}

%claude:
The string helpers exist because libc is minimal: there is no
\verb+strlower+, no \verb+estrdup+ that exits on failure, no
\verb+estredup+ that takes a (start, end) pair instead of a NUL
terminator. The browser uses (start, end) pairs heavily (the URL
parser produces them by the dozen), so [<estredup()>] is one of the
hot helpers.

<<function [[strlower]](webfs)>>=
char*
strlower(char *s)
{
    char *t;

    for(t=s; *t; t++)
        if('A' <= *t && *t <= 'Z')
            *t += 'a'-'A';
    return s;
}
@

<<function [[estrdup]](webfs)>>=
char*
estrdup(char *s)
{
    s = strdup(s);
    if(s == nil)
        sysfatal("strdup: out of memory");
    setmalloctag(s, getcallerpc(&s));
    return s;
}
@

<<function [[estredup]](webfs)>>=
char*
estredup(char *s, char *e)
{
    char *t;

    t = emalloc(e-s+1);
    memmove(t, s, e-s);
    t[e-s] = '\0';
    setmalloctag(t, getcallerpc(&s));
    return t;
}
@

<<function [[estrmanydup]](webfs)>>=
char*
estrmanydup(char *s, ...)
{
    char *p, *t;
    int len;
    va_list arg;

    len = strlen(s);
    va_start(arg, s);
    while((p = va_arg(arg, char*)) != nil)
        len += strlen(p);
    len++;

    t = emalloc(len);
    strcpy(t, s);
    va_start(arg, s);
    while((p = va_arg(arg, char*)) != nil)
        strcat(t, p);
    return t;
}
@

\section{Files}

%claude:
[<Ibuf>] is the buffered reader on top of libthread's \verb+ioproc+.
The semantics are designed for line-oriented protocols like HTTP and
FTP: [<readline()>] reads up to a newline, [<unreadline()>] pushes a
line back, [<readibuf()>] reads a chunk.
%
The single-buffer
implementation is simple but has a subtle ring-buffer bug noted in
the [<readline()>] body: \verb+wp+ only advances, never resets, so
fat-headers sites used to crash mothra until the explicit reset on
drain was added.


<<function [[readibuf]](webfs)>>=
int
readibuf(Ibuf *b, char *buf, int len)
{
    int n;

    n = b->wp - b->rp;
    if(n > 0){
        if(n > len)
            n = len;
        memmove(buf, b->rp, n);
        b->rp += n;
        return n;
    }
    return ioreadn(b->io, b->fd, buf, len);
}
@

<<function [[unreadline]](webfs)>>=
void
unreadline(Ibuf *b, char *line)
{
    int i, n;

    i = strlen(line);
    n = b->wp - b->rp;
    memmove(&b->buf[i+1], b->rp, n);
    memmove(b->buf, line, i);
    b->buf[i] = '\n';
    b->rp = b->buf;
    b->wp = b->rp+i+1+n;
}
@

<<function [[readline]](webfs)>>=
int
readline(Ibuf *b, char *buf, int len)
{
    int n;
    char *p;

    len--;

    for(p = buf;;){
        if(b->rp >= b->wp){
            /* claude: reset on drain -- same upstream ring-buffer bug as
             * hget's readline. wp only advances; without resetting to
             * b->buf after the ring drains, cumulative reads push wp
             * past b->buf+sizeof(b->buf) and the next read() writes off
             * the end of the allocation. Fat-header sites
             * (en.wikipedia.org etc.) trip it. unreadline() already
             * re-anchors rp/wp at b->buf when it fires, so the two
             * mutators stay consistent. */
            b->rp = b->wp = b->buf;
            n = ioread(b->io, b->fd, b->wp, sizeof(b->buf)/2);
            if(n < 0)
                return -1;
            if(n == 0)
                break;
            b->wp += n;
        }
        n = *b->rp++;
        if(len > 0){
            *p++ = n;
            len--;
        }
        if(n == '\n')
            break;
    }

    /* drop trailing white */
    for(;;){
        if(p <= buf)
            break;
        n = *(p-1);
        if(n != ' ' && n != '\t' && n != '\r' && n != '\n')
            break;
        p--;
    }

    *p = 0;
    return p-buf;
}
@

\section{Dates}

%claude:
HTTP dates appear in three places: \verb+Last-Modified+ headers,
\verb+Set-Cookie+ \verb+expires+ attributes, and \verb+If-Modified-Since+
request headers. The grammar is the famously ugly RFC~822 / RFC~850 /
ANSI~C trichotomy:

\begin{verbatim}
    Sun, 06 Nov 1994 08:49:37 GMT    ; RFC 822, RFC 1123 (preferred)
    Sunday, 06-Nov-94 08:49:37 GMT   ; RFC 850, obsolete
    Sun Nov  6 08:49:37 1994         ; ANSI C asctime() format
\end{verbatim}

%claude:
The browser parses all three with [<strtotime()>] (used both by
webfs's cookie code and by webcookies). The implementation is one
hand-coded scanner per format; no \verb+strptime+ in libc.



