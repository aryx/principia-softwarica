<<function [[scrollto]](mothra)>>=
void scrollto(char *tag){
    Rtext *tp;
    Action *ap;
    if(current == nil || text == nil)
        return;
    if(tag && tag[0]){
        for(tp=current->text;tp;tp=tp->next){
            ap=tp->user;
            if(ap && ap->name && strcmp(ap->name, tag)==0){
                current->yoffs=tp->topy;
                break;
            }
        }
    }
    plsetpostextview(text, current->yoffs);
}
