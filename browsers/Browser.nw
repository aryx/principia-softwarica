<<function [[freetext]](mothra)>>=
void freetext(Rtext *t){
    Rtext *tt;
    Action *a;

    tt = t;
    for(; t!=0; t = t->next){
        t->b=0;
        free(t->text);
        t->text=0;
        if(a = t->user){
            t->user=0;
            free(a->image);
            free(a->link);
            free(a->name);
            free(a);
        }
    }
    plrtfree(tt);
}
