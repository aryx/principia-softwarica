\subsection{Status codes}

<<function [[httprcode]](webfs)>>=
static int
httprcode(HttpState *hs)
{
    int n;
    char *p;
    char buf[256];

    n = readline(&hs->b, buf, sizeof(buf)-1);
    if(n <= 0)
        return n;
    if(httpdebug)
        fprint(2, "-> %s\n", buf);
    p = strchr(buf, ' ');
    if(memcmp(buf, "HTTP/", 5) != 0 || p == nil){
        werrstr("bad response from server");
        return -1;
    }
    buf[n] = 0;
    return atoi(p+1);
}
