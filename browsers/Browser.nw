<<function [[addcookie]](webfs)>>=
static void
addcookie(Jar *j, Cookie *c)
{
    int i;

    if(!c->name || !c->value || !c->path || !c->dom){
        fprint(2, "not adding incomplete cookie\n");
        return;
    }

    if(cookiedebug)
        fprint(2, "add %K\n", c);

    for(i=0; i<j->nc; i++)
        if(cookiecmp(&j->c[i], c) == 0){
            if(cookiedebug)
                fprint(2, "cookie %K matches %K\n", &j->c[i], c);
            if(exactcookiecmp(&j->c[i], c) == 0){
                if(cookiedebug)
                    fprint(2, "\texactly\n");
                j->c[i].mark = 0;
                return;
            }
            delcookie(j, &j->c[i]);
        }

    j->dirty = 1;
    if(j->nc == j->mc){
        j->mc += 16;
        j->c = erealloc9p(j->c, j->mc*sizeof(Cookie));
    }
    j->c[j->nc] = *c;
    copycookie(&j->c[j->nc]);
    j->nc++;
}
