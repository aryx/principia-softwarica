<<function [[skipspace]](webfs)>>=
/*
 * skip linear whitespace.  we're a bit more lenient than RFC2616 2.2.
 */
static char*
skipspace(char *s)
{
    while(*s=='\r' || *s=='\n' || *s==' ' || *s=='\t')
        s++;
    return s;
}
