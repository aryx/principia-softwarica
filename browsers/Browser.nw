<<function [[findcmd]](webfs)>>=
static Ctab*
findcmd(char *cmd, Ctab *tab, int ntab)
{
    int i;

    for(i=0; i<ntab; i++)
        if(strcmp(tab[i].name, cmd) == 0)
            return &tab[i];
    return nil;
}
