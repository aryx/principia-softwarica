<<function [[jarfmt]](webfs)>>=
/* HTTP format */
static int
jarfmt(Fmt *fp)
{
    int i;
    Jar *jar;

    jar = va_arg(fp->args, Jar*);

    if(jar == nil || jar->nc == 0)
        return 0;

    fmtstrcpy(fp, "Cookie: ");
    if(jar->c[0].version)
        fmtprint(fp, "$Version=%s; ", jar->c[0].version);
    for(i=0; i<jar->nc; i++)
        fmtprint(fp, "%s%s=%s", i ? "; ": "", jar->c[i].name, jar->c[i].value);
    fmtstrcpy(fp, "\r\n");
    return 0;
}
