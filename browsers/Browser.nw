<<function [[search]](mothra)>>=
void search(void){
    static char last[256];
    char buf[256];
    Reprog *re;
    Rtext *tp;

    for(;;){
        if(current == nil || current->text == nil || text == nil)
            return;
        strncpy(buf, last, sizeof(buf)-1);
        if(eenter("Search for", buf, sizeof(buf), &mouse) <= 0)
            return;
        strncpy(last, buf, sizeof(buf)-1);
        re = regcompnl(buf);
        if(re == nil){
            message("%r");
            continue;
        }
        for(tp=current->text;tp;tp=tp->next)
            if(tp->flags & PL_SEL)
                break;
        if(tp == nil)
            tp = current->text;
        else {
            tp->flags &= ~PL_SEL;
            tp = tp->next;
        }
        while(tp != nil){
            tp->flags &= ~PL_SEL;
            if(tp->text && *tp->text)
            if(regexec(re, tp->text, nil, 0)){
                tp->flags |= PL_SEL;
                plsetpostextview(text, tp->topy);
                break;
            }
            tp = tp->next;
        }
        free(re);
        updtext(current);
    }
}
