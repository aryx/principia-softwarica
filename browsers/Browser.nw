<<function [[newfield]](mothra)>>=
Field *newfield(Form *form){
    Field *f;
    f=emalloc(sizeof(Field));
    if(form->efields==0)
        form->fields=f;
    else
        form->efields->next=f;
    form->efields=f;
    f->next=0;
    f->form=form;
    return f;
}
