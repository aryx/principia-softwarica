unicode_out_le(Rune *base, int n, long *notused)
{
    int i;
    uchar *p;
    Rune r;

    USED(notused);
    p = (uchar*)base;
    for(i=0; i<n; i++){
        r = base[i];
        *p++ = r;
        *p++ = r>>8;
    }
    nrunes += n;
    noutput += 2*n;
    write(1, (char *)base, 2*n);
}
