setwide(void)
{
    if(!given) {
        addr1 = zero + (dol>zero);
        addr2 = dol;
    }
}
@

% + (dol>zero) means zero + 1  when non empty file, so line 1.


[<squeeze()>] validates that the address range is sane---called
with~0 when an empty buffer is acceptable (e.g., for the [[r]] command) or~1 when
at least one line is required (e.g., for the [[p]] command).
% commands like 'p' will fail that assumes at least one line
% sanity check user input! array bound checking! cos addr1/addr2 can be user
% input if setwide given

<<function [[squeeze]](ed.c)>>=
/// main -> commands('r') -> <>
void
squeeze(int i)
{
    if(addr1 < zero+i || addr2 > dol || addr1 > addr2)
        error(Q);
}
