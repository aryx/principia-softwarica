\subsection{[[putfile()]]}

[<putfile()>] is the dual of [<getfile()>]: it writes in [<iobuf>].
% write in iobuf, but all the lines, not just one like in getfile().
% so dual of append(getfile,), not just getfile()

<<function [[putfile]](ed.c)>>=
/// main -> commands('w) -> <>
void
putfile(void)
{
    int *a1;
    Rune *lp;
    long c;

    a1 = addr1;
    do {
        // modifies (and returns) linebuf[]
        lp = getline(*a1++);
        for(;;) {
            count++;
            c = *lp++;
            if(c == 0) {
                // a null Rune in tfile converts to \n in the written file
                if(Bputrune(&iobuf, '\n') < 0)
                    error(Q);
                break;
            }
            // else
            if(Bputrune(&iobuf, c) < 0)
                error(Q);
        }
    } while(a1 <= addr2);
    if(Bflush(&iobuf) < 0)
        error(Q);
}
@

