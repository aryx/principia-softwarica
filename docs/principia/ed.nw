@

<<globals ed.c>>=
jmp_buf savej;
@
% kinda like poor's man exception mechanism. Simple but effective.

<<function [[error]](ed.c)>>=
void
error(char *s)
{
    error_1(s);
    longjmp(savej, 1);
}
@
% longtmp =~ exn to jump just before commands() to reread commands!


