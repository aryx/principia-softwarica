% special ".\n" here to finish the text entry.
% OK_0 means you can read more lines
% positive means error

% gety and gettty, will modify linebuf for the caller
<<function [[gety]](ed.c)>>=
/// gettty -> <>
int
gety(void)
{
    int c;
    Rune *p = linebuf;
    <<[[gety()]] other locals>>
    for(;;) {
        c = getchr();
        if(c == '\n') {
            *p = 0;
            return 0;
        }
        // else
        if(c == EOF) {
            <<[[<<get()]] if [[gf]]>>
            return c;
        }
        // else
        if(c == 0)
            continue;
        // else
        *p++ = c;
        if(p >= &linebuf[LBSIZE-sizeof(Rune)])
            error(Q);
    }
}
