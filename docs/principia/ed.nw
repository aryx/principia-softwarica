% called when can enter text until '.\n'
% get line from tty (terminal). small wrapper over the raw gety
%claude:
[<gettty()>] reads a line of user input (via [<gety()>]) and checks
for the special [[.\backslash n]] terminator that ends text-entry mode
in commands like [[a]] and [[i]].
[<gety()>] does the actual character-by-character reading into
[[linebuf]], stopping at a newline.

<<function [[gettty]](ed.c)>>=
/// main -> commands('a') -> add -> <>
int
gettty(void)
{
    int rc;

    rc = gety();
    if(rc)
        return rc;
    // else
    if(linebuf[0] == '.' && linebuf[1] == '\0')
        return EOF;
    return 0; // OK_0 ?
}
