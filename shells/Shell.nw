    // pprompt() internally set doprompt back to false at the end
    pprompt();
@
% remember that set to true in global at startup.
% so first character read we will get a prompt.

%claude:
The subtlety in [<pprompt()>] is that after printing the current
prompt string, it switches [[promptstr]] to the {\em second}
element of [[$prompt]] (the continuation prompt).
%
This way, if the lexer needs more input for a multi-line
command, the next call to [<pprompt()>] will display
the continuation prompt instead of the main one.
%
The main prompt is restored in [<Xrdcmds()>] before each new command as shown above.

<<function [[pprompt]]>>=
void
pprompt(void)
{
    var *prompt;

    if(runq->iflag){
        // printing the prompt
        pstr(err, promptstr);
        flush(err);

        // set promptstr for the next pprompt()
        prompt = vlook("prompt");
        if(prompt->val && prompt->val->next)
            promptstr = prompt->val->next->word;
        else
            promptstr="\t";
    }
    runq->lineno++;
    doprompt = false;
}
