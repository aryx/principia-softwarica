    c = rchr(runq->cmdfd);

    if(c=='\n' && !incomm){		/* don't continue a comment */
        <<[[getnext()]] when backslash and newline, set doprompt>>
        c=' ';
    }
    else{
        peekc = c;
        c='\\';
    }
}
