bool pl_hitpopup(Panel *g, Mouse *m){
    Panel *p;
    Popup *pp = g->data;
    <<[[pl_hitpopup()]] other locals>>

    if(g->state==UP){
        switch(m->buttons&7){
        case CLICK_LEFT:   p=pp->pop[0]; g->state=DOWN1; break;
        case CLICK_MIDDLE: p=pp->pop[1]; g->state=DOWN2; break;
        case CLICK_RIGHT:  p=pp->pop[2]; g->state=DOWN3; break;
        <<[[pl_hitpopup()]] when [[UP]], switch buttons other cases>>
        }
        <<[[pl_hitpopup()]] when [[UP]], if no popup menu [[p]]>>
        else if(g->state!=UP){
            <<[[pl_hitpopup()]] when from [[UP]] to [[DOWNX]] and valid [[p]]>>
        }
    } else{ // a DOWNX state
        switch(g->state){
        case DOWN1: p=pp->pop[0]; break;
        case DOWN2: p=pp->pop[1]; break;
        case DOWN3: p=pp->pop[2]; break;
