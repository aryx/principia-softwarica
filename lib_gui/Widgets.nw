\section{Button}

%claude:
[[libpanel]] has three kinds of buttons --- regular, check, and
radio --- sharing the same [<Button>] data structure and methods.
The [[btype]] field distinguishes them.
They differ mainly in drawing (check buttons have a checkbox,
radio buttons have a filled square) and in hit behavior
(check toggles, radio ensures mutual exclusion among siblings).

\subsection{[[Button]]}

<<struct [[Button]]>>=
struct Button{
    // enum<ButtonType>
    int btype;			/* button type */

    Icon *icon;			/* what to write on the button */

    <<[[Button]] other fields>>

    void (*pl_buttonhit)(Panel *, buttons);	/* call back user code on button hit */
    void (*hit)(Panel *, buttons, bool);	/* call back user code on check/radio hit */
    <<[[Button]] other methods>>
};
@


<<constant [[BUTTON]]>>=
#define	BUTTON	1
@
<<constant [[CHECK]]>>=
#define	CHECK	2
@
<<constant [[RADIO]]>>=
#define	RADIO	3
@


<<[[Button]] other fields>>=
// state of buttons when hit
buttons buttons;
@
% Why do we need that as the state is passed to the user callback?
% Because we call the user hit callback of a widget on the release
% action, but at that time we do not remember what was the button that
% was clicked, so on the click event we store it and so we can use it
% at the release event.


<<[[Button]] other fields>>=
bool check;			/* for check/radio buttons */
@





<<function [[pl_initbtype]]>>=
void pl_initbtype(Panel *v, int flags, Icon *icon, void (*hit)(Panel *, buttons, bool), int btype){
    Button *bp = v->data;

    v->flags=flags|LEAF;
    v->state=UP;

    v->draw=pl_drawbutton;
    v->hit=pl_hitbutton;
    v->type=pl_typebutton;

    v->getsize=pl_getsizebutton;
    v->childspace=pl_childspacebutton;

    bp->btype=btype;
    bp->check=false;
    bp->hit=hit;
    bp->icon=icon;

    switch(btype){
    case BUTTON: v->kind="button"; break;
    case CHECK:  v->kind="checkbutton"; break;
    case RADIO:  v->kind="radiobutton"; break;
    }
}
@



\subsection{Basic button}

\subsubsection{Initializing}

<<function [[plbutton]]>>=
Panel *plbutton(Panel *parent, int flags, Icon *icon, void (*hit)(Panel *, buttons)){
    Panel *p;

