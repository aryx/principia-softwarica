<<[[pl_hitentry()]] handle copy/paste when middle or right click>>=
if((old&7)==CLICK_LEFT){
    if((m->buttons&7)==CLICK_LEFT|CLICK_MIDDLE){
        Entry *ep;

        plsnarf(p);

        /* cut */
        ep=p->data;
        ep->entp=ep->entry;
        *ep->entp='\0';
        pldraw(p, p->b);
    }
    if((m->buttons&7)==CLICK_LEFT|CLICK_RIGHT)
        plpaste(p);
}
@

<<function [[pl_snarfedit]]>>=
char *pl_snarfedit(Panel *p){
    int s0, s1;
    Rune *t;
    t=pleget(p);
    plegetsel(p, &s0, &s1);
    if(t==0 || s0>=s1)
        return nil;
    return smprint("%.*S", s1-s0, t+s0);
}
@

<<function [[pl_pasteedit]]>>=
void pl_pasteedit(Panel *p, char *s){
    Rune *t;
    if(t=runesmprint("%s", s)){
        plepaste(p, t, runestrlen(t));
        free(t);
    }
}
@


