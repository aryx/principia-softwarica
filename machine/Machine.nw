    switch(st) {
    case 0:	/* logical left */
        reg.cout = reg.cbit;
        break;
    case 1:	/* logical right */
        reg.cout = (v >> 31) & 1;
        break;
    case 2:	/* arith right */
        reg.cout = reg.cbit;
        break;
    case 3:	/* rotate right */
        if(isreg) {
            reg.cout = reg.cbit;
        }
        else {
            reg.cout = v & 1;
            v = ((ulong)v >> 1) | (reg.cbit << 31);
        }
    }
}
