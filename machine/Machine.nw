% note local cbit != reg.cbit
<<function [[dpex]]>>=
void
dpex(instruction inst, long o1, long o2, int rd)
{
    bool cbit = false;

    switch((inst>>21) & 0xf) {
    <<[[dpex()]] switch arith/logic opcode cases>>
    }
    <<[[dpex()]] if Sbit>>
}
