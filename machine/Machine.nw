/*
 * data processing instruction (R<>R),R,R
 */
void
Idp2(instruction inst)
{
    int rn, rd, rm, rs, st;
    long o1, o2, o3;

    rn = (inst>>16) & 0xf;
    rd = (inst>>12) & 0xf;
    rm = inst & 0xf;
    st = (inst>>5) & 0x3;
    rs = (inst>>8) & 0xf;

    o1 = reg.r[rn];
    <<adjust o1 if rn is REGPC>>
    o2 = reg.r[rm];
    <<adjust o2 if rm is REGPC>>
    o3 = reg.r[rs];
    <<adjust o3 if rs is REGPC>>

    o2 = shift(o2, st, o3, true);
    dpex(inst, o1, o2, rd);

    <<[[Idp2()]] trace>>
    <<[[Idpx()]] compensate REGPC>>
