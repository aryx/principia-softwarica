<<function [[Idp1]]>>=
/*
 * data processing instruction (R<>#),R,R
 */
void
Idp1(instruction inst)
{
    int rn, rd, rm, st, sc;
    long o1, o2;

    rn = (inst>>16) & 0xf;
    rd = (inst>>12) & 0xf;
    rm = inst & 0xf;
    st = (inst>>5) & 0x3;
    sc = (inst>>7) & 0x1f;

    o1 = reg.r[rn];
    <<adjust o1 if rn is REGPC>>
    o2 = reg.r[rm];
    <<adjust o2 if rm is REGPC>>

    o2 = shift(o2, st, sc, false);
    dpex(inst, o1, o2, rd);

    <<[[Idp1()]] trace>>
    <<[[Idpx()]] compensate REGPC>>
}
@

