<<[[dpex()]] switch arith/logic opcode cases>>=
case  ORSB:
    reg.r[rd] = o2 - o1;
    if(inst & Sbit) {
        reg.cc1 = o2;
        reg.cc2 = o1;
        reg.compare_op = CCcmp;
    }
    return;
@

