%******************************************************************************
\chapter{Timing a Command: [[/bin/time]]}
%******************************************************************************
\label{chap:time}

% time: most basic perf tool! and super useful!

\section{[[main()]]}

%yoann: as said in previous section, Waitmsg, fork/exec/wait is all you need

<<function [[main]](time.c)>>=
void
main(int argc, char *argv[])
{
    Waitmsg *w;
    long l;
    <<[[main()]](time.c) other locals>>

    <<[[main()]](time.c) usage if no args>>

    switch(fork()){
    case 0:
        // in child
        exec(argv[1], &argv[1]);

        <<[[main()]](time.c) in child after [[exec]]>>
        error(argv[1]);
    case -1:
        error("fork");
    }
    // else, in parent

    notify(notifyf);

    loop:
    w = wait();
    <<[[main()]](time.c) if [[w == nil]]>>
    l = w->time[0];
    add("%ld.%.2ldu", l/1000, (l%1000)/10);
    l = w->time[1];
    add("%ld.%.2lds", l/1000, (l%1000)/10);
    l = w->time[2];
    add("%ld.%.2ldr", l/1000, (l%1000)/10);
    add("\t");

    <<[[main()]](time.c) display also argv>>
    <<[[main()]](time.c) display also wait message and status>>
    fprint(STDERR, "%s\n", output);
    exits(w->msg);
}
@


<<global [[output]](time.c)>>=
char	output[4096];
@


<<function [[add]](time.c)>>=
void
add(char *a, ...)
{
    static bool beenhere=false;
    va_list arg;

    if(beenhere)
        strcat(output, " ");
    va_start(arg, a);
    vseprint(output+strlen(output), output+sizeof(output), a, arg);
    va_end(arg);
    beenhere++;
}
@


<<[[main()]](time.c) in child after [[exec]]>>=
if(argv[1][0] != '/' && strncmp(argv[1], "./", 2) &&
   strncmp(argv[1], "../", 3)){
    sprint(output, "/bin/%s", argv[1]);
    exec(output, &argv[1]);
