KERNELDIR=kernel/COMPILE/9/bcm
KERNEL=kernel/COMPILE/9/bcm/9pi

# QEMU's raspi1ap machine is the same SoC as the Raspberry Pi 1 (BCM2835,
# ARM1176), so we can boot 9pi under emulation instead of flashing an SD card.
# Two quirks (see docs/qemu_arm_debug.txt for the full story):
#  - 9pi is linked -H6 -T0x80008000 (phys load 0x8000); there is no VideoCore
#    firmware in QEMU to place it, so we use the generic loader device to force
#    the load address and entry point.
#  - the emulated SD controller only accepts a power-of-2 card size, and
#    dosdisk.img is 512MiB+512B, so we boot a padded copy (QEMU_SD) instead.
QEMU_SD=qemu-sd.img

$QEMU_SD: dosdisk.img
	cp dosdisk.img $QEMU_SD
	qemu-img resize -f raw $QEMU_SD 1G

# the mini-uart console (serial1) is put on stdio+monitor; the framebuffer
# opens in a window. Ctrl-A C toggles the terminal between the serial console
# and the qemu monitor.
# claude: '</dev/tty' is required: mk runs recipe commands with stdin bound to
# an internal (empty) pipe, not the terminal, so without this redirect qemu's
# serial console never receives your keystrokes and the shell looks frozen even
# though it prints the '%' prompt. Reading straight from /dev/tty bypasses mk's
# pipe and gives qemu the real keyboard.
# claude: usb-kbd/usb-mouse attach behind QEMU's emulated LAN9514 hub (same as
# a real pi1). They used to wedge the boot in a ~2M/s FIQ storm; that is now
# fixed in usbdwc.c (the dwcotg driver), so they enumerate (~5-6s) and the
# usb/kb HID driver picks them up -- run 'cat /dev/usb/ep3.0/ctl' to see them.
# The keyboard types cleanly and the mouse tracks: usbdwc.c detects emulation
# (from the dwc2 Synopsys id) and skips split transactions, which QEMU does not
# model -- driving them caused ~25-30s enumeration and a runaway key-repeat.
# See docs/qemu_arm_debug.txt for the full story and a QMP input-injection
# recipe for headless HID testing.
run:V: $QEMU_SD
	qemu-system-arm -M raspi1ap -device loader,'file='$KERNEL',addr=0x8000,cpu-num=0,force-raw=on' -drive 'file='$QEMU_SD',if=sd,format=raw' -serial null -serial mon:stdio -device usb-kbd -device usb-mouse $QEMU_EXTRA_OPTIONS </dev/tty

# headless variant: no framebuffer window, everything on the terminal
run-nogui:V: $QEMU_SD
	qemu-system-arm -M raspi1ap -device loader,'file='$KERNEL',addr=0x8000,cpu-num=0,force-raw=on' -drive 'file='$QEMU_SD',if=sd,format=raw' -serial null -serial mon:stdio -display none $QEMU_EXTRA_OPTIONS </dev/tty

# claude: debug/trace variant. Boots headless with the interactive serial shell,
# plus QEMU exception logging (-d int; FIQ is exception 6) and event tracing, all
# written to qemu-trace.log (gitignored) so they do not drown the console. The
# default traces are the two subsystems that were key to bringing the kernel up:
# the dwc2 USB host controller (the FIQ storm, split transactions) and the
# bcm2835 system timer (the compare-match wrap). List available events with
# 'qemu-system-arm --trace help'; add more with QEMU_EXTRA_OPTIONS, e.g.
#   mk run-trace 'QEMU_EXTRA_OPTIONS=--trace bcm2835_gpio_*'
# tail -f qemu-trace.log in another terminal while you drive the shell here.
# See docs/qemu_arm_debug.txt for how to read these traces.
run-trace:V: $QEMU_SD
	qemu-system-arm -M raspi1ap -device loader,'file='$KERNEL',addr=0x8000,cpu-num=0,force-raw=on' -drive 'file='$QEMU_SD',if=sd,format=raw' -serial null -serial mon:stdio -display none -d int -D qemu-trace.log --trace 'usb_dwc2_*' --trace 'bcm2835_systmr*' -device usb-kbd -device usb-mouse $QEMU_EXTRA_OPTIONS </dev/tty

# claude: automated regression test. Boots 9pi headless under QEMU and drives the
# emulated usb keyboard/mouse over QMP, asserting the boot sequence, that the
# kernel banner appears once (no watchdog reset loop -> emulation detected), clean
# single-char key echo (no runaway repeat), and live mouse reports. Exits nonzero
# on any regression, so it is CI-friendly. Run 'mk kernel' first (this drives the
# already-built $KERNEL). See docs/scripts/qmp_regress.py and docs/qemu_raspi1ap.txt.
run-test:V: $QEMU_SD
	python3 docs/scripts/qmp_regress.py $KERNEL $QEMU_SD

# boot on real hardware instead of QEMU
run-realpi:V:
	echo copy what is in dosdisk.img to your Raspberry Pi SD card
	echo for example with 'dd if=dosdisk.img of=/dev/sda'
	echo and then insert this SD card in your Raspberry Pi.

