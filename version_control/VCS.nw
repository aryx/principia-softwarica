<<function [[qput]]>>=
void
qput(Objq *q, Object *o, int color)
{
    Qelt t;
    int i;

    assert(o->type == GCommit);
    <<[[qput()]] realloc if needed>>
    q->heap[q->nheap].o = o;
    q->heap[q->nheap].color = color;
    q->heap[q->nheap].ctime = o->commit->ctime;
    <<[[qput()]] resort by [[ctime]]>>
    q->nheap++;
}
@
% see Objq just for GCommit.

<<[[qput()]] realloc if needed>>=
if(q->nheap == q->heapsz){
    q->heapsz *= 2;
    q->heap = earealloc(q->heap, q->heapsz, sizeof(Qelt));
}
@


<<[[qput()]] resort by [[ctime]]>>=
for(i = q->nheap; i > 0; i = (i-1)/2){
    if(q->heap[i].ctime < q->heap[(i-1)/2].ctime)
        break;
    // else exchange
    t = q->heap[i];
    q->heap[i] = q->heap[(i-1)/2];
    q->heap[(i-1)/2] = t;
}
@
% (i-1) / 2 ??


<<function [[qpop]]>>=
int
qpop(Objq *q, Qelt *e)
{
    int i, l, r, m;
    Qelt t;

    if(q->nheap == 0)
        return 0;
    *e = q->heap[0];
    if(--q->nheap == 0)
        return 1;

    i = 0;
    q->heap[0] = q->heap[q->nheap];
    while(true){
        m = i;
        l = 2*i+1;
        r = 2*i+2;
        if(l < q->nheap && q->heap[m].ctime < q->heap[l].ctime)
            m = l;
        if(r < q->nheap && q->heap[m].ctime < q->heap[r].ctime)
            m = r;
        if(m == i)
            break;
        t = q->heap[m];
        q->heap[m] = q->heap[i];
        q->heap[i] = t;
        i = m;
    }
    return 1;
}
@

