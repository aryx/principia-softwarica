\section{Secure Hash Algorithm (SHA1) hashes}

\subsection{Binary hashes}

<<struct [[Hash]]>>=
struct Hash {
    byte h[20];
};
@

% [[h.h]] then when [[Hash h]] parameter

<<global [[Zhash]]>>=
Hash    Zhash;
@
% Zerohash, used for loose error management
% in plan9 bss section is memset to 0? see \book{Kernel}


%alt: \subsection{Hash methods}

<<function [[hasheq]]>>=
int
hasheq(Hash *a, Hash *b)
{
    return memcmp(a->h, b->h, sizeof(a->h)) == 0;
}
@

%ex: hashcmp(h.h, rh->h, npfx)

<<function [[hashcmp]]>>=
int
hashcmp(uchar *a, uchar *b, uint nbit)
{
    int x, y, i, r;

    i = nbit/8;
    r = memcmp(a, b, i);
    if(r != 0 || nbit % 8 == 0)
        return r;
    x = a[i] >> (8 - nbit % 8); 
    y = b[i] >> (8 - nbit % 8); 
    return x - y;
}
@



\subsection{Hexadecimal hashes}

% hexa hash = char*, string of 40 characters.

% requires 2 char per byte so from 20 bytes to 40 characters in hexa

% %H in fmt and seprint to get a string

<<pragmas varargck>>=
#pragma varargck type "H" Hash
@
<<[[gitinit()]] fmtinstall calls>>=
fmtinstall('H', Hfmt);
@
<<function [[Hfmt]]>>=
int
Hfmt(Fmt *fmt)
{
    Hash h;
    int i, n, l;
    char c0, c1;

    l = 0;
    h = va_arg(fmt->args, Hash);
    for(i = 0; i < sizeof h.h; i++){
        n = (h.h[i] >> 4) & 0xf;
        c0 = (n >= 10) ? n-10 + 'a' : n + '0';
        n = h.h[i] & 0xf;
        c1 = (n >= 10) ? n-10 + 'a' : n + '0';
        l += fmtprint(fmt, "%c%c", c0, c1);
    }
    return l;
}
@

\subsection{Conversion functions}

<<function [[hparse]]>>=
errorneg1
hparse(Hash *h/*OUT*/, char *b)
{
    int i, c0, c1;

    for(i = 0; i < nelem(h->h); i++){
        if((c0 = charval(b[2*i+0])) == ERROR_NEG1)
            return ERROR_NEG1;
        if((c1 = charval(b[2*i+1])) == ERROR_NEG1)
            return ERROR_NEG1;
        h->h[i] = (c0 << 4) | c1;
    }
    return OK_0;
}
@
% >>

<<function [[charval]]>>=
int
charval(int c)
{
    if(c >= '0' && c <= '9')
        return c - '0';
    if(c >= 'a' && c <= 'f')
        return c - 'a' + 10;
    if(c >= 'A' && c <= 'F')
        return c - 'A' + 10;
    // else
    werrstr("invalid hex char");
    return ERROR_NEG1;
}
@


<<macro [[GETBE32]]>>=
#define GETBE32(b)\
        ((((b)[0] & 0xFFul) << 24) | \
         (((b)[1] & 0xFFul) << 16) | \
         (((b)[2] & 0xFFul) <<  8) | \
         (((b)[3] & 0xFFul) <<  0))
@
% >>
% a hash of a hash :)

