@
<<[[main()]](conf.c) show config entry for [[argv[i]]]>>=
// syntax is git/fs <sect>.<key> or just <key>
p = strchr(argv[i], '.');
if(p == nil){
    s = nil;
    p = argv[i];
}else{
    *p = '\0';
