<<function [[emalloc]]>>=
void *
emalloc(ulong n)
{
    void *v;
    
    v = mallocz(n, 1);
    if(v == nil)
        sysfatal("malloc: %r");
    setmalloctag(v, getcallerpc(&n));
    return v;
}
@

<<function [[eamalloc]]>>=
void *
eamalloc(ulong n, ulong sz)
{
    uvlong na;
    void *v;

    na = (uvlong)n*(uvlong)sz;
    if(na >= (1ULL<<30))
        sysfatal("alloc: overflow");
    v = mallocz(na, 1);
    if(v == nil)
        sysfatal("malloc: %r");
    setmalloctag(v, getcallerpc(&n));
    return v;
}
@
% >>

