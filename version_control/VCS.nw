<<function [[resolveref]]>>=
/// main(walk.c -b) | main(save.c -p) | (main(log.c) -> showcommits) -> <>
errorneg1
resolveref(Hash *r/*OUT*/, char *ref)
{
    Eval ev;

    if(evalexpr(&ev, ref) == ERROR_NEG1){
        free(ev.stk);
        return ERROR_NEG1;
    }
    if(ev.nstk != 1){
        werrstr("ambiguous ref expr");
        free(ev.stk);
        return ERROR_NEG1;
    }
    *r = ev.stk[0]->hash;
    free(ev.stk);
    return OK_0;
}
