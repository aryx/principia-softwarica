    (((c) != '\n') && isspace(c))
@

% isspace in libc.h? isspacerune is, but isspace?


<<function [[strip]]>>=
char *
strip(char *s)
{
    char *e;

    while(isspace(*s))
        s++;
    e = s + strlen(s);
    while(e > s && isspace(*--e))
        *e = 0;
    return s;
}
@

<<function [[nextline (git9/pack.c)]]>>=
static void
nextline(char **str, int *nstr)
{
    char *s;

    if((s = strchr(*str, '\n')) != nil){
        *nstr -= s - *str + 1;
        *str = s + 1;
    }
}
@


