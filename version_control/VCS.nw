\subsection{[[readloose()]] and [[Cloaded]]}

<<function [[readloose]]>>=
/// readobject -> readidxobject | ??? -> <>
static errorneg1
readloose(Biobuf *f, Object *o, int flag)
{
    struct { char *tag; int type; } *p, types[] = {
        {"blob", GBlob},
        {"tree", GTree},
        {"commit", GCommit},
        <<[[readloose()]] local [[types]] other elements>>
        {nil},
    };
    char *d, *s, *e, *ed;
    vlong sz, n;
    int l;

    n = decompress(&d, f, nil);
    <<[[readloose()]] sanity check [[n]]>>

    s = d;
    ed = d + n;
    o->type = GNone;
    for(p = types; p->tag; p++){
        l = strlen(p->tag);
        if(strncmp(s, p->tag, l) == 0){
            s += l;
            o->type = p->type;
            while(s != ed && !isspace(*s))
                s++;
            break;
        }
    }
    if(o->type == GNone){
        free(o->data);
        return ERROR_NEG1;
    }
    // else
    sz = strtol(s, &e, 0);
    <<[[readloose()]] sanity check [[e]]>>
    <<[[readloose()]] sanity check [[sz]]>>
    o->all = d;
    o->data = e;
    o->size = sz;
    o->flag |= Cloaded|flag;
    return OK_0;

error:
    free(d);
    return ERROR_NEG1;
}
@

