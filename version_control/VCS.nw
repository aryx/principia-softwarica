<<function [[main (git9/log.c)]]>>=
void
main(int argc, char **argv)
{
    char path[1024], repo[1024], *p, *r;
    int i, nrel, nrepo;

    ARGBEGIN{
    case 'e':
        queryexpr = EARGF(usage());
        break;
    case 'c':
        commitid = EARGF(usage());
        break;
    case 's':
        shortlog++;
        break;
    case 'n':
        msgcount = atoi(EARGF(usage()));
        break;
    default:
        usage();
        break;
    }ARGEND;

    gitinit(repo, sizeof(repo), &nrel);

    nrepo = strlen(repo);
    if(argc != 0){
        if(getwd(path, sizeof(path)) == nil)
            sysfatal("getwd: %r");
        if(strncmp(path, repo, nrepo) != 0)
            sysfatal("path shifted??");
        p = path + nrepo;
        pathfilt = emalloc(sizeof(Pfilt));
        for(i = 0; i < argc; i++){
            if(*argv[i] == '/'){
                if(strncmp(argv[i], repo, nrepo) != 0)
                    continue;
                r = smprint("./%s", argv[i]+nrepo);
            }else
                r = smprint("./%s/%s", p, argv[i]);
            cleanname(r);
            filteradd(pathfilt, r);
            free(r);
        }
    }
    if(chdir(repo) == -1)
        sysfatal("chdir: %r");

    //9front-only
    //tmfmtinstall();
    out = Bfdopen(1, OWRITE);
    if(queryexpr != nil)
        showquery(queryexpr);
    else
        showcommits(commitid);
    Bterm(out);
    exits(nil);
}
@


