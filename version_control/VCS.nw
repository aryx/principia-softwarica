    char    *ref;
    Hash    ours;
    Hash    theirs;
};
@

<<function [[findkey]]>>=
int
findkey(Map *m, int nm, char *ref)
{
    int i;
    for(i = 0; i < nm; i++)
        if(strcmp(m[i].ref, ref) == 0)
            return i;
