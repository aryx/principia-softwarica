<<function [[scanword]]>>=
/*
 * Scans for non-empty word, copying it into buf.
 * Strips off word, leading, and trailing space
 * from input.
 * 
 * Returns -1 on empty string or error, leaving
 * input unmodified.
 */
static errorneg1
scanword(char **str, int *nstr, char *buf, int nbuf)
{
    char *p;
    int n;
    errorneg1 r;

    r = ERROR_NEG1;
    p = *str;
    n = *nstr;
    while(n && isblank(*p)){
        n--;
        p++;
    }

    for(; n && *p && !isspace(*p); p++, n--){
        r = OK_0;
        *buf++ = *p;
        nbuf--;
        if(nbuf == 0)
            return ERROR_NEG1;
    }
    while(n && isblank(*p)){
        n--;
        p++;
    }
    *buf = '\0';
    *str = p;
    *nstr = n;
    return r;
}
@


<<function [[endswith]]>>=
bool
endswith(char *n, char *s)
{
    int nn, ns;

    nn = strlen(n);
    ns = strlen(s);
    return nn > ns && strcmp(n + nn - ns, s) == 0;
}
@

