<<function [[refreshpacks]]>>=
/// readidxobject | expandprefix -> <> -> loadpack
static void
refreshpacks(void)
{
    Packf *pf, *new;
    int i, n, l;
    int nnew;
    Dir *d;

    n = slurpdir(".git/objects/pack", &d);
    <<[[refreshpacks()]] sanity check [[n]]>>
    nnew = 0;
    new = eamalloc(n, sizeof(Packf));

    for(i = 0; i < n; i++){
        l = strlen(d[i].name);
        if(l > 4 && strcmp(d[i].name + l - 4, ".idx") != 0)
            continue;
        d[i].name[l - 4] = '\0';
        if(loadpack(&new[nnew], d[i].name) != -1)
            nnew++;
    }
    <<[[refreshpacks()]] free previous [[packf]]>>
    packf = new;
    npackf = nnew;
    free(d);
}
@

<<[[refreshpacks()]] free previous [[packf]]>>=
// free the previously loaded one if any
for(i = 0; i < npackf; i++){
    pf = &packf[i];
    free(pf->idx);
    if(pf->pack != nil)
        Bterm(pf->pack);
}
free(packf);
@

<<[[refreshpacks()]] sanity check [[n]]>>=
if(n == ERROR_NEG1)
    return;
@

%\subsection{Loading a pack}

<<function [[loadpack]]>>=
/// refreshpacks -> <>
static errorneg1
loadpack(Packf *pf, char *name)
{
    char buf[128];
    int i;
    fdt ifd;
    Dir *d;

    memset(pf, 0, sizeof(Packf));
    snprint(buf, sizeof(buf), ".git/objects/pack/%s.idx", name);
    snprint(pf->path, sizeof(pf->path), ".git/objects/pack/%s.pack", name);
    <<[[loadpack()]] steal loaded info from previous opened pack if same>>
    // else
    ifd = open(buf, OREAD);
    <<[[loadpack()]] sanity check [[ifd]]>>
    d = dirfstat(ifd);
    <<[[loadpack()]] sanity check [[d]]>>
    pf->nidx = d->length;
    pf->idx = emalloc(pf->nidx);
    if(readn(ifd, pf->idx, pf->nidx) != pf->nidx){
        close(ifd);
        free(pf->idx);
        free(d);
        return ERROR_NEG1;
    }
    close(ifd);
    free(d);
    return OK_0;
}
@


<<[[loadpack()]] sanity check [[ifd]]>>=
if(ifd == ERROR_NEG1)
    return ERROR_NEG1;
@
<<[[loadpack()]] sanity check [[d]]>>=
if(d == nil){
    close(ifd);
    return ERROR_NEG1;
}
@
<<[[loadpack()]] steal loaded info from previous opened pack if same>>=
/*
 * if we already have the pack open, just
 * steal the loaded info
 */
for(i = 0; i < npackf; i++){
    if(strcmp(pf->path, packf[i].path) == 0){
        pf->idx = packf[i].idx;
        pf->nidx = packf[i].nidx;
        pf->pack = packf[i].pack;
        packf[i].idx = nil;
        packf[i].pack = nil;
        return OK_0;
    }
}
@


\subsection{Opening a pack}

<<[[Pack]] extra fields>>=
// openpack()/closepack() reference counting
int refs;
@

<<function [[openpack]]>>=
static Biobuf*
openpack(Packf *pf)
{
    <<[[openpack()]] locals>>

    if(pf->pack != nil){
        pf->refs++;
        return pf->pack;
    }
    // else
    <<[[openpack()]] if too many opened packs>>
    pf->refs++;
    pf->pack = Bopen(pf->path, OREAD);
    return pf->pack;
}
@
% >>

<<function [[closepack]]>>=
static void
closepack(Packf *pf)
{
    pf->refs--;
}
@



<<[[openpack()]] locals>>=
vlong t;
int i, best;
@


<<[[Pack]] extra fields>>=
// for LRU eviction of opened packs
vlong   opentm;
@


<<global [[openpacks]]>>=
int openpacks;
@

<<constant [[Npackcache]]>>=
Npackcache  = 32,
@

<<[[openpack()]] if too many opened packs>>=
/*
 * If we've got more packs open
 * than we want cached, try to
 * free up the oldest ones.
 *
 * If we can't find a slot, this
 * isn't fatal; we can just use
 * another fd.
 */
while(openpacks >= Npackcache){
    t = (1ull<<62)-1;
    best = -1;
    for(i = 0; i < npackf; i++){
        if(&packf[i] != pf
        && packf[i].pack != nil
        && packf[i].opentm < t
        && packf[i].refs == 0){
            t = packf[i].opentm;
            best = i;
        }
    }
    if(best == -1){
        fprint(STDERR, "no available pack slots\n");
        break;
    }
    Bterm(packf[best].pack);
    packf[best].pack = nil;
    openpacks--;
}
openpacks++;
pf->opentm = nsec();
@
% >>

\subsection{Reading a packed object}

% assumes seek at the right offset before (using index)

% similar to readloose(), but for packed object

<<function [[readpacked]]>>=
/// readidxobject -> <>
static errorneg1
readpacked(Biobuf *f, Object *o, int flag)
{
    int c, s, n, t;
    vlong l, p;
    Buf b;

    p = Boffset(f);
    c = Bgetc(f);
    <<[[readpacked()]] sanity check [[c]]>>
    l = c & 0xf;
    s = 4;
    t = (c >> 4) & 0x7;
    <<[[readpacked()]] sanity check [[t]]>>
    while(c & 0x80){
        if((c = Bgetc(f)) == -1)
            return ERROR_NEG1;
        l |= (vlong)(c & 0x7f) << s;
        s += 7;
    }
    <<[[readpacked()]] sanity check [[l]]>>
    switch(t){
    <<[[readpacked()]] switch object type [[t]] cases>>
    default:
        werrstr("invalid object at %lld", Boffset(f));
        return ERROR_NEG1;
    }
    o->flag |= Cloaded|flag;
    return OK_0;
}
@


<<[[readpacked()]] sanity check [[c]]>>=
if(c == -1)
    return ERROR_NEG1;
@
<<[[readpacked()]] sanity check [[t]]>>=
if(!t){
    werrstr("unknown type for byte %x at %lld", c, p);
    return ERROR_NEG1;
}
@
<<[[readpacked()]] sanity check [[l]]>>=
if(l >= (1ULL << 32)){
    werrstr("object too big");
    return ERROR_NEG1;
}
@
% >>

<<[[readpacked()]] switch object type [[t]] cases>>=
case GCommit:
case GTree:
case GTag:
case GBlob:
    b.sz = 64 + l;
    b.data = emalloc(b.sz);
    n = snprint(b.data, 64, "%T %lld", t, l) + 1;
    b.len = n;
    if(bdecompress(&b, f, nil) == ERROR_NEG1){
        free(b.data);
        return ERROR_NEG1;
    }
    o->len = Boffset(f) - o->off;
    o->type = t;
    o->all = b.data;
    o->data = b.data + n;
    o->size = b.len - n;
    break;
@

