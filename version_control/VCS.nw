<<function [[enqueueparent]]>>=
/// fetchpack -> <>
void
enqueueparent(Objq *q, Object *o)
{
    Object *p;
    int i;

    if(o->type != GCommit)
        return;
    for(i = 0; i < o->commit->nparent; i++){
        if((p = readobject(o->commit->parent[i])) == nil)
            continue;
        qput(q, p, 0);
        unref(p);
    }
}
