<<function [[parsecmd]]>>=
char*
parsecmd(char *buf, char *cmd, int ncmd)
{
    int i;
    char *p;

    for(p = buf, i = 0; *p && i < ncmd - 1; i++, p++){
        if(*p == ' ' || *p == '\t'){
            cmd[i] = 0;
            break;
        }
        cmd[i] = *p;
    }
    while(*p == ' ' || *p == '\t')
        p++;
    return p;
}
