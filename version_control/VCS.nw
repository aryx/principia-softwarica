<<function [[findslashes]]>>=
void
findslashes(char *path)
{
    char *p;

    p = cleanname(path);
    if(p[0] == '.'){
        if(p[1] == '\0')
            return;
        else if(p[1] == '.' && (p[2] == '/' || p[2] == '\0'))
            sysfatal("relative path escapes git root");
    }
    
    snprint(relapath, sizeof relapath, "%s/", p);
    p = relapath;
    if(*p == '/')
        p++;

    for(; *p; p++)
        if(*p == '/')
            nslash++;
}
