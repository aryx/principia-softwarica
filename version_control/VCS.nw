BEGIN{
        src=ENVIRON["src"];
        dst=ENVIRON["dst"];
}
{
        if(!done)
                print "git/branch -nb "dst" rebase.wip";
        c=$1; $1="";
        print "git/export "c" | git/import '$nflag'#"$0;
        done=1
}
END{
        if(!done)
                print "git/branch -nb "dst" ";
        else{
                print "git/branch -nb rebase.wip "src
                print "git/branch -r rebase.wip";
        }
}' 

