}

showed=()
mntgen /mnt/scratch
bind $branch/tree/ /mnt/scratch/a
bind . /mnt/scratch/b
for(f in `$nl{git/walk $bparam -c -f$filt $cparam $files}){
        if(~ $#showed 0){
                echo diff `{git/query $commit} uncommitted
                showed=1
        }
        cd /mnt/scratch
        a=a/$f
        b=b/$f
        if(! test -f a/$f)
                a=/dev/null
        if(! test -f b/$f)
                b=/dev/null
        diff -u $a $b
}
exit ''
