<<function [[show (git9/query.c)]]>>=
void
show(Dirent *e, char m)
{
    if(e->mode & DMDIR)
        showdir(e->h, e->name, m);
    else
        print("%c %P%s\n", m, e->name);
}
@


<<function [[showdir]]>>=
/// show -> <>
void
showdir(Hash dh, char *dname, char m)
{
    Dirent *p, *e;
    Object *d;

    path[npath++] = dname;
    if((d = readobject(dh)) == nil)
        sysfatal("bad hash %H", dh);
    assert(d->type == GTree);
    p = d->tree->ent;
    e = p + d->tree->nent;
    for(; p != e; p++){
        if(p->ismod)
            continue;
        if(p->mode & DMDIR)
            showdir(p->h, p->name, m);
        else
            print("%c %P%s\n", m, p->name);
    }
    print("%c %P\n", m);
    unref(d);
    npath--;
}
@


