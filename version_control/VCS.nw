\subsection{[[gitup()]] part 1}

<<fn [[gitup]](common.rc)>>=
fn gitup{
        gitroot=`$nl{git/conf -r >[2]/dev/null}
        if(~ $#gitroot 0)
                die 'not a git repository'
        gitrel=`$nl{pwd | drop $gitroot | sed 's@^/@@'}
        if(~ $#gitrel 0)
                gitrel='.'
        if(! cd $gitroot)
                die cd $gitroot: no repo there

        <<[[gitup()]](common.rc) start git/fs>>
}
@
%$

<<global [[nl]](common.rc)>>=
nl='
'
@

% `skip{} is rc extension to use scoped ifs to split output of command
% default is space, tab, newline; here just newline
% useful for? filenames with space in it?


<<[[add.rc]] set [[$paths]] derived from [[$*]]>>=
paths=`$nl{cleanname -d $gitrel $* | drop $gitroot}
@
%$

\subsection{[[drop()]]}

<<fn [[drop]](common.rc)>>=
fn drop {
        awk '
        BEGIN{ARGC=0}
        {
                if(index($0, ARGV[1]) == 1)
                        $0=substr($0, length(ARGV[1])+1)
                print
        }
        ' $*
}
@

