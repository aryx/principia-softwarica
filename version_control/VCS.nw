<<function [[showquery]]>>=
static void
showquery(char *q)
{
    Object *o;
    Hash *h;
    int n, i;

    n = resolverefs(&h, q);
    if(n == -1)
        sysfatal("resolve: %r");

    for(i = 0; i < n && (msgcount == -1 || msgcount > 0); i++){
        o = readobject(h[i]);
        if(o == nil)
            sysfatal("read %H: %r", h[i]);
        if(matchesfilter(o)){
            show(o);
            if(msgcount != -1)
                msgcount--;
        }
        unref(o);
    }
    exits(nil);
}
