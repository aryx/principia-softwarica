<<[[merge.rc]] command line processing>>

if(! ~ $#* 1)
        exec auxrc/usage

theirs=`{git/query $1}
ours=`{git/query HEAD}
base=`{git/query $theirs ^ ' ' ^ $ours ^ '@'}

if(~ $base $theirs)
        die 'nothing to merge, doofus'
