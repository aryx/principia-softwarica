\section{Commit expression evaluator}

<<function [[evalexpr]]>>=
errorneg1
evalexpr(Eval *ev, char *ref)
{
    memset(ev, 0, sizeof(*ev));
    ev->str = ref;
    ev->p = ref;

    while(true){
        if(evalpostfix(ev) == ERROR_NEG1)
            return ERROR_NEG1;
        if(ev->p[0] == '\0')
            return OK_0;
        else if(take(ev, ":") || take(ev, "..")){
            if(evalpostfix(ev) == ERROR_NEG1)
                return ERROR_NEG1;
            if(ev->p[0] != '\0'){
                werrstr("junk at end of expression");
                return ERROR_NEG1;
            }
            return range(ev);
        }
    }
}
@

<<function [[take]]>>=
bool
take(Eval *ev, char *m)
{
    int l;

    l = strlen(m);
    if(strncmp(ev->p, m, l) != 0)
        return false;
    ev->p += l;
    return true;
}
@

\subsection{[[evalpostfix()]]}

% name -> hash -> object

<<function [[evalpostfix]]>>=
errorneg1
evalpostfix(Eval *ev)
{
    char name[256];
    Hash h;
    Object *o;
    errorneg1 ret;

    eatspace(ev);
    if(!word(ev, name, sizeof(name))){
        werrstr("expected name in expression");
        return ERROR_NEG1;
    }
    ret = readref(&h, name);
    <<[[evalpostfix()]] sanity check [[ret]] invalid ref>>
    <<[[evalpostfix()]] if [[Zhash]]>>
    else {
        o = readobject(h);
        <<[[evalpostfix()]] sanity check [[o]] invalid ref>>
    }
    push(ev, o);

    while(true){
        eatspace(ev);
        switch(ev->p[0]){
        case '^':
        case '~':
            ev->p++;
            ret = parent(ev);
            <<[[evalpostfix()]] sanity check [[ret]]>>
            break;
        case '@':
            ev->p++;
            ret = lca(ev);
            <<[[evalpostfix()]] sanity check [[ret]]>>
            break;
        default:
            goto done;
            break;
        }   
    }
done:
    return OK_0;
}
@
