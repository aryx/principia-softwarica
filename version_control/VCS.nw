<<function [[showconf]]>>=
static int
showconf(char *cfg, char *sect, char *key)
{
    char *ln, *p;
    Biobuf *f;
    int foundsect, nsect, nkey, found;

    if((f = Bopen(cfg, OREAD)) == nil)
        return 0;

    found = 0;
    nsect = sect ? strlen(sect) : 0;
    nkey = strlen(key);
    foundsect = (sect == nil);
    while((ln = Brdstr(f, '\n', 1)) != nil){
        p = strip(ln);
        if(*p == '[' && sect){
            foundsect = strncmp(sect, ln, nsect) == 0;
        }else if(foundsect && strncmp(p, key, nkey) == 0){
            p = strip(p + nkey);
            if(*p != '=')
                continue;
            p = strip(p + 1);
            print("%s\n", p);
            found = 1;
            if(!showall){
                free(ln);
                goto done;
            }
        }
        free(ln);
    }
done:
    return found;
}
@


