<<function [[readref]]>>=
static Object *
readref(char *pathstr)
{
    fdt f;
    char buf[128], path[128], *p, *e;
    Hash h;
    int n;

    snprint(path, sizeof(path), "%s", pathstr);
    while(true){
        if((f = open(path, OREAD)) == ERROR_NEG1)
            return nil;
        if((n = readn(f, buf, sizeof(buf) - 1)) == ERROR_NEG1)
            return nil;
        close(f);
        buf[n] = '\0';
        if(strncmp(buf, "ref:", 4) !=  0)
            break;

        // else
        p = buf + 4;
        while(isspace(*p))
            p++;
        if((e = strchr(p, '\n')) != nil)
            *e = 0;
        snprint(path, sizeof(path), ".git/%s", p);
    }

    if(hparse(&h, buf) == ERROR_NEG1)
        return nil;

    return readobject(h);
}
@



