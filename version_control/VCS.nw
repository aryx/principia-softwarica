\section{[[resolverefs()]]}

%    n = resolverefs(&h, query);

<<function [[resolverefs]]>>=
// main(get.c) -> <>
errorneg1
resolverefs(Hash **r/*OUT*/, char *ref)
{
    Eval ev;
    Hash *h;
    int i;
    errorneg1 res;

    res = evalexpr(&ev, ref);

    if(res == ERROR_NEG1){
        free(ev.stk);
        return ERROR_NEG1;
    }
    h = eamalloc(ev.nstk, sizeof(Hash));
    for(i = 0; i < ev.nstk; i++)
        h[i] = ev.stk[i]->hash;
    *r = h;
    free(ev.stk);
    return ev.nstk;
}
