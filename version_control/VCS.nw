int
slurpdir(char *p, Dir **d)
{
    int r;
    fdt f;

    f = open(p, OREAD);
    if(f == ERROR_NEG1)
        return ERROR_NEG1;
    r = dirreadall(f, d);
    close(f);
    return r;
}   
