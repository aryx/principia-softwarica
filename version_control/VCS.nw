%git9: in theory should have SHA1 of blob/dir but git9 differs

<<function [[idxcmp]]>>=
int
idxcmp(void *pa, void *pb)
{
    Idxent *a, *b;
    int c;

    a = (Idxent*)pa;
    b = (Idxent*)pb;
    if((c = strcmp(a->path, b->path)) != 0)
        return c;
    assert(a->order != b->order);
    return a->order < b->order ? -1 : 1;
}
@

