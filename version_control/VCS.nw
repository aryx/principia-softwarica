\subsection{[[gitup()]] part 1}

<<fn [[gitup]](common.rc)>>=
fn gitup{
        gitroot=`$nl{git/conf -r >[2]/dev/null}
        if(~ $#gitroot 0)
                die 'not a git repository'
        gitrel=`$nl{pwd | drop $gitroot | sed 's@^/@@'}
        if(~ $#gitrel 0)
                gitrel='.'
        if(! cd $gitroot)
                die cd $gitroot: no repo there

        <<[[gitup()]](common.rc) start git/fs>>
}
@
%$

<<global [[nl]](common.rc)>>=
nl='
'
