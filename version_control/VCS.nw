<<function [[emptydir]]>>=
Object*
emptydir(void)
{
    static Object *e;

    if(e != nil)
        return ref(e);
    e = emalloc(sizeof(Object));
    e->type = GTree;
    e->tree = emalloc(sizeof(Tinfo));
    e->tree->ent = nil;
    e->tree->nent = 0;
    e->flag |= Cloaded|Cparsed;
    e->hash = Zhash;
    e->off = -1;
    ref(e);
    cache(e);
    return e;
}
@

