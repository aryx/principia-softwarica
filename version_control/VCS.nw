\subsection{[[word()]]}
%not in string utilities appendix! word semantic specific to git like '..' below
% and also take Eval as parameter

<<function [[word]]>>=
bool
word(Eval *ev, char *b, int nb)
{
    char *p, *e;
    int n;

    p = ev->p;
    for(e = p; isword(*e) && strncmp(e, "..", 2) != 0; e++)
        /* nothing */;
    /* 1 for nul terminator */
    n = e - p + 1;
    if(n >= nb)
        n = nb;
    snprint(b, n, "%s", p);
    ev->p = e;
    return n > 0;
}
@

<<function [[isword]]>>=
bool
isword(char e)
{
    return isalnum(e) || e == '/' || e == '-' || e == '_' || e == '.';
}
