<<function [[readctl]]>>=
static char *
readctl(Req *r)
{
    fdt fd;
    int n;
    char data[1024], ref[512];
    char *s, *e;

    fd = open(".git/HEAD", OREAD);
    <<[[readctl()]] sanity check [[fd]]>>
    /* empty HEAD is invalid */
    n = readn(fd, ref, sizeof(ref) - 1);
    <<[[readctl()]] sanity check [[n]]>>
    close(fd);

    s = ref;
    ref[n] = '\0';
    if(strncmp(s, "ref:", 4) == 0)
        s += 4;
    while(*s == ' ' || *s == '\t')
        s++;
    if((e = strchr(s, '\n')) != nil)
        *e = '\0';
    if(strstr(s, "refs/") == s)
        s += strlen("refs/");

    snprint(data, sizeof(data), "branch %s\nrepo %s\n", s, gitdir);
    readstr(r, data);
    return nil;
}
@

<<[[readctl()]] sanity check [[fd]]>>=
if(fd == ERROR_NEG1)
    return Erepo;
@
<<[[readctl()]] sanity check [[n]]>>=
if(n <= 0)
    return Erepo;
