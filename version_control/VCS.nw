static errorneg1
matchpfx(Hash *h, char *ref)
{
    int i, c;
    Hash pfx;
    char *p;

    memset(&pfx, 0, sizeof(Hash));
    for(i = 0, p = ref; *p; p++, i++){
        if((c = charval(*p)) == -1)
            return ERROR_NEG1;
        pfx.h[i/2] |= c;
        if((i & 1) == 0)
            pfx.h[i/2] <<= 4;
    }
    return expandprefix(h, pfx, i*4);
}
