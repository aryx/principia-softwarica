\subsection{[[commit.rc]]}

<<git9/commit.rc>>=
#!/bin/rc -e
rfork ne
. /lib/git/common.rc

<<fn [[findbranch]](commit.rc)>>
<<fn [[cleanmsg]](commit.rc)>>
<<fn [[editmsg]](commit.rc)>>
<<fn [[parents]](commit.rc)>>
<<fn [[commit]](commit.rc)>>
<<fn [[update]](commit.rc)>>
<<fn [[filterdiff]](commit.rc)>>
<<fn [[pickhunks]](commit.rc)>>
<<fn [[apply]](commit.rc)>>

gitup

<<[[commit.rc]] command line processing>>

<<[[commit.rc]] create [[$msgfile.tmp]]>>

files=()
<<[[commit.rc]] adjust [[$files]] if merge parents>>
if(! ~ $#* 0)
        files=($files `$nl{git/walk -fRMA -c `$nl{cleanname -d $gitrel $*}})
if(~ $status '' || ~ $#files 0 && ! test -f .git/merge-parents && ~ $#revise 0)
        die 'nothing to commit'
<<[[commit.rc]] if [[$partial]]>>

 @{
        flag e +

        # prepare the commit
        whoami
        findbranch
        parents
        editmsg

        commit
        update
} || die 'could not commit:' $status
exit ''
@

% flag e +  actually disable the flag, so no more exit on error inside
% subshell because want better error message with the die after


\subsection{[[whoami()]]}

<<fn [[whoami]](common.rc)>>=
fn whoami{
        name=`$nl{git/conf user.name}
        email=`$nl{git/conf user.email}
        <<[[whomai()]](common.rc) if adm keys>>
        if(~ $name '')
                name=$user
        if(~ $email '')
                email=$user@$sysname
        status=''
}
@


<<[[whomai()]](common.rc) if adm keys>>=
if(test -f /adm/keys.who){
        if(~ $name '')
                name=`$nl{awk -F'|' '$1=="'$user'" {x=$3} END{print x}' </adm/keys.who}
        if(~ $email '')
                email=`$nl{awk -F'|' '$1=="'$user'" {x=$5} END{print x}' </adm/keys.who}
}
@

\subsection{[[gitup()]] part 2}

<<[[gitup()]](common.rc) start git/fs>>=
gitfs=$gitroot/.git/fs
startfs=()
mkdir -p $gitfs
if(! test -e $gitfs/ctl)
        startfs=true
if(! grep -s '^repo '$gitroot'$' $gitfs/ctl >[2]/dev/null)
        startfs=true
if(~ $#startfs 1)
        git/fs >[1=2]
if not
        status=''
@
%$

% not used for git/add, but will be used later

