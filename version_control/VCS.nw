    default:
        usage();
    }ARGEND;

    if(argc != 3)
        usage();

    Binit(&stdout, 1, OWRITE);
    memset(&l, 0, sizeof(l));
    memset(&r, 0, sizeof(r));

    calcdiff(&l, argv[1], argv[1], argv[0], argv[0]);
    calcdiff(&r, argv[1], argv[1], argv[2], argv[2]);

    if(l.binary || r.binary)
        sysfatal("cannot merge binaries");

    x = merge(&l, &r);

    freediff(&l);
    freediff(&r);
    exits(x);
}
