\section{Murmurhash2}

% used for?

<<function [[murmurhash2]]>>=
/// writepack -> readmeta -> loadcommit -> loadtree -> <>
u64int
murmurhash2(void *pp, usize n)
{
    u32int m = 0x5bd1e995;
    u32int r = 24;
    u32int h, k;
    uchar *w, *e;
    
    h = Seed ^ n;
    e = pp;
    e += n & -4;
    for (w = pp; w != e; w += 4) {
        k = (u32int)w[0] | (u32int)w[1] << 8 | (u32int)w[2] << 16 | (u32int)w[3] << 24;
        k *= m;
        k ^= k >> r;
        k *= m;

        h *= m;
        h ^= k;
    }

    switch (n & 0x3) {
    case 3: h ^= w[2] << 16;
    case 2: h ^= w[1] << 8;
    case 1: h ^= w[0] << 0;
        h *= m;
    }

    h ^= h >> 13;
    h *= m;
    h ^= h >> 15;

    return h;
}
@


