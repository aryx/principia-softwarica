fmtinstall('P', Pfmt);
@
<<function [[Pfmt]]>>=
int
Pfmt(Fmt *f)
{
    int i, n;

    n = 0;
    for(i = 0; i < npath; i++)
        n += fmtprint(f, "%s/", path[i]);
    return n;
}
@
