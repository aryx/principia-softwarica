\section{Initializing a new repository: [[git init]]}

% git/init -u -b xxx

<<git9/init.rc>>=
#!/bin/rc -e
rfork ne
. /lib/git/common.rc

flagfmt='u:upstream upstream,b:branch branch'; args='name'
eval `{auxrc/getflags $*} || exec auxrc/usage

dir=$1
if(~ $#dir 0)
        dir=.
if(~ $#branch 0)
        branch=master
if(test -e $dir/.git)
        die $dir/.git already exists
<<[[init.rc]] set [[$name]] derived from [[$dir]]>>
<<[[init.rc]] check [[$upstream]] flag>>

mkdir -p $dir/.git/refs/^(heads remotes)
mkdir -p $dir/.git/^(fs objects)
>$dir/.git/config {
        echo '[core]'
        echo '  repositoryformatversion = p9.0'
        <<[[init.rc]] set origin in [[.git/config]]>>
        echo '[branch "'$branch'"]'
        echo '  remote = origin'
}
>$dir/.git/INDEX9
>$dir/.git/HEAD {
        echo ref: refs/heads/$branch
}
exit ''
@
%old: was branch=front, but more standard to use 'master' (or now 'main' on github)
%old: was `''{auxrc/getflags} but useless skip here I think; ifs is not overriden

%many things:
% - rc -e, die early on error (see \book{Shell})
% - rfork ne, fresh env, fresh namespace (see also \book{Shell})
% - ^ string distribute (kind of map)
% - common.rc, see appendix (for die here)
% - die(), see appendix error management
% - flagmt: auxrc/getflags utility shell functions (=~ getopt)

<<[[init.rc]] set [[$name]] derived from [[$dir]]>>=
name=`{basename `{cleanname -d `{pwd} $dir}}
@
%$
% basename/cleanname utilities, see \book{Utilities}

%note: beauty of rc choice of `{} syntax that can nest!

