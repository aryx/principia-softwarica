        >[1=2] echo 'fast forwarding...'
        echo $theirs > .git/refs/`{git/branch}
        git/revert .
        exit ''
}
echo $ours >> .git/merge-parents
echo $theirs >> .git/merge-parents

merge $ours $base $theirs
echo 'merge complete: remember to commit'
exit ''

@

