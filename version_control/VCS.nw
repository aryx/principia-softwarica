\section{Tracing packets}

<<function [[tracepkt]]>>=
void
tracepkt(int v, char *pfx, char *b, int n)
{
    char *f;
    int o, i;

    if(chattygit < v)
        return;
    o = 0;
    f = emalloc(n*4 + 1);
    for(i = 0; i < n; i++){
        if(isprint(b[i])){
            f[o++] = b[i];
            continue;
        }
        f[o++] = '\\';
        switch(b[i]){
        case '\\':  f[o++] = '\\';  break;
        case '\n':  f[o++] = 'n';   break;
        case '\r':  f[o++] = 'r';   break;
        case '\v':  f[o++] = 'v';   break;
        case '\0':  f[o++] = '0';   break;
        default:
            f[o++] = 'x';
            f[o++] = "0123456789abcdef"[(b[i]>>4)&0xf];
            f[o++] = "0123456789abcdef"[(b[i]>>0)&0xf];
            break;
        }
    }
    f[o] = '\0';
    fprint(STDERR, "%s %04x:\t%s\n", pfx, n, f);
    free(f);
}
@


