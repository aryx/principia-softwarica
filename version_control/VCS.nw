<<[[add.rc]] if [[$remove]] flag>>
<<[[add.rc]] sanity check [[$*]]>>

<<[[add.rc]] set [[$paths]] derived from [[$*]]>>
walk -f ./$paths | grep -v '^(./)?.git/' | \
        sed 's/^/'$s' NOQID 0 /' >> .git/INDEX9
exit ''
@
%$

%gitup explained below
