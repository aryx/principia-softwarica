<<function [[decompress]]>>=
/// readloose | ??? -> <>
errorneg1
decompress(void **p, Biobuf *b, vlong *csz)
{
    Buf d = {.len=0, .data=nil, .sz=0};

    if(bdecompress(&d, b, csz) == ERROR_NEG1){
        free(d.data);
        return ERROR_NEG1;
    }
    *p = d.data;
    return d.len;
}
@

<<struct [[Buf]]>>=
struct Buf {
    int len;
    int sz;
    int off;
    char *data;
};
@

<<function [[bdecompress]]>>=
int
bdecompress(Buf *d, Biobuf *b, vlong *csz)
{
    vlong o;

    o = Boffset(b);
    if(inflatezlib(d, bappend, b, breadc) == -1 || d->data == nil){
        free(d->data);
        return -1;
    }
    if (csz)
        *csz = Boffset(b) - o;
    return d->len;
}
@

<<function [[bappend]]>>=
int
bappend(void *p, void *src, int len)
{
    Buf *b = p;
    char *n;

    while(b->len + len >= b->sz){
        b->sz = b->sz*2 + 64;
        n = realloc(b->data, b->sz);
        if(n == nil)
            return -1;
        b->data = n;
    }
    memmove(b->data + b->len, src, len);
    b->len += len;
    return len;
}
@

<<function [[breadc]]>>=
int
breadc(void *p)
{
    return Bgetc(p);
}
@


