\subsection{[[mergeperm()]]}

<<fn [[mergeperm]](common.rc)>>=
fn mergeperm {
        if(~ $1 /dev/null && cmp $2 $3>/dev/null)
                status=gone
        if not if (~ $3 /dev/null && cmp $1 $2>/dev/null)
                status=gone
        if not {
                mergedperms='-x'
                if(test -x $2){
                        if(test -x $1 -a -x $3)
                                mergedperms='+x'
                }
                if not{
                        if(test -x $1 -o -x $3)
                                mergedperms='+x'
                }
                status=()
        }
}
@

