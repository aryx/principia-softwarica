#!/bin/rc -e
rfork ne
. /lib/git/common.rc

gitup

flagfmt='r:remove'; args='file ...'
eval `''{auxrc/getflags $*} || exec auxrc/usage

s=A
if(~ $remove 1)
        s=R
if(~ $#* 0)
        exec auxrc/usage

paths=`$nl{cleanname -d $gitrel $* | drop $gitroot}
walk -f ./$paths | grep -v '^(./)?.git/' | \
        sed 's/^/'$s' NOQID 0 /' >> .git/INDEX9
exit ''
