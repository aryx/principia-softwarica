<<function [[parseobject]]>>=
void
parseobject(Object *o)
{
    if(o->flag & Cparsed)
        return;
    switch(o->type){
    case GTree: parsetree(o);   break;
    case GCommit:   parsecommit(o); break;
    case GTag:  parsetag(o);    break;
    default:    break;
    }
    o->flag |= Cparsed;
}
