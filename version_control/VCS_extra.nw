<<macro [[GETBE16]]>>=
#define GETBE16(b)\
        ((((b)[0] & 0xFFul) <<  8) | \
         (((b)[1] & 0xFFul) <<  0))
@

<<macro [[GETBE32]]>>=
#define GETBE32(b)\
        ((((b)[0] & 0xFFul) << 24) | \
         (((b)[1] & 0xFFul) << 16) | \
         (((b)[2] & 0xFFul) <<  8) | \
         (((b)[3] & 0xFFul) <<  0))
@

<<macro [[GETBE64]]>>=
#define GETBE64(b)\
        ((((b)[0] & 0xFFull) << 56) | \
         (((b)[1] & 0xFFull) << 48) | \
         (((b)[2] & 0xFFull) << 40) | \
         (((b)[3] & 0xFFull) << 32) | \
         (((b)[4] & 0xFFull) << 24) | \
         (((b)[5] & 0xFFull) << 16) | \
         (((b)[6] & 0xFFull) <<  8) | \
         (((b)[7] & 0xFFull) <<  0))
@

<<macro [[PUTBE16]]>>=
#define PUTBE16(b, n)\
    do{ \
        (b)[0] = (n) >> 8; \
        (b)[1] = (n) >> 0; \
    } while(0)
@

<<macro [[PUTBE32]]>>=
#define PUTBE32(b, n)\
    do{ \
        (b)[0] = (n) >> 24; \
        (b)[1] = (n) >> 16; \
        (b)[2] = (n) >> 8; \
        (b)[3] = (n) >> 0; \
    } while(0)
@

<<macro [[PUTBE64]]>>=
