<<function [[readobject]]>>=
/*
 * Loads and returns a cached object.
 */
Object*
readobject(Hash h)
{
    Object *o;

    if((o = readidxobject(nil, h, 0)) == nil)
        return nil;
    parseobject(o);
    ref(o);
    return o;
}
