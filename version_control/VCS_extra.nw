<<git9/hist.rc>>=
#!/bin/rc
rfork ne

. /lib/git/common.rc
gitup

flagfmt='n:num count'; args='files...'
eval `''{auxrc/getflags $*} || exec auxrc/usage
if(~ $#* 0) exec auxrc/usage

fn dodiff {
        while(t=`{read}){
                h=$t(1)
                o=$gitfs/object/`{git/query $h~}
                c=$gitfs/object/$h
                echo 'Hash:' $h
                echo -n 'Date: '; date `{walk -em $c/msg}
                echo -n 'Author: '; cat $c/author
                echo -n 'Message: '; cat $c/msg
                echo
                for(f in $files){
                        curr=$c/tree/$f
                        prev=$o/tree/$f
                        if(! test -e $curr)
                                curr=/dev/null
                        if(! test -e $prev)
                                prev=/dev/null
                        diff -u $prev $curr
                }
                echo --' '
                echo ⑨
                echo
        }
}

files=`{cleanname -d $gitrel $*}
args=(-s $files)
if(! ~ $#num 0)
        args=(-n $num $args)
git/log $args | dodiff
@
%$

