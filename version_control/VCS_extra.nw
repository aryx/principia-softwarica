<<function [[gitmode]]>>=
int
gitmode(Dirent *e)
{
    if(e->islink)
        return 0120000;
    else if(e->ismod)
        return 0160000;
    else if(e->mode & DMDIR)
        return 0040000;
    else if(e->mode & 0100)
        return 0100755;
    else
        return 0100644;
}
