<<function [[matchcap]]>>=
char *
matchcap(char *s, char *cap, int full)
{
    if(strncmp(s, cap, strlen(cap)) == 0)
        if(!full || strlen(s) == strlen(cap))
            return s + strlen(cap);
    return nil;
}
