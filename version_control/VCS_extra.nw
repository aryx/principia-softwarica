<<function [[finish]](patch.c)>>=
int
finish(int ok)
{
    Fchg *c;
    int i, fd;

    for(i = 0; i < nchanged; i++){
        c = &changed[i];
        if(!ok){
            if(c->tmp != nil && remove(c->tmp) == -1)
                fprint(2, "remove %s: %r\n", c->tmp);
            goto Free;
        }
        if(!dryrun){
            if(strcmp(c->new, "/dev/null") == 0){
                if(remove(c->old) == -1){
                    ok = 0;
                    fprint(2, "remove %s: %r\n", c->old);
                    goto Free;
                }
                goto Print;
            }
            if((fd = open(c->tmp, ORDWR)) == -1){
                ok = 0;
                fprint(2, "open %s: %r\n", c->tmp);
                goto Free;
            }
            if(strcmp(c->old, c->new) == 0 && remove(c->old) == -1
            || rename(fd, c->new) == -1
            || close(fd) == -1){
                ok = 0;
                fprint(2, "cleanup: %r");
            }
        }
Print:
        if(strcmp(c->new, "/dev/null") == 0)
            print("%s\n", c->old);
        else
            print("%s\n", c->new);
Free:
        free(c->tmp);
        free(c->old);
        free(c->new);
    }
    free(changed);
    return ok;
}
