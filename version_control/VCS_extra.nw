    do{ \
        (b)[0] = (n) >> 56; \
        (b)[1] = (n) >> 48; \
        (b)[2] = (n) >> 40; \
        (b)[3] = (n) >> 32; \
        (b)[4] = (n) >> 24; \
        (b)[5] = (n) >> 16; \
        (b)[6] = (n) >> 8; \
        (b)[7] = (n) >> 0; \
    } while(0)
