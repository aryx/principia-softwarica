<<function [[readvint]]>>=
static vlong
readvint(char *p, char *ep, char **pp)
{
    int s, c;
    vlong n;
    
    s = 0;
    n = 0;
    do {
        if(p == ep)
            return -1;
        c = *p++;
        n |= (vlong)(c & 0x7f) << s;
        s += 7;
    } while (c & 0x80 && s < 63);
    *pp = p;
    return n;
}
