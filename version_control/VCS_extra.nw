<<function [[bdecompress]]>>=
int
bdecompress(Buf *d, Biobuf *b, vlong *csz)
{
    vlong o;

    o = Boffset(b);
    if(inflatezlib(d, bappend, b, breadc) == -1 || d->data == nil){
        free(d->data);
        return -1;
    }
    if (csz)
        *csz = Boffset(b) - o;
    return d->len;
}
@

<<function [[decompress]]>>=
int
decompress(void **p, Biobuf *b, vlong *csz)
{
    Buf d = {.len=0, .data=nil, .sz=0};

    if(bdecompress(&d, b, csz) == -1){
        free(d.data);
        return -1;
    }
    *p = d.data;
    return d.len;
}
