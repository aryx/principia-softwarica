<<function [[objectcrc]]>>=
static u32int
objectcrc(Biobuf *f, Object *o)
{
    char buf[8096];
    int n, r;

    o->crc = 0;
    Bseek(f, o->off, 0);
    for(n = o->len; n > 0; n -= r){
        r = Bread(f, buf, n > sizeof(buf) ? sizeof(buf) : n);
        if(r == -1)
            return -1;
        if(r == 0)
            return 0;
        o->crc = crc32(o->crc, buf, r);
    }
    return 0;
}
