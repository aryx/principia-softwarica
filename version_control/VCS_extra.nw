<<function [[slurp]](patch.c)>>=
int
slurp(Fbuf *f, char *path)
{
    int n, i, fd, sz, len, nlines, linesz;
    char *buf;
    int *lines;
    Dir *d;

    if((fd = open(path, OREAD)) == -1){
        fprint(2, "open %s: %r", path);
        return -1;
    }
    if((d = dirfstat(fd)) == nil)
        fail("stat %s: %r", path);
    sz = 8192;
    len = 0;
    buf = emalloc(sz);
    while(1){
        if(len == sz){
            sz *= 2;
            buf = erealloc(buf, sz);
        }
        n = read(fd, buf + len, sz - len);
        if(n == 0)
            break;
        if(n == -1)
            fail("read %s: %r", path);
        len += n;
    }

    nlines = 0;
    linesz = 32;
    lines = emalloc(linesz*sizeof(int));
    lines[nlines++] = 0;
    for(i = 0; i < len; i++){
        if(buf[i] != '\n')
            continue;
        if(nlines+2 == linesz){
            linesz *= 2;
            lines = erealloc(lines, linesz*sizeof(int));
        }
        lines[nlines++] = i+1;
    }
    lines[nlines] = len;
    f->len = len;
    f->buf = buf;
    f->lines = lines;
    f->nlines = nlines;
    f->lastln = 0;
    f->lastfuzz = 0;
    f->mode = d->mode;
    free(d);
    close(fd);
    return 0;
}
