<<function [[clear]]>>=
static void
clear(Object *o)
{
    if(!o)
        return;

    assert(o->refs == 0);
    assert((o->flag & Ccache) == 0);
    assert(o->flag & Cloaded);
    switch(o->type){
    case GCommit:
        if(!o->commit)
            break;
        free(o->commit->parent);
        free(o->commit->author);
        free(o->commit->committer);
        free(o->commit);
        o->commit = nil;
        break;
    case GTree:
        if(!o->tree)
            break;
        free(o->tree->ent);
        free(o->tree);
        o->tree = nil;
        break;
    default:
        break;
    }

    free(o->all);
    o->all = nil;
    o->data = nil;
    o->flag &= ~(Cloaded|Cparsed);
}
@

<<function [[unref]]>>=
void
unref(Object *o)
{
    if(!o)
        return;
    o->refs--;
    if(o->refs == 0)
        clear(o);
}
@

<<function [[ref]]>>=
