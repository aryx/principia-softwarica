<<function [[readline]](diff)>>=
int
readline(Biobuf *bp, char *buf, int nbuf)
{
    int c;
    char *p, *e;

    p = buf;
    e = p + nbuf-1;
    do {
        c = Bgetc(bp);
        if (c < 0) {
            if (p == buf)
                return -1;
            break;
        }
        *p++ = c;
        if (c == '\n')
            break;
    } while (p < e);
    *p = 0;
    if (c != '\n' && c >= 0) {
        do c = Bgetc(bp);
        while (c >= 0 && c != '\n');
    }
    return p - buf;
}
@

<<constant [[HALFLONG]](diff)>>=
#define HALFLONG 16
@

<<macro [[low]](diff)>>=
#define low(x)  (x&((1L<<HALFLONG)-1))
@

<<macro [[high]](diff)>>=
#define high(x) (x>>HALFLONG)
