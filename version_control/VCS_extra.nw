<<function [[bappend]]>>=
int
bappend(void *p, void *src, int len)
{
    Buf *b = p;
    char *n;

    while(b->len + len >= b->sz){
        b->sz = b->sz*2 + 64;
        n = realloc(b->data, b->sz);
        if(n == nil)
            return -1;
        b->data = n;
    }
    memmove(b->data + b->len, src, len);
    b->len += len;
    return len;
}
@

<<function [[breadc]]>>=
int
breadc(void *p)
{
    return Bgetc(p);
}
