# Linux-specific targets

IMG=dosdisk.img
#coupling: if you change IMGSIZE, three things must be kept in sync with the
# number of 512-byte sectors in the image (IMGSIZE in MB * 2048, +1 for the
# prepended bootsector, so end-sector = IMGSIZE*2048 + 1):
#  - kernel/init/user/boot/386/boot.rc  'part dos 1 <end>' line, and
#    kernel/init/user/boot/arm/boot.rc  'part dos 1 <end>' line
#    (then remake the kernel, because boot.rc is embedded in it)
#  - the partition table in MISC/pc/bootsector: part0 nsec must be IMGSIZE*2048
#    (the arm boot no longer reads it since boot.rc hardcodes the partition, but
#    keep it correct for the PC BIOS view and for fdisk). For 512MB that is
#    end-sector 1048577 and nsec 1048576.
# Historically these said 204801 (100MB); once the image grew past 100MB, dossrv
# read past the old 100MB partition end and failed with "sector N, read: 0".
IMGSIZE=512 #in MB

#pad: I need the quote arount the 'xx=yy' below because of rc
# otherwise you will get a syntax error
#mcopy: -s = recursive, -o = ??  -D l = force lowercase filenames ??
disk-pc:V:
	rm -f $IMG
	dd 'if=/dev/zero' 'of=tmp.img' 'bs=1M' 'count='$IMGSIZE
	mkfs.vfat tmp.img
	mcopy -i tmp.img -s -o ROOT/* :: || echo skipped mcopy status
	cat MISC/pc/bootsector tmp.img > $IMG
	rm -f tmp.img

disk-pi:V:
	rm -f $IMG
	dd 'if=/dev/zero' 'of=tmp.img' 'bs=1M' 'count='$IMGSIZE
	mkfs.vfat tmp.img
	mcopy -i tmp.img -s -o ROOT/* :: || echo skipped mcopy status
	mcopy -i tmp.img -s -o MISC/pi/* :: || echo skipped mcopy status
	mcopy -i tmp.img $KERNEL ::
	cat MISC/pc/bootsector tmp.img > $IMG
	rm -f tmp.img


#alt: to mtools, but less portable and harder to use in docker
MNT=MISC/MNT
UID=`id -u`
GID=`id -g`
# the offset is to skip the sector containing the partition table
OPTIONS='offset=512,uid='$UID',gid='$GID
#alt: disk-pc:
#       ...
#	sudo mount dosdisk.img -t vfat $MNT -o $OPTIONS
#	cp -a ROOT/* $MNT/
#	sudo umount $MNT
#alt: disk-pi:
#       ...
#	sudo mount dosdisk.img -t vfat $MNT -o $OPTIONS
#	cp -a ROOT/* $MNT/
#	cp -a MISC/pi/* $MNT/
#	cp -a $KERNEL $MNT/
#	sudo umount $MNT

disksrc:V:
	sudo mount dosdisk.img -t vfat $MNT -o $OPTIONS
	rm -rf $MNT/*
	cp -a ROOT/* $MNT/
	# not dosdisk.img!
	cp -a [a-ce-z]* database debuggers $MNT/src || echo some errors are ok 
	# symlinks not supported on vfat
	cp include/ALL/* $MNT/src/include/ALL/ || echo some errors are ok 
	cp -a ROOT $MNT/src/
	sudo umount $MNT

mount:V:
	sudo mount dosdisk.img -t vfat $MNT -o $OPTIONS
umount:V:
	sudo umount $MNT
