static
Xfid*
filsysremove(Filsys *fs, Xfid *x, Fid*)
{
    Fcall fc;

    return filsysrespond(fs, x, &fc, Eperm);
}
@

<<function [[filsyswstat]]>>=
static
Xfid*
filsyswstat(Filsys *fs, Xfid *x, Fid*)
{
