    // else, a directory

    o = x->req.offset;
    e = x->req.offset + x->req.count;
    clock = getclock();
    b = malloc(messagesize-IOHDRSZ);	/* avoid memset of emalloc */
    <<[[filsysread()]] sanity check b>>

    n = 0;
    switch(FILE(f->qid)){
    <<[[filsysread()]] cases>>
    }

    fc.data = (char*)b;
    fc.count = n;
