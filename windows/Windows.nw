<<[[winctl()]] other locals>>=
Rune *rp;
int nr;
@
%claude:
The [[WCwrite]] handler is the consumer side: it receives runes from
the application (e.g., the shell printing its prompt), processes any
backspace characters, then inserts at [[qh]] and advances [[qh]].
The key flow-control mechanism is in the [[alts adjustments]]:
when auto-scrolling is off and [[qh]] has moved past the visible
area, [[WCwrite]] is disabled ([[CHANNOP]]) so the application blocks
on its write---this prevents unbounded buffering of invisible output.

<<[[winctl()]] event loop cases>>=
case WCwrite:
    recv(cwm.cw, &pair);
    rp = pair.s;
    nr = pair.ns;

    <<[[winctl()]] when WCwrite, if runes contains backspace>>

    w->qh = winsert(w, rp, nr, w->qh) + nr;
    <<[[winctl()]] when WCwrite, if scrolling or mouseopen>>
    wsetselect(w, w->q0, w->q1);
    wscrdraw(w);

    free(rp);
    break;
@
