%claude:
[<wresize()>] swaps the window's image. If this is a move (or the
dimensions are unchanged), the old content is copied into the new
image with [[draw]]. The old image is freed, and [<wsetname()>] publishes
the new image under an incremented name so the client can reconnect
via [[getwindow()]]. The [[resized]] flag and [[mouse.counter]]
increment ensure the client gets a resize event on its next
[[/dev/mouse]] read, which prompts it to call [[getwindow()]] to
pick up the new image.

<<function [[wresize]]>>=
void
wresize(Window *w, Image *i, bool move)
{
    Rectangle r, or;

    or = w->i->r;
    if(move || (Dx(or)==Dx(i->r) && Dy(or)==Dy(i->r)))
        draw(i, i->r, w->i, nil, w->i->r.min);
    freeimage(w->i);
    w->i = i;
    wsetname(w); // publish new window name by incrementing namecount
    w->mc.image = i;

    <<[[wresize()]] textual window updates>>

    wborder(w, Selborder);
    w->topped = ++topped;

    w->resized = true;
    w->mouse.counter++;
}
