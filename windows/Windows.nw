switch(r){
<<[[wkeyctl()]] special key cases and no special mode>>
}
// else

/* otherwise ordinary character; just insert */
<<[[wkeyctl()]] ordinary character>>
@

% will see soon special keys

<<[[wkeyctl()]] locals>>=
uint q0;
@

<<[[wkeyctl()]] ordinary character>>=
q0 = w->q0;
q0 = winsert(w, &r, 1, q0);
wshow(w, q0+1);
@
