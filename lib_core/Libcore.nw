<<function [[_xinc]]>>=
void
_xinc(long *p)
{

    lock(&xincport_lock);
    (*p)++;
    unlock(&xincport_lock);
}
@
% who calls _xinc?? ainc?
% atom.s defines _xinc and _ainc as the same function

<<function [[_xdec]]>>=
long
_xdec(long *p)
{
    long r;

    lock(&xincport_lock);
    r = --(*p);
    unlock(&xincport_lock);
    return r;
}
