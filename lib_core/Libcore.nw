static Pool sbrkmem = {
    .name=      "sbrkmem",
    .maxsize=   (3840UL-1)*1024*1024,   /* up to ~0xf0000000 */
    .minarena=  4*1024,
    .quantum=   32,
    .alloc=     sbrkalloc,
    .merge=     sbrkmerge,
    .flags=     0,

    .lock=      plock,
