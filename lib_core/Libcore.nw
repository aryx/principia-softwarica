[[floor()]] and [[ceil()]] use [<modf()>] to split
a number into integer and fractional parts, then adjust
for negative numbers.

% floor and ceiling in an appartment :)

<<function [[floor]]>>=
/*
 * floor and ceil-- greatest integer <= arg
 * (resp least >=)
 */
double
floor(double d)
{
    double fract;

    if(d < 0) {
        fract = modf(-d, &d);
        if(fract != 0.0)
            d += 1;
        d = -d;
    } else
        modf(d, &d);
    return d;
}
