<<function [[mkcrctab]]>>=
ulong*
mkcrctab(ulong poly)
{
    ulong *crctab;
    ulong crc;
    int i, j;

    crctab = malloc(256 * sizeof(ulong));
    if(crctab == nil)
        return nil;

    for(i = 0; i < 256; i++){
        crc = i;
        for(j = 0; j < 8; j++){
            if(crc & 1)
                crc = (crc >> 1) ^ poly;
            else
                crc >>= 1;
        }
        crctab[i] = crc;
    }
    return crctab;
}
@

