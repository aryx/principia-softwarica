\section{Halting (ARM)}

%claude:
When [[runproc()]] finds no ready process, it calls
[[arch_idlehands()]], which enables interrupts and
executes the ARM [[WFI]] (Wait For Interrupt) instruction.
The CPU halts until the next interrupt (typically the
clock) arrives, saving power:

% runproc -> <>
<<function [[arch_idlehands]](raspberry pi1)(arm)>>=
TEXT arch_idlehands(SB), $-4
    MOVW    CPSR, R3
    ORR $(PsrDirq|PsrDfiq), R3, R1      /* splfhi */
    MOVW    R1, CPSR

    DSB
    MOVW    nrdy(SB), R0
    CMP $0, R0
    MCR.EQ  CpSC, 0, R0, C(CpCACHE), C(CpCACHEintr), CpCACHEwait
    DSB

    MOVW    R3, CPSR            /* splx */
    RET
@
%$
% nrdy is #processes in ready state

% MCR.EQ?
% Disable interrupts because hzclock will not help in finding a process to run.
% We are here because we could not find any process to schedule.
% Only something that increments nrdy can.
