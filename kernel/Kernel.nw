    lock(s);
    if(img->s == s && s->ref == 1) // race?
        img->s = nil;
    unlock(img);
}
@
% segment unattached when was last ref of segment because we will free it
% how img->s can be <> s? what is the race?

<<[[putseg()]] if s had an image>>=
