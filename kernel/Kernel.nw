void
qunlock(QLock *q)
{
    Proc *p;

    lock(&q->use);
    <<[[qunlock()]] sanity checks>>

    p = q->head;
    if(p){
        // dequeue(q)
        q->head = p->qnext;
        if(q->head == nil)
            q->tail = nil;

        unlock(&q->use);
        ready(p);
    }else{
        q->locked = false;
        q->qpc = nilptr;
        unlock(&q->use);
    }
}
