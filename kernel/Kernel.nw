\subsubsection{Starting the other processors}

%claude:
After CPU~0 finishes its initialization and starts the first user
process, it calls [launchinit] to bring up the secondary CPUs.
For each secondary CPU, [launchinit] allocates a [[Cpu]] structure
and a fresh L1 page table (cloned from CPU~0's), then calls
[startcpus]. The startup handshake uses the BCM2836 mailbox
mechanism: CPU~0 writes the physical address of [cpureset] into
the target CPU's mailbox, which wakes it up. A per-CPU lock
synchronizes the handshake---CPU~0 locks it before starting the
CPU and waits for the secondary to unlock it once running.

<<[[main()]] start the other processors(arm)>>=
launchinit(getncpus());
@

% launchinit() makes sense only in pi2 context. In pi1 it is
% essentially an NOP.

<<function [[launchinit]](arm)>>=
void
launchinit(int ncpus)
{
    int xcpu;
    Cpu *mm;
    PTE *l1;

    <<[[launchinit()]] sanity check ncpus(arm)>>
    for(xcpu = 1; xcpu < ncpus; xcpu++){
        cpus[xcpu] = mm = mallocalign(CPUSIZE, CPUSIZE, 0, 0);
        l1 = mallocalign(L1SIZE, L1SIZE, 0, 0);
        if(mm == nil || l1 == nil)
            panic("launchinit");
        memset(mm, 0, CPUSIZE);
        mm->cpuno = xcpu;

        memmove(l1, cpu->mmul1, L1SIZE);  /* clone cpu0's l1 table */
        cachedwbse(l1, L1SIZE);
        mm->mmul1 = l1;
        cachedwbse(mm, CPUSIZE);

    }
    cachedwbse(cpus, sizeof cpus);
    xcpu = startcpus(ncpus);
    if(xcpu < ncpus)
            panic("only %d cpu%s started", xcpu, xcpu == 1? "" : "s");
}
@
