\subsubsection{[[seg()]]}

%yoann: explain, "segment of addr" ? used in which context?
%claude:
Given a virtual address, [[seg()]] finds which segment
it belongs to by scanning [[up->seg[]]]. This is used
throughout the kernel whenever a user-space address must
be validated or its segment located (e.g., in page fault
handling, [[read]]/[[write]] syscalls, debugging):

\l rename segment_of_addr
% okaddr | ... -> <> 
<<function [[seg]]>>=
Segment*
seg(Proc *p, user_addr addr, bool dolock)
{
    Segment **s, **et, *sg;

    et = &p->seg[NSEG];
    for(s = p->seg; s < et; s++) {
        sg = *s;
        if(sg == nil)
            continue;
        if(addr >= sg->base && addr < sg->top) {
            if(!dolock)
                return sg;
            // else

            qlock(&sg->lk);
            // can have a race, need to check again
            if(addr >= sg->base && addr < sg->top)
                return sg;
            qunlock(&sg->lk);
        }
    }
    return nil;
}
