%yoann: seen data structure, now ready for qlock() function itself and explain
%claude:
With the data structure in place, the [[qlock()]] function
itself is straightforward. If the lock is free, take it
immediately. Otherwise, add the current process to the
wait queue and go to sleep:

<<function [[qlock]]>>=
void
qlock(QLock *q)
{
    Proc *p;

    <<[[qlock()]] sanity checks>>
    lock(&q->use);
    <<[[qlock()]] start of qlock, stat>>
    if(!q->locked) {
        q->locked = true;
        q->qpc = getcallerpc(&q);
        unlock(&q->use);
        return;
    }
    // else
    <<[[qlock()]] sanity check up>>
    <<[[qlock()]] when qlock already held, stat>>

    // add_queue(q, up)
    p = q->tail;
    if(p == nil)
        q->head = up;
    else
        p->qnext = up;
    q->tail = up;
    // up->qnext could be non nil before? no otherwise that means
    // the process is already waiting for a lock and so had no occasion
    // to run another qlock() instruction.
    up->qnext = nil;

    up->state = Queueing;
    up->qpc = getcallerpc(&q);
    unlock(&q->use);

    // switch to another process! 
    sched(); 
    // will resume here when another process unlock() the lock and ready() us
    q->qpc = getcallerpc(&q);
}
@ 

<<[[qlock()]] sanity check up>>=
if(up == nil)
    panic("qlock");
@
