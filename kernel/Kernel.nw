\section{[[/proc/]]}
%#p

%claude:
The [[/proc]] filesystem (device letter [[#p]]) is the most complex
special fileserver in the kernel. Each running process appears as
a directory [[/proc/\emph{pid}/]] containing files for inspection
and control: [[ctl]] for sending commands, [[mem]] for reading/writing
the address space, [[status]] for state information, [[note]] for
posting notifications, [[regs]]/[[fpregs]] for register access,
[[wait]] for collecting child exit statuses, [[syscall]] for tracing
output, and [[profile]] for tick profiling data. The qid encoding
packs both the file type (5 bits) and the process slot number
(26 bits) into the path, with the pid in the version field for
consistency checking.

\subsection{[[/proc/x/ctl]]}

\subsection{[[/proc/x/mem]]}

\subsection{[[/proc/x/status]]}

\subsection{[[/proc/x/args]]}

\subsection{[[/proc/x/wait]]}

%claude:
Reading [[/proc/\emph{pid}/wait]] is an alternative to the
[[await()]] system call for collecting child exit statuses.
The [[qwaitr]] lock ensures only one reader can block waiting
for children at a time---if a second reader tries, it gets an
``in use'' error.

<<[[Proc]] hierarchy fields>>=
QLock qwaitr;
@

<<[[procread()]] cases>>=
case Qwait:
    if(!canqlock(&p->qwaitr))
        error(Einuse);

    if(waserror()) {
        qunlock(&p->qwaitr);
        nexterror();
    }

    <<[[procread()]] when Qwait case, sanity check process has children>>
    pid = p->pid;
    while(p->waitq == nil) {
        unlock(&p->exl);
        sleep(&p->waitr, haswaitq, p);
        if(p->pid != pid)
            error(Eprocdied);
        lock(&p->exl);
    }
    wq = p->waitq;
    p->waitq = wq->next;
    p->nwait--;
    unlock(&p->exl);

    qunlock(&p->qwaitr);
    poperror();

    n = snprint(a, n, "%d %lud %lud %lud %q",
        wq->w.pid,
        <<[[procread()]] Qwait case, snprint time field arguments>>
        wq->w.msg);
    free(wq);
    return n;
@

<<[[procread()]] when Qwait case, sanity check process has children>>=
// same in sysawait
lock(&p->exl);
if(up == p && p->nchild == 0 && p->waitq == 0) {
    unlock(&p->exl);
    error(Enochild);
}
@

<<[[pwait()]] lock qwaitr>>=
if(!canqlock(&up->qwaitr))
    error(Einuse); // someone is reading /proc/pid/wait?
if(waserror()) {
    qunlock(&up->qwaitr);
    nexterror();
}
@

<<[[pwait()]] unlock qwaitr>>=
qunlock(&up->qwaitr);
poperror();
@
