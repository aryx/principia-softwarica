Here is the structure:
\begin{verbatim}
  Proc
   |
   +-- seg[NSEG]:  array of Segment pointers
         |
         +-- seg[SG_TEXT]  --> Segment (base=UTZERO, top=...)
         +-- seg[SG_DATA]  --> Segment (base=..., top=...)
         +-- seg[SG_BSS]   --> Segment (base=..., top=...)
         +-- seg[SG_STACK] --> Segment (base=USTKTOP-USTKSIZE, top=USTKTOP)
                                 |
                                 +-- map[]:  array of Pagetable pointers
                                       |
                                       +-- Pagetable
                                             |
                                             +-- pages[]:  array of Page pointers
                                                   |
                                                   +-- Page (pa=..., va=...)
\end{verbatim}


