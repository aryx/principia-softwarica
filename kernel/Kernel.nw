% used by mmuwalk, dma allocator, smp, etc
% e.g. xspanalloc(64*1024*i8237dma, BY2PG, 64*1024);
% e.g. xspanalloc(4*BY2PG, BY2PG, 0);
<<function [[xspanalloc]]>>=
kern_vp
xspanalloc(ulong size, int align, ulong span)
{
    ulong a, v, t;
    a = (kern_addr)xalloc(size+align+span);
    <<[[xspanalloc()]] sanity check a>>

    if(span > 2) {
        v = (a + span) & ~(span-1);
        t = v - a;
        if(t > 0)
            xhole(PADDR(a), t);
        t = a + span - v;
        if(t > 0)
            xhole(PADDR(v+size+align), t);
    }
    else
        v = a;

    if(align > 1)
        v = (v + align) & ~(align-1);

    return (kern_vp)v;
}
@

<<[[xspanalloc()]] sanity check a>>=
if(a == nilptr)
    panic("xspanalloc: %lud %d %lux", size, align, span);
@


\section{Memory pools}

%claude:
[[xalloc]] is too coarse for general use---it can only
handle a small number of holes (128). The kernel needs a
finer-grained allocator for the many small, short-lived
structures it creates (and free) during normal operation (channel
tables, path strings, etc.). This is provided by the
[[Pool]] allocator, which manages {arenas} obtained from
[[xalloc]] and subdivides them using a best-fit algorithm.

\subsection{[[Pool]]}
% pool allocation, aka arena?
% yes, but used for a best-fit allocator I think

%yoann: explain Pool data structure actually defined in libc because same machinery used for kernel malloc and user malloc, and except shown below:
%claude:
The [[Pool]] structure is defined in [[lib_core/include/pool.h]],
not in the kernel, because the same allocation machinery is
shared between the kernel's [[malloc()]] and the user-space
[[malloc()]] in libc---only the backing allocator differs
([[xalloc]] for the kernel, [[brk]] for user space).
The full definition is shown below as a verbatim excerpt but see
the \book{Libcore} for more information:

\begin{verbatim}

// from pool.h
struct Pool {
  char* name;
  ulong maxsize;

  ulong cursize;
  ulong curfree;
  ulong curalloc;

  ulong minarena; /* smallest size of new arena */
  ulong quantum;  /* allocated blocks should be multiple of */
  ulong minblock; /* smallest newly allocated block */

  void* freeroot; /* actually Free* */
  void* arenalist;  /* actually Arena* */

  void* (*alloc)(ulong);
  int (*merge)(void*, void*);
  void  (*move)(void* from, void* to);

  int flags;
  int nfree;
  int lastcompact;

  void  (*lock)(Pool*);
  void  (*unlock)(Pool*);
  void  (*print)(Pool*, char*, ...);
  void  (*panic)(Pool*, char*, ...);
  void  (*logstack)(Pool*);

  void* private;
};
\end{verbatim}

%yoann: the important fields are ??
%claude:
The important fields are [[alloc]] (the callback to get
more memory---[[xalloc]] for the kernel), [[merge]] (to
coalesce freed blocks---[[xmerge]] for the kernel),
[[freeroot]] (the free-block tree), [[arenalist]] (the
list of memory regions obtained from [[alloc]]), and the
[[lock]]/[[unlock]] callbacks for thread safety.

%yoann: explain Private
%claude:
The [[Private]] structure holds the per-pool lock and a
message buffer. The message buffer is needed because the
pool code cannot print while holding the lock (it would
risk deadlock if [[print]] itself tries to allocate), so
messages are saved and printed after unlock:
<<pool.c struct Private>>=
struct Private {
    Lock        lk;
    char        msg[256]; /* a rock for messages to be printed at unlock */
};
@

\subsection{[[plock()]]}

%yoann: explain plock
%claude:
The pool's lock callback uses [[ilock()]] (not a regular
[[lock()]]) because interrupt handlers sometimes need to
allocate memory. If a regular lock were used, a syscall
holding the pool lock could be interrupted, and the
interrupt handler's allocation attempt would deadlock.
<<function [[plock]]>>=
static void
plock(Pool *p)
{
    Private *pv;

    pv = p->private;
    ilock(&pv->lk);
    pv->lk.pc = getcallerpc(&p);
    pv->msg[0] = 0;
}
@

%yoann: Use ilock! don't want interrupt in middle of kernel malloc?
%  because interrupt code sometimes allocate stuff? in which case
%  we could not get out of the interrupt? (same reason for nlock?)
% Works with SMP? Yes because Lock will do mutual exclusion over all
% processors.

<<function [[punlock]]>>=
static void
punlock(Pool *p)
{
    Private *pv;
    char msg[sizeof pv->msg];

    pv = p->private;
    if(pv->msg[0] == 0){
        iunlock(&pv->lk);
        return;
    }

    memmove(msg, pv->msg, sizeof msg);
    iunlock(&pv->lk);
    iprint("%.*s", sizeof pv->msg, msg);
}
@

\subsection{[[pmainmem]]}

%yoann: explain pmainmem. Again static allocated in Data section in layer0 to help boostrap
%claude:
The two pool instances, [[pmainmem]] (for general kernel
allocations, 4~MB) and [[pimagmem]] (for graphics
image data, 16~MB, see \book{Graphics}), have their [[Pool]]
structures statically allocated in the data section---another
layer~0 bootstrap (the pool structures themselves, not the
memory they manage).

%claude:
Their [[alloc]] callback is [[xalloc]], so when the pool
needs more memory it asks [[xalloc]] for a new arena.
The 4~MB [[maxsize]] is a cap, not a reservation---Pool
only requests arenas as needed, leaving the remaining
[[xalloc]] memory available for other direct allocations
(the [[Proc]] array, the [[Page]] array, etc.). Here is
how the kernel memory looks after initialization:
\begin{verbatim}
  xalloc-managed kernel memory (kernelpercent of RAM):

              +---------------------------+
              | free (xalloc hole)        |
              +---------------------------+
              | pmainmem arena 2          |  (Pool, on demand)
              +---------------------------+
              | pimagmem arena 1          |  (Pool, on demand)
              +---------------------------+
              | pmainmem arena 1          |  (Pool, on demand)
              +---------------------------+
              | Page array                |  (direct xalloc)
              +---------------------------+
              | Proc array (~6 MB)        |  (direct xalloc)
              +---------------------------+
\end{verbatim}
Arenas from different pools and direct [[xalloc]] calls
can interleave---the order depends on when each allocation
happens during boot and normal operation.
%claude:
Arenas are never returned to [[xalloc]] (no [[xfree]]
call), so the pools only grow, which avoids fragmentation
in [[xalloc]]'s hole list.

% note that no xfree() or xhole() here ... so it always grow
% (which is good for the fragmentation issue of xalloc anyway)
% kernel memory = 4Mo max? this is actually adjusted in confinit()!
<<global [[pmainmem]]>>=
static Private pmainpriv;
static Pool pmainmem = {
    .name=  "Main",
    .maxsize=   4*MB,
    .minarena=  128*KB,
    .quantum=   32,

    .alloc= xalloc,
    .merge= xmerge,

    .flags= POOL_TOLERANCE,

    .lock=plock,
    .unlock= punlock,

    .print= poolprint,
    .panic= ppanic,

    .private=   &pmainpriv,
};
@


% this is really for image ... for kernel draw, 16Mo, not for KImage
% this is also adjusted in confinit
<<global [[pimagmem]]>>=
static Private pimagpriv;
static Pool pimagmem = {
    .name=  "Image",
    .maxsize=   16*MB,
    .minarena=  2*MB,
    .quantum=   32,

    .alloc= xalloc,
    .merge= xmerge,

    .flags= 0,

    .lock= plock,
    .unlock= punlock,

    .print= poolprint,
    .panic= ppanic,

    .private=   &pimagpriv,
};
@
% xmerge !!!!! xalloc !!!!

<<global mainmem and imagmem>>=
// exported in include/pool.h, defined here!
Pool*   mainmem = &pmainmem;
Pool*   imagmem = &pimagmem;
@


