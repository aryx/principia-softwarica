\section{Serial line}

%claude:
On the Raspberry Pi, printing to the screen requires
a working framebuffer, font rendering, and drawing
primitives---none of which are available during early
boot. The serial UART is the escape hatch: it works
with a single register write, so [[uartputs()]] can
output text from the very first instruction. This is
how kernel developers debug boot failures.

% Complex to debug kernel on Raspberry Pi because need to gets lots
% of stuff working before being able to print a character on the screen:
% Framebuffer, font, drawing primitives.
% Alternative is to print text on serial line!
%x86: simpler with cga.c and builtin font support.

% Can demo with Qemu? Can get output on console?

\subsection{[[serialoq]]}

<<global [[serialoq]]>>=
// option<Queue>
Queue*  serialoq;       /* serial console output */
@ 

<<function [[consactive]]>>=
int
consactive(void)
{
    if(serialoq)
        return qlen(serialoq) > 0;
    return 0;
}
@ 

<<[[echo()]] hooks>>=
if(serialoq)
    echoserialoq(buf, n);
@


<<function [[echoserialoq]]>>=
static void
echoserialoq(char *buf, int n)
{
    char *e, *p;
    char ebuf[128];
    int x;

    p = ebuf;
    e = ebuf + sizeof(ebuf) - 4;
    while(n-- > 0){
        if(p >= e){
            qiwrite(serialoq, ebuf, p - ebuf);
            p = ebuf;
        }
        x = *buf++;
        if(x == '\n'){
            *p++ = '\r';
            *p++ = '\n';
        } else if(x == 0x15){
            *p++ = '^';
            *p++ = 'U';
            *p++ = '\n';
        } else
            *p++ = x;
    }
    if(p != ebuf)
        qiwrite(serialoq, ebuf, p - ebuf);
}
@ 
% quite similar to echoscreen


<<[[putstrn0()]] serialoq handling>>=
/*
 *   Convert \n to \r\n for serial
 *   line consoles.  Locking of the queues is left up to the screen
 *   or uart code.  Multi-line messages to serial consoles may get
 *   interspersed with other messages.
 */
<<[[putstrn0()]] if serialoq nil>>
// else

while(n > 0) {
    t = memchr(str, '\n', n);
    if(t && !kbd.raw) {
        m = t-str;
        if(usewrite){
            qwrite(serialoq, str, m);
            qwrite(serialoq, "\r\n", 2);
        } else {
            qiwrite(serialoq, str, m);
            qiwrite(serialoq, "\r\n", 2);
        }
        n -= m+1;
        str = t+1;
    } else {
        if(usewrite)
            qwrite(serialoq, str, n);
        else
            qiwrite(serialoq, str, n);
        break;
    }
}
@

