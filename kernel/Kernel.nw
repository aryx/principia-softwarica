\subsection{[[/sys/reboot]]}

%claude:
Writing ``halt'', ``reboot'', or ``panic'' to [[/sys/reboot]]
triggers a system shutdown. The reboot path is particularly
interesting on multi-core systems: the kernel must migrate to
CPU~0 (the boot processor), shut down all other CPUs, disable
interrupts and caches, then copy a small trampoline
([[rebootcode.s]]) to a fixed physical address. This trampoline
turns off the MMU and copies the new kernel image to its
load address before jumping to it.

<<devsys.c enum Qxxx cases>>=
Qreboot,
@

<<[[sysdir]] fields>>=
"reboot",   {Qreboot},  0,      0660,
@

<<devsys.c decls and globals>>=
enum
{
    CMhalt,
    CMreboot,
    CMpanic,
};

Cmdtab rebootmsg[] =
{
    CMhalt,     "halt",     1,
    CMreboot,   "reboot",   0,
    CMpanic,    "panic",    0,
};
@


<<[[syswrite()]] locals>>=
Cmdbuf *cb;
Cmdtab *ct;
@

<<[[syswrite()]] cases>>=
case Qreboot:
    if(!iseve())
        error(Eperm);
    cb = parsecmd(a, n);

    if(waserror()) {
        free(cb);
        nexterror();
    }
    ct = lookupcmd(cb, rebootmsg, nelem(rebootmsg));
    switch(ct->index) {
    case CMhalt:
        arch_reboot(nil, 0, 0);
        break;
    case CMreboot:
        rebootcmd(cb->nf-1, cb->f+1);
        break;
    case CMpanic:
        *(ulong*)0=0;
        panic("/dev/reboot");
    }
    poperror();
    free(cb);
    break;
@

