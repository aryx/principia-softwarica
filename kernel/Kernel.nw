%******************************************************************************
\chapter{Profiling Support}
%******************************************************************************
\label{chap:profiling-support}
%\section{Profiling user processes}

% should cooperate with Profiling.nw at some point

%claude:
In this chapter, I will present two forms of profiling support
in the kernel: timing and sampling. The timing infrastructure
tracks how much CPU time each process spends in user mode vs kernel
mode, reported via [[/dev/cputime]] and [[/proc/\emph{pid}/status]].
The sampling infrastructure ([[/bin/tprof]]) uses a periodic timer to
record which instruction the program is executing, building a
coverage histogram over the text segment. A third mechanism,
[[/bin/prof]], requires cooperation between the compiler, linker,
and kernel through the [[Tos]] structure at the top of the user stack.

\section{[[/dev/cputime]] and [[/proc/#/status]]}

%claude:
Each process tracks five time counters: user time, system time,
real (wall-clock) time, and cumulative user/system time of
children. The counters are incremented by [[accountime()]], which is
called on every clock tick and checks [[p->insyscall]] to decide
whether to attribute the tick to user or system time. The real time
is stored as the tick count at process creation, so the actual
elapsed time is computed on-the-fly as [[CPUS(0)->ticks - p->time[TReal]]].

<<enum [[proctimer]]>>=
enum Proctime 
{
    TUser = 0,    /* Proc.time */
    TSys,
    TReal,

    // to accumulate also the time of the children of the process
    TCUser,
    TCSys,
};
@ 

<<[[Proc]] stats and profiling fields>>=
// hash<enum<proctime>, ulong>
ulong time[5];  /* User, Sys, Real; child U, S */
@
% the ulong is number of ticks, so use Ttick? except for Real where it's
%  the tick number when the process was started
% used to be time[6] with a TCReal, but didn't make sense
% because time[TCREal] was never used because the real time
% is the full time of everything and we don't need to maintain
% that info; it's very easy to compute ... it's the rest that is hard
% to track.

<<[[sysrfork()]] setting time field>>=
memset(p->time, 0, sizeof(p->time));
p->time[TReal] = CPUS(0)->ticks;
@
% could factorize in newproc? but maybe to be the most precise
% they prefer to do that the closes to the point where they actually
% ready the process?

<<[[kproc()]] setting time field>>=
memset(p->time, 0, sizeof(p->time));
p->time[TReal] = CPUS(0)->ticks;
@

<<[[accountime()]] update time of current process>>=
p->time[p->insyscall ? TSys : TUser]++;
@
% this is called by hzclock so every tick


<<[[consread()]] cases>>=
case Qcputime:
    k = offset;
    if(k >= 5*NUMSIZE)
        return 0;
    if(k+n > 5*NUMSIZE)
        n = 5*NUMSIZE - k;
    /* easiest to format in a separate buffer and copy out */

    for(i=0; i<5 && NUMSIZE*i<k+n; i++){
        l = up->time[i];
        if(i == TReal)
            l = CPUS(0)->ticks - l;
        l = TK2MS(l);
        readnum(0, tmp+NUMSIZE*i, NUMSIZE, l, NUMSIZE);
    }
    memmove(buf, tmp+k, n);
    return n;
@
% this is /dev/ so only the current process can see it

<<[[procread()]] Qstatus case, time part>>=
for(i = 0; i < 5; i++) {
    l = p->time[i];
    if(i == TReal)
        l = CPUS(0)->ticks - l;
    l = TK2MS(l);
    readnum(0, statbuf+j+NUMSIZE*i, NUMSIZE, l, NUMSIZE);
}
