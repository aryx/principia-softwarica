ulong
procalarm(ulong time) // Tms
{
    Proc **l, *f;
    ulong when, old; // Tval ticks

    <<[[procalarm()]] compute remaining time in old alarm>>
    <<[[procalarm()]] if time is zero, reset alarm>>
