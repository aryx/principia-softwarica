\subsection{Clock initialization (ARM)}

%claude:
[[clockinit()]] measures the CPU frequency by timing
cycles against the 1~MHz system timer, then registers
[[clockintr]] as the handler for [[IRQtimer3]]. After
this, the hardware will generate an interrupt when
system timer~3's compare register matches the counter:

% http://embedded-xinu.readthedocs.io/en/latest/arm/rpi/BCM2835-System-Timer.html

% 9 use system time compare register number 3 (tn->c3).

% This just enable the timer interrupts.
% You still need to add a timer (timersinit and arch_timerset).

<<function [[clockinit]](arm)>>=
void
clockinit(void)
{
    Systimers *tn;
    Armtimer *tm;
    u32int t0, t1, tstart, tend;

    <<[[clockinit()]] if many processors>>

    tn = (Systimers*)SYSTIMERS;
    tstart = tn->clo;
    do{
        t0 = arch_lcycles();
    }while(tn->clo == tstart);
    tend = tstart + 10000;
    do{
        t1 = arch_lcycles();
    }while(tn->clo != tend);
    t1 -= t0;

    cpu->cpuhz = 100 * t1;
    cpu->cpumhz = (cpu->cpuhz + Mhz/2 - 1) / Mhz;

    cpu->cyclefreq = cpu->cpuhz;

    if(cpu->cpuno == 0){
        tn->c3 = tn->clo - 1;

        tm = (Armtimer*)ARMTIMER;
        tm->load = 0;
        tm->ctl = TmrPrescale1|CntEnable|CntWidth32;

        arch_intrenable(IRQtimer3, clockintr, nil, 0, "clock");
    }
    <<[[clockinit()]] if not cpu0>>
}
@
%qemu: SYSTIMER and ARMTIMER are not supported so the while loop above
% will loop forever

% so will generate at Arch_HZ ?
\l aspectize ARMTIMER? important?

\subsection{Timer initialization}

%claude:
[[timersinit()]] creates the periodic timer that drives
[[hzclock()]]. The timer's [[tf]] callback is set to
[[nil]], which [[timerintr()]] interprets as ``call
[[hzclock()]]''. This is the timer that makes the kernel
tick:

% note that portable code.

<<global [[timersinited]]>>=
static bool timersinited;
@

<<function [[timersinit]]>>=
void
timersinit(void)
{
    Timer *t;

    timersinited = true;
    todinit();

    t = malloc(sizeof(Timer));
    if(t == nil)
        error(Enomem);
    t->tmode = Tperiodic;
    t->tt = nil;
    t->tns = 1000000000 / Arch_HZ;
    /*
     * T->tf == nil means the HZ clock for this processor.
     */
    t->tf = nil;
    timeradd(t);
}
