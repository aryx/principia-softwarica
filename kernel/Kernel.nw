% ibrk | fork | exec -> <>
<<function [[arch_flushmmu]](arm)>>=
void
arch_flushmmu(void)
{
    int s;

    s = arch_splhi();
    up->newtlb = true;
    arch_mmuswitch(up);
    arch_splx(s);
}
