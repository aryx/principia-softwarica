\subsection{[[fiq()]]}

%claude:
Unlike IRQ dispatch which walks a linked list of handlers, FIQ
dispatch is trivial: there is at most one FIQ source, stored in
the global [[vfiq]]. The [[ureg->pc -= 4]] adjustment is the
standard ARM convention for interrupt return address correction.

<<function [[fiq]](arm)>>=
/*
 * called direct from lexception.s to handle fiq interrupt.
 */
void
fiq(Ureg *ureg)
{
    Vctl *v;

    cpu->perf.intrts = arch_perfticks();
    v = vfiq;
    if(v == nil)
        panic("cpu%d: unexpected item in bagging area", cpu->cpuno);
    cpu->intr++;
    ureg->pc -= 4;
    arch_coherence();

    // Dispatch!
    v->f(ureg, v->a);

    arch_coherence();
    intrtime();
}
@

% arch_exit -> <>
<<function [[splfhi]](arm)>>=
TEXT splfhi(SB), 1, $-4
    MOVW    $(CPUADDR+4), R2        /* save caller pc in Mach */
    MOVW    R14, 0(R2)

    MOVW    CPSR, R0            /* turn off irqs and fiqs */
    ORR $(PsrDirq|PsrDfiq), R0, R1
    MOVW    R1, CPSR
    RET
@
