\section{System calls}
%Software interrupts (a.k.a syscalls)

%claude:
We already traced the syscall path in the Overview chapter.
Here we see the actual code. The [[SWI]] instruction puts
the ARM in SVC mode and jumps to [[vectors[2]]], which
loads [[_vsvc]] from [[vtable[2]]].

\subsection{[[_vsvc()]] (ARM)}

%claude:
[[_vsvc]] builds a [[Ureg]] on the kernel stack by pushing
registers in the right order, then calls [[arch__syscall()]]
in C. On return, it restores the registers and executes
[[RFE]] (Return From Exception) to resume user mode.
The key steps are:
%yoann1: why _vsvc execute on kernel stack? and where this stack is set and the stacker pointer set to point there?

\begin{verbatim}
  1. Push ureg->pc (= R14, the return address)
  2. Push ureg->psr (= SPSR, the saved user CPSR)
  3. Push ureg->type (= PsrMsvc, to identify this as a syscall)
  4. Push R0-R14 (all user registers, via MOVM.DB.S)
  5. Set R12 = kernel SB, R10 = cpu, R9 = up
  6. Call arch__syscall(ureg)
  7. Restore R0-R14, SPSR from the Ureg
  8. RFE -> back to user mode
\end{verbatim}

<<constant [[CPU]](arm)>>=
#define CPU     10      /* R10 is cpu-> */
@
<<constant [[UP]](arm)>>=
#define UP      9       /* R9 is up-> */
@


% Use R14 below as temporary register.
% SPSR vs CPSR? Previous CPSR before the SWI (one of user)
% (not super useful here but for _virq() it will allow to know 
% if you interrupted an interrupt or if you had a fault while in kernel mode)

% number in SWI is not used. R0 is used for the syscall number.

% What is the value of R13 after an exception??
%  for _vsvc it is the last value of the banked register R13 for
%  supervisor mode (set in _start)
\t also [R0-R14], (R13) ?? R13 of user vs R13 of kernel?

<<function [[_vsvc]](arm)>>=
TEXT _vsvc(SB), 1, $-4          /* SWI */
    CLREX
    MOVW.W  R14, -4(R13)        /* ureg->pc = interrupted PC */
    MOVW    SPSR, R14       /* ureg->psr = SPSR */
    MOVW.W  R14, -4(R13)        /* ... */
    MOVW    $PsrMsvc, R14       /* ureg->type = PsrMsvc */
    MOVW.W  R14, -4(R13)        /* ... */

    /* avoid the ambiguity described in notes/movm.w. */
    MOVM.DB.S [R0-R14], (R13)   /* save user level registers */
    SUB $(15*4), R13        /* r13 now points to ureg */

    MOVW    $setR12(SB), R12    /* Make sure we've got the kernel's SB loaded */

    /* get R(CPU) for this cpu */
    <<[[_vsvc()]] set cpu register(arm)>>

    MOVW    8(R(CPU)), R(UP)        /* up */ // Cpu->proc

    MOVW    R13, R0         /* first arg is pointer to ureg */
    SUB $8, R13         /* space for argument+link */

    BL  arch__syscall(SB)

    ADD $(8+4*15), R13      /* make r13 point to ureg->type */
    MOVW    8(R13), R14     /* restore link */
    MOVW    4(R13), R0      /* restore SPSR */
    MOVW    R0, SPSR        /* ... */
    MOVM.DB.S (R13), [R0-R14]   /* restore registers */
    ADD $8, R13         /* pop past ureg->{type+psr} */
    RFE             /* MOVM.IA.S.W (R13), [R15] */
@
%$
