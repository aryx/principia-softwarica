%******************************************************************************
\chapter{Error Management}
%******************************************************************************

%claude:
This appendix covers the kernel's error handling
mechanisms: [[panic()]] for unrecoverable errors that
halt the system, [[error()]] for recoverable errors
that unwind the call stack (using [[setjmp]]/[[longjmp]]-style
labels), and [[waserror()]]/[[poperror()]] which together
form a try/catch mechanism in C. The [[errstr]] syscall
lets user programs retrieve error strings---\plan's
replacement for \unix's numeric [[errno]].

\section{[[panic()]]}

<<global [[panicking]]>>=
bool panicking;
@


<<function [[panic]]>>=
void
devcons_panic(char *fmt, ...)
{
    int n, s;
    va_list arg;
    char buf[PRINTSIZE];

    <<[[panic()]] reset kprintoq>>

    if(panicking)
        for(;;);
    panicking = true;

    s = arch_splhi();
    strcpy(buf, "panic: ");
    va_start(arg, fmt);
    n = vseprint(buf+strlen(buf), buf+sizeof(buf), fmt, arg) - buf;
    va_end(arg);
    iprint("%s\n", buf);
    <<[[panic()]] run consdebug hook>>
    arch_splx(s);
    prflush();
    buf[n] = '\n';
    putstrn(buf, n+1);
    //TODO: put in comment for now because already got some panic with
    // lapic, but it seems to work still :)
    //arch_dumpstack();
    //exit(1);
}
@ 

% devcons_panic -> <>
<<function [[prflush]]>>=
void
prflush(void)
{
    ulong now;

    now = cpu->ticks;
    while(consactive())
        if(cpu->ticks - now >= Arch_HZ)
            break;
}
@ 


<<function [[sysfatal]]>>=
/* libmp at least contains a few calls to sysfatal; simulate with panic */
// note that this is not a system call, even though it's prefixed with sys
//@Scheck: no dead, override also sysfatal from libc/9sys/sysfatal.c
void sysfatal(char *fmt, ...)
{
    char err[256];
    va_list arg;

    va_start(arg, fmt);
    vseprint(err, err + sizeof err, fmt, arg);
    va_end(arg);
    panic("sysfatal: %s", err);
}
