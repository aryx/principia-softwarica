\subsection{Buffered input}

% see chapter later for queue IO
%claude:
The console uses a {two-queue} design. Raw keystrokes arrive in
[[kbdq]] (the ``unprocessed'' queue, fed by [echo] via [qproduce]).
When a process reads [[/dev/cons]] in cooked mode, the [consread]
code pulls bytes one at a time from [[kbdq]], applies line editing
(backspace, Control-U, newline detection), and when a complete line
is ready, writes it into [[lineq]] (the ``processed'' queue).
The process then reads from [[lineq]]. In raw mode, this two-stage
pipeline is short-circuited: bytes go from [[kbdq]] directly to
the reader without line editing.

<<global [[kbdq]]>>=
Queue*  kbdq;           /* unprocessed console input */
@ 

<<function [[kbdqinit]]>>=
void
kbdqinit(void)
{
    kbdq = qopen(4*1024, 0, 0, 0);
    if(kbdq == nil)
        panic("kbdinit");
    qnoblock(kbdq, true);
}
@


<<global [[lineq]]>>=
Queue*  lineq;          /* processed console input */
@ 

<<function [[lineqinit]]>>=
void
lineqinit(void)
{

    lineq = qopen(2*1024, 0, nil, nil);
    if(lineq == nil)
        panic("lineqinit");
    qnoblock(lineq, true);
}
@ 
%old: was called printinit

<<[[ConsKbd]] other fields>>=
char    line[1024]; /* current input line */
int x;      /* index into line */
@

%!!! this is an important one!
%claude:
This is the core of console input. The outer [[while]] loop
spins until [[lineq]] has data. Inside, it reads one byte at a time
from [[kbdq]] and implements a simple line editor: backspace
decrements the index, Control-U resets it to zero, newline marks
the line as complete (sets [[send]]), and Control-D sends whatever
has been accumulated (even if empty, which the reader sees as EOF).
When [[send]] is true or the line buffer is full, the accumulated
bytes are written to [[lineq]] in one shot. This batching means a
[[read]] on [[/dev/cons]] always returns a complete line in cooked mode.

<<[[consread()]] Qcons case>>=
case Qcons:
    qlock(&kbd);
    if(waserror()) {
        qunlock(&kbd);
        nexterror();
    }
    while(!qcanread(lineq)){
        if(qread(kbdq, &ch, 1) == 0)
            continue;
        send = false;
        if(ch == 0){
            /* flush output on rawoff -> rawon */
            if(kbd.x > 0)
                send = !qcanread(kbdq);
        
        <<[[consread()]] else if raw mode>>
        }else{
            switch(ch){
            case '\b':
                if(kbd.x > 0)
                    kbd.x--;
                break;
            case 0x15:  /* ^U */
                kbd.x = 0;
                break;
            case '\n':
                send = true;
                kbd.line[kbd.x++] = ch;
                break;
            case 0x04:  /* ^D */
                send = true;
                break;
            default:
                kbd.line[kbd.x++] = ch;
                break;
            }
        }
        if(send || kbd.x == sizeof kbd.line){
            qwrite(lineq, kbd.line, kbd.x);
            kbd.x = 0;
        }
    }
    n = qread(lineq, buf, n);
    qunlock(&kbd);
    poperror();
    return n;
@


