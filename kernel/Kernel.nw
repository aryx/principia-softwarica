Writers wait separately from readers:

<<[[Procstate]] cases>>=
QueueingW, // see wlock()
@

<<function [[wlock]]>>=
void
wlock(RWlock *q)
{
    Proc *p;

    lock(&q->use);
    rwstats.wlock++;
    if(q->readers == 0 && !q->writer){
        /* noone waiting, go for it */
        q->wpc = getcallerpc(&q);
        q->wproc = up;
        q->writer = true;
        unlock(&q->use);
        return;
    }
    // else, already a writer or readers

    /* wait */
    <<[[wlock()]] sanity check up>>
    rwstats.wlockq++;

    // add_queue(q, up)
    p = q->tail;
    if(p == nil)
        q->head = up;
    else
        p->qnext = up;
    q->tail = up;
    up->qnext = nil;

    up->state = QueueingW;
    unlock(&q->use);
    sched();
}
@ 

<<[[wlock()]] sanity check up>>=
if(up == nil)
    panic("wlock");
@
%ocaml: use sentinel

<<function [[wunlock]]>>=
void
wunlock(RWlock *q)
{
    Proc *p;

    lock(&q->use);
    p = q->head;
    if(p == nil){
        q->writer = false;
        unlock(&q->use);
        return;
    }
    if(p->state == QueueingW){
        /* start waiting writer */
        // dequeue(q)
        q->head = p->qnext;
        if(q->head == nil)
            q->tail = nil;

        unlock(&q->use);
        ready(p);
        return;
    }

    if(p->state != QueueingR)
        panic("wunlock");

    /* waken waiting readers */
    while(q->head != nil && q->head->state == QueueingR){
        p = q->head;
        q->head = p->qnext;
        q->readers++;
        ready(p);
    }

    if(q->head == nil)
        q->tail = nil;
    q->writer = false;
    unlock(&q->use);
}
@ 


<<function [[canrlock]]>>=
/* same as rlock but punts if there are any writers waiting */
bool
canrlock(RWlock *q)
{
    lock(&q->use);
    rwstats.rlock++;
    if(q->writer == false && q->head == nil){
        /* no writer, go for it */
        q->readers++;
        unlock(&q->use);
        return true;
    }
    unlock(&q->use);
    return false;
}
@ 

\section{Atomic [[Ref]]erences and [[Counter]]}

%claude:
We already saw [[arch_xinc()]]/[[arch_xdec()]], which
atomically adjust a raw counter. [[Ref]] below wraps a counter
with a [[Lock]] instead of using [[arch_xinc]] directly.
This may seem redundant. However,
the [[Lock]] does allow [[decref()]] to additionnally and atomically check
for underflow and panic. But the main reason is likely
historical: [[Ref]] is portable code (in [[port/]]) that
predates the arch-specific atomic operations, and using
a [[Lock]] keeps it independent of any particular
architecture's atomic primitives.

<<struct [[Ref]]>>=
// For reference counting shared things (e.g. a Page)
struct Ref
{
    long ref;

    Lock;
};
@ 

<<function [[incref]]>>=
long
incref(Ref *r)
{
    long x;

    lock(r);
    x = ++r->ref;
    unlock(r);
    return x;
}
@ 


<<function [[decref]]>>=
long
decref(Ref *r)
{
    long x;

    lock(r);
    x = --r->ref;
    unlock(r);
    if(x < 0)
        panic("decref pc=%#p", getcallerpc(&r));
    return x;
}
@ 

%claude:
Many kernel objects (pages, channels, segments) embed a
[[Ref]] for reference counting---the object is freed when
[[decref()]] returns~0.

<<struct [[Counter]]>>=
typedef struct Ref Counter;
@ 
