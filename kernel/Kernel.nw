%yoann: explain goal and signature of vmemchr
%claude:
[[vmemchr()]] is a validated [[memchr()]]---it searches
for character [[c]] in the user buffer starting at [[s]]
for up to [[n]] bytes, checking that each page is valid
as it crosses page boundaries. This is needed because a
user buffer may span multiple pages, some of which might
not be mapped yet:

% v for verified? validated?

% used by sysexec() and other syscalls
% memchr on virtual address? and so that can span different pages, and 
% even different segments! can generate faults? I think so.
\l user_vp or virt_vp?
<<function [[vmemchr]]>>=
/*
 * &s[0] is known to be a valid address.
 */
void*
vmemchr(user_vp s, int c, int n)
{
    int m;
    user_addr a;
    user_vp t;

    a = (user_addr)s;
    while(PGROUND(a) != PGROUND(a+n-1)){
        /* spans pages; handle this page */
        m = BY2PG - (a & (BY2PG-1));
        t = memchr((void*)a, c, m);
        if(t)
            return t;
        a += m;
        n -= m;
        if(a < KZERO)
            validaddr(a, 1, false);
    }

    /* fits in one page */
    return memchr((void*)a, c, n);
}
