%claude:
When a user process executes a floating point instruction with the FPU
disabled, the CPU raises an ``undefined instruction'' exception. The
trap handler calls [fpuemu], which is the entry point for the lazy
FPU scheme. It checks whether the faulting instruction is actually a
VFP operation (using [[ISVFPOP]]), and if so calls [mathemu] to
enable the FPU and let the instruction be retried. The [fpstuck]
function is a debugging safeguard: if the same process faults
repeatedly at the same PC, something is wrong and the kernel panics
rather than looping forever.

<<function [[fpuemu]](arm)>>=
/* only called to deal with user-mode instruction faults */
int
fpuemu(Ureg* ureg)
{
    int s, nfp, cop, op;
    uintptr pc;

    if(waserror()){
        postnote(up, 1, up->errstr, NDebug);
        return 1;
    }

    if(up->fpstate & FPillegal)
        error("floating point in note handler");

    nfp = 0;
    pc = ureg->pc;
    validaddr(pc, 4, 0);
    if(!condok(ureg->psr, *(ulong*)pc >> 28))
        iprint("fpuemu: conditional instr shouldn't have got here\n");
    op  = (*(ulong *)pc >> 24) & MASK(4);
    cop = (*(ulong *)pc >>  8) & MASK(4);
    if(cpu->fpon)
        fpstuck(pc);        /* debugging; could move down 1 line */
    if (ISVFPOP(cop, op)) {  /* if vfp, fpu must be off */
        mathemu(ureg);      /* enable fpu & retry */
        nfp = 1;
    }

    poperror();
    return nfp;
}
@

