\subsection{[[arch_mmuswitch()]] (ARM)}

%claude:
On each context switch, [[arch_mmuswitch()]] installs
the new process's hardware page tables. It clears the
user portion of the L1, repopulates it from the
process's [[mmul2]] list, and invalidates the TLB.
If the pager modified the process's pages while it was
asleep ([[newtlb]] flag), the L2 pages are also cleared.

<<[[Cpu]] [[Arch]] mmu fields(arm)>>=
int mmupid;
@

<<function [[arch_mmuswitch]](arm)>>=
void
arch_mmuswitch(Proc* proc)
{
    int x;
    PTE *l1;
    Page *page;

    /* do kprocs get here and if so, do they need to? */
/*** "This is plausible, but wrong" - Charles Forsyth 1 Mar 2015
    if(cpu->mmupid == proc->pid && !proc->newtlb)
        return;
***/
    cpu->mmupid = proc->pid;

    <<[[arch_mmuswitch()]] write back and invalidate cache before switch(arm)>>

    if(proc->newtlb){
        mmul2empty(proc, 1);
        proc->newtlb = false;
    }

    mmul1empty();

    /* move in new map */
    l1 = cpu->mmul1;
    for(page = proc->mmul2; page != nil; page = page->next){
        x = page->daddr;
        l1[x] = PPN(page->pa)|Dom0|Coarse;
        /* know here that L1lo < x < L1hi */
        if(x+1 - cpu->mmul1lo < cpu->mmul1hi - x)
            cpu->mmul1lo = x+1;
        else
            cpu->mmul1hi = x;
    }

    <<[[arch_mmuswitch()]] write back cache after adjusting page tables(arm)>>

    /* lose any possible stale tlb entries */
    mmuinvalidate();
}
@



