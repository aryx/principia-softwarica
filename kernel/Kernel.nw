% union mount, but will see later. Can aspectize? maybe too hard.

<<destructor [[mountfree]]>>=
void
mountfree(Mount *m)
{
    Mount *f;

    while(m) {
        f = m->next;
        cclose(m->to);
        m->mountid = 0;
        free(m->spec);
        free(m);
        m = f;
    }
}
