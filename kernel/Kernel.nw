%  and will see the different device driver owner of the files

\section{[[Soc]] and [[soc]] (ARM)}

%claude:
The [[Soc]] structure captures the hardware specifics of
the System-on-Chip: how much DRAM, where the I/O registers
start, and various MMU and bus parameters. It is the single
place where the differences between Raspberry Pi~1 and Pi~2
are recorded:
<<struct [[Soc]](arm)>>=
struct Soc {            /* SoC dependent configuration */
    ulong   dramsize;
    phys_addr physio;
    <<[[Soc]] bus fields>>
    <<[[Soc]] mmu fields>>
    <<[[Soc]] other fields>>
};
@

<<global [[soc]](raspberry pi1)(arm)>>=
Soc soc = {
    .dramsize   = 512*MiB,    // 0 to 0x20000000
    .physio     = 0x20000000, // after RAM
    <<[[soc(raspberry pi1)]] other fields(arm)>>
};
@
