% when called from ibrk() we know s->ref == 1, so the procflushseg
% is really used only for extra segment and people using segfree()
<<function [[mfreeseg]]>>=
/*
 *  called with s->lk locked
 */
void
mfreeseg(Segment *s, ulong start, int pages)
{
    int i, j, size;
    ulong soff;
    PageOrSwap *pg;
    Page *list;

    soff = start-s->base;
    j = (soff&(PAGETABMAPMEM-1))/BY2PG; // PTX

    size = s->pagedirsize;
    list = nil;
    for(i = soff/PAGETABMAPMEM; i < size; i++) { // PDX
        if(pages <= 0)
            break;
        if(s->pagedir[i] == nil) { // space was never accessed, good, easier
            pages -= PAGETABSIZE-j;
            j = 0;
            continue;
        }
        while(j < PAGETABSIZE) {
            pg = s->pagedir[i]->pagetab[j];
            /*
             * We want to zero s->pagedir[i]->page[j] and putpage(pg),
             * but we have to make sure other processors flush the
             * entry from their TLBs before the page is freed.
             * We construct a list of the pages to be freed, zero
             * the entries, then (below) call procflushseg, and call
             * putpage on the whole list.
             *
             * Swapped-out pages don't appear in TLBs, so it's okay
             * to putswap those pages before procflushseg.
             */
            if(pg){
                <<[[mfreeseg]] if pg is a swap address>>
                else{
                    pg->next = list;
                    list = pg;
                }
                s->pagedir[i]->pagetab[j] = nil;
            }
            if(--pages == 0)
                goto out;
            j++;
        }
        j = 0;
    }
out:
    <<[[mfreeseg()]] if segment was shared, flush it>>
    /* free the pages */
    for(pg = list; pg != nil; pg = list){
        list = list->next;
        putpage(pg);
    }
}
@



%******************************************************************************
\chapter{Processes}
%******************************************************************************
\label{chap:processes}

%claude:
In this chapter, I will present the process lifecycle: how
processes are allocated, created ([[rfork]]), loaded with a
new program ([[exec]]), how a parent waits for children
([[await]]), and how processes terminate ([[exits]]).
These four syscalls are the foundation of \plan's process
model.

<<[[systab]] process syscalls>>=
[RFORK]     sysrfork,
[EXEC]      sysexec,
[AWAIT]     sysawait,
[EXITS]     sysexits,
@

\section{Overview}

% fork/exec Unix model!
% powerful. Can do pipe easily by forking, modifying env, and then exec.

% plan9 use rfork vs fork because can fork different ressources, not
% just process (memory, file descriptor, namespace!)
% very general, very powerful (e.g., sandboxing is trivial, see Section~\ref{X})

% plan9 also introduced exits with a string! not error code.

% await also subtle. Can wait for children and children for parent.
% Note that wait in parent will remember if children already finished!
%claude:
\plan inherits the \unix\ {fork/exec} model: [[rfork]]
creates a child process (a copy of the parent), and [[exec]]
replaces the child's memory with a new program. This
two-step approach is powerful---between the fork and the
exec, the child can set up pipes, redirect files, or
modify its namespace before running the new program.
%claude: %unix:
\plan generalizes \unix\ [[fork]] into [[rfork]] (``resource
fork''): instead of always copying everything, [[rfork]]
takes flags that independently control which resources to
copy, share, or create fresh---memory, file descriptors,
namespace, environment, notes, and rendezvous group.
A traditional [[fork]] is [[rfork]] with everything copied;
a thread (shared memory) is [[rfork]] with [[RFMEM]] set.
Sandboxing is trivial with [[RFNOMNT]]: the child gets a
fresh namespace where [[mount]] and [[bind]] are forbidden,
so it cannot reach any file server the parent does not
explicitly pass. This achieves what Linux needs [[chroot]]
jails or Docker containers for---but as a simple flag to
[[rfork]], with no extra kernel infrastructure.




%real-world: Windows sucks for this. no fork/exec but many exec (lack
% of orthogonality)
%linux: zombie processes? Can happen in plan9?

\section{Process allocation}

%linux: used to be static array. Configured at compile-time?
%xv6: use static array
%claude:
The [[Proc]] structure is large and long-lived, so processes
are pre-allocated in a pool during boot rather than malloc'd
on each fork. The pool is an array of [[conf.nproc]] entries
(up to 2000), allocated by [[xalloc]] during initialization.
A free list threads through unused entries, and a hash table
provides fast pid-to-process lookup.

\subsection{Process ID: [[Proc.pid]]}

%yoann: explain pid is fundamental and need be unique so pidalloc below and use Counter (Ref) for exclusive access
%claude:
Every process needs a unique identifier. The [[pid]] field
holds it, and [[pidalloc]] (a [[Counter]], i.e., a [[Ref]])
ensures uniqueness: each [[newproc()]] call atomically
increments it to get a fresh value.

<<[[Proc]] state fields>>=
ulong pid;
@
% could have introduced before in Core chapter?

<<global [[pidalloc]]>>=
static Counter  pidalloc;
@




\subsection{[[Procalloc]]}

%claude:
The process allocator is a simple pool: an [[xalloc]]'ed
array of [[Proc]] structures ([[arena]]) and a free list
([[free]]) threaded through [[Proc.qnext]]. When a process
exits, it is returned to the free list for reuse:

<<struct [[Procalloc]]>>=
// Process allocator
struct Procalloc
{
    // array<Proc>, xalloc'ed in procinit() (conf.nproc)
    Proc* arena;
    // list<ref<Proc>> (next = Proc.qnext)
    Proc* free;

    <<[[Procalloc]] other fields>>
  
    // extra
    Lock;
};
@ 
%ocaml: Do not use special allocator? just use ocaml alloc and Gc to cleanup
% (slower, more fragmentation, but ok)

<<global [[procalloc]]>>=
static struct Procalloc procalloc;
@ 
%ocaml: can reuse name 'allocator' (could also here because static)

% Use special allocator where pre-allocated all proc because procs
% are big long-lived structures, so want xalloc all of them.

% reuse proc, but increment pidalloc each time, so 
% if have ref to Proc, can save pid and make sure when resume
% that the pid is the same. if not, means proc died and got reused.

\subsection{PID hashing}

% this is used to get from pid to the Proc. For instance
% useful in /proc/x/... to get the Proc of x.
%claude:
The kernel needs to look up a [[Proc]] by pid (e.g., when
accessing [[/proc/x/...]]). A linear scan of the arena
would be slow, so [[Procalloc]] includes a hash table of
128 buckets chained through [[Proc.pidhash]]:

<<[[Procalloc]] other fields>>=
// hash<Proc.pid, ref<Proc>> (next = Proc.pidhash)>
Proc* ht[128];
@
%ocaml: use a Hashtbl directly

<<[[Proc]] extra fields>>=
// hash<Proc.pid, ref<Proc>> Procalloc.ht
Proc  *pidhash; /* next proc in pid hash */ 
@
%ocaml: use a Hashtbl directly

% define phash(p) p->pid%nelem(procalloc.ht) ?

<<function [[pidhash]]>>=
static void
pidhash(Proc *p)
{
    int h;

    h = p->pid % nelem(procalloc.ht);
    lock(&procalloc);
    // add_hash(procalloc.ht, p->pid, p)
    p->pidhash = procalloc.ht[h];
    procalloc.ht[h] = p;
    unlock(&procalloc);
}
@ 
%ocaml: Hashtbl.add

<<function [[pidunhash]]>>=
static void
pidunhash(Proc *p)
{
    int h;
    Proc **l;

    h = p->pid % nelem(procalloc.ht);
    lock(&procalloc);
    // remove_hash(procalloc.ht, p->pid, p)
    for(l = &procalloc.ht[h]; *l != nil; l = &(*l)->pidhash)
        if(*l == p){
            *l = p->pidhash;
            break;
        }
    unlock(&procalloc);
}
@ 
%ocaml: Hashtbl.remove

%yoann: explain goal of procindex
%claude:
[[procindex()]] translates a pid into an index in the
[[procalloc.arena]] array. It is used by [[devproc]] to
implement [[/proc/\emph{pid}/...]]:

<<function [[procindex]]>>=
int
procindex(ulong pid)
{
    Proc *p;
    int h;
    int s;

    s = -1;
    // hash_lookup(pid, procalloc.ht)
    h = pid % nelem(procalloc.ht);
    lock(&procalloc);
    for(p = procalloc.ht[h]; p != nil; p = p->pidhash)
        if(p->pid == pid){
            s = p - procalloc.arena;
            break;
        }
    unlock(&procalloc);
    return s;
}
@
