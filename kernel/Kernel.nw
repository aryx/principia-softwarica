\subsection{[[cpu]] initialization}

%claude:
[[arch__cpu0init()]] initializes the boot CPU's [[Cpu]]
structure: sets [[cpuno]] to~0, registers it in the
[[cpus]] array, and clears [[up]] (no process running
yet). [[machon()]] then marks this CPU as active in the
[[Active]] bitmap so the scheduler knows it exists:

% not portable code, because (arm), but in practice most archi have same code
% and manipulate only port data-structure

<<function [[arch__cpu0init]](arm)>>=
void
arch__cpu0init(void)
{
    conf.ncpu = 0; // set in machon() instead (machon() is called after cpuinit)

    cpu->cpuno = 0;
    cpus[cpu->cpuno] = cpu;

    arch__cpuinit();
    active.exiting = false;

    up = nil;
}
@

<<function [[arch__cpuinit]](arm)>>=
void
arch__cpuinit(void)
{
    Cpu *cpu0;

    cpu->ticks = 1;
    cpu->perf.period = 1;

    cpu0 = CPUS(0);
    <<[[arch__cpuinit()]] it not cpu0>>
}
@
% done later:   //machon(m->cpuno);
%old: m0 -> cpu0
%dead:        cpu->delayloop = m0->delayloop;

% now wait that mmuinit1 has been called.
<<function [[machon]](arm)>>=
/* enable scheduling of this cpu */
void
machon(uint xcpu)
{
    ulong cpubit;

    cpubit = 1 << xcpu;
    lock(&active);
    if ((active.cpus & cpubit) == 0) {  /* currently off? */
        conf.ncpu++;
        active.cpus |= cpubit;
    }
    unlock(&active);
}
@
