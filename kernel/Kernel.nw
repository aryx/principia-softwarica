\subsection{Paging in}

%claude:
A page table entry is ``paged out'' if it is either
[[nil]] (never loaded---demand loading) or marked as
a swap address ([[onswap]]). In both cases, [[pio()]]
must read data from disk before the page can be used:

<<function [[pagedout]]>>=
#define pagedout(s) (((ulong)s)==0 || onswap(s))
@
% demand loading or on swap


<<[[fixfault()]] page in for [[SG_TEXT]] pte if pagedout>>=
if(pagedout(*pte))
    pio(s, addr, soff, pte);
@

<<[[fixfault()]] page in for [[SG_DATA]] or swapin ([[SG_BSS]], etc) pte if pagedout>>=
if(pagedout(*pte))
    pio(s, addr, soff, pte);
@



%claude:
[[pio()]] (``page I/O'') loads a page from disk. It
first checks the page cache ([[lookpage()]])---if the
page is already cached, no I/O is needed. Otherwise, it
allocates a fresh page, reads the data from the
executable's channel (or the swap file), and adds the
page to the cache. The segment lock ([[s->lk]]) is
released during the I/O to avoid blocking other
processes; this creates a race (another process might
fault on the same page), which is handled by rechecking
after re-acquiring the lock.

% called by fixfault
% actually p is more SwapOrNil than PageOrSwap
<<function [[pio]]>>=
void
pio(Segment *s, virt_addr addr, ulong soff, PageOrSwap **p)
{
    Page *new;
    Arch_KMap *k;
    Chan *c;
    int n, ask;
    char *kaddr;
    ulong daddr; // disk address
    Page *loadrec;

retry:
    loadrec = *p;

    if(loadrec == nil) {  /* from a text/data image */
        daddr = s->fstart+soff;
        new = lookpage(s->image, daddr);
        if(new != nil) {
            *p = new;
            return;
        }

        c = s->image->c;
        ask = s->flen-soff;
        if(ask > BY2PG)
            ask = BY2PG;
    }else{          /* from a swap image */
        daddr = swapaddr(loadrec);
        new = lookpage(&swapimage, daddr);
        if(new != nil) {
            putswap(loadrec);
            *p = new;
            return;
        }
        c = swapimage.c;
        ask = BY2PG;
    }
    qunlock(&s->lk);

    new = newpage(false, nil, addr);
    k = arch_kmap(new);
    kaddr = (char*)VA(k);

    while(waserror()) {
        if(strcmp(up->errstr, Eintr) == 0)
            continue;
        arch_kunmap(k);
        putpage(new);
        faulterror(Eioload, c, false);
    }

    // reading the Page!! slow! which is why it's done without s->lk locked
    n = devtab[c->type]->read(c, kaddr, ask, daddr);

    if(n != ask)
        faulterror(Eioload, c, false);
    if(ask < BY2PG)
        memset(kaddr+ask, 0, BY2PG-ask);

    poperror();
    arch_kunmap(k);
    qlock(&s->lk);

    if(loadrec == nil) {  /* This is demand load */
        /*
         *  race, another proc may have gotten here first while
         *  s->lk was unlocked
         */
        if(*p == nil) { 
            new->daddr = daddr;
            cachepage(new, s->image);
            *p = new;
        }
        else
            putpage(new);
    }else{          /* This is paged out */
        /*
         *  race, another proc may have gotten here first
         *  (and the pager may have run on that page) while
         *  s->lk was unlocked
         */
        if(*p != loadrec){
            if(!pagedout(*p)){
                /* another process did it for me */
                putpage(new);
                goto done; // =~ return, just need adjust cachectl before
            } else {
                /* another process and the pager got in */
                putpage(new);
                goto retry;
            }
        }

        new->daddr = daddr;
        cachepage(new, &swapimage);
        *p = new;
        putswap(loadrec);
    }
done:
<<[[pio()]] set cachectl if flushme segment>>
}
