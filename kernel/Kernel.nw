\subsubsection{Halting}

%claude:
When a CPU has nothing to run, [[arch_idlehands]] could use WFI (Wait
For Interrupt) to save power. However, WFI is disabled on the Pi~2
because local timer interrupts can be lost, causing the CPU to hang.

<<function [[arch_idlehands]](raspberry pi2)(arm)>>=
TEXT arch_idlehands(SB), $-4
    MOVW    CPSR, R3
    ORR $(PsrDirq|PsrDfiq), R3, R1      /* splfhi */
    MOVW    R1, CPSR

    DSB
    MOVW    nrdy(SB), R0
    CMP $0, R0
/*** with WFI, local timer interrupts can be lost and dispatching stops
    WFI_EQ
***/
    DSB

    MOVW    R3, CPSR            /* splx */
    RET
@
%$

<<instruction [[WFI_EQ]](arm)>>=
#define WFI_EQ  WORD    $0x0320f003 /* wait for interrupt if eq */
@
%$
%dead: #define WFI WORD    $0xe320f003 /* wait for interrupt */


\subsection{Setting [[cpu]]}

%claude:
On a uniprocessor, the [[cpu]] pointer lives at a fixed address
([[CPUADDR]]) and never changes. With SMP, each exception handler
must figure out which CPU it is running on and load the correct
[[Cpu]] pointer. The CPUID macro reads the multiprocessor ID
register, and the result indexes into the [[cpus]] array.
This code appears in both [[_vsvc]] (syscall entry) and
[[_vswitch]] (trap from user mode).

<<[[_vsvc()]] set cpu register(arm)>>=
CPUID(R1)
SLL $2, R1          /* convert to word index */
MOVW    $cpus(SB), R2
ADD R1, R2
MOVW    (R2), R(CPU)        /* m = cpus[cpuid] */
CMP $0, R(CPU)
MOVW.EQ $CPUADDR, R0        /* paranoia: use CPUADDR if 0 */
@

<<[[_vswitch()]] set cpu register(arm)>>=
CPUID(R1)
SLL $2, R1          /* convert to word index */
MOVW    $cpus(SB), R2
ADD R1, R2
MOVW    (R2), R(CPU)        /* m = cpus[cpuid] */
CMP $0, R(CPU)
MOVW.EQ $CPUADDR, R0        /* paranoia: use CPUADDR if 0 */
@
% This is when comes from trap from user mode.
% If trap from kernel code, no need set R(CPU)

\subsection{Concurrency adjustments}

%claude:
The Pi~1's [[arch_tas]] uses the SWP instruction, which is deprecated
on ARMv7 and does not work correctly on multiprocessors. The Pi~2
replaces it with the LDREX/STREX (load/store exclusive) pair, which
provides true atomic compare-and-swap via the cache coherency
protocol. LDREX loads a value and marks the cache line as
``exclusive''; STREX stores a new value only if the line is still
exclusive, returning success or failure. If another CPU touched
the same cache line in between, STREX fails and the code retries.
DMB (data memory barrier) instructions bracket the sequence to
ensure proper ordering.

<<instruction LDREX(arm)>>=
#define LDREX(fp,t)   WORD $(0xe<<28|0x01900f9f | (fp)<<16 | (t)<<12)
@
<<instruction STREX(arm)>>=
/* `The order of operands is from left to right in dataflow order' - asm man */
#define STREX(f,tp,r) WORD $(0xe<<28|0x01800f90 | (tp)<<16 | (r)<<12 | (f)<<0)
@
% >> >> >> >>

<<instruction CLREX(arm)>>=
#define CLREX   WORD    $0xf57ff01f
@
%$


<<instruction DMB(arm)>>=
#define DMB WORD    $0xf57ff05f /* data mem. barrier; last f = SY */
@

<<function [[arch_tas]](raspberry pi2)(arm)>>=
TEXT    arch_tas(SB), $-4
    /* returns old (R0) after modifying (R0) */
    MOVW    R0,R5
    DMB

    MOVW    $1,R2       /* new value of (R0) */
    MOVW    $MAXSC, R8
tas1:
    LDREX(5,7)      /* LDREX 0(R5),R7 */
    CMP.S   $0, R7      /* old value non-zero (lock taken)? */
    BNE lockbusy    /* we lose */
    SUB.S   $1, R8
    BEQ lockloop2
    STREX(2,5,4)        /* STREX R2,(R5),R4 */
    CMP.S   $0, R4
    BNE tas1        /* strex failed? try again */
    DMB
    B   tas0
lockloop2:
    BL  abort(SB)
lockbusy:
    CLREX
tas0:
    MOVW    R7, R0      /* return old value */
    RET
@
%$

\subsection{Timer adjustments}

%claude:
On the Pi~1, there is a single system timer shared by the one CPU.
On the Pi~2, CPU~0 still uses the system timer, but the secondary
CPUs use the ARM generic timer (a per-CPU countdown timer accessed
via coprocessor 14). CPU~0 configures the prescaler to produce a
1~MHz tick, and each secondary CPU enables its own local timer
interrupt via [[arch_intrenable]] with the [[IRQcntpns]] vector.

<<constant [[Localctl]](arm)>>=
Localctl    = 0x00,
@
<<constant [[Prescaler]](arm)>>=
Prescaler   = 0x08,
@
<<[[clockinit()]] if many processors>>=
if(((cprdsc(0, CpID, CpIDfeat, 1) >> 16) & 0xF) != 0) {
    /* generic timer supported */
    if(cpu->cpuno == 0){
        *(ulong*)(ARMLOCAL + Localctl) = 0;             /* magic */
        *(ulong*)(ARMLOCAL + Prescaler) = 0x06aaaaab;   /* magic for 1 Mhz */
    }
    cpwrsc(0, CpTIMER, CpTIMERphys, CpTIMERphysctl, Imask);
}
@
% the magic 0x06aaaaab is mentioned page 4 in
% https://www.raspberrypi.org/documentation/hardware/raspberrypi/bcm2836/QA7_rev3.4.pdf
% It generates a divided of 19.2 which maybe related to the fact that
% the frequency of a crystal is 19.2Mgz

<<[[clockinit()]] if not cpu0>>=
else
    arch_intrenable(IRQcntpns, localclockintr, nil, 0, "clock");
@

<<function [[localclockintr]](arm)>>=
static void
localclockintr(Ureg *ureg, void *)
{
    if(cpu->cpuno == 0)
        panic("cpu0: Unexpected local generic timer interrupt");
    cpwrsc(0, CpTIMER, CpTIMERphys, CpTIMERphysctl, Imask|Enable);
    timerintr(ureg, 0);
}
@

<<function [[arch_lcycles]](raspberry pi2)(arm)>>=
TEXT arch_lcycles(SB), 1, $-4
    MRC CpSC, 0, R0, C(CpCLD), C(CpCLDcyc), 0
    RET
@
%$


<<[[arch_timerset()]] if not cpu0(arm)>>=
if(cpu->cpuno > 0){
    cpwrsc(0, CpTIMER, CpTIMERphys, CpTIMERphysval, period);
    cpwrsc(0, CpTIMER, CpTIMERphys, CpTIMERphysctl, Enable);
}
@


