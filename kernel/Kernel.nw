    // enum<mount>, but mainly for MCREATE, the MBEFORE|MAFTER is encoded via list
    int mflag;

    // option<string>
    char  *spec; // for mount(), nil for bind()
    <<[[Mount]] other fields>>

    <<[[Mount]] extra fields>>
};
