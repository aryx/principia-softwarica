%yoann: maybe transition paragraph saying following functions are mostly about double linked list management in palloc around prev/next head/tail fields
%claude:
The following functions manage [[palloc]]'s doubly-linked
free page list via the [[prev]]/[[next]] pointers in
[[Page]] and the [[head]]/[[tail]] pointers in [[Palloc]]:

<<function [[pageunchain]]>>=
// assumes palloc is held
static void
pageunchain(Page *p)
{
    if(canlock(&palloc))
        panic("pageunchain (palloc %p)", &palloc);

    // remove_queue(p, palloc);
    if(p->prev)
        p->prev->next = p->next;
    else
        palloc.head = p->next;
    if(p->next)
        p->next->prev = p->prev;
    else
        palloc.tail = p->prev;
    p->prev = p->next = nil;

    palloc.freecount--;
}
@
%ocaml: use generic function for double linked list

<<destructor [[putpage]]>>=
void
putpage(PageOrSwap *p)
{
    <<[[putpage]] if p is a swap address>>

    lock(&palloc);
    lock(p);

    if(p->ref == 0)
        panic("putpage");

    if(--p->ref > 0) {
        unlock(p);
        unlock(&palloc);
        return;
    }
    // else
    <<[[putpage]] if p has an image>>
    else 
        pagechainhead(p);

    <<[[putpage]] wakeup process waiting for freepage if any>>
    unlock(p);
    unlock(&palloc);
}
@
