\section{Page fault}

% see also trapinit()

% addr be kernel (virtual) address or user (virtual) address?
% can it be kernel address? I don't think so. should panic in that case
% at least to understand.

%claude:
This is where interrupt handling meets memory management.
When a data abort or prefetch abort reaches [[arch__trap()]],
it calls [[faultarm()]] with the faulting address. The
call chain is:
\begin{verbatim}
  faultarm(ARM) -> fault(portable) -> fixfault(portable)
                                          -> arch_putmmu(ARM)
\end{verbatim}
%claude:
The ARM-specific code extracts the faulting address and
determines read vs.\ write; the portable code decides
what to do about it.

\subsection{[[faultarm()]] (ARM)}

%claude:
[[faultarm()]] is the ARM-specific wrapper: it calls the
portable [[fault()]] function with the faulting address.
If [[fault()]] returns an error in user mode, a note is
posted (the process can handle it or will be killed);
if it is a kernel fault, the system panics.

% virt_addr here? can be from kernel??

% [interrupt] -> _vxxx -> vswitch -> trap -> <>
<<function [[faultarm]](arm)>>=
/*
 *  called by trap to handle access faults
 */
static void
faultarm(Ureg *ureg, virt_addr va, bool user, bool read)
{
    bool insyscall;
    int n;
    char buf[ERRMAX];

    if(up == nil) {
        //dumpregs(ureg);
        panic("fault: nil up in faultarm, pc %#p accessing %#p", ureg->pc, va);
    }
    insyscall = up->insyscall;
    up->insyscall = true; // ???
    <<[[faultarm()]] if debug>>
    n = fault(va, read); // portable code

    if(n < 0){
        if(!user){
            dumpregs(ureg);
            panic("fault: kernel accessing %#p", va);
        }
        /* don't dump registers; programs suicide all the time */
        snprint(buf, sizeof buf, "sys: trap: fault %s va=%#p",
            read? "read": "write", va);
        postnote(up, 1, buf, NDebug);
    }
    up->insyscall = insyscall;
}
@
% LP split hide error management code in first pass

% insyscall saving? means can have trap in a syscall itself?

\subsection{[[fault()]]}

%claude:
The portable [[fault()]] function finds which segment
contains the faulting address (via [<seg()>]) and calls
[[fixfault()]] to resolve it. The [[for(;;)]] loop
handles the case where [[fixfault()]] returns an error
because the segment was invalidated while waiting for
I/O---it simply retries.

% ret_code2?
% virt_addr here! can be from kernel??
<<function [[fault]]>>=
int
fault(virt_addr addr, bool read)
{
    Segment *s;
    char *sps;

    if(up == nil)
        panic("fault: nil up");
    if(up->nlocks.ref)
        print("fault: addr %#p: nlocks %ld\n", addr, up->nlocks.ref);

    sps = up->psstate;
    up->psstate = "Fault";
    arch_spllo();

    cpu->pfault++;
    for(;;) {
        s = seg(up, addr, /*dolock*/true); /* leaves s->lk qlocked if seg != nil */
        if(s == nil) {
            up->psstate = sps;
            return -1;
        }
        if(!read && (s->type&SG_RONLY)) {
            qunlock(&s->lk);
            up->psstate = sps;
            return -1;
        }

        if(fixfault(s, addr, read, /*putmmu*/true) == 0) /* qunlocks s->lk */
            break;

        // else? try again?
    }

    up->psstate = sps;
    return 0;
}
@
% why loop?

\subsection{[[fixfault()]]}

%claude:
[[fixfault()]] is the heart of virtual memory. It walks
the software segment tables to find (or create) the
[[Page]] for the faulting address, then calls
[[arch_putmmu()]] to install the mapping in the hardware
page table. What it does depends on the segment type:
\begin{verbatim}
  SG_TEXT:  demand-load from executable (read-only)
  SG_BSS:  allocate a zero-filled page
  SG_STACK: allocate a zero-filled page
  SG_DATA:  demand-load, or copy-on-write if shared
\end{verbatim}
%claude:
The [[PTEVALID]], [[PTERONLY]], and [[PTEWRITE]] flags
are software-defined bits that [[fixfault()]] passes to
[[arch_putmmu()]], which translates them into the
hardware AP bits ([[Uro]] or [[Urw]]):

% properties of 1 page, 1 byte
% PTE = page table entry, so spec about one page (also for entries in PD)
% Not hardware spec, but bits communicated from portable part of
% virtual memory to arch-specific hooks for virtual memory.

<<type [[PTExxx]]>>=
#define PTEVALID    (1<<0)
#define PTERONLY    0
#define PTEWRITE    (1<<1)
<<[[PTExxx]] other cases>>
@
%dead: #define PTEKERNEL   (1<<3)
\t mv earlier, and factorize across arch (was used in port/ code)
% need PTEVALID? not sure.

% pa is aligned at page, so can use low 12 bytes hence 1<<8
% in a PTE what is implicit is the va. the va is the index
% in the PD (Page Directory) + index in the PT (Page table)




% The big one! very important function!
%ret_code
<<function [[fixfault]]>>=
errorneg1
fixfault(Segment *s, virt_addr addr, bool read, bool doputmmu)
{
    int type;
    int ref;
    Pagetable **pde, *pt;
    Page **pte, *lkp, *new;
    ulong mmupte = nilptr;
    ulong soff;

    addr &= ~(BY2PG-1);
    soff = addr - s->base;

    // walk
    pde = &s->pagedir[soff/PAGETABMAPMEM];
    if(*pde == nil)
        *pde = ptalloc();
    pt = *pde;
    pte = &pt->pagetab[(soff&(PAGETABMAPMEM-1))/BY2PG];
    if(pte < pt->first)
        pt->first = pte;
    if(pte > pt->last)
        pt->last = pte;

    type = s->type&SG_TYPE;

    switch(type) {
    case SG_TEXT:           /* Demand load */
        <<[[fixfault()]] page in for [[SG_TEXT]] pte if pagedout>>

        mmupte = PPN((*pte)->pa) | PTERONLY|PTEVALID;
        (*pte)->modref = PG_REF;
        break;

    case SG_BSS:
    case SG_SHARED:         /* Zero fill on demand */
    case SG_STACK:
        if(*pte == nil) {
            new = newpage(true, &s, addr); // true so clear! zeroed BSS & heap!
            if(s == nil) //?? when can be nil at exit?
                return ERROR_NEG1;
            *pte = new;
        }
        goto common;

    case SG_DATA:
    common:         /* Demand load/pagein/copy on write */
        <<[[fixfault()]] page in for [[SG_DATA]] or swapin ([[SG_BSS]], etc) pte if pagedout>>

        <<[[fixfault()]] if read and copy on write, adjust mmupte and break>>
        // else

        lkp = *pte;

        lock(lkp);

        if(lkp->image == &swapimage)
            ref = lkp->ref + swapcount(lkp->daddr);
        else
            ref = lkp->ref;
        <<[[fixfault()]] if one ref and page has an image>>
        unlock(lkp);

        <<[[fixfault()]] if write and more than one ref then copy page>>

        mmupte = PPN((*pte)->pa) | PTEWRITE | PTEVALID;
        (*pte)->modref = PG_MOD|PG_REF;
        break;

    <<[[fixfault()]] [[SG_PHYSICAL]] case>>

    default:
        panic("fault");
        break;
    }
    qunlock(&s->lk);

    if(doputmmu)
        arch_putmmu(addr, mmupte, *pte);

    return OK_0;
}
@

% BSS filled with 0! very important and different from Linux.

\subsection{[[arch_putmmu()]] (ARM)}
% and back to ARM specific.
% faultarm(ARM) -> fault -> fixfault -> arch_putmmu(ARM)

%claude:
[[arch_putmmu()]] installs a mapping in the hardware page
table. If the L1 entry for this virtual address is
[[Fault]] (no L2 table yet), it allocates a page for the
L2 table (reusing one from the per-process [[mmul2cache]]
if available). It then writes the L2 entry with the
physical page address and the appropriate permission bits,
and invalidates the TLB entry for this address so the
MMU picks up the new mapping.

\t rename pa argument below to mmupte
% fixfault -> <>
<<function [[arch_putmmu]](arm)>>=
void
arch_putmmu(virt_addr va, phys_addr pa, Page* page)
{
    int x;
    Page *pg;
    PTE *l1, *pte;

    x = L1X(va);
    l1 = &cpu->mmul1[x];
    if(*l1 == Fault){
        /* wasteful - l2 pages only have 256 entries - fix */
        <<[[arch_putmmu()]] if mmul2cache not empty(arm)>>
        else{
            /* auxpg since we don't need much? memset if so */
            pg = newpage(true, nil, 0);
            pg->va = VA(arch_kmap(pg));
        }
        pg->daddr = x;

        //add_list(pg, up->mmul2)
        pg->next = up->mmul2;
        up->mmul2 = pg;

        <<[[arch_putmmu()]] write back cache before fixing va fault(arm)>>

        *l1 = PPN(pg->pa)|Dom0|Coarse;
        <<[[arch_putmmu()]] write back cache after changing pde(arm)>>

        <<[[arch_putmmu()]] maintain mmul1lo and mmul1hi(arm)>>
    }
    pte = UINT2PTR(KADDR(PPN(*l1)));

    /* protection bits are
     *  PTERONLY|PTEVALID;
     *  PTEWRITE|PTEVALID;
     *  PTEWRITE|PTEUNCACHED|PTEVALID;
     */
    x = Small;
    <<[[arch_putmmu()]] if PTEUNCACHED, do not change x(arm)>>
    else
        x |= L2ptedramattrs;

    if(pa & PTEWRITE)
        x |= L2AP(Urw);
    else
        x |= L2AP(Uro);

    pte[L2X(va)] = PPN(pa)|x;
    <<[[arch_putmmu()]] write back cache after changing pte(arm)>>

    /* clear out the current entry */
    mmuinvalidateaddr(PPN(va));

    /*  write back dirty entries - we need this because the pio() in
     *  fault.c is writing via a different virt addr and won't clean
     *  its changes out of the dcache.  Page coloring doesn't work
     *  on this mmu because the virtual cache is set associative
     *  rather than direct mapped.
     */
    <<[[arch_putmmu()]] if [[PG_TXTFLUSH]], invalidate cache(arm)>>
    arch_checkmmu(va, PPN(pa));
}
@

