        case Aaccess:
        case Aremove:
           <<[[namec()]] case Aremove, Aaccess, handle mountpoint part2>>
            break;
    
        }
        break;
    <<[[namec()]] other cases>>
    default:
        panic("unknown namec access %d\n", amode);
    }

    <<[[namec()]] set genbuf from Elemlist e>>

    <<[[namec()]] free Elemlist e>>
    poperror(); /* e c */
    free(aname);
    poperror(); /* aname */

    return c;
}
