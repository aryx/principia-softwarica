%Floating points (single and double) see Appendix X. 

% Those coprocessors have primary and secondary registers
% that are accessible via MRC instruction.
% C0, C1, etc. See \book{Assembler}.

\subsubsection{System control coprocessor ([[CpSC]])}

% Most important for kernel.
%claude:
The system control coprocessor ([[CpSC]], coprocessor~15) is
the most important for the kernel. Its registers control the
MMU ([[CpTTB]] for the page table base, [[CpTLB]] for TLB
management), report page faults ([[CpFSR]] for fault status,
[[CpFAR]] for the faulting address), and configure miscellaneous
features such as caches and the exception vector location.

<<type CpSC primary registers(arm)>>=
