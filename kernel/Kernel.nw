\section{The [[runq]]ueue}

%claude:
The run queue is an array of [[Nrq]] queues, one per
priority level. Each queue is a FIFO linked list of
[[Proc]] pointers. The bitmap [[runvec]] has bit~$i$ set
if [[runq[i]]] is non-empty, allowing [[runproc()]] to
quickly find the highest-priority non-empty queue:
\begin{verbatim}
  runq[19]:  (highest priority)
  runq[18]:
    ...
  runq[13]:  kproc1 -> kproc2
    ...
  runq[10]:  proc_A -> proc_B -> proc_C
    ...
  runq[0]:   (lowest priority)

  runvec = ... 0010_0000_0100_0000_0000  (bits 10, 13 set)
\end{verbatim}

<<constant [[Nrq]]>>=
Nrq   = Npriq+2,  /* number of priority levels including real time */
@
% +2 because of Edf real-time scheduling. See Chapter~\ref{chap:edf}.

<<global [[runq]]>>=
// The run queue!!
// hash<enum<priority>, queue<ref<Proc>>>
Schedq  runq[Nrq];
@ 
%ocaml: use only one lock for the whole runq and put related 
% runvec and nready in the same structure instead of separate globals.


<<struct [[Schedq]]>>=
// essentially a queue<ref<Proc>>
struct Schedq
{
    // list<ref<Proc>> (next = Proc.rnext)
    Proc* head;
    // ref<Proc>, the tail
    Proc* tail;
    // size of list
    int n; 
  
    // extra
    Lock; // protects also the globals nrdy and runvec
};
