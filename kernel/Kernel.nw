\section{[[DirEntry]]}

% also in libc.h (but called Dir there)
% so if change fields here, need to change also in libc.h but
% there are code like direntry_setname that compute offsets so safer to not change

%claude:
Where \unix\ uses numeric [[uid]]/[[gid]], \plan\ uses string usernames
directly in [[\hlink{DirEntry}]], eliminating the need for [[/etc/passwd]].
The structure is serialized into a platform-independent wire format
matching the 9P stat message.

<<struct [[DirEntry]]>>=
struct DirEntry {
  /* system-modified data */
  ushort  type; /* server type */
  uint  dev;  /* server subtype */

  /* file data */
  Qid qid;  /* unique id from server */
  // bitset<enum<dirmode>>
  ulong mode; /* permissions */

  ulong atime;  /* last read time */
  ulong mtime;  /* last write time */

  vlong length; /* file length: see <u.h> */
  char  *name;  /* last element of path */

  char  *uid; /* owner name */
  char  *gid; /* group name */
  char  *muid;  /* last modifier name */
};
@ 
