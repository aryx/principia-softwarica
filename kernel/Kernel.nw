\subsection{[[/env/]]}

%#e

%claude:
The [[ksetenv()]] function lets the kernel set environment variables
during initialization. It works by opening a file through [[namec()]]
using the device shorthand [[#e]] (or [[#ec]] for configuration
variables) and writing the value to it---the kernel uses its own
filesystem interface to talk to the environment device, treating
itself as just another client.

<<function [[ksetenv]]>>=
/*
 *  to let the kernel set environment variables
 */
void
ksetenv(char *ename, char *eval, bool conf)
{
    Chan *c;
    char buf[2*KNAMELEN];
    
    snprint(buf, sizeof(buf), "#e%s/%s", conf?"c":"", ename);
    c = namec(buf, Acreate, OWRITE, 0600);
    devtab[c->type]->write(c, eval, strlen(eval), 0);
    cclose(c);
}
@
