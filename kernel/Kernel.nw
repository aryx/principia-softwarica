\subsection{[[Sargs]]}

%claude:
The syscall arguments live on the user stack, but the
kernel copies them into [[Proc.sargs]] before dispatching.
This avoids repeated user-space accesses (which could
fault) and ensures the arguments cannot be modified by
another thread while the syscall is running.
[[MAXSYSARG]] is~5 because [[mount()]] has the most
parameters of any syscall:
[[mount(fd, afd, mpt, flag, arg)]].
<<constant [[MAXSYSARG]]>>=
#define MAXSYSARG  5 /* for mount(fd, afd, mpt, flag, arg) */
@
% used to be arch specific, but same value in every arch

<<struct [[Sargs]]>>=
// syscall arguments copied from user stack
struct Sargs
{
    ulong args[MAXSYSARG];
};
@ 

<<[[Proc]] other fields>>=
Sargs sargs;    /* address of this is known by db */
@ 
%old: s -> sargs

<<[[sysrfork()]] when [[RFPROC]] propagate fields from up to p>>=
p->sargs = up->sargs;
@

\subsection{[[arch__syscall()]] (ARM)}

% SWI -> EXCEPTION -> vectors -> vtable -> _vsvc -> <>
%claude:
[[arch__syscall()]] is the C-level syscall dispatcher,
called by [[_vsvc]] with a pointer to the saved [[Ureg]].
It extracts the syscall number from [[ureg->r0]], copies
the arguments from the user stack into [[up->sargs]],
calls [[systab[scallnr]()]], stores the return value in
[[ureg->r0]], and handles errors. Before returning, it
checks for pending notes ([[notify]]) and deferred
scheduling.
<<function [[arch__syscall]](arm)>>=
void
arch__syscall(Ureg* ureg)
{
    int scallnr;
    long ret;
    user_addr sp;
    <<[[syscall()]] other locals(arm)>>

    <<[[syscall()]] sanity check call from userspace(arm)>>
    <<[[syscall()]] adjust kentry>>

    cpu->syscall++;
    up->insyscall = true;

    up->pc = ureg->pc;
    up->dbgreg = ureg;

    // syscall number!
    scallnr = ureg->r0;
    //up->scallnr = scallnr;

    <<[[syscall()]] if RFORK, handle floating point(arm)>>

    arch_spllo();
    sp = ureg->sp;

    <<[[syscall()]] [[Proc_tracesyscall]] if, syscall entry(arm)>>

    up->nerrlab = 0;
    ret = -1;

    startns = todget(nil);
    if(!waserror()){
        <<[[syscall()]] sanity check scallnr(arm)>>
        <<[[syscall()]] sanity check sp(arm)>>

        // copy syscall arguments from user stack to up->sargs
        up->sargs = *((Sargs*)(sp+BY2WD)); // extra BY2WD for?
        up->psstate = sysctab[scallnr];

        //!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
        //IMPORTANT: The actual system call
        ret = systab[scallnr](up->sargs.args);
        //!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

        poperror();
    }else{
        /* failure: save the error buffer for errstr */
        e = up->syserrstr;
        up->syserrstr = up->errstr;
        up->errstr = e;
    }
    <<[[syscall()]] if nerrlab(arm)>>

    /*
     *  Put return value in frame.  On the x86 the syscall is
     *  just another trap and the return value from syscall is
     *  ignored.  On other machines the return value is put into
     *  the results register by caller of syscall.
     */
    ureg->r0 = ret;

    <<[[syscall()]] [[Proc_tracesyscall]] if, syscall exit(arm)>>

    up->insyscall = false;
    up->psstate = nil;

    <<[[syscall()]] call noted()>>
    <<[[syscall()]] call notify(arm)>>

    <<[[syscall()]] if delaysched(arm)>>
    arch__kexit(ureg);
}
@
%    /*  iprint("%s: syscall %s\n", up->text, sysctab[scallnr]?sysctab[scallnr]:"huh?"); */
