\subsection{[[echo()]]}

% double role! to add in kbdq and print on screen

%claude:
[echo] serves a dual purpose: it enqueues the keyboard bytes into
[[kbdq]] via [qproduce] so that processes reading [[/dev/cons]]
can consume them, and it echoes them back to the screen via the
[[screenputs]] hook so the user can see what they typed.
The [[screenputs]] function pointer is initially [[nil]] and gets
set later when the graphics subsystem initializes (e.g., to
[[swconsole_screenputs]] for framebuffer output or [[cgascreenputs]]
on x86). In raw mode, echoing is suppressed -- the characters still
go into [[kbdq]], but nothing is displayed, which is exactly what
programs like [[rio]] need when they handle their own display.

<<function [[echo]]>>=
static void
echo(char *buf, int n)
{
    <<[[echo()]] locals>>

    if(n == 0)
        return;

    <<[[echo()]] special keys handler>>

    qproduce(kbdq, buf, n); //!! add in kbd queue to be read from /dev/cons

    <<[[echo()]] return before any echoscreen if raw mode>>

    <<[[echo()]] hooks>>
}
@ 
% kbdq!!!!
% another special key handler ...

<<[[echo()]] hooks>>=
if(screenputs != nil)
   echoscreen(buf, n);
@

<<hook screenputs>>=
void    (*screenputs)(char*, int) = nil;
@ 
% see later set to cgascreenputs
%update: set to swconsole_screenputs which use framebuffer and libmemdraw!

<<function [[echoscreen]]>>=
static void
echoscreen(char *buf, int n)
{
    char *e, *p;
    char ebuf[128];
    int x;

    p = ebuf;
    e = ebuf + sizeof(ebuf) - 4;
    while(n-- > 0){
        if(p >= e){
            screenputs(ebuf, p - ebuf);
            p = ebuf;
        }
        x = *buf++;
        if(x == 0x15){ // ??
            *p++ = '^';
            *p++ = 'U';
            *p++ = '\n';
        } else
            *p++ = x;
    }
    if(p != ebuf)
        screenputs(ebuf, p - ebuf);
}
@ 
