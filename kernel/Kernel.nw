\subsection{[[tadd()/tdel()]]}

%claude:
[[tadd()]] inserts a timer into the sorted list (by
[[twhen]]). If the new timer becomes the head (earliest),
it returns the new deadline so the caller can reprogram
the hardware. [[tdel()]] removes a timer:

% timeradd | timerintr | addclock0link -> <>
<<function [[tadd]]>>=
static Tfast
tadd(Timers *tt, Timer *nt)
{
    Timer *t, **last;

    /* Called with tt locked */
    <<[[tadd()]] sanity check nt>>
    <<[[tadd()]] set [[nt->twhen]]>>

    // insert_sorted(nt, tt, (a->twhen <=> b->twhen))
    for(last = &tt->head; t = *last; last = &t->tnext){
        if(t->twhen > nt->twhen)
            break;
    }
    nt->tnext = *last;
    *last = nt;

    nt->tt = tt;
    if(last == &tt->head)
        return nt->twhen;
    return 0;
}
@ 
