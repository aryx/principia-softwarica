\subsection{Clock callbacks: [[addclock0link()]]}

%claude:
[[addclock0link()]] registers a periodic callback on
CPU~0's timer list. Device drivers use this to run
polling functions at regular intervals (e.g., checking
the Ethernet controller, updating the console). If
[[ms]] is~0, the callback runs at the [[hzclock]]
frequency (every 10~ms):

% very important! used a lot.

<<function [[addclock0link]]>>=
Timer*
addclock0link(void (*f)(void), Tms ms)
{
    Timer *nt;
    Tfast when;

    <<[[addclock0link()]] sanity check timersinit>>

    nt = malloc(sizeof(Timer));
    <<[[addclock0link()]] sanity check nt>>
    <<[[addclock0link()]] sanitize ms>>

    nt->tns = (Tnano)ms * 1000000LL; // MS2NS(ms)
    nt->tmode = Tperiodic;
    nt->tt = nil;
    nt->tf = (void (*)(Ureg*, Timer*))f;

    // those clock callbacks are all done on the bootstrap processor
    ilock(&timers[0]);
    when = tadd(&timers[0], nt);
    if(when)
        arch_timerset(when);
    iunlock(&timers[0]);
    return nt;
}
