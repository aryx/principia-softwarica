\section{[[waserror()]], [[nexterror()]], [[poperror()]]}
% waserror(), nexterror(), etc
% =~ poor's man exn mechanism (=> improve C!!)

%claude:
This is \plan's exception mechanism in C, built on
[[arch_setlabel]]/[[arch_gotolabel]] (the same primitives
used by the scheduler). [[waserror()]] pushes a label
onto a per-process stack and returns false.
If [[error()]] or [[nexterror()]] is later called, it
pops the stack and jumps back to the [[waserror()]]
call site, which now returns true---entering the
``catch'' branch. [[poperror()]] simply decrements the
stack when the protected code completes normally.

<<macro waserror poperror>>=
// poor's man exceptions in C
//  - waserror() =~ try  
//     * if (!waserror()) { } else { } <=> try { } catch { }
//     * if (waserror()) { }  <=> finally { }
//  - poperror() = nothing
//  - error() =~ raise
//  - nexterror() =~ re raise from exn handler
// note, arch_setlabel() return false, so the branch is never taken first
// but nexterror() is using arch_gotolabel() which returns true, see l_switch.s
#define waserror()  (up->nerrlab++, arch_setlabel(&up->errlab[up->nerrlab-1]))
#define poperror()    up->nerrlab--
@ 


<<function [[nexterror]]>>=
// raise an exception
void
proc_nexterror(void)
{
    arch_gotolabel(&up->errlab[--up->nerrlab]);
}
@ 


% different idioms:

% RAII: finally
% x = malloc();
% if(waserror() {
%   free(x);
%   nexterror();
% }
% ...

% try and swallow:
% if(!waserror() {
%   stuff_that_can_raise_error();
%   poperror();
% }
% ...

% try and catch
% if(!waserror() {
%   stuff_that_can_raise_error();
