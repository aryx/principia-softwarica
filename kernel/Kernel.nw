if((p = getconf("*maxmem")) != nil){
    memsize = strtoul(p, 0, 0);
    if (memsize < 16*MB)        /* sanity */
        memsize = 16*MB;
}
@

<<[[arch__confinit()]] sanity check [[conf.mem[0]]](arm)>>=
