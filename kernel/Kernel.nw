\subsection{malloc tags}

%yoann: intro of motivation for malloc tags and libc poolalloc probably again
%claude:
When [[Npadlong]] is nonzero, [[malloc()]] reserves extra
words {before} the returned pointer to store debugging tags:
the PC of the caller who did the [[malloc]] and the PC of
the last [[realloc]]. This lets the kernel (or a developer
inspecting a crash dump) figure out {who} allocated a given
block. The pool allocator in libc (see [[lib_core/libc/port/pool.c]])
provides the underlying bookkeeping; these tags are an
additional layer on top.

<<[[malloc()]] if Npadlong>>=
if(Npadlong){
    v = (ulong*)v+Npadlong;
    setmalloctag(v, getcallerpc(&size));
    setrealloctag(v, 0);
}
@



<<function [[setmalloctag]]>>=
void
setmalloctag(kern_vp v, kern_addr pc)
{
    kern_wp u;
    USED(v, pc); //??
    if(Npadlong <= MallocOffset || v == nil)
        return;
    u = v;
    u[-Npadlong+MallocOffset] = pc;
