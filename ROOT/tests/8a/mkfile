#TOP=../../..
#<$TOP/mkfiles/386/mkfile

hello: hello.8
     8l -o $target hello.8

%.8: %.s
     8a $prereq

clean nuke:V:
	rm -f *.8 8.out hello

# note: unlike 5i for ARM, this repo has no x86 interpreter (see
# machine/Machine.nw: "actually there is no 8i"), so there is no
# run:V: target here -- hello must be run under an actual Plan 9
# (e.g. the dosdisk.img/qemu setup).
