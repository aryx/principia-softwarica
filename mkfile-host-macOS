# This requires brew install dosfstools mtools

# similar to the one in mkfile-host-Linux

IMG=dosdisk.img
IMGSIZE=512 #in MB

disk-pc:V:
	rm -f $IMG
	dd 'if=/dev/zero' 'of=tmp.img' 'bs=1M' 'count='$IMGSIZE
	mkfs.vfat tmp.img
	mcopy -i tmp.img -s -o ROOT/* :: || echo skipped mcopy status
	cat MISC/pc/bootsector tmp.img > $IMG
	rm -f tmp.img

# for mk run, for qemu to be resizable because too small otherwise
QEMU_EXTRA_OPTIONS=-display cocoa,zoom-to-fit=on


