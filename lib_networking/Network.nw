nullbind(Ipifc*, int, char**)
{
    error("cannot bind null device");
}
@

<<function [[nullunbind]]>>=
static void
nullunbind(Ipifc*)
{
}
@

<<function [[nullbwrite]]>>=
static void
nullbwrite(Ipifc*, Block*, int, uchar*)
{
    error("nullbwrite");
}
@

