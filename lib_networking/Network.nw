            DPRINT("udp: checksum error %I\n", raddr);
            freeblist(bp);
            return;
        }
    }
    uh4->Unused = ottl;
    hnputs(uh4->udpplen, olen);
    break;

<<[[udpiput()]] checking checksum ipv6 case>>

default:
    panic("udpiput: version %d", version);
    return; /* to avoid a warning */
}
