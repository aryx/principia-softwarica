\subsubsection{Trim the packet}

<<[[udpiput()]] trim the packet, adjust bp removing header>>=
/*
 * Trim the packet down to data size
 */
len -= UDP_UDPHDR_SZ;
switch(version){
case V4:
    bp = trimblock(bp, UDP4_IPHDR_SZ+UDP_UDPHDR_SZ, len);
    break;
<<[[udpiput()]] trim the packet, ipv6 case>>
default:
