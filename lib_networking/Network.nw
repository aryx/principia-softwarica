% max conversation

% ipproto = -1 cos fake protocol, we will not receive any packet
% from the ethernet to be directed to this protocol (which is why
% also rcv is nil)

<<function [[Fsproto]]>>=
int
Fsproto(Fs *f, Proto *p)
{
    if(f->np >= Maxproto)
        return -1;

    p->f = f;

    <<[[Fsproto()]] adjust f->t2p>>

    p->conv = malloc(sizeof(Conv*) * (p->nc+1));
    if(p->conv == nil)
        panic("Fsproto");

    p->nextrport = 600;

    p->x = f->np;
    f->p[f->np++] = p;

    return 0;
}
