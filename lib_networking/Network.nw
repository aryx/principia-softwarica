<<constant [[UDP_USEAD7]]>>=
UDP_USEAD7  = 52,
@

<<[[udpkick()]] locals>>=
Udpcb *ucb;
ipaddr laddr, raddr;
ushort rport;
@

<<[[udpkick()]] special headers processing>>=
ucb = (Udpcb*)c->ptcl;
switch(ucb->headers) {
case 7:
    /* get user specified addresses */
    bp = pullupblock(bp, UDP_USEAD7);
    if(bp == nil)
        return;
    ipmove(raddr, bp->rp);
    bp->rp += IPaddrlen;
    ipmove(laddr, bp->rp);
    bp->rp += IPaddrlen;

    /* pick interface closest to dest */
    if(ipforme(f, laddr) != Runi)
        findlocalip(f, laddr, raddr);
    bp->rp += IPaddrlen;        /* Ignore ifc address */
    rport = nhgets(bp->rp);
    bp->rp += 2+2;          /* Ignore local port */
    break;
default:
    rport = 0;
    break;
}
@


