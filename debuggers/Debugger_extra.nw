<<function [[regname]]>>=
/*
 * collect a register name; return register offset
 * this is not what i'd call a good division of labour
 */

char *
regname(int regnam)
{
    static char buf[64];
    char *p;
    int c;

    p = buf;
    *p++ = regnam;
    while (isalnum(c = readchar())) {
        if (p >= buf+sizeof(buf)-1)
            error("register name too long");
        *p++ = c;
    }
    *p = 0;
    reread();
    return (buf);
}
