<<function [[system]]>>=
char*
system(void)
{
    char *cpu, *p, *q;
    static char *kernel;

    cpu = getenv("cputype");
    if(cpu == 0) {
        cpu = "mips";
        print("$cputype not set; assuming %s\n", cpu);
    }
    p = getenv("terminal");
    if(p == 0 || (p=strchr(p, ' ')) == 0 || p[1] == ' ' || p[1] == 0) {
        p = "ch";
        print("missing or bad $terminal; assuming %s\n", p);
    }
    else{
        p++;
        q = strchr(p, ' ');
        if(q)
            *q = 0;
    }

    if(kernel != nil)
        free(kernel);
    kernel = smprint("/%s/9%s", cpu, p);

    return kernel;
}
@


