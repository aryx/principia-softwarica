<<function [[rc]]>>=
void
rc(Node *r, Node *args)
{
    Node res;
    int pid;
    char *p, *q, *argv[4];
    Waitmsg *w;

    USED(r);
    if(args == 0)
        error("error(string): arg count");
    expr(args, &res);
    if(res.type != TSTRING)
        error("error(string): arg type");

    argv[0] = "/bin/rc";
    argv[1] = "-c";
    argv[2] = res.string->string;
    argv[3] = 0;

    pid = fork();
    switch(pid) {
    case -1:
        error("fork %r");
    case 0:
        exec("/bin/rc", argv);
        exits(0);
    default:
        w = waitfor(pid);
        break;
    }
    p = w->msg;
    q = strrchr(p, ':');
    if (q)
        p = q+1;

    r->op = OCONST;
    r->type = TSTRING;
    r->string = strnode(p);
