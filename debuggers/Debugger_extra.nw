<<function [[mapent]]>>=
List*
mapent(Map *m)
{
    int i;
    List *l, *n, **t, *h;

    h = 0;
    t = &h;
    for(i = 0; i < m->nsegs; i++) {
        if(m->seg[i].inuse == 0)
            continue;
        l = al(TSTRING);
        n = al(TLIST);
        n->l = l;
        *t = n;
        t = &n->next;
        l->string = strnode(m->seg[i].name);
        l->fmt = 's';
        l->next = al(TINT);
        l = l->next;
        l->ival = m->seg[i].b;
        l->fmt = 'W';
        l->next = al(TINT);
        l = l->next;
        l->ival = m->seg[i].e;
        l->fmt = 'W';
        l->next = al(TINT);
        l = l->next;
        l->ival = m->seg[i].f;
        l->fmt = 'W';
    }
    return h;
}
