pcline(Node *r, Node *args)
{
    Node res;
    char *p, buf[128];

    if(args == 0)
        error("pcline(addr): arg count");
    expr(args, &res);
    if(res.type != TINT)
        error("pcline(addr): arg type");

    r->type = TINT;
    r->fmt = 'D';
    if(fileline(buf, sizeof(buf), res.ival) == 0) {
        r->ival = 0;
        return;
    }

    p = strrchr(buf, ':');
    if(p == 0)
        error("pcline(addr): funny file %s", buf);
    r->ival = strtol(p+1, 0, 0);        
}
