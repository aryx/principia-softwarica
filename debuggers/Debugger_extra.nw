<<function [[fmtsize]]>>=
int
fmtsize(Value *v)
{
    int ret;

    switch(v->fmt) {
    default:
        return  fsize[v->fmt];
    case 'i':
    case 'I':
        if(v->type != TINT || machdata == 0)
            error("no size for i fmt pointer ++/--");
        ret = (*machdata->instsize)(cormap, v->ival);
        if(ret < 0) {
            ret = (*machdata->instsize)(symmap, v->ival);
            if(ret < 0)
                error("%r");
        }
        return ret;
    }
}
