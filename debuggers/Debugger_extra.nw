<<function [[oindex]]>>=
void
oindex(Node *n, Node *res)
{
    Node l, r;

    expr(n->left, &l);
    expr(n->right, &r);

    if(r.type != TINT)
        error("bad type for []");

    switch(l.type) {
    default:
        error("lhs[] has bad type");
    case TINT:
        indir(cormap, l.ival+(r.ival*fsize[l.fmt]), l.fmt, res);
        res->comt = l.comt;
        res->fmt = l.fmt;
        break;
    case TLIST:
        nthelem(l.l, r.ival, res);
        break;
    case TSTRING:
        res->ival = 0;
        if(r.ival >= 0 && r.ival < l.string->len) {
            int xx8;    /* to get around bug in vc */
            xx8 = r.ival;
            res->ival = l.string->string[xx8];
        }
        res->op = OCONST;
        res->type = TINT;
        res->fmt = 'c';
        break;
    }
}
@

<<function [[oappend]]>>=
void
oappend(Node *n, Node *res)
{
    Value *v;
    Node r, l;
    int  empty;

    expr(n->left, &l);
    expr(n->right, &r);
    if(l.type != TLIST)
        error("must append to list");
    empty = (l.l == nil && (n->left->op == ONAME));
    append(res, &l, &r);
    if(empty) {
        v = n->left->sym->v;
        v->type = res->type;
        v->Store = res->Store;
        v->comt = res->comt;
    }
}
@

