    if(args == 0)
        error("follow(addr): no addr");
    expr(args, &res);
    if(res.type != TINT)
        error("follow(addr): arg type");

    n = (*machdata->foll)(cormap, res.ival, rget, f);
    if (n < 0)
        error("follow(addr): %r");
    tail = &r->l;
    for(i = 0; i < n; i++) {
        l = al(TINT);
        l->ival = f[i];
        l->fmt = 'X';
        *tail = l;
        tail = &l->next;
    }
