<<function [[machbyname]]>>=
/*
 *      select a machine by name
 */
int
machbyname(char *name)
{
    Machtab *mp;

    // choose a default if no name given
    if (!name) {
        asstype = AARM;
        machdata = &armmach;
        mach = &marm;
        return 1;
    }
    for (mp = machines; mp->name; mp++){
        if (strcmp(mp->name, name) == 0) {
            asstype = mp->asstype;
            machdata = mp->machdata;
            mach = mp->mach;
            return 1;
        }
    }
    return 0;
}
