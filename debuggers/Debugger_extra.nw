<<function [[acidfmt]]>>=
static int
acidfmt(char *fmt, char *buf, int blen)
{
    char *r, *w, *e;
    
    w = buf;
    e = buf+blen;
    for(r=fmt; *r; r++){
        if(w >= e)
            return -1;
        if(*r != '%'){
            *w++ = *r;
            continue;
        }
        if(*r == '%'){
            *w++ = *r++;
            if(*r == '%'){
                if(w >= e)
                    return -1;
                *w++ = *r;
                continue;
            }
            while(*r && strchr(fmtflags, *r)){
                if(w >= e)
                    return -1;
                *w++ = *r++;
            }
            if(*r == 0 || strchr(fmtverbs, *r) == nil)
                return -1;
            if(w+3 > e)
                return -1;
            *w++ = 'l';
            *w++ = 'l';
            *w++ = *r;
        }
    }
    if(w >= e)
        return -1;
    *w = 0;

    return 0;
}
