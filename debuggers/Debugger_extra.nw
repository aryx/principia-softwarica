<<function getfile (acid/builtin.c)>>=
void
getfile(Node *r, Node *args)
{
    int n;
    char *p;
    Node res;
    String *s;
    Biobuf *bp;
    List **l, *new;

    if(args == 0)
        error("file(filename): arg count");
    expr(args, &res);
    if(res.type != TSTRING)
        error("file(filename): arg type");

    r->op = OCONST;
    r->type = TLIST;
    r->l = 0;

    p = res.string->string;
    bp = Bopen(p, OREAD);
    if(bp == 0)
        return;

    l = &r->l;
    for(;;) {
        p = Brdline(bp, '\n');
        n = Blinelen(bp);
        if(p == 0) {
            if(n == 0)
                break;
            s = strnodlen(0, n);
            Bread(bp, s->string, n);
        }
        else
            s = strnodlen(p, n-1);

        new = al(TSTRING);
        new->string = s;
        new->fmt = 's';
        *l = new;
        l = &new->next;
    }
    Bterm(bp);
}
