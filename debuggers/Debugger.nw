\section{Interpreter setup}
%\section{Initializations}

%claude:
Initialization is a multi-step process: set up the lexer
keyword table ([<kinit()>]), push stdin as the input source,
create the built-in variables ([<loadvars()>]) and register
the builtin C functions ([<installbuiltin()>]), parse the
executable and load its symbols ([<attachfiles()>]),
load the standard [[acid]] library files, call the user's
[[acidinit]] function if defined, and import the target's
symbols as [[acid]] variables ([<varsym()>]).

<<global [[initialising]]>>=
int	initialising;
@
%todo: bool

% Why some code needs to know if in initialising part?

<<[[main()]](acid) initializations>>=
initialising = 1;

Binit(&bioout, STDOUT, OWRITE);
bout = &bioout;

// setup lexer
kinit();
// to read commands on stdin once all modules have been loaded
pushfile(nil);

loadvars();
installbuiltin();

<<[[main()]](acid) sanity check [[mtype]]>>
<<[[main()]](acid) [[attachfiles(aout, pid)]]>>

<<[[main()]](acid) load modules>>
userinit();
varsym();
<<[[main()]](acid) check acidmap>>

<<[[main()]](acid) notify setup>>

initialising = 0;
@



\subsection{Predefined variables: [[loadvars()]]}

% seen mkvar before, format, types

%claude:
[<loadvars()>] creates the predefined [[acid]] variables:
[[pid]] (current process ID), [[proc]] (current process handle),
[[notes]] (pending notes/signals), and [[proclist]] (list of
attached processes).
%
These are initialized to zero/empty and
will be set to real values later when a process is attached
or created via [[new()]].

<<function [[loadvars]]>>=
/// main -> <>
void
loadvars(void)
{
    Lsym *l;
    Value *v;

    l =  mkvar("proc");
    v = l->v;
    v->type = TINT;
    v->fmt = 'X';
    v->set = 1;
    v->ival = 0;

    l = mkvar("pid");		/* Current process */
    v = l->v;
    v->type = TINT;
    v->fmt = 'D';
    v->set = 1;
    v->ival = 0;

    mkvar("notes");			/* Pending notes */

    l = mkvar("proclist");		/* Attached processes */
    l->v->type = TLIST;
}
@

% 'X' and 'D' formats

% those, especially proc and pid will be set by newproc() later
% called from acid: new() for example.

\subsection{Builtin functions: [[installbuiltin()]]}

%claude:
[<installbuiltin()>] iterates through the [<tab>] array and
registers each C function as an [[acid]] builtin by setting
the [[builtin]] field of the corresponding [[Lsym]].

<<function [[installbuiltin]]>>=
void
installbuiltin(void)
{
    Btab *b;
    Lsym *s;

    b = tab;
    while(b->name) {
        s = look(b->name);
        if(s == nil)
            s = enter(b->name, Tid);

        s->builtin = b->fn;
        <<[[installbuiltin()]] if [[bprint]]>>
        b++;
    }
}
@


% ???
<<[[installbuiltin()]] if [[bprint]]>>=
if(b->fn == bprint)
    mkprint(s);
@


\section{Loading the executable}
%\section{[[attachfiles()]] and [[readtext()]]}

%claude:
[<attachfiles()>] opens the executable and, if a PID was
given, attaches to the running process. [<readtext()>] does the
heavy lifting: it calls [<crackhdr()>] to parse the executable
header, [<loadmap()>] to create the symbol map, and
[<syminit()>] to load the symbol table. It then prints the
architecture identification line that you see at startup
(e.g., ``[[./buggy:386 plan 9 executable]]'').

\subsection{[[attachfiles()]]}

<<[[main()]](acid) [[attachfiles(aout, pid)]]>>=
if (attachfiles(aout, pid) < 0)
    varreg();		/* use default register set on error */
@

<<global [[text]]>>=
fdt	text;
@

<<function [[attachfiles]]>>=
/// main -> <>
static errorneg1
attachfiles(char *aout, int pid)
{
    interactive = false;
    <<[[attachfiles()]] if error>>

    if(aout) {				/* executable given */
        <<[[attachfiles()]] if [[wtflag]]>>
        else
            text = open(aout, OREAD);

        <<[[attachfiles()]] sanity check [[text]]>>
        readtext(aout);
    }
    <<[[attachfiles()]] if [[pid]] given>>
    return OK_0;
}
@


<<[[attachfiles()]] if error>>=
if(setjmp(err))
    return ERROR_NEG1;
@

<<[[attachfiles()]] sanity check [[text]]>>=
if(text < 0)
    error("%s: can't open %s: %r\n", argv0, aout);
@


\subsection{[[readtext()]]}

<<global fhdr (acid/globals.c)>>=
Fhdr	fhdr;
@

% rely on global text set before in attachfiles
<<function [[readtext]]>>=
/// main -> attachfiles -> <>
void
readtext(char *s)
{
    <<[[readtext()]] locals>>

    <<[[readtext()]] if [[mtype != nil]]>>
    // else

    if(!crackhdr(text, &fhdr)) {
        print("can't decode file header\n");
        return;
    }

    symmap = loadmap(nil, text, &fhdr);
    <<[[readtext()]] sanity check [[symmap]]>>

    if(syminit(text, &fhdr) < 0) {
        print("%s: (error) syminit: %r\n", argv0);
        return;
    }
    // first output! the executable and archi
    print("%s:%s\n", s, fhdr.name);

    <<[[readtext()]] if [[mach->sbreg]]>>
    <<[[readtext()]] make objtype variable>>
    <<[[readtext()]] make textfile variable>>

    machbytype(fhdr.type);
    varreg();
}
@
