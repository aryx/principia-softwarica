%token <ival>	Tconst
%token <fval>	Tfconst
%token <string>	Tstring

%token <ival> Tfmt

%token Tif Tdo Tthen Telse Twhile  Tloop
%token Thead Ttail Tappend
%token Tfn Tret Tlocal
%token Tcomplex Twhat Tdelete Teval Tbuiltin
@

<<union yacc>>=
%union
{
  uvlong  ival;
  float	  fval;
  String* string;

  Lsym	*sym;
  <<[[union yacc]] other fields>>
}
