\section{Interrupt management}

% got interrupted

%claude:
When the user presses Ctrl-C, the kernel delivers an
interrupt note to [[acid]]. The [<catcher()>] signal handler
sets [[gotint]] to true and continues. The [[gotint]] flag
is checked at three points: in [<lexc()>] (while reading input),
in [<execute()>] (while running code), and in [<yylex()>]
(at EOF). This ensures that long-running [[acid]] scripts
can be interrupted without corrupting internal state.

<<global [[gotint]]>>=
bool	gotint;
@

<<[[main()]](acid) notify setup>>=
notify(catcher);
@

<<function [[catcher]]>>=
void
catcher(void *junk, char *s)
{
    USED(junk);

    if(strstr(s, "interrupt")) {
        gotint = true;
        noted(NCONT);
    }
    noted(NDFLT);
}
@



<<[[lexc()]] if [[gotint]]>>=
if(gotint)
    error("interrupt");
@

<<[[execute()]] if [[gotint]]>>=
if(gotint)
    error("interrupted");
@

<<[[yylex()]] when [[Eof]], if [[gotint]]>>=
if(gotint) {
    gotint = false;
    stacked = 0;
    Bprint(bout, "\nacid: ");
    goto loop;
}
@


<<[[error()]] reset [[gotint]]>>=
gotint = false;
@

