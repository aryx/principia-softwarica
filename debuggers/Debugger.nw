    FI386,			/* 8.out */
    FI386B,			/* I386 bootable */
    FARM,			/* 5.out */
    FARMB,			/* ARM bootable */
    FMIPS,			/* v.out */
    FMIPSB,			/* mips bootable */
    FMIPS2BE,		        /* 4.out */
};
