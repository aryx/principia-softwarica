/// sproc -> <>
void
nocore(void)
{
    int i;

    if(cormap == nil)
        return;

    for (i = 0; i < cormap->nsegs; i++)
        if (cormap->seg[i].inuse && cormap->seg[i].fd >= 0)
            close(cormap->seg[i].fd);
    free(cormap);
    cormap = nil;
}
