\subsection{[[acid: interpret()]]}
%alt: Eval

%claude:
The [[interpret()]] builtin takes a string and evaluates it
as [[acid]] code. It pushes the string as an input source
(via [<pushstr()>], which sets [[lexio->text]] instead of
[[lexio->fin]]), calls [<yyparse()>] to parse and execute it,
then pops the input source. This enables dynamic code
generation: an [[acid]] function can build a string containing
[[acid]] code and execute it at runtime.

<<[[tab]] entries>>=
"interpret",interpret,
@

<<function [[interpret]]>>=
/// acid: interpret() -> <>
void
interpret(Node *r, Node *args)
{
    Node res;
    bool isave;

    if(args == nil)
        error("interpret(string): arg count");
    expr(args, &res);
    if(res.type != TSTRING)
        error("interpret(string): arg type");

    pushstr(&res);

    isave = interactive;
    interactive = false;
    r->ival = yyparse();
    interactive = isave;
    popio();
    r->op = OCONST;
    r->type = TINT;
    r->fmt = 'D';
}
@
% note that yyparse() will call execute()!

<<[[IOstack]] other fields>>=
char	*text;
char	*ip;
@

<<function [[pushstr]]>>=
/// acid: interpret() -> interpret -> <>
void
pushstr(Node *s)
{
    IOstack *io;

    io = malloc(sizeof(IOstack));
    <<[[pushstr()]] sanity check [[io]]>>
    io->line = line;
    line = 1;
    io->name = strdup("<string>");
    <<[[pushstr()]] sanity check [[io->name]]>>
    io->line = line;
    line = 1;

    // this time we do not use io->fin but io->text
    io->fin = nil;
    io->text = strdup(s->string->string);
    <<[[pushstr()]] sanity check [[io->text]]>>
    io->ip = io->text;

    io->prev = lexio;
    lexio = io;
}
@

