\section{[[acid: newproc()]]}

%claude:
When the user types [[new()]] at the [[acid]] prompt, the
[[acid]] library function [[new()]] (defined in [[/lib/acid/port]])
calls the builtin [<newproc()>], which forks a child process
to run the target program. Here is the [[new()]] definition
from the library:

% can't explain full path, but at some point will type
% acid: new()
% which is defined in /lib/acid/port with:

%   defn new()
%   {
%   	bplist = {};
%   	newproc(progargs);
%   	// Dont miss the delay slot calls
%   	bpset(follow(main)[0]);
%   	cont();
%   	bpdel(*PC);
%   }

% so will call newproc() that will fork and modify ptab

\subsection{[[newproc()]]}

%claude:
The [<newproc()>] builtin takes an optional string of arguments,
splits it on whitespace (like a simple shell), prepends the
executable name ([[aout]]), and calls [<nproc()>] to do the
actual fork/exec.

<<function [[newproc]]>>=
/// main -> yyparse -> new -> <> -> nproc -> sproc
void
newproc(Node *r, Node *args)
{
    int i;
    Node res;
    char *p, *e;
    char *argv[Maxarg], buf[Strsize];

    i = 1;
    argv[0] = aout;

    if(args) {
        expr(args, &res);
        if(res.type != TSTRING)
            error("newproc(): arg not string");
        if(res.string->len >= sizeof(buf))
            error("newproc(): too many arguments");
        memmove(buf, res.string->string, res.string->len);
        buf[res.string->len] = '\0';
        p = buf;
        e = buf+res.string->len;
        for(;;) {
            while(p < e && (*p == '\t' || *p == ' '))
                *p++ = '\0';
            if(p >= e)
                break;
            argv[i++] = p;
            if(i >= Maxarg)
                error("newproc: too many arguments");
            while(p < e && *p != '\t' && *p != ' ')
                p++;
        }
    }
    argv[i] = nil;
    r->op = OCONST;
    r->type = TINT;
    r->fmt = 'D';
    r->ival = nproc(argv);
}
@

<<acid constants>>=
Maxarg		= 512,
@

\subsection{[[nproc()]]}

%claude:
[<nproc()>] implements the fork/hang/exec pattern, the same
one used by [[ratrace]]. The child writes [[hang]] to its
own [[ctl]], closes all file descriptors, reopens the console
for stdin/stdout/stderr, then calls [[exec()]]. The [[hang]]
ensures the child stops after [[exec]], giving the parent
control.
%
The parent calls [<install()>] to register the child's PID
in the process table, then [[msg(pid, "waitstop")]] to block
until the child is actually stopped. It then calls [<sproc()>]
to set up the memory map and [<dostop()>] to invoke the
[[stopped()]] callback if one is defined.

<<function [[nproc]]>>=
/// main -> yyparse -> new -> newproc -> <> -> sproc
int
nproc(char **argv)
{
    char buf[128];
    int pid, i;
    fdt fd;

    pid = fork();
    switch(pid) {
    case -1:
        error("new: fork %r");
    case 0:
        // child
        rfork(RFNAMEG|RFNOTEG);

        snprint(buf, sizeof(buf), "/proc/%d/ctl", getpid());
        fd = open(buf, ORDWR);
        if(fd < 0)
            fatal("new: open %s: %r", buf);

        write(fd, "hang", 4);
        close(fd);

        close(STDIN);
        close(STDOUT);
        close(STDERR);
        for(i = 3; i < NFD; i++)
            close(i);

        open("/dev/cons", OREAD);
        open("/dev/cons", OWRITE);
        open("/dev/cons", OWRITE);
        // Exec!
        exec(argv[0], argv);
        // should never reach
        fatal("new: exec %s: %r");

    //parent
    default:
        install(pid);
        msg(pid, "waitstop");

        notes(pid);
        sproc(pid);
        dostop(pid);

        break;
    }

    return pid;
}
@

<<acid constants>>=
NFD		= 100,
@

% msg() will block until process stop
% but already in hang() mode so should be stopped already?


\subsection{[[install()]]}

%claude:
[<install()>] registers a new process: it finds a free slot
in [[ptab]], opens [[/proc/<pid>/ctl]], and adds the PID to
the [[proclist]] variable (so the [[acid]] user can see which
processes are being debugged). [<deinstall()>] does the reverse
when a process exits.

<<function [[install]]>>=
static void
install(int pid)
{
    Lsym *s;
    List *l;
    char buf[128];
    int i, fd, new, p;

    new = -1;
    for(i = 0; i < Maxproc; i++) {
        p = ptab[i].pid;
        if(p == pid)
            return;
        if(p == 0 && new == -1)
            new = i;
    }
    if(new == -1)
        error("no free process slots");

    snprint(buf, sizeof(buf), "/proc/%d/ctl", pid);
    fd = open(buf, OWRITE);
    if(fd < 0)
        error("pid=%d: open ctl: %r", pid);

    ptab[new].pid = pid;
    ptab[new].ctl = fd;

    s = look("proclist");
    l = al(TINT);
    l->fmt = 'D';
    l->ival = pid;
    l->next = s->v->l;
    s->v->l = l;
    s->v->set = 1;
}
@

<<function [[deinstall]]>>=
void
deinstall(int pid)
{
    int i;
    Lsym *s;
    List *f, **d;

    for(i = 0; i < Maxproc; i++) {
        if(ptab[i].pid == pid) {
            close(ptab[i].ctl);
            ptab[i].pid = 0;
            s = look("proclist");
            d = &s->v->l;
            for(f = *d; f; f = f->next) {
                if(f->ival == pid) {
                    *d = f->next;
                    break;
                }
            }
            s = look("pid");
            if(s->v->ival == pid)
                s->v->ival = 0;
            return;
        }
    }
}
@



\subsection{[[notes()]]}

%claude:
[<notes()>] reads pending notes (signals) from
[[/proc/<pid>/note]] and stores them as a list of strings
in the [[acid]] variable [[notes]]. This lets the user see
why the process stopped---e.g., ``sys: trap: divide error''
or ``sys: trap: fault read''.

<<function notes (acid/proc.c)>>=
void
notes(int pid)
{
    Lsym *s;
    Value *v;
    int i, fd;
    char buf[128];
    List *l, **tail;

    s = look("notes");
    if(s == nil)
        return;

    // else
    v = s->v;

    snprint(buf, sizeof(buf), "/proc/%d/note", pid);
    fd = open(buf, OREAD);
    if(fd < 0)
        error("pid=%d: open note: %r", pid);

    v->set = 1;
    v->type = TLIST;
    v->l = 0;
    tail = &v->l;
    for(;;) {
        i = read(fd, buf, sizeof(buf));
        if(i <= 0)
            break;
        buf[i] = '\0';
        l = al(TSTRING);
        l->string = strnode(buf);
        l->fmt = 's';
        *tail = l;
        tail = &l->next;
    }
    close(fd);
}
@


\subsection{[[sproc()]]}

%claude:
[<sproc()>] sets up the live process for debugging: it opens
[[/proc/<pid>/mem]] for reading and writing the target's memory,
verifies that the executable matches the running process
(via [<checkqid()>]), creates [[cormap]] with
[<attachproc()>], and renames the map segments to [[*text]]
and [[*data]] (the [[*]] prefix distinguishes live memory
from the file-based segments in [[symmap]]).

<<function [[sproc]]>>=
/// (main -> yyparse -> execute -> new -> newproc -> nproc) | main -> <>
void
sproc(int pid)
{
    char buf[64];
    fdt fcor;
    Lsym *s;
    int i;

    <<[[sproc()]] sanity check [[symmap]]>>

    snprint(buf, sizeof(buf), "/proc/%d/mem", pid);
    fcor = open(buf, ORDWR);
    <<[[sproc()]] sanity check [[fcor]]>>

    checkqid(symmap->seg[0].fd, pid);

    s = look("pid");
    s->v->ival = pid;

    nocore();

    cormap = attachproc(pid, kernel, fcor, &fhdr);
    <<[[sproc()]] sanity check [[cormap]]>>

    i = findseg(cormap, "text");
    if (i > 0)
        cormap->seg[i].name = "*text";

    i = findseg(cormap, "data");
    if (i > 0)
        cormap->seg[i].name = "*data";

    install(pid);
}
@
% install(pid) redundant when comes from nproc I think

<<[[sproc()]] sanity check [[symmap]]>>=
if(symmap == nil)
    error("no map");
@

<<[[sproc()]] sanity check [[fcor]]>>=
if(fcor < 0)
    error("setproc: open %s: %r", buf);
@

<<[[sproc()]] sanity check [[cormap]]>>=
if (cormap == nil)
    error("setproc: can't make coremap: %r");
@

\subsection{[[checkqid()]]}

%claude:
[<checkqid()>] is a safety check: it compares the QID
(a unique file identifier in \plan, similar to an inode number)
of the executable file opened by [[acid]] with the QID of
[[/proc/<pid>/text]]. If they differ, the running process
was compiled from a different version of the source than the
file [[acid]] loaded symbols from, and symbol lookups may be wrong.

<<function [[checkqid]]>>=
void
checkqid(int f1, int pid)
{
    fdt fd;
    Dir *d1, *d2;
    char buf[128];

    if(kernel)
        return;

    d1 = dirfstat(f1);
    if(d1 == nil){
        print("checkqid: (qid not checked) dirfstat: %r\n");
        return;
    }

    snprint(buf, sizeof(buf), "/proc/%d/text", pid);
    fd = open(buf, OREAD);
    if(fd < 0 || (d2 = dirfstat(fd)) == nil){
        print("checkqid: (qid not checked) dirstat %s: %r\n", buf);
        free(d1);
        if(fd >= 0)
            close(fd);
        return;
    }

    close(fd);

    if(d1->qid.path != d2->qid.path || d1->qid.vers != d2->qid.vers || d1->qid.type != d2->qid.type){
        print("path %llux %llux vers %lud %lud type %d %d\n",
            d1->qid.path, d2->qid.path, d1->qid.vers, d2->qid.vers, d1->qid.type, d2->qid.type);
        print("warning: image does not match text for pid %d\n", pid);
    }
    free(d1);
    free(d2);
}
@

\subsection{[[nocore()]]}

<<function [[nocore]]>>=
/// sproc -> <>
void
nocore(void)
{
    int i;

    if(cormap == nil)
        return;

    for (i = 0; i < cormap->nsegs; i++)
        if (cormap->seg[i].inuse && cormap->seg[i].fd >= 0)
            close(cormap->seg[i].fd);
    free(cormap);
    cormap = nil;
}
@


\subsection{[[dostop()]]}

%claude:
[<dostop()>] looks for a user-defined [[acid]] function called
[[stopped]] and, if found, calls it with the PID as argument.
This is a callback hook: the user can define [[stopped(pid)]]
in their [[acid]] library to automatically perform actions
whenever a process stops---for example, printing registers
or the current source line.

<<function [[dostop]]>>=
/// main -> yyparse -> new -> newproc -> nproc -> sproc; <>
void
dostop(int pid)
{
    Lsym *s;
    Node *np, *p;

    s = look("stopped");
    if(s && s->proc) {
        np = an(ONAME, ZN, ZN);
        np->sym = s;
        np->fmt = 'D';
        np->type = TINT;
        p = con(pid);
        p->fmt = 'D';
        np = an(OCALL, np, p);
        execute(np);
    }
}
@



