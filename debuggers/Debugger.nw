<<struct [[Reglist]]>>=
/*
 *	machine register description
 */
struct Reglist {
    char	*rname;		/* register name */

    short	roffs;		/* offset in u-block */

    // bitset<enum<register_flag>>
    char	rflags;		/* INTEGER/FLOAT, WRITABLE */
    char	rformat;	/* print format: 'x', 'X', 'f', '8', '3', 'Y', 'W' */
};
@

<<enum [[register_flag]]>>=
