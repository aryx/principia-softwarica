<<function fatal (acid/main.c)>>=
/// -> <>
void
fatal(char *fmt, ...)
{
    char buf[128];
    va_list arg;

    va_start(arg, fmt);
    vseprint(buf, buf+sizeof(buf), fmt, arg);
    va_end(arg);
    fprint(STDERR, "%s: %L (fatal problem) %s\n", argv0, buf);
    exits(buf);
}
@

