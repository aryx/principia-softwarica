<<function [[enter]]>>=
Lsym*
enter(char *name, int t)
{
    Lsym *s;
    uint h;
    char *p;
    Value *v;

    h = 0;
    for(p = name; *p; p++)
        h = h*3 + *p;
    h %= Hashsize;

    s = gmalloc(sizeof(Lsym));
    memset(s, 0, sizeof(Lsym));
    s->name = strdup(name);

    s->hash = hash[h];
    hash[h] = s;
    s->lexval = t;

    v = gmalloc(sizeof(Value));
    s->v = v;

    v->fmt = 'X';
    v->type = TINT;
    memset(v, 0, sizeof(Value));

    return s;
}
@


