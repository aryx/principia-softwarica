%\section{[[acid <pid>]]}

% alternative path, attach to existing pid

%claude:
When invoked as [[acid <pid>]], [[acid]] attaches to an
already-running (or [[Broken]]) process instead of starting
a new one. It reads the executable path from
[[/proc/<pid>/text]] and calls [<sproc()>] to set up [[cormap]].

<<global [[prog]]>>=
static char	prog[128];
@

<<[[main()]](acid) if [[acid pid]]>>=
if(isnumeric(argv[0])) {
    pid = strtol(argv[0], 0, 0);
    snprint(prog, sizeof(prog), "/proc/%d/text", pid);
    aout = prog;

    if(argc > 1)
        aout = argv[1];
    else
      <<[[main()]](acid) when [[acid pid]] if [[kernel]]>>
}
