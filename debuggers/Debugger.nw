void
dostop(int pid)
{
    Lsym *s;
    Node *np, *p;

    s = look("stopped");
    if(s && s->proc) {
        np = an(ONAME, ZN, ZN);
        np->sym = s;
        np->fmt = 'D';
        np->type = TINT;
        p = con(pid);
        p->fmt = 'D';
        np = an(OCALL, np, p);
        execute(np);
