\section{[[error()]] and exception management}

% setjmp/longjmp poor's man exception in C, see Libcore

%claude:
[<error()>] is [[acid]]'s exception mechanism: it prints
the error message, unwinds any stacked I/O channels,
resets the [[interactive]] flag, and [[longjmp]]s back to
the REPL's [[setjmp]] point. This is the C equivalent of
throwing an exception---any error during parsing or execution
is caught at the top level, and the user gets back to the
[[acid:]] prompt.

<<global [[err]]>>=
jmp_buf	err;
@

<<function error (acid/exec.c)>>=
/// ??? -> <>
void
error(char *fmt, ...)
{
    int i;
    char buf[2048];
    va_list arg;

    <<[[error()]](acid) unstack io channels>>

    ret = 0;
    <<[[error()]] reset [[gotint]]>>

    Bflush(bout);
    <<[[error()]](acid) if [[silent]]>>
    else {
        va_start(arg, fmt);
        vseprint(buf, buf+sizeof(buf), fmt, arg);
        va_end(arg);
        fprint(STDERR, "%L: (error) %s\n", buf);
    }
    while(popio())
        ;
    interactive = true;
    longjmp(err, 1);
}
@



%claude:
[<unwind()>] restores all symbol table entries to their
global values by popping the entire [[pop]] chain for
every symbol. This cleans up local variable bindings
left behind when an error occurs inside a function call.

<<function [[unwind]]>>=
void
unwind(void)
{
    int i;
    Lsym *s;
    Value *v;

    for(i = 0; i < Hashsize; i++) {
        for(s = hash[i]; s; s = s->hash) {

            while(s->v->pop) {
                v = s->v->pop;
                free(s->v);
                s->v = v;
            }
        }
    }
}
@




