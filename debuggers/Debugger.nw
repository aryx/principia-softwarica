\subsection{[[acid: include()]]}

<<function [[include]]>>=
void
include(Node *r, Node *args)
{
    Node res;
    bool isave;

    if(args == 0)
        error("include(string): arg count");
    expr(args, &res);
    if(res.type != TSTRING)
        error("include(string): arg type");

    pushfile(res.string->string);

    isave = interactive;
    interactive = false;
    r->ival = yyparse();
    interactive = isave;
    popio();
    r->op = OCONST;
    r->type = TINT;
    r->fmt = 'D';
}
