<<function [[decl]]>>=
void
decl(Node *n)
{
    Node *l;
    Value *v;
    Frtype *f;
    Lsym *type;

    type = n->sym;
    if(type->lt == 0)
        error("%s is not a complex type", type->name);

    l = n->left;
    if(l->op == ONAME) {
        v = l->sym->v;
        v->comt = type->lt;
        v->fmt = 'a';
        return;
    }

    /*
     * Frame declaration
     */
    for(f = l->sym->local; f; f = f->next) {
        if(f->var == l->left->sym) {
            f->type = n->sym->lt;
            return;
        }
    }
    f = malloc(sizeof(Frtype));
    if(f == 0)
        fatal("out of memory");

    f->type = type->lt;

    f->var = l->left->sym;
    f->next = l->sym->local;
    l->sym->local = f;
}
@


