\section{[[threadmain()]]}

%recall:
%$ ratrace [-c cmd [arg...]] | [pid]

<<function [[threadmain]]>>=
void
threadmain(int argc, char **argv)
{
    int pid;
    <<[[threadmain()]] other locals>>

    <<[[threadmain()]] argv processing>>
    <<[[threadmain()]] if command given via [[-c]]>>
    else {
        if(argc != 2)
            usage();
        pid = atoi(argv[1]);
        //TODO? send a 'stop' to its ctl file?
    }

    out   = chancreate(sizeof(char*), 0);
    quit  = chancreate(sizeof(char*), 0);
    forkc = chancreate(sizeof(ulong *), 0);

    nread++;
    procrfork(writer, nil, Stacksize, 0);
    reader((void*)pid);
}
@
