<<function [[getstatus]]>>=
char *
getstatus(int pid)
{
    int fd, n;
    char *argv[16], buf[64];
    static char status[128];

    snprint(buf, sizeof(buf), "/proc/%d/status", pid);
    fd = open(buf, OREAD);
    if(fd < 0)
        error("open %s: %r", buf);

    n = read(fd, status, sizeof(status)-1);
    close(fd);
    if(n <= 0)
        error("read %s: %r", buf);
    status[n] = '\0';

    if(tokenize(status, argv, nelem(argv)-1) < 3)
        error("tokenize %s: %r", buf);

    return argv[2];
}
@

