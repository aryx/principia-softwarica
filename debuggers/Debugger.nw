\subsection{[[msg()]]}


<<function [[msg]]>>=
void
msg(int pid, char *msg)
{
    int i;
    int l;
    char err[ERRMAX];

    for(i = 0; i < Maxproc; i++) {

        if(ptab[i].pid == pid) {
            l = strlen(msg);
            if(write(ptab[i].ctl, msg, l) != l) {
                errstr(err, sizeof err);
                if(strcmp(err, "process exited") == 0)
                    deinstall(pid);
                error("msg: pid=%d %s: %s", pid, msg, err);
            }
            return;
        }
    }
    error("msg: pid=%d: not found for %s", pid, msg);
}
@


