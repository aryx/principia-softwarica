    case TINT:
        switch(r.type) {
        case TINT:
            res->ival = l.ival > r.ival;
            break;
        case TFLOAT:
            res->ival = l.ival > r.fval;
            break;
        default:
            error("bad rhs type >");
        }
        break;
    case TFLOAT:
        switch(r.type) {
        case TINT:
            res->ival = l.fval > r.ival;
            break;
        case TFLOAT:
            res->ival = l.fval > r.fval;
            break;
        default:
            error("bad rhs type >");
