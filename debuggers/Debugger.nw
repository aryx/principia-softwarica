<<function [[unwind]]>>=
void
unwind(void)
{
    int i;
    Lsym *s;
    Value *v;

    for(i = 0; i < Hashsize; i++) {
        for(s = hash[i]; s; s = s->hash) {
            while(s->v->pop) {
                v = s->v->pop;
                free(s->v);
                s->v = v;
            }
        }
    }
}
@




