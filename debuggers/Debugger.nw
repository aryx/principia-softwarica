\section{Garbage collection}

<<function [[marktree]]>>=
void
marktree(Node *n)
{

    if(n == 0)
        return;

    marktree(n->left);
    marktree(n->right);

    n->gcmark = 1;
    if(n->op != OCONST)
        return;

    switch(n->type) {
    case TSTRING:
        n->string->gcmark = 1;
        break;
    case TLIST:
        marklist(n->l);
        break;
    case TCODE:
        marktree(n->cc);
        break;
    }
}
@

<<function [[marklist]]>>=
void
marklist(List *l)
{
    while(l) {
        l->gcmark = 1;
        switch(l->type) {
        case TSTRING:
            l->string->gcmark = 1;
            break;
        case TLIST:
            marklist(l->l);
            break;
        case TCODE:
            marktree(l->cc);
            break;
        }
        l = l->next;
    }
}
@

<<function [[gc]]>>=
void
gc(void)
{
    int i;
    Lsym *f;
    Value *v;
    Gc *m, **p, *next;

    if(dogc < Mempergc)
        return;
    dogc = 0;

    /* Mark */
    for(m = gcl; m; m = m->gclink)
        m->gcmark = 0;

    /* Scan */
    for(i = 0; i < Hashsize; i++) {
        for(f = hash[i]; f; f = f->hash) {
            marktree(f->proc);
            if(f->lexval != Tid)
                continue;
            for(v = f->v; v; v = v->pop) {
                switch(v->type) {
                case TSTRING:
                    v->string->gcmark = 1;
                    break;
                case TLIST:
                    marklist(v->l);
                    break;
                case TCODE:
                    marktree(v->cc);
                    break;
                }
            }
        }
    }

    /* Free */
    p = &gcl;
    for(m = gcl; m; m = next) {
        next = m->gclink;
        if(m->gcmark == 0) {
            *p = next;
            free(m);	/* Sleazy reliance on my malloc */
        }
        else
            p = &m->gclink;
    }
}
@

