% return false when done, so can be used as while(popio())

<<function [[popio]]>>=
/// loadmodule | error -> <>
bool
popio(void)
{
    IOstack *s;

    if(lexio == nil)
        return false;

    if(lexio->prev == nil){
        if(lexio->fin)
            restartio();
        return false;
    }
    // else

    if(lexio->fin)
        Bterm(lexio->fin);
    else
        free(lexio->text);
    free(lexio->name);

    // restore global line
    line = lexio->line;

    // s = pop_list(lexio)
    s = lexio;
    lexio = s->prev;
    free(s);

    return true;
}
