\section{[[acid: start()]]}

<<function [[start]]>>=
void
start(Node *r, Node *args)
{
    Node res;

    USED(r);
    if(args == nil)
        error("start(pid): no pid");
    expr(args, &res);
    if(res.type != TINT)
        error("start(pid): arg type");

