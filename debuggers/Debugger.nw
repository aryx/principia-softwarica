<<function [[readtext]]>>=
/// main -> attachfiles -> <>
void
readtext(char *s)
{
    <<[[readtext()]] locals>>

    <<[[readtext()]] if [[mtype != nil]]>>
    // else

    if(!crackhdr(text, &fhdr)) {
        print("can't decode file header\n");
