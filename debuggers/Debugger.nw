<<function [[Lfmt]]>>=
int
Lfmt(Fmt *f)
{
    int i;
    char buf[1024];
    IOstack *e;

    e = lexio;
    if(e) {
        i = snprint(buf, sizeof(buf), "%s:%d", e->name, line);
        while(e->prev) {
            e = e->prev;
            if(initialising && e->prev == 0)
                break;
            i += snprint(buf+i, sizeof(buf)-i, " [%s:%d]", e->name, e->line);
        }
    } else
        snprint(buf, sizeof(buf),  "no file:0");
    fmtstrcpy(f, buf);
    return 0;
}
@

