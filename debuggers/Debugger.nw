\section{[[die()]]}

<<function die (acid/main.c)>>=
/// main -> <>
void
die(void)
{
    Lsym *s;
    List *f;

    Bprint(bout, "\n");

    s = look("proclist");
    if(s && s->v->type == TLIST) {
        for(f = s->v->l; f; f = f->next)
            Bprint(bout, "echo kill > /proc/%d/ctl\n", (int)f->ival);
    }
    exits(nil);
}
@

\section{[[fatal()]]}

<<function fatal (acid/main.c)>>=
/// -> <>
void
fatal(char *fmt, ...)
{
    char buf[128];
    va_list arg;

    va_start(arg, fmt);
    vseprint(buf, buf+sizeof(buf), fmt, arg);
    va_end(arg);
    fprint(STDERR, "%s: %L (fatal problem) %s\n", argv0, buf);
    exits(buf);
}
@

