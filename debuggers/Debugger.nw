\subsection{User customization: [[$HOME/lib/acid]] and [[acidinit()]]}
%\section{[[userinit()]]}

%claude:
[<userinit()>] loads the user's personal [[acid]] library
from \verb+~/lib/acid+ (if it exists), then calls the
[[acidinit]] function if one was defined in any of the
loaded modules. This lets users customize their debugging
environment---for instance, defining a custom [[acidinit]]
that automatically sets breakpoints or loads type definitions.

<<function [[userinit]]>>=
/// main -> <>
void
userinit(void)
{
    Lsym *l;
    Node *n;
    char *buf, *p;

    <<[[userinit()]] if user acid file>>

    interactive = false;
    <<[[userinit()]] unwind if error>>

    l = look("acidinit");
    if(l && l->proc) {
        n = an(ONAME, ZN, ZN);
        n->sym = l;
        n = an(OCALL, n, ZN);
        execute(n);
    }
}
