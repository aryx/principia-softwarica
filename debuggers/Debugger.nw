@

<<function [[attachfiles]]>>=
/// main -> <>
static errorneg1
attachfiles(char *aout, int pid)
{
    interactive = false;
    <<[[attachfiles()]] if error>>

    if(aout) {				/* executable given */
        <<[[attachfiles()]] if [[wtflag]]>>
        else
            text = open(aout, OREAD);

        <<[[attachfiles()]] sanity check [[text]]>>
        readtext(aout);
    }
    <<[[attachfiles()]] if [[pid]] given>>
    return OK_0;
}
@


<<[[attachfiles()]] if error>>=
if(setjmp(err))
    return ERROR_NEG1;
