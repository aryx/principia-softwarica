\section{[[acid: stop()]]}

<<function [[stop]]>>=
void
stop(Node *r, Node *args)
{
    Node res;

    USED(r);
    if(args == 0)
        error("stop(pid): no pid");
    expr(args, &res);
    if(res.type != TINT)
        error("stop(pid): arg type");

    Bflush(bout);

    msg(res.ival, "stop");

    notes(res.ival);
