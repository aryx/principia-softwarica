\section{Initializations}

%claude:
Initialization is a multi-step process: set up the lexer
keyword table ([<kinit()>]), push stdin as the input source,
create the built-in variables ([<loadvars()>]) and register
the builtin C functions ([<installbuiltin()>]), parse the
executable and load its symbols ([<attachfiles()>]),
load the standard [[acid]] library files, call the user's
[[acidinit]] function if defined, and import the target's
symbols as [[acid]] variables ([<varsym()>]).

<<global [[initialising]]>>=
int	initialising;
@
%todo: bool

% Why some code needs to know if in initialising part?

<<[[main()]](acid) initializations>>=
initialising = 1;

Binit(&bioout, STDOUT, OWRITE);
bout = &bioout;

// setup lexer
kinit();
// to read commands on stdin once all modules have been loaded
pushfile(nil);

loadvars();
installbuiltin();

<<[[main()]](acid) sanity check [[mtype]]>>
<<[[main()]](acid) [[attachfiles(aout, pid)]]>>

<<[[main()]](acid) load modules>>
userinit();
varsym();
<<[[main()]](acid) check acidmap>>

<<[[main()]](acid) notify setup>>

initialising = 0;
@



\subsection{[[loadvars()]]}

% seen mkvar before, format, types

%claude:
[<loadvars()>] creates the predefined [[acid]] variables:
[[pid]] (current process ID), [[proc]] (current process handle),
[[notes]] (pending notes/signals), and [[proclist]] (list of
attached processes). These are initialized to zero/empty and
will be set to real values later when a process is attached
or created via [[new()]].

<<function [[loadvars]]>>=
/// main -> <>
void
loadvars(void)
{
    Lsym *l;
    Value *v;

    l =  mkvar("proc");
    v = l->v;
    v->type = TINT;
    v->fmt = 'X';
    v->set = 1;
    v->ival = 0;

    l = mkvar("pid");		/* Current process */
    v = l->v;
    v->type = TINT;
    v->fmt = 'D';
    v->set = 1;
    v->ival = 0;

    mkvar("notes");			/* Pending notes */

    l = mkvar("proclist");		/* Attached processes */
    l->v->type = TLIST;
}
@

% 'X' and 'D' formats

% those, especially proc and pid will be set by newproc() later
% called from acid: new() for example.

\subsection{[[installbuiltin()]]}

%claude:
[<installbuiltin()>] iterates through the [[tab]] array and
registers each C function as an [[acid]] builtin by setting
the [[builtin]] field of the corresponding [[Lsym]].

<<function [[installbuiltin]]>>=
void
installbuiltin(void)
{
    Btab *b;
    Lsym *s;

    b = tab;
    while(b->name) {
        s = look(b->name);
        if(s == nil)
            s = enter(b->name, Tid);

        s->builtin = b->fn;
        <<[[installbuiltin()]] if [[bprint]]>>
        b++;
    }
}
@


